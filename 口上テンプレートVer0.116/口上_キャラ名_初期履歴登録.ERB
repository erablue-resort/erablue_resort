	体験内容 '= @"<font color='#%カラーパレット_HTML("薄ピンク")%'>%相手キャラ名%との子供を{子供人数}人出産した</font><img src='えっちハート'>"
ELSE
	体験内容 '= @"<font color='#%カラーパレット_HTML("薄ピンク")%'>%CALLNAME:相手キャラ%との子供を{子供人数}人出産した</font><img src='えっちハート'>"
	体験内容２ '= @"<font color='#%カラーパレット_HTML("薄ピンク")%'>%CALLNAME:対象キャラ%との子供が{子供人数}人産まれた</font><img src='えっちハート'>"
ENDIF

;--------------------------------
;以下は編集しないこと
CALL 履歴データベース登録(CFLAG:対象キャラ:人物番号, 体験内容, "うふふ", , -999, 履歴順カウント++)
IF 相手キャラ >= 0
	CALL 履歴データベース登録(CFLAG:相手キャラ:人物番号, 体験内容２, "うふふ", , -999, 履歴順カウント++)
ENDIF

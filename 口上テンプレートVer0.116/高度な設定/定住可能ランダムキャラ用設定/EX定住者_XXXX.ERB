;===================================================
; 作品別のEXキャラ誘致設定ファイル
; XXXX = EXキャラカテゴリ（「デジモン」など）
; YYYY = 出演作品（「デジモンシリーズ」など。XXXXと完全一致のパターンもアリ）
;===================================================

; 前提準備 ～CSVについて
; CSVは以下の部分をランダムキャラ用に調整する

; 名前・呼び名・二つ名をすべて同一にする。以下は例：
;     名前,[正義実現委員会部員]正義実現委員会部員
;     呼び名,正義実現委員会部員

; 「素質,ランダムキャラ,1」を記述する
; 「CSTR,ランダムキャラ設定,XXXX」を記述する

; 種族・年齢層・体格・その他見た目に関係する素質はCSVに記述しておく。
; ただし、年齢や体型・体格・バストサイズ等は「基礎」による固定値設定にせず、「素質」によるアバウトな設定とする

; 一方、性格など内面の素質は基本的には設定“しない”（ランダム生成により決定される値で上書きされてしまうため）
; もしもCSVの値で固定したい場合は後述の「EXキャラ誘致特殊設定」を用いてください

; わからない場合は具体例「Chara3480 正義実現委員会部員.csv」と「EX定住者_ブルーアーカイブ.ERB」を見てね


@EXキャラ誘致条件_XXXX
#DIM ループ用
#DIM ユニーク招待済フラグ

;XXXXのカテゴリに属するキャラが誘致候補になる条件を記述する処理
;以下のコードは例なので適するものを選ぼう
;凝りたい場合はERB頑張ってください

;ここは属するキャラごとに適するものを選ぼう
;女性が招待可能でないとダメ
SIF GETBIT(OPTION変数:性別招待制御, 0)
	RETURN 0
; ;男性が招待可能でないとダメ
; SIF GETBIT(OPTION変数:性別招待制御, 1)
; 	RETURN 0
; ;ふたなりが招待可能でないとダメ
; SIF GETBIT(OPTION変数:性別招待制御, 2)
; 	RETURN 0
; ;無性が招待可能でないとダメ
; SIF GETBIT(OPTION変数:性別招待制御, 3)
; 	RETURN 0

;YYYYのネームドキャラを1人以上招待していないとダメ
ユニーク招待済フラグ = 0
FOR ループ用, 0, CHARANUM
	IF CSTR:ループ用:出演作品 == "YYYY" && CFLAG:ループ用:招待不可フラグ == 0
		ユニーク招待済フラグ = 1
		BREAK
	ENDIF
NEXT
SIF !ユニーク招待済フラグ
	RETURN 0

; ;特定イベントクリアしてないとダメ
; SIF イベント完了フラグ確認("ほげほげほげほげ") <= 0
; 	RETURN 0

RETURN 1


@EXキャラ誘致候補_XXXX
#DIM 候補数
#DIM DYNAMIC TMP_SELECT, 10

;XXXXのカテゴリに属するキャラから1人誘致候補を選ぶ処理
;すべての候補を等確率で出すならこのコードから変更する必要はない
;凝りたい場合はERB頑張ってください

候補数 = DT_SELECT("ランダムCSVデータベース", "ランダムキャラ設定 = 'XXXX'", , TMP_SELECT)
IF 候補数 <= 0
	RESULT:1 = 0
	RETURN 0
ELSEIF 候補数 > 10
	THROW XXXXのランダムキャラ候補が多すぎます。開発者に連絡し、要素数の拡張を依頼してください。
ENDIF

RESULT:1 = 候補数
RETURN DT_CELL_GET("ランダムCSVデータベース", TMP_SELECT:(RAND:候補数), "CSV番号", 1)



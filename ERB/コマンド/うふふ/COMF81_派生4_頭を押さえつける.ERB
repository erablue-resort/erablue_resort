
@COMNAME_S81_4
#FUNCTIONS
TSTR:コマンド名受渡 = 頭を押さえつける

;===================================================
;コマンドタイプ
;===================================================
@COMTYPE_S_81_4
#FUNCTION
TFLAG:コマンドタイプ受渡 = COMTYPE("うふふ")
;複数人を対象に同時にできるか、出来るなら上限人数を入れる
;同時モード許可 = 

;ランダム弱点の候補にするかを設定。敏感素質を考慮に入れるため、CVABSを入れること
;また特定部位が必要な場合、「_ちんこ」や「_角」などのように追加で表記する
;弱点コマンドカテゴリ = 

;キャラが自動で使用しても良い場合に入れる
;オートコマンド許可 = 1

@COM_TOOLTIP_S81_4
LOCALS = <br>■頭を押さえつける<br>
LOCALS += "相手がイラマチオをしている時に頭を押さえつけるコマンド。"
LOCALS += "<br>実行者が[舌使い][猫舌]を持っている場合、効果が増減する。"
LOCALS += "<br>COMタイプ：うふふ<br>取得ソース：快Ｓ・露出・接触・奉仕・苦痛・不潔(一定条件時)"
LOCALS += "<br>固有の取得経験：口淫経験(PLAYER)<br>"
TSTR:ツールチップ受渡 = %LOCALS%

@COM_S81_4
;奉仕快楽
RCVAR:TARGET:奉仕コマンドフラグ = 1
RCVAR:TARGET:苦痛コマンドフラグ = 1
RCVAR:TARGET:汎用喘ぎ_文節低減フラグ = 1
;-------------------------------------------------
;ソース追加処理
;-------------------------------------------------
CALL SOURCE_CALC_快Ｃ(PLAYER, TARGET, 150)
CALL SOURCE_CALC_快Ｓ(TARGET, PLAYER, 100)
CALL SOURCE_CALC_露出(TARGET, PLAYER, 30)
CALL SOURCE_CALC_接触(TARGET, PLAYER, 120)
CALL SOURCE_CALC_奉仕(TARGET, PLAYER, 350)
CALL SOURCE_CALC_苦痛(TARGET, PLAYER, 150)
IF ABL:TARGET:技巧 < 4
	;技巧がないとめっちゃ苦しい
	CALL SOURCE_CALC_苦痛(TARGET, PLAYER, 600)
ELSE
	CALL SOURCE_CALC_苦痛(TARGET, PLAYER, 200)
ENDIF

CALL SOURCE_CALC_不潔(TARGET, PLAYER, 250)
;-------------------------------------------------
;特殊ソース処理
;-------------------------------------------------

;-------------------------------------------------
;経験の処理
;-------------------------------------------------
;フェラ経験
EXP:PLAYER:口淫経験 += 1

;同性愛
SIF 同性愛性癖判定(TARGET,PLAYER)
	EXP:TARGET:同性愛経験 += 4
SIF 同性愛性癖判定(PLAYER,TARGET)
	EXP:PLAYER:同性愛経験 += 4

SIF PLAYER != MASTER
	EXP:PLAYER:嗜虐快楽経験 += 1

RETURN 1

;-------------------------------------------------
;実行判定
;-------------------------------------------------
@COM_ABLE_S81_4
;実行判定
SIF SAVESTR:ゲームフェイズ管理 != "通常モード"
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE_S("81_4")
	RETURN RESULT
;イラマチオモードじゃない時はアウト
SIF !MODE_存在判定_完全一致("イラマチオ", TARGET, PLAYER)
	RETURN 0

RETURN 1

;-------------------------------------------------
;実行時メッセージ
;-------------------------------------------------
@MESSAGE_COM_S81_4
PRINTFORML %CALLNAME:PLAYER%は%CALLNAME:TARGET%の頭を押さえつけ、喉奥へとペニスを飲み込ませた…



;===================================================
;観光客をナンパ
;===================================================
@COMNAME418
#FUNCTIONS
TSTR:コマンド名受渡 = 観光客をナンパ


;===================================================
;コマンドタイプ
;===================================================
@COMTYPE_418
#FUNCTION
TFLAG:コマンドタイプ受渡 = COMTYPE("単独可能")


;===================================================
;ツールチップ文章
;===================================================
@COM_TOOLTIP_418
TSTR:ツールチップ受渡 '= "<br>観光客をナンパ<br>"
TSTR:ツールチップ受渡 += "観光客(ランダムキャラ)をナンパし、デートするコマンド。<br>同行してくれる時間は３６０分、あるいは夜９時まで。一緒に隠密中・うふふ中も時間がカウントされる。"
TSTR:ツールチップ受渡 += "<br>COMタイプ：単独可能<br>取得ソース：なし"
TSTR:ツールチップ受渡 += "<br>固有の取得経験：なし<br>"


;===================================================
;コマンド実行処理
;===================================================
@COM418
#LOCALSIZE 1
#DIM 追加キャラ番号
#DIM ナンパ成功フラグ

PRINTFORMW %CALLNAME:PLAYER%は観光客をナンパするために辺りを探し始めた…
ナンパ成功フラグ = 0
CALL ランダム観光客ナンパ実行(ナンパ成功フラグ)
追加キャラ番号 = RESULT
IF 追加キャラ番号
	IF ナンパ成功フラグ
		PRINTFORMW %CALLNAME:PLAYER%は%CALLNAME:追加キャラ番号%とデートに行くことになった！
		TARGET = 追加キャラ番号
	ELSE
		PRINTFORML %CALLNAME:PLAYER%は今ナンパを断った相手のことが気になって、ナンパどころではなくなってしまった
		PRINTFORMW ……%CALLNAME:追加キャラ番号%というのか。覚えておこう…
		TIME += 10
		RETURN 1
	ENDIF
ELSE
	PRINTW ナンパを中止しました
	RETURN -1
ENDIF

;同行者は解除
FOR LOCAL, 1, CHARANUM
	SIF TARGET:LOCAL < 1
		BREAK
	IF CFLAG:(TARGET:LOCAL):同行
		CFLAG:(TARGET:LOCAL):同行 = 0
	ENDIF
NEXT

CFLAG:TARGET:デート = PLAYER + 100
CFLAG:PLAYER:デート = TARGET + 100
CFLAG:TARGET:デート残り時間 = 360
CFLAG:TARGET:デートスコア = 0
TFLAG:TARGET変更用 = TARGET
CALL 初体験日登録処理(TARGET, PLAYER, "初デート", DAY * 1440 + TIME, GETPLACENAME(CFLAG:PLAYER:現在マップ種別, CFLAG:PLAYER:現在位置), "", "", 1)
CALL 初体験日登録処理(TARGET, PLAYER, "デート", DAY * 1440 + TIME, GETPLACENAME(CFLAG:PLAYER:現在マップ種別, CFLAG:PLAYER:現在位置), "", "", 0)
CALL 履歴データベース登録(CFLAG:TARGET:人物番号, @"初めて%CALLNAME:PLAYER%とデートをした","日常")
CALL 初体験日登録処理(PLAYER, TARGET, "初デート", DAY * 1440 + TIME, GETPLACENAME(CFLAG:PLAYER:現在マップ種別, CFLAG:PLAYER:現在位置), "", "", 1)
CALL 初体験日登録処理(PLAYER, TARGET, "デート", DAY * 1440 + TIME, GETPLACENAME(CFLAG:PLAYER:現在マップ種別, CFLAG:PLAYER:現在位置), "", "", 0)
CALL 履歴データベース登録(CFLAG:PLAYER:人物番号, @"初めて%CALLNAME:TARGET%とデートをした","日常")
TIME += 10
RETURN 1


;===================================================
;実行可能判定
;===================================================
@COM_ABLE418
;連れ出す実行判定
SIF SAVESTR:ゲームフェイズ管理 != "通常モード"
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(418)
	RETURN RESULT
;1日に1人まで
SIF TFLAG:キャラ中途追加人数 > 0
	RETURN 0
;あなたデート中はダメ
SIF CFLAG:MASTER:デート
	RETURN 0
;10時より前はダメ
SIF TIME < 600
	RETURN 0
;20時半以降もダメ
SIF TIME >= 1230
	RETURN 0
;飲み会時禁止
SIF TFLAG:調教モード == 3
	RETURN 0
;場所判定
SIF !ナンパ可否場所判定()
	RETURN 0
RETURN 1


;===================================================
;実行時メッセージ
;===================================================

;-------------------------------------------------
;場所判定
;-------------------------------------------------
@ナンパ可否場所判定
#FUNCTION

SELECTCASE CFLAG:PLAYER:現在マップ種別
	CASE 0
		SIF GROUPMATCH(CFLAG:PLAYER:現在位置, 1, 2, 3, 15, 304, 307, 503, 1503, 1504, 1505, 1506)
			RETURNF 1
	CASE 1
		SIF GROUPMATCH(CFLAG:PLAYER:現在位置, 1, 2)
			RETURNF 1
	CASE 3
		SIF GROUPMATCH(CFLAG:PLAYER:現在位置, 1, 2, 3)
			RETURNF 1
	CASE 100
		RETURNF 1
ENDSELECT
RETURNF 0


;-------------------------------------------------
;成功判定
;ナンパが成功の場合空文字列を
;失敗の場合その理由を文字列で返す
;-------------------------------------------------
@ナンパ成功判定(ＤＢ名, 管理番号)
#FUNCTIONS
#DIMS ＤＢ名
#DIM 管理番号
#DIM 成功率
#DIM Ｒキャラ性別
#DIM Ｒキャラ性愛傾向
#DIMS 断り理由

Ｒキャラ性別 = ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "性別")
Ｒキャラ性愛傾向 = ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "性愛傾向")

;恋愛対象チェック　対象外なら無条件で失敗
IF Ｒキャラ性愛傾向 == 3
	;両刀はスルー
ELSEIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "性癖素質", "同性愛") > 0
	;同性愛（異性愛）持ちもスルー
ELSEIF Ｒキャラ性別 == 3 || TALENT:PLAYER:性別 == 3
	;どっちかがふたなりならスルー
ELSEIF Ｒキャラ性別 == 0
	;無性は恋愛しない
	RETURNF "興味がない"
ELSEIF TALENT:PLAYER:性別 == 0
	;あなたが無性の場合断られる
	RETURNF "貴方に魅力を感じない"
ELSEIF Ｒキャラ性別 == 2
	;男性の場合
	IF Ｒキャラ性愛傾向 == 2
		;男性愛は女性お断り
		SIF TALENT:PLAYER:性別 == 1
			RETURNF "女に興味はない"
	ELSE
		;通常時は同性お断り
		SIF TALENT:PLAYER:性別 == 2
			RETURNF "男同士の趣味はない"
	ENDIF
ELSE
	;女性の場合
	IF Ｒキャラ性愛傾向 == 1
		;女性愛は男性お断り
		SIF TALENT:PLAYER:性別 == 2
			RETURNF "男に興味はない"
	ELSE
		;通常時は同性お断り
		SIF TALENT:PLAYER:性別 == 1
			RETURNF "女同士の趣味はない"
	ENDIF
ENDIF

;成功率の計算
;ランダムキャラを呼ぶ手段の１つである以上、例外を除いて相手の素質には関係しない
;みんなリゾートという非日常で浮かれているんだろうね
断り理由 '= "今はそういう気分じゃない"
成功率 = 25 + ABL:PLAYER:話術技能 * 5
SIF あなた特殊能力:遊び人 > 0
	成功率 += あなた特殊能力:遊び人 * 20

;恋人持ちのチェック（セフレありの場合無視）
;これがその例外。あなたがとんでもない遊び人なら成功するかも……？
IF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "セフレあり") == 0
	SELECTCASE ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "恋人持ち")
		CASE 1
			;恋人持ち
			断り理由 '= "恋人がいる"
			成功率 -= 130
		CASE 2
			;人妻
			断り理由 '= "既婚者である"
			成功率 -= 140
		CASE 3
			;未亡人　子供がいるかで分岐
			IF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "子持ち") == 1
				断り理由 '= "子供がいる"
				成功率 -= 70
			ELSE
				断り理由 '= "操を立てた相手がいる"
				成功率 -= 50
			ENDIF
		CASE -1
			;想い人あり
			断り理由 '= "心に決めた人がいる"
			成功率 -= 90
	ENDSELECT
ENDIF

SIF 成功率 <= RAND:100
	RETURNF 断り理由
RETURNF ""


;-------------------------------------------------
;ランダムキャラ生成とナンパの実行
;-------------------------------------------------
@ランダム観光客ナンパ実行(ナンパ成功フラグ)
#LOCALSIZE 2
#LOCALSSIZE 1
#DIM REF ナンパ成功フラグ
#DIMS 表示文字列
#DIMS 追加表示格納
#DIM 管理番号
#DIM 特殊種族フラグ, 1 ; 0=ワーウルフ
#DIM 追加キャラ番号
#DIM Ｒキャラ性別
#DIMS ナンパ失敗理由

;次の候補を確認する際にリセットしない処理群
;そっくりさん関連
SIF そっくりさん画像枚数_閾値 < 1
	そっくりさん画像枚数_閾値 = 10
SIF そっくりさんフラグ
	CALL ランダムキャラそっくりさん候補リスト作成

$従業員_LOOP
DRAWLINE
PRINTL 選んだ候補（ランダムキャラ）に声をかけます。
PRINTPLAIN [110] 別の候補を探す　を選んだ場合、前のキャラには戻れないので注意してください。
PRINTL
DRAWLINE

;左パネル (メニュー)
表示文字列 '= ランダムキャラ表示_左パネル("このキャラに声をかける", "別の候補を探す", "ナンパを中止する")

;キャラ生成処理
CALL ランダムキャラ生成準備開始(Ｒキャラ追加候補記録, 1)
管理番号 = RESULT

;観光客ナンパ固有の仕様１
;性別：先に判定
Ｒキャラ性別 = ランダム性別()
CALL ランダムキャラデータ_SET_B(Ｒキャラ追加候補記録, 管理番号, "素質", "性別", Ｒキャラ性別)

;未経験：非処女・非童貞が出やすい
IF GETBIT(Ｒキャラ性別, 0)
	;処女
	IF RAND:10 == 0
		;10％で処女
		CALL ランダムキャラデータ_SET_B(Ｒキャラ追加候補記録, 管理番号, "素質", "処女", 1)
	ELSE
		CALL ランダムキャラデータ_SET_B(Ｒキャラ追加候補記録, 管理番号, "素質", "処女", 0)
	ENDIF
ENDIF
IF GETBIT(Ｒキャラ性別, 1)
	;童貞
	SELECTCASE RAND:100
		CASE 0
			;1％の確率でA性交も経験済の非童貞
			CALL ランダムキャラデータ_SET_B(Ｒキャラ追加候補記録, 管理番号, "素質", "非童貞", 3)
		CASE 1 TO 9
			;10％で童貞
			CALL ランダムキャラデータ_SET_B(Ｒキャラ追加候補記録, 管理番号, "素質", "非童貞", 0)
		CASEELSE
			;残りは非童貞
			CALL ランダムキャラデータ_SET_B(Ｒキャラ追加候補記録, 管理番号, "素質", "非童貞", 1)
	ENDSELECT
ENDIF

;残りは標準設定でランダム生成実行
CALL ランダムキャラ生成(Ｒキャラ追加候補記録, 管理番号)

;そっくりさん処理
IF そっくりさんフラグ && RAND:3 == 0
	CALL ランダムキャラそっくりさん適用(Ｒキャラ追加候補記録, 管理番号)
ENDIF

;メインパネル (キャラデータ表示処理)
表示文字列 += ランダムキャラ表示_メインパネル(Ｒキャラ追加候補記録, 管理番号, 特殊種族フラグ)

$表示_LOOP
;上パネル (汎用立ち絵表示)
CALL ランダムキャラ表示_上パネル(Ｒキャラ追加候補記録, 管理番号, 特殊種族フラグ)
追加表示格納 '= RESULTS

HTML_PRINT 追加表示格納
FOR LOCAL, 0, 10
	PRINTL
NEXT

HTML_PRINT 表示文字列
FOR LOCAL, 0, 25
	PRINTL
NEXT
DRAWLINE

$INPUT_LOOP
INPUT

SELECTCASE RESULT
	CASE 100
		追加キャラ番号 = CHARANUM

		PRINTFORML %ランダムキャラデータ_GETS(Ｒキャラ追加候補記録, 管理番号, "呼び名")%に声をかけた
		ナンパ失敗理由 '= ナンパ成功判定(Ｒキャラ追加候補記録, 管理番号)
		ナンパ成功フラグ = (ナンパ失敗理由 == "")

		IF !ナンパ成功フラグ
			PRINTFORMW しかし「%ナンパ失敗理由%」と断られてしまった…
			PRINTL 
			PRINTL 
			PRINTL ……今の相手を覚えておこうか？
			PRINTL ※はいを選ぶとキャラとして追加されますが、今日のナンパは中止になります。
			PRINTL 　いいえを選ぶとキャラはいなくなり、二度と出会えなくなります。
			CALL CHOICE("", "はい", "いいえ")
			IF RESULT == 1
				PRINTL ナンパの成否をいちいち気にしても仕方がない。
				PRINTFORMW %CALLNAME:PLAYER%は断った相手のことを忘れ、次の候補を探し始めた…
				GOTO 従業員_LOOP
			ENDIF
		ENDIF

		ADDCHARA 999
		CALL ランダムキャラデータ復元(Ｒキャラ追加候補記録, 追加キャラ番号, 管理番号)
		TFLAG:キャラ中途追加人数 += 1

		CALL ADD_PERSON_FROM_CHARA(追加キャラ番号)
		CALL コマンド存在チェック
		CALL キャラクター初期化(追加キャラ番号)

		CFLAG:追加キャラ番号:招待不可フラグ = 0
		CALL ステータス記録_ランダムキャラデータベース(Ｒキャラ追加候補記録, 管理番号, CFLAG:追加キャラ番号:人物番号)

		IF ナンパ成功フラグ
			;日中にキャラを挿入する際に必要な処理
			CALL 日帰り開始処理(追加キャラ番号)
			;ナンパキャラの性欲をある程度確保しておく
			CALL 性欲ゲージ増加(追加キャラ番号, MAXBASE:追加キャラ番号:性欲 * 5)
		ENDIF
		CALL SORT_CHARALIST()
		CALL TARGET_SET()
		RETURN 追加キャラ番号
	CASE 110
		GOTO 従業員_LOOP
	CASE 120
		INVERTBIT OPTION変数:汎用立ち絵制御, 0
		GOTO 表示_LOOP
	CASE 130
		INVERTBIT OPTION変数:ワーウルフ画像ケモ度, 0
		;今の従業員がワーウルフなら即時適用
		SIF 特殊種族フラグ:0
			CALL ランダムキャラ画像キー再選択(Ｒキャラ追加候補記録, 管理番号)
		GOTO 表示_LOOP
	CASE 131
		CALL ランダムキャラそっくりさん設定
		GOTO 表示_LOOP
	CASE 999
		RETURN 0
	CASEELSE
ENDSELECT


;データベースの情報をキャラに対して反映する共通処理
;どの情報を対象とするかは条件で与えるが、扱いを間違えるとキャラが壊れるので基本的にラッパ関数から使用する
@ランダムキャラデータ復元_実処理(ＤＢ名, キャラ番号, 条件, 順序 = "")
#DIMS ＤＢ名
#DIM キャラ番号
#DIMS 条件
#DIMS 順序
#DIM DYNAMIC ランダムキャラレコード, ランダムキャラレコード最大数
#DIM ランダムキャラレコード行数
#DIM ループ用

ランダムキャラレコード行数 = DT_SELECT(ＤＢ名, 条件, 順序, ランダムキャラレコード)
SIF ランダムキャラレコード行数 > ランダムキャラレコード最大数
	THROW ランダムキャラレコードの行数が多すぎます。開発者に連絡し、要素数の拡張を依頼してください。

FOR ループ用, 0, ランダムキャラレコード行数
	SELECTCASE DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "カテゴリ", 1)
		;管理用ヘッダ
		CASE "人物番号"
			;NOOP

		;CSVに記述できる内容
		CASE "番号"
			;違う番号のキャラの内容を反映するのは危険なので無視
		; CASE "助手"
		; 	;CSVには記述できるがキャラ追加せずに取り出す方法がないためいろいろ不都合があり無視 それにもともと未使用だし
		CASE "名前"
			NAME:キャラ番号 '= DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "値_文字列", 1)
		CASE "呼び名"
			CALLNAME:キャラ番号 '= DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "値_文字列", 1)
		CASE "あだ名"
			;未使用
			;N/I/C/K/N/A/M/E:キャラ番号 '= DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "値_文字列", 1)
		CASE "主人の呼び方"
			;未使用
			;M/A/S/T/E/R/N/A/M/E:キャラ番号 '= DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "値_文字列", 1)
		CASE "基礎"
			MAXBASE:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
			BASE:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "素質"
			TALENT:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "能力"
			ABL:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "経験"
			EXP:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "刻印"
			MARK:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		; CASE "相性"
		; 	;使用禁止に設定されている
		CASE "珠"
			JUEL:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "装着物"
			EQUIP:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "フラグ", "CFLAG"
			CFLAG:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "CSTR"
			CSTR:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) '= DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "値_文字列", 1)

		;追加の変数
		;CSVに直接記述できないためCSTRに保存してキャラクター初期化時に反映させているが、ランダムキャラデータベースではその制限がないため直接扱う
		CASE "知識素質"
			知識素質:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "性癖素質"
			性癖素質:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "基礎BATTLE_STATE"
			基礎BATTLE_STATE:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "表示奥義"
			表示奥義:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) '= DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "値_文字列", 1)
		CASE "陥落奥義"
			陥落奥義:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) '= DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "値_文字列", 1)
		CASE "同行候補キャラ"
			;関係のあるランダムキャラを全て追加してから@ランダムキャラ初期化処理_同行候補キャラで処理するため、ここでは何もしない
		CASE "初期関係性"
			;関係のあるランダムキャラを全て追加してから@ランダムキャラ初期化処理_初期関係性で処理するため、ここでは何もしない

		;その他の変数
		;対応したCSTRはなく、CSVには反映されない
		CASE "フレーバー素質"
			フレーバー素質:キャラ番号:DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1) = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
		CASE "出生"
			;関係のあるランダムキャラを全て追加してから@ランダムキャラ初期化処理_出生で処理するため、ここでは何もしない

		;CSVエディタ専用の内容
		;キャラへは直接反映しない
		CASE "同行候補キャラ_CSV", "初期関係性_CSV"
			;NOOP
	ENDSELECT
NEXT


;データベースの管理番号で指定した情報を全てキャラに対して反映する処理
;他のキャラ初期化処理は関数の外側で行う
@ランダムキャラデータ復元(ＤＢ名 = Ｒキャラ初期値記録, キャラ番号, 管理番号)
#DIMS ＤＢ名
#DIM キャラ番号
#DIM 管理番号

JUMP ランダムキャラデータ復元_実処理(ＤＢ名, キャラ番号, @"管理番号 = {管理番号}")


;データベースの同行候補キャラ情報をキャラに対して反映する処理
;@キャラクター初期化から呼ばれる
;関係のあるランダムキャラを全て追加してから初期化を行うこと
@ランダムキャラ初期化処理_同行候補キャラ(ＤＢ名 = Ｒキャラ初期値記録, キャラ番号, 開始要素番号)
#DIMS ＤＢ名
#DIM キャラ番号
#DIM 開始要素番号
#DIM 管理番号
#DIM DYNAMIC ランダムキャラレコード, ランダムキャラレコード最大数
#DIM ランダムキャラレコード行数
#DIM ループ用
#DIM 対象管理番号
#DIM 対象人物番号
#DIM 対象キャラ番号

;管理番号を取得 存在しないなら反映するデータはない
管理番号 = ランダムキャラデータ_GET_KEY_FROM_PERSON(ＤＢ名, CFLAG:キャラ番号:人物番号)
SIF 管理番号 == 0
	RETURN 開始要素番号

ランダムキャラレコード行数 = DT_SELECT(ＤＢ名, @"管理番号 = {管理番号} And カテゴリ = '同行候補キャラ'", , ランダムキャラレコード)
SIF ランダムキャラレコード行数 > ランダムキャラレコード最大数
	THROW ランダムキャラレコードの行数が多すぎます。開発者に連絡し、要素数の拡張を依頼してください。

;処理の開始
FOR ループ用, 0, ランダムキャラレコード行数
	対象管理番号 = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1)
	SIF ランダムキャラデータ_IS_KEY_IGNORED(ＤＢ名, 対象管理番号)
		CONTINUE
	対象人物番号 = ランダムキャラデータ_GET(ＤＢ名, 対象管理番号, "人物番号")
	SIF 対象人物番号 == 0 || !EXIST_PERSON(対象人物番号)
		CONTINUE
	対象キャラ番号 = FIND_CHARA_FROM_PERSON_ID(対象人物番号)
	SIF 対象キャラ番号 < 0
		CONTINUE
	SIF FINDCHARA(同行候補キャラ番号:キャラ番号:0, 対象キャラ番号) >= 0
		CONTINUE

	同行候補キャラ番号:キャラ番号:開始要素番号 = 対象キャラ番号
	同行候補キャラ番号:キャラ番号:開始要素番号 = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
	開始要素番号 ++
NEXT
RETURN 開始要素番号


;データベースの初期関係性情報をキャラに対して反映する処理
;@初期関係性データベース登録から呼ばれる
;関係のあるランダムキャラを全て追加してから初期化を行うこと
@ランダムキャラ初期化処理_初期関係性(ＤＢ名 = Ｒキャラ初期値記録, キャラ番号)
#DIMS ＤＢ名
#DIM キャラ番号
#DIM 管理番号
#DIM DYNAMIC ランダムキャラレコード, ランダムキャラレコード最大数
#DIM ランダムキャラレコード行数
#DIM ループ用
#DIM 対象管理番号
#DIM 対象人物番号
#DIM 対象キャラ番号
#DIM TMP_RANDCHARA, 1

;管理番号を取得 存在しないなら反映するデータはない
管理番号 = ランダムキャラデータ_GET_KEY_FROM_PERSON(ＤＢ名, CFLAG:キャラ番号:人物番号)
SIF 管理番号 == 0
	RETURN 0

ランダムキャラレコード行数 = DT_SELECT(ＤＢ名, @"管理番号 = {管理番号} And カテゴリ = '初期関係性'", , ランダムキャラレコード)
SIF ランダムキャラレコード行数 > ランダムキャラレコード最大数
	THROW ランダムキャラレコードの行数が多すぎます。開発者に連絡し、要素数の拡張を依頼してください。

;処理の開始
FOR ループ用, 0, ランダムキャラレコード行数
	対象管理番号 = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1)
	SIF ランダムキャラデータ_IS_KEY_IGNORED(ＤＢ名, 対象管理番号)
		CONTINUE
	対象人物番号 = ランダムキャラデータ_GET(ＤＢ名, 対象管理番号, "人物番号")
	SIF 対象人物番号 == 0 || !EXIST_PERSON(対象人物番号)
		CONTINUE
	対象キャラ番号 = FIND_CHARA_FROM_PERSON_ID(対象人物番号)
	SIF 対象キャラ番号 < 0
		CONTINUE
	;同行率セット
	IF GET_RELATION(キャラ番号, 対象キャラ番号) / 100 < 80
		CALL SET_同行候補(キャラ番号, 対象キャラ番号, 8000)
	ENDIF
	;同一組み合わせはスキップ
	SIF DT_SELECT("関係性データベース", @"(対象キャラ１ = {CFLAG:キャラ番号:人物番号} Or 対象キャラ２ = {CFLAG:キャラ番号:人物番号}) And (対象キャラ１ = {CFLAG:対象キャラ番号:人物番号} Or 対象キャラ２ = {CFLAG:対象キャラ番号:人物番号})", , TMP_RANDCHARA) > 0
		CONTINUE
	SELECTCASE DT_CELL_GETS(ＤＢ名, ランダムキャラレコード:ループ用, "値_文字列", 1)
		CASE "恋慕"
			;既に恋慕があるなら恋慕初期はスキップ
			SIF DT_SELECT("関係性データベース", @"(対象キャラ１ = {CFLAG:キャラ番号:人物番号} Or 対象キャラ２ = {CFLAG:キャラ番号:人物番号} Or 対象キャラ１ = {CFLAG:対象キャラ番号:人物番号} Or 対象キャラ２ = {CFLAG:対象キャラ番号:人物番号}) And 関係性種別 = '恋慕'", , TMP_RANDCHARA) > 0
				CONTINUE
			SIF TALENT:キャラ番号:恋慕
				CONTINUE
			SIF TALENT:対象キャラ番号:恋慕
				CONTINUE

			DT_ROW_ADD "関係性データベース", "対象キャラ１", CFLAG:キャラ番号:人物番号, "対象キャラ２", CFLAG:対象キャラ番号:人物番号, "関係性種別", "恋慕"
			SIF TALENT:キャラ番号:恋人持ち != 2
				TALENT:キャラ番号:恋人持ち = 1
			SIF TALENT:対象キャラ番号:恋人持ち != 2
				TALENT:対象キャラ番号:恋人持ち = 1
			SETBIT TALENT:キャラ番号:陥落不可, 0
			SETBIT TALENT:対象キャラ番号:陥落不可, 0
		CASE "セフレ"
			DT_ROW_ADD "関係性データベース", "対象キャラ１", CFLAG:キャラ番号:人物番号, "対象キャラ２", CFLAG:対象キャラ番号:人物番号, "関係性種別", "セフレ"
			TALENT:キャラ番号:セフレあり = 1
			TALENT:対象キャラ番号:セフレあり = 1
	ENDSELECT
NEXT
RETURN 0


;ランダムキャラデータベースの出生情報を人物データベースに対して反映する処理
;@キャラクター初期化から呼ばれる
;関係のあるランダムキャラを全て追加してから初期化を行うこと
@ランダムキャラ初期化処理_出生(ＤＢ名 = Ｒキャラ初期値記録, キャラ番号)
#DIMS ＤＢ名
#DIM キャラ番号
#DIM 管理番号
#DIM DYNAMIC ランダムキャラレコード, ランダムキャラレコード最大数
#DIM ランダムキャラレコード行数
#DIM ループ用
#DIM 対象管理番号
#DIM 対象人物番号

;管理番号を取得 存在しないなら反映するデータはない
管理番号 = ランダムキャラデータ_GET_KEY_FROM_PERSON(ＤＢ名, CFLAG:キャラ番号:人物番号)
SIF 管理番号 == 0
	RETURN 0

ランダムキャラレコード行数 = DT_SELECT(ＤＢ名, @"管理番号 = {管理番号} And カテゴリ = '出生'", , ランダムキャラレコード)
SIF ランダムキャラレコード行数 > ランダムキャラレコード最大数
	THROW ランダムキャラレコードの行数が多すぎます。開発者に連絡し、要素数の拡張を依頼してください。

;処理の開始
FOR ループ用, 0, ランダムキャラレコード行数
	SELECTCASE DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "項目", 1)
		CASE ランダムキャラ出生_母
			対象管理番号 = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
			SIF ランダムキャラデータ_IS_KEY_IGNORED(ＤＢ名, 対象管理番号)
				CONTINUE
			対象人物番号 = ランダムキャラデータ_GET(ＤＢ名, 対象管理番号, "人物番号")
			SIF 対象人物番号 == 0 || !EXIST_PERSON(対象人物番号)
				CONTINUE

			CALL SET_PERSON_母親(CFLAG:キャラ番号:人物番号, 対象人物番号)
		CASE ランダムキャラ出生_父
			対象管理番号 = DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1)
			SIF ランダムキャラデータ_IS_KEY_IGNORED(ＤＢ名, 対象管理番号)
				CONTINUE
			対象人物番号 = ランダムキャラデータ_GET(ＤＢ名, 対象管理番号, "人物番号")
			SIF 対象人物番号 == 0 || !EXIST_PERSON(対象人物番号)
				CONTINUE

			CALL SET_PERSON_父親(CFLAG:キャラ番号:人物番号, 対象人物番号)
		CASE ランダムキャラ出生_出生順
			CALL SET_PERSON_出生順(CFLAG:キャラ番号:人物番号, DT_CELL_GET(ＤＢ名, ランダムキャラレコード:ループ用, "値_数値", 1))
	ENDSELECT
NEXT
RETURN 0

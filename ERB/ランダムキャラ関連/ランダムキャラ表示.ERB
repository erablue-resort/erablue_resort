@ランダムキャラ表示_左パネル(採用時選択肢 = "", 別候補時選択肢 = "", キャンセル時選択肢 = "")
#FUNCTIONS
#DIMS 採用時選択肢
#DIMS 別候補時選択肢
#DIMS キャンセル時選択肢
#DIMS 表示文字列

;左パネル (メニュー)
表示文字列 '= "<div rect='81,31,1937,2812' border='31' bcolor='#C0C0C0'></div><div rect='2050,31,3875,2812' border='31' bcolor='#C0C0C0'></div>"
表示文字列 += "<div rect='156,156,1937,2812'>"
IF 採用時選択肢 != ""
	表示文字列 += @"<button value='100'>[100] %採用時選択肢%</button>"
	表示文字列 += "<br>"
ENDIF
IF 別候補時選択肢 != ""
	表示文字列 += @"<button value='110'>[110] %別候補時選択肢%</button>"
	表示文字列 += "<br>"
ENDIF
表示文字列 += "<button value='120'>[120] 汎用立ち絵機能を切り替える</button>"
表示文字列 += "<br>"
表示文字列 += "<button value='130'>[130] ワーウルフの立ち絵を変更する</button>"
表示文字列 += "<br>"
表示文字列 += "<button value='131'>[131] そっくりさん立ち絵を変更する</button>"
表示文字列 += "<br>"
表示文字列 += "<br>"
IF キャンセル時選択肢 != ""
	表示文字列 += @"<button value='999'>[999] %キャンセル時選択肢%</button>"
ENDIF
表示文字列 += "</div>"
RETURNF 表示文字列


@ランダムキャラ表示_メインパネル(ＤＢ名, 管理番号, 特殊種族フラグ)
#FUNCTIONS
#LOCALSIZE 2
#LOCALSSIZE 1
#DIMS ＤＢ名
#DIM 管理番号
#DIM REF 特殊種族フラグ, 0
#DIMS 表示文字列
#DIMS 追加表示格納
#DIMS 素質行格納
#DIM Ｒキャラ性別
#DIM 改行フラグ

;メインパネル (キャラデータ表示処理)
表示文字列 '= "<div rect='2125,156,3675,2812'>"

LOCALS '= ランダムキャラデータ_GETS(ＤＢ名, 管理番号, "名前")
表示文字列 += @"■%LOCALS, 26, LEFT%"

LOCAL = ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "基礎BATTLE_STATE", "属性")
表示文字列 += @"<font color='#%属性数値文字色変換_HTML(LOCAL)%'>"
表示文字列 += @"属性：%属性数値文字列変換(LOCAL)%</font>"

表示文字列 += @"　得意武器：%得意武器表示文字列(ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "基礎BATTLE_STATE", "得意武器"))%"
表示文字列 += @"　タイプ：%成長タイプ:(ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "基礎BATTLE_STATE", "ステータスタイプ保存"))%"
表示文字列 += "<br><br>"

表示文字列 += "□ 情報 □---------------------------------------------------------------<br>"

表示文字列 += @"　種族：%GET_TALENTNAME(200, ランダムキャラデータ_GET(ＤＢ名, 管理番号, "素質", 200))%"
LOCALS '= ランダムキャラデータ_GETS_B(ＤＢ名, 管理番号, "CSTR", "特殊種族")
特殊種族フラグ:0 = 0
IF LOCALS != ""
	表示文字列 += @" [%LOCALS%]"
	SIF LOCALS == "ワーウルフ"
		特殊種族フラグ:0 = 1
ENDIF

追加表示格納 '= ""
SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "角あり")
	追加表示格納 += "（角あり）"
SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "尻尾あり")
	追加表示格納 += "（尻尾）"
SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "エルーン耳")
	追加表示格納 += "（エルーン耳）"
SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "ハーヴィン耳")
	追加表示格納 += "（ハーヴィン耳）"
SELECTCASE ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "発情期あり")
	CASE IS > 0
		追加表示格納 += "（発情期あり）"
	CASE IS < 0
		追加表示格納 += "（発情期なし）"
ENDSELECT
表示文字列 += REPLACE(追加表示格納, "）（", "／")
表示文字列 += "<br>"

表示文字列 += "　性別："
追加表示格納 '= ""
Ｒキャラ性別 = ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "性別")
SELECTCASE Ｒキャラ性別
	CASE 1
		表示文字列 += "女性"
		SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "処女")
			追加表示格納 += "（処女）"
		SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "Ａ処女")
			追加表示格納 += "（Ａ処女）"
	CASE 2
		表示文字列 += "男性"
		SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "非童貞") == 0
			追加表示格納 += "（童貞）"
		SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "Ａ処女")
			追加表示格納 += "（Ａ処女）"
	CASE 3
		表示文字列 += "ふたなり"
		SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "非童貞") == 0
			追加表示格納 += "（童貞）"
		SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "処女")
			追加表示格納 += "（処女）"
		SIF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "Ａ処女")
			追加表示格納 += "（Ａ処女）"
	CASEELSE
		表示文字列 += "その他"
ENDSELECT
表示文字列 += REPLACE(追加表示格納, "）（", "／")
表示文字列 += "<br>"

IF GETBIT(Ｒキャラ性別, 0)
	;女性・ふたなりはバストサイズの表示
	表示文字列 += @"　バストサイズ：%GET_TALENTNAME(205, ランダムキャラデータ_GET(ＤＢ名, 管理番号, "素質", 205))%　　"
ENDIF

表示文字列 += @"　性知識Ｌｖ："
;性知識：処女/童貞、年齢層、エルーンかどうかで分布が異なる
SELECTCASE ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "知識素質", "性知識")
	CASE -2
		表示文字列 += "無知"
	CASE -1
		表示文字列 += "獣並み"
	CASE 0
		IF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "性的興味") > 0
			表示文字列 += "耳年増"
		ELSE
			表示文字列 += "疎い"
		ENDIF
	CASE 1
		表示文字列 += "必要十分"
	CASE 2
		表示文字列 += "有識者"
ENDSELECT
表示文字列 += "<br>"

表示文字列 += @"　容姿：%GET_TALENTNAME(160, ランダムキャラデータ_GET(ＤＢ名, 管理番号, "素質", 160)), 14, LEFT%"

LOCAL:0 = ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "年齢層")
LOCAL:1 = ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "外見年齢")
表示文字列 += @"年齢：%GET_年齢文字列(Ｒキャラ性別, LOCAL:0, LOCAL:1), 17, LEFT%"
表示文字列 += "<br>"

表示文字列 += @"　体格：%GET_TALENTNAME(161, ランダムキャラデータ_GET(ＤＢ名, 管理番号, "素質", 161)), 14, LEFT%"

表示文字列 += @"体型：%GET_TALENTNAME(163, ランダムキャラデータ_GET(ＤＢ名, 管理番号, "素質", 163))%"
表示文字列 += "<br>"

IF Ｒキャラ性別 == 3
	;男性器サイズの表示はふたなりのみ
	表示文字列 += @"　男性器サイズ：%GET_TALENTNAME(162, ランダムキャラデータ_GET(ＤＢ名, 管理番号, "素質", 162))%"
ENDIF
表示文字列 += "<br><br>"

表示文字列 += "□ 素質 □---------------------------------------------------------------<br>"

素質行格納 '= "　"
FOR LOCAL, 6, 160
	LOCALS '= GET_TALENTNAME(LOCAL, ランダムキャラデータ_GET(ＤＢ名, 管理番号, "素質", LOCAL))
	SIF STRLENS(LOCALS) <= 0
		CONTINUE
	;男の時、V感覚はスキップ
	SIF LOCAL == 102 && !GETBIT(Ｒキャラ性別, 0)
		CONTINUE

	IF (STRLENS(HTML_TOPLAINTEXT(素質行格納 + LOCALS)) + 2) / (3625 / 50) > 0
		表示文字列 += 素質行格納 + "<br>"
		素質行格納 '= "　"
	ENDIF
	素質行格納 += @"[%LOCALS%]"
NEXT
FOR LOCAL, 220, 300
	LOCALS '= GET_TALENTNAME(LOCAL, ランダムキャラデータ_GET(ＤＢ名, 管理番号, "素質", LOCAL))
	SIF STRLENS(LOCALS) <= 0
		CONTINUE

	IF (STRLENS(HTML_TOPLAINTEXT(素質行格納 + LOCALS)) + 2) / (3625 / 50) > 0
		表示文字列 += 素質行格納 + "<br>"
		素質行格納 '= "　"
	ENDIF
	素質行格納 += @"[%LOCALS%]"
NEXT
FOR LOCAL, 0, 10
	LOCALS '= ランダムキャラデータ_GETS_B(ＤＢ名, 管理番号, "CSTR", @"固有素質{LOCAL}")
	SIF STRLENS(LOCALS) <= 0
		CONTINUE

	IF (STRLENS(HTML_TOPLAINTEXT(素質行格納 + LOCALS)) + 2) / (3625 / 50) > 0
		表示文字列 += 素質行格納 + "<br>"
		素質行格納 '= "　"
	ENDIF
	素質行格納 += @"[%LOCALS%]"
NEXT
FOR LOCAL, 1, 100
	LOCAL:1 = ランダムキャラデータ_GET(ＤＢ名, 管理番号, "知識素質", LOCAL)
	SIF LOCAL:1 == 0
		CONTINUE
	LOCALS '= ERDNAME(知識素質, LOCAL)
	SIF STRLENS(LOCALS) <= 0
		CONTINUE
	LOCALS += @"Lv{LOCAL:1}"

	IF (STRLENS(HTML_TOPLAINTEXT(素質行格納 + LOCALS)) + 2) / (3625 / 50) > 0
		表示文字列 += 素質行格納 + "<br>"
		素質行格納 '= "　"
	ENDIF
	素質行格納 += @"[%LOCALS%]"
NEXT
表示文字列 += 素質行格納 + "<br><br>"

表示文字列 += "□ 能力 □---------------------------------------------------------------<br>"
改行フラグ = 0
FOR LOCAL, 0, 30
	;非表示
	SIF GROUPMATCH(LOCAL, 16, 17, 21, 22, 23, 24, 25, 26, 27, 28)
		CONTINUE

	LOCAL:1 = ランダムキャラデータ_GET(ＤＢ名, 管理番号, "能力", LOCAL)
	SIF LOCAL:1 == 0
		CONTINUE
	IF 改行フラグ == 3
		表示文字列 += "<br>"
		改行フラグ = 0
	ENDIF
	表示文字列 += @"%ABLNAME:LOCAL, 16%:{LOCAL:1, 3, LEFT} "
	改行フラグ ++
NEXT
FOR LOCAL, 21, 30
	;非表示
	SIF GROUPMATCH(LOCAL, 23, 25, 26, 28)
		CONTINUE

	LOCAL:1 = ランダムキャラデータ_GET(ＤＢ名, 管理番号, "能力", LOCAL)
	SIF LOCAL:1 == 0
		CONTINUE
	IF 改行フラグ == 3
		表示文字列 += "<br>"
		改行フラグ = 0
	ENDIF
	表示文字列 += @"%ABLNAME:LOCAL, 16%:{LOCAL:1, 3, LEFT} "
	改行フラグ ++
NEXT
表示文字列 += "<br><br>"

表示文字列 += "□ 経験 □---------------------------------------------------------------<br>"
改行フラグ = 0
FOR LOCAL, 0, 200
	;肉体熟知は別枠
	SIF LOCAL == 89
		CONTINUE

	LOCAL:1 = ランダムキャラデータ_GET(ＤＢ名, 管理番号, "経験", LOCAL)
	SIF LOCAL:1 == 0
		CONTINUE
	IF 改行フラグ == 3
		表示文字列 += "<br>"
		改行フラグ = 0
	ENDIF
	表示文字列 += @"%EXPNAME:LOCAL, 16%:{LOCAL:1, 3, LEFT} "
	改行フラグ ++
NEXT
表示文字列 += "</div>"
RETURNF 表示文字列


@ランダムキャラ表示_上パネル(ＤＢ名, 管理番号, 特殊種族フラグ)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS ＤＢ名
#DIM 管理番号
#DIM REF 特殊種族フラグ, 0
#DIMS 表示文字列
#DIM 画像フラグ, 2

;上パネル (汎用立ち絵表示)
LOCALS '= ランダムキャラデータ_GETS_B(ＤＢ名, 管理番号, "CSTR", "汎用立ち絵登録文字列")
表示文字列 '= "<div rect='81,31,5860,1200' padding='6' border='31' bcolor='#C0C0C0'>"
表示文字列 += "<br>"
IF OPTION変数:汎用立ち絵制御
	表示文字列 += @"<button value='120'>[120] 汎用立ち絵 ON / <font color='#%カラーパレット_HTML("グレーアウト")%'>OFF</font></button>"
	表示文字列 += "<br>"
	表示文字列 += @"<button value='130'>[130] ワーウルフの立ち絵を変更する<br>　　　（現在：\@ OPTION変数:ワーウルフ画像ケモ度? ケモより# 人より\@）</button>"
	表示文字列 += "<br>"
ELSE
	表示文字列 += @"<button value='120'>[120] 汎用立ち絵 <font color='#%カラーパレット_HTML("グレーアウト")%'>ON</font> / OFF</button>"
	表示文字列 += "<br>"
ENDIF
表示文字列 += "</div>"
IF OPTION変数:汎用立ち絵制御
	表示文字列 += "<div rect='2050,31,2400,1200' padding='6' border='31' bcolor='#C0C0C0'>"
	IF LOCALS == ""
		表示文字列 += "<img src='顔ノーイメ' height='1125'>"
	ELSE
		SPRITEDISPOSE @"顔グラ3000"
		GDISPOSE 3000
		IF STRFIND(LOCALS, "そっくりさん設定_") == 0
			CALL GCREATE_拡張子(3000, @"%REPLACE(LOCALS, "そっくりさん設定_", "")%/顔_デフォルト")
		ELSE
			CALL GCREATE_拡張子(3000, @"汎用グラフィック/顔_%LOCALS%")
		ENDIF
		画像フラグ:0 = RESULT
		SPRITEDISPOSE @"短冊グラ3000"
		GDISPOSE 3001
		IF STRFIND(LOCALS, "そっくりさん設定_") == 0
			CALL GCREATE_拡張子(3001, @"%REPLACE(LOCALS, "そっくりさん設定_", "")%/短冊_デフォルト")
		ELSE
			CALL GCREATE_拡張子(3001, @"汎用グラフィック/短冊_%LOCALS%")
		ENDIF
		画像フラグ:1 = RESULT
		;設定中の顔グラが存在すればそちらを拡縮で表示
		LOCAL = 画像サイズ切り替えOPTION記憶:1
		画像サイズ切り替えOPTION記憶:1 = 1
		IF 特殊種族フラグ:0
			;ワーウルフの場合のボタン追加処理
			SIF 画像フラグ:0 && スプライト作成(@"顔グラ3000", 3000, 0)
				表示文字列 += @"<button value='130' title='%LOCALS%'><img src='顔グラ3000'height='1125'></button>"
			SIF 画像フラグ:1 && スプライト作成(@"短冊グラ3000", 3001, 0)
				表示文字列 += @"<button value='130' title='%LOCALS%'><img src='短冊グラ3000'height='1125'></button>"
		ELSE
			SIF 画像フラグ:0 && スプライト作成(@"顔グラ3000", 3000, 0)
				表示文字列 += @"<img src='顔グラ3000'height='1125'>"
			SIF 画像フラグ:1 && スプライト作成(@"短冊グラ3000", 3001, 0)
				表示文字列 += @"<img src='短冊グラ3000'height='1125'>"
		ENDIF
		画像サイズ切り替えOPTION記憶:1 = LOCAL
	ENDIF
	表示文字列 += "</div>"
ENDIF
RESULTS '= 表示文字列
RETURN

	ランダムキャラデータ_GETS_B(ＤＢ名, 管理番号, "CSTR", "特殊種族")
	))
}


@ランダムキャラそっくりさん設定
DRAWLINE
PRINTL ランダムキャラの立ち絵に既存キャラの立ち絵を適用することが出来ます。
PRINTL 使用する場合、ランダムキャラ生成時に33％の確率でそっくりさんが出現します。
PRINTL
PRINT ・そっくりさん立ち絵を使用 
IF そっくりさんフラグ == 0
	SETCOLOR カラーパレット("グレーアウト")
	PRINTBUTTON "[する]", 0
	RESETCOLOR
	PRINTPLAIN  / [しない]
ELSE
	PRINTPLAIN [する] / 
	SETCOLOR カラーパレット("グレーアウト")
	PRINTBUTTON "[しない]", 0
	RESETCOLOR
ENDIF
PRINTL
IF そっくりさんフラグ
	PRINT ・そっくりさん候補になる画像枚数
	PRINTFORM 　　{そっくりさん画像枚数_閾値, 2}枚　
	PRINTBUTTON "[変更]", 1
	PRINTL
ENDIF
PRINTBUTTON "[999] 戻る", 999
PRINTL

PRINTL
BINPUT
PRINTL
PRINTL
SELECTCASE RESULT
	CASE 0
		INVERTBIT そっくりさんフラグ, 0
		RESTART
	CASE 1
		$枚数LOOP
		DRAWLINE
		PRINTL そっくりさん候補になる画像の最低枚数を設定出来ます。
		PRINTL 1以上の数値を入力してください。デフォルトは10枚以上です。
		PRINTL
		INPUT
		PRINTL
		IF RESULT < 1
			PRINTW 0以下の数値は入力出来ません。
			GOTO 枚数LOOP
		ENDIF
		そっくりさん画像枚数_閾値 = RESULT
		RESTART
	CASE 999
		SIF そっくりさんフラグ
			CALL ランダムキャラそっくりさん候補リスト作成
		RETURN 0
ENDSELECT


@ランダムキャラそっくりさん候補リスト作成
#LOCALSIZE 2
#DIM 候補キャラ

VARSET LOCAL
VARSET そっくりさん候補配列_非男
VARSET そっくりさん候補配列_男
FOR 候補キャラ, 1, CHARANUM
	;ランダムキャラは対象にしない
	SIF NO:候補キャラ == 999
		CONTINUE
	;画像枚数OK？
	SIF GET_RESOURCES_FILES(CSTR:候補キャラ:画像フォルダ, "*.webp", 1) < そっくりさん画像枚数_閾値
		CONTINUE
	IF CSVTALENT(NO:候補キャラ, GETNUM(TALENT, "性別")) != 2
		そっくりさん候補配列_非男:LOCAL = 候補キャラ
		LOCAL ++
	ELSE
		そっくりさん候補配列_男:(LOCAL:1) = 候補キャラ
		LOCAL:1 ++
	ENDIF
NEXT


@ランダムキャラそっくりさん適用(ＤＢ名, 管理番号, 肩書き = "一般人")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS ＤＢ名
#DIM 管理番号
#DIMS 肩書き
#DIM そっくりキャラ
#DIM Ｒキャラ性別
#DIM Ｒキャラ種族
#DIMS Ｒキャラ名前

;性別の一致するキャラの立ち絵から選択する
Ｒキャラ性別 = ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "性別")
IF Ｒキャラ性別 == 2
	SIF そっくりさん候補配列_男:0 == 0
		RETURN -1
	そっくりキャラ = そっくりさん候補配列_男:(RAND:(FINDELEMENT(そっくりさん候補配列_男, 0)))
ELSE
	SIF そっくりさん候補配列_非男:0 == 0
		RETURN -1
	そっくりキャラ = そっくりさん候補配列_非男:(RAND:(FINDELEMENT(そっくりさん候補配列_非男, 0)))
ENDIF

;画像フォルダを指定
CALL ランダムキャラデータ_SETS_B(ＤＢ名, 管理番号, "CSTR", "汎用立ち絵登録文字列", @"そっくりさん設定_%CSTR:そっくりキャラ:画像フォルダ%")

;素質を共通化、容姿を専用化
IF CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "角あり")) > 0
	;角あるならドラフ化
	Ｒキャラ種族 = 種族_ドラフ
ELSEIF CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "エルーン耳")) > 0
	;ケモミミあるならエルーン化
	Ｒキャラ種族 = 種族_エルーン
ELSEIF CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "体格")) == -3 || (CSVBASE(NO:そっくりキャラ, GETNUM(BASE, "身長")) > 0 && CSVBASE(NO:そっくりキャラ, GETNUM(BASE, "身長")) <= 1000)
	;体格ハーヴィン並、あるいは設定身長が100cm以下ならハーヴィン化
	Ｒキャラ種族 = 種族_ハーヴィン
ELSE
	;どれにも引っかからないならヒューマン
	Ｒキャラ種族 = 種族_ヒューマン
ENDIF
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "種族", Ｒキャラ種族)
;特殊種族は使わない
CALL ランダムキャラデータ_SETS_B(ＤＢ名, 管理番号, "CSTR", "特殊種族", "")
;種族特徴コピー
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "角あり", CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "角あり")))
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "ハーヴィン耳", CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "ハーヴィン耳")))
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "エルーン耳", CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "エルーン耳")))
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "尻尾あり", CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "尻尾あり")))

;名前が書き換え前の種族の規則に沿っているため、再設定
Ｒキャラ名前 '= ランダムキャラ名前生成(Ｒキャラ種族, Ｒキャラ性別)
CALL ランダムキャラデータ_SETS(ＤＢ名, 管理番号, "名前", , @"[%肩書き%]%Ｒキャラ名前%")
CALL ランダムキャラデータ_SETS(ＤＢ名, 管理番号, "呼び名", , Ｒキャラ名前)

;体格
IF CSVBASE(NO:そっくりキャラ, GETNUM(BASE, "身長")) > 0
	;正確な計算式ではなくざっくりで出す
	SELECTCASE CSVBASE(NO:そっくりキャラ, GETNUM(BASE, "身長"))
		CASE IS <= 1000
			CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "体格", -3)
		CASE IS <= 1350
			CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "体格", -2)
		CASE IS <= 1550
			CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "体格", -1)
		CASE IS <= 1750
			CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "体格", 0)
		CASE IS <= 1950
			CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "体格", 1)
		CASEELSE
			CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "体格", 2)
	ENDSELECT
ELSE
	CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "体格", CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "体格")))
ENDIF

;体型
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "体型", CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "体型")))

IF ランダムキャラデータ_GET_B(ＤＢ名, 管理番号, "素質", "性別") != 2
	;バスト
	IF CSVBASE(NO:そっくりキャラ, GETNUM(BASE, "バスト")) > 0
		;正確な計算式ではなくざっくりで出す
		SELECTCASE CSVBASE(NO:そっくりキャラ, GETNUM(BASE, "バスト")) * 10000 / CSVBASE(NO:そっくりキャラ, GETNUM(BASE, "身長")) / 53
			CASE IS <= 90
				CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "バストサイズ", バストサイズ_絶壁)
			CASE IS <= 96
				CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "バストサイズ", バストサイズ_貧乳)
			CASE IS <= 101
				CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "バストサイズ", バストサイズ_並乳)
			CASE IS <= 110
				CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "バストサイズ", バストサイズ_巨乳)
			CASE IS <= 116
				CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "バストサイズ", バストサイズ_爆乳)
			CASEELSE
				CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "バストサイズ", バストサイズ_魔乳)
		ENDSELECT
	ELSE
		CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "バストサイズ", CSVTALENT(NO:そっくりキャラ, GETNUM(TALENT, "バストサイズ")))
	ENDIF
ENDIF

;容姿そっくりさん
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "容姿", 10)

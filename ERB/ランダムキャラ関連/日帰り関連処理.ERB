@日帰り開始処理(対象キャラ, 新規キャラフラグ = 1)
#DIM 対象キャラ
#DIM 新規キャラフラグ
#DIM EXP番号

;滞在中は無効
SIF CFLAG:対象キャラ:滞在期間 > 0
	RETURN 0

;あなたの起床時に非滞在のキャラが通らなかった処理をこのタイミングで実施
;変数初期化
CALL TRAIN_CHARAVAR_RESET(対象キャラ)

;来訪時処理
CFLAG:対象キャラ:滞在期間 = 1
CFLAG:対象キャラ:リゾート来訪回数 += 1
BASE:対象キャラ:体力 = MAXBASE:対象キャラ:体力
IF !新規キャラフラグ
	CALL 招待時妊娠メッセージ(対象キャラ)
	;CALL 招待時妊娠メッセージ(0, 1) を外で呼ぶ
ENDIF
IF 初体験日:対象キャラ:リゾート初来訪 == 0
	初体験日:対象キャラ:リゾート初来訪 = DAY
	CALL 履歴データベース登録(CFLAG:対象キャラ:人物番号, @"初めてリゾートを訪れた","日常")
ENDIF

;一日開始時処理
IF 新規キャラフラグ
	;危険日などを設定する
	CALL SET_PREGNANCY_PALAM(対象キャラ)
	;乱数のセット
	CFLAG:対象キャラ:C_DAY_RAND = RAND:1000
ENDIF
;衣装設定
CALL CLOTHES_TODAY(対象キャラ)
CALL CLOTHES_RESET(対象キャラ)
CALL CLOTHES_RESET_TRAIN(対象キャラ)
;勃起、ムード、理性、怒り
BASE:対象キャラ:勃起 = 0
BASE:対象キャラ:ムード = 0
BASE:対象キャラ:理性 = MAXBASE:対象キャラ:理性
BASE:対象キャラ:怒り = 0
CFLAG:対象キャラ:勃起度 = 0
CFLAG:対象キャラ:同行 = 0
CFLAG:対象キャラ:酔いすぎ = 0
;EXP変動は表示しない（現在経験の記録はTRAIN_CHARAVAR_RESETで処理済）
;お祭り参加扱いにはならない
;デートお誘いを封印
TCVAR:対象キャラ:キャラからデート誘いフラグ = -1

;起床時処理
;キャラの位置や状態をあなたに合わせる
CFLAG:対象キャラ:現在位置 =  CFLAG:MASTER:現在位置
CFLAG:対象キャラ:現在マップ種別 = CFLAG:MASTER:現在マップ種別
CFLAG:対象キャラ:睡眠 = 0
CFLAG:対象キャラ:同室 = 1

;キャラのルーチンに仮のものを設定
移動ルーチン:対象キャラ:ルーチンID = 日帰りで観光
移動ルーチン:対象キャラ:PMルーチンID = 
CALLFORM ROUTINE_SCHEDULE_%移動ルーチン:対象キャラ:ルーチンID%(対象キャラ)

;一日開始時のEXP数値を記録
FOR EXP番号, 0, 200
	EXP記録_一日開始時:対象キャラ:EXP番号 = EXP:対象キャラ:EXP番号
NEXT

TCVAR:対象キャラ:日帰りフラグ = 1

;CALL SORT_CHARALIST() を外で呼ぶ
;CALL TARGET_SET() を外で呼ぶ
RETURN 1


@日帰りキャラ帰宅処理
#DIM 対象キャラ

FOR 対象キャラ, 0, CHARANUM
	;日帰りフラグが無い場合は無視
	SIF !TCVAR:対象キャラ:日帰りフラグ
		CONTINUE

	IF CFLAG:対象キャラ:滞在期間 == 1
		CALL 滞在終了時初期化(対象キャラ)
		CFLAG:対象キャラ:滞在期間 = -1
	ENDIF

	TCVAR:対象キャラ:日帰りフラグ = 0
NEXT


;------------------------------------------------------------------------------
;日帰りルーチン
;あなたとの同行が解除された時、リゾートから去る
;------------------------------------------------------------------------------
@MOVE_ROUTINE_日帰りで観光(キャラ番号, ARGS)
#DIM キャラ番号
#DIM 時間計算

SELECTCASE ARGS
	CASE "参加判定"
		RETURN 1

	CASE "起床時刻"
		時間計算 = 450 - (TALENT:キャラ番号:早起き * 30)
		;リゾートに呼ばれた時点で必ず起きているようにする
		RETURN MIN(時間計算, MAX(TIME, 1))

	CASE "就寝時刻"
		時間計算 = 1320 - (TALENT:キャラ番号:早寝 * 60)
		RETURN 時間計算

	CASE "就寝場所"
		RESULT:1 = 0
		RESULT:2 = 999
		RETURN 1

	CASE "初期位置"
		CFLAG:キャラ番号:現在位置 = 999
		CFLAG:キャラ番号:現在マップ種別 = 0
ENDSELECT

@ROUTINE_SCHEDULE_日帰りで観光(キャラ番号)
#DIM キャラ番号
#DIM スケジュール番号

CALL RESET_SCHEDULE(キャラ番号)
スケジュール番号 = 0

CALL SET_SCHEDULE(キャラ番号, スケジュール番号, 0, "日帰り_帰宅", "優先度", "100")
スケジュール番号++


;------------------------------------------------------------------------------
;帰宅
;------------------------------------------------------------------------------
@SCHEDULE_日帰り_帰宅(キャラ番号, 小分類, 処理内容)
#DIM キャラ番号
#DIMS 小分類
#DIMS 処理内容

SELECTCASE 処理内容
	CASE "開始処理"
		スケジュール状態:キャラ番号:目的マップ = 0
		スケジュール状態:キャラ番号:目的地 = 998
		RETURN 1
	CASE "経過処理"
		IF 追従中キャラ(キャラ番号)
			;キャラがPLAYERと一緒に移動している場合は何もなし
		ELSE
			;目的地に向かって移動することはなく、瞬時に消える
			CFLAG:キャラ番号:現在位置 = 999
			CFLAG:キャラ番号:現在マップ種別 = 0
		ENDIF
	CASE "終了処理"
		RETURN 1
ENDSELECT

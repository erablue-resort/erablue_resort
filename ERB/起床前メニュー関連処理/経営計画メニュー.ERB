IF チュートリアルフラグ:食事開発 == 0
	LOCALS += @"<font color='#%カラーパレット_HTML("黄")%'><button value='101'>[101] 食事メニュー開発</font>　<font color='#%カラーパレット_HTML("真っ赤")%'>NEW!</font></button>"

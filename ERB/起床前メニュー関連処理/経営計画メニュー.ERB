DRAWLINE

$INPUT_LOOP
BINPUT
LOCAL = RESULT
SELECTCASE LOCAL
	CASE 100
		CALL 施設改装メニュー処理
	CASE 101
		CALL 食堂メニュー開発処理
	CASE 102
		CALL 食堂メニュー設定処理
	CASE 110
		CALL お祭り企画メニュー処理
	CASE 120
		CALL 大規模エリア建築メニュー処理
	CASE 999
		RETURN 0
ENDSELECT


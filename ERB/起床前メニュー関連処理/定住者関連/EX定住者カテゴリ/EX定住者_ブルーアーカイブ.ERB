@EXキャラ誘致条件_ブルーアーカイブ
#DIM ループ用
#DIM ユニーク招待済フラグ

;女性が招待可能でないとダメ
SIF GETBIT(OPTION変数:性別招待制御, 0)
	RETURN 0

;ブルーアーカイブのネームドキャラを1人以上招待していないとダメ
ユニーク招待済フラグ = 0
FOR ループ用, 0, CHARANUM
	IF CSTR:ループ用:出演作品 == "ブルーアーカイブ" && CFLAG:ループ用:招待不可フラグ == 0
		ユニーク招待済フラグ = 1
		BREAK
	ENDIF
NEXT
SIF !ユニーク招待済フラグ
	RETURN 0

RETURN 1


@EXキャラ誘致候補_ブルーアーカイブ
#DIM 候補数
#DIM DYNAMIC TMP_SELECT, 10

候補数 = DT_SELECT("ランダムCSVデータベース", "ランダムキャラ設定 = 'ブルーアーカイブ'", , TMP_SELECT)
IF 候補数 <= 0
	RESULT:1 = 0
	RETURN 0
ELSEIF 候補数 > 10
	THROW ブルーアーカイブのランダムキャラ候補が多すぎます。開発者に連絡し、要素数の拡張を依頼してください。
ENDIF

RESULT:1 = 候補数
RETURN DT_CELL_GET("ランダムCSVデータベース", TMP_SELECT:(RAND:候補数), "CSV番号", 1)


@EXキャラ誘致特殊設定_ブルーアーカイブ(ＤＢ名, 管理番号, 追加キャラナンバー)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS ＤＢ名
#DIM 管理番号
#DIM 追加キャラナンバー

;ブルアカキャラ固有の生成仕様
CALL ランダムキャラデータ_SETS_B(ＤＢ名, 管理番号, "CSTR", "ランダムキャラ設定", "ブルーアーカイブ")

;得意武器：銃固定
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "基礎BATTLE_STATE", "得意武器", 1p5)

;未経験：処女確定
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "処女", 1)
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "Ａ処女", 1)
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "非童貞", 0)

;飲兵衛／酒に強い：CSVの値で固定
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "飲兵衛", CSVTALENT(追加キャラナンバー, GETNUM(TALENT, "飲兵衛")))
CALL ランダムキャラデータ_SET_B(ＤＢ名, 管理番号, "素質", "酒に強い", CSVTALENT(追加キャラナンバー, GETNUM(TALENT, "酒に強い")))

;プレゼント好み：酒は除外
CALL ランダムキャラデータ_SETS_B(ＤＢ名, 管理番号, "CSTR", "プレゼント好み", ランダムプレゼント好み(-1))

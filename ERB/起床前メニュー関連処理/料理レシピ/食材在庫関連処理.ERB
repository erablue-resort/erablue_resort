
@食材ゲージ減少_一日終了時()
#DIM 消費量

消費量 = 0
VARSET メニュー無効化フラグ

;開発中のため暫定措置で毎日MAX
FLAG:食材在庫量 = 1000

;現在の設定レシピのランクに応じて減少
FOR LOCAL, 1, 6
	IF 現在設定メニュー:LOCAL
		消費量 = DT_CELL_GET("料理メニューデータベース", 現在設定メニュー:LOCAL, "料理ランク", 1) * 10
		IF FLAG:食材在庫量 < 消費量
			;不足時
			メニュー無効化フラグ:LOCAL = 1
			FLAG:食材在庫量 = 0
		ELSE
			FLAG:食材在庫量 = MAX(0, FLAG:食材在庫量 - 消費量)
		ENDIF
	ENDIF
NEXT


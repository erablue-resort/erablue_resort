
@食材ゲージ変動_一日終了時()
#DIM 消費量

消費量 = 0
VARSET メニュー無効化フラグ

;開発中のため暫定措置で毎日MAX
FLAG:食材在庫量 = 1000

;在庫増加
;基礎増加
FLAG:食材在庫量 += 10
;居住区があるとやや食料生産がある
SIF MATCH(開拓エリア開発番号, 大規模番号_居住区エリア) > 0
	FLAG:食材在庫量 += 30
;漁船があると食料生産がある
SIF 海改造度:6:0 > 0
	FLAG:食材在庫量 += 40
;牧場はそこそこの食料生産がある
SIF MATCH(開拓エリア開発番号, 大規模番号_居住区エリア) > 0
	FLAG:食材在庫量 += 50
FOR LOCAL, 0, 家畜設定上限
	IF 現在設定家畜:LOCAL != ""
		;家畜がいる場合更に増える
		FLAG:食材在庫量 += 5
	ENDIF
NEXT

;現在の設定レシピのランクに応じて減少
FOR LOCAL, 1, 6
	IF 現在設定メニュー:LOCAL
		消費量 = DT_CELL_GET("料理メニューデータベース", 現在設定メニュー:LOCAL, "料理ランク", 1) * 10
		IF FLAG:食材在庫量 < 消費量
			;不足時
			メニュー無効化フラグ:LOCAL = 1
			FLAG:食材在庫量 = 0
		ELSE
			FLAG:食材在庫量 = MAX(0, FLAG:食材在庫量 - 消費量)
		ENDIF
	ENDIF
NEXT



@食材ゲージ変動_一日終了時(合計ルピ収入)
#DIM 消費量
#DIM 合計消費量
#DIM 停止フラグ
#DIM 食材費
#DIM REF 合計ルピ収入

消費量 = 0
食材費 = 0
停止フラグ = 0
合計消費量 = 0
VARSET メニュー無効化フラグ

; ;開発中のため暫定措置で毎日MAX
; FLAG:食材在庫量 = 1000

;在庫増加
FLAG:食材在庫量 += 食材ゲージ増加計算()

;現在の設定レシピのランクに応じて減少
FOR LOCAL, 1, 6
	IF 現在設定メニュー:LOCAL
		消費量 = DT_CELL_GET("料理メニューデータベース", 現在設定メニュー:LOCAL, "料理ランク", 1) * 10
		合計消費量 += 消費量
		IF FLAG:食材在庫量 < 消費量
			;不足時
			IF MONEY > (消費量  - FLAG:食材在庫量) * 100
				食材費 += (消費量  - FLAG:食材在庫量) * 100
			ELSE
				メニュー無効化フラグ:LOCAL = 1
				停止フラグ ++
			ENDIF
			FLAG:食材在庫量 = 0
		ELSE
			FLAG:食材在庫量 = MAX(0, FLAG:食材在庫量 - 消費量)
		ENDIF
	ENDIF
NEXT
RSTR:リゾート収支計算_記録文字列 += @"食材の在庫を{食材ゲージ増加計算()}生産し、{合計消費量}消費した。（残り{FLAG:食材在庫量}/1000）<br>"

IF 食材費
	RSTR:リゾート収支計算_記録文字列 += @"不足分の食材費として以下のルピを消費した。<br>"
	IF 停止フラグ
		RSTR:リゾート収支計算_記録文字列 += @"<font color='#%カラーパレット_HTML("赤")%'>"
		RSTR:リゾート収支計算_記録文字列 += @"ルピが足りないため、一部の料理効果が無効化されています。</font><br>"
		;レポート強調用記憶：リゾート収支計算(－ZP不足によるフィールド停止)
		SIF レポート強調フラグ:リゾート収支計算 == 0
			レポート強調フラグ:リゾート収支計算 = -1
	ENDIF
	RSTR:リゾート収支計算_記録文字列 += @"食材費合計：%NUM_FORMAT(食材費)%<br>"
	MONEY -= 食材費
	合計ルピ収入 -= 食材費
ENDIF
RSTR:リゾート収支計算_記録文字列 += "-------------------------------------------------------------------------------------------------------------------<br>"


@食材ゲージ増加計算()
#FUNCTION
#DIM 増加値

;基礎増加
増加値 = 10

;居住区があるとやや食料生産がある
SIF MATCH(開拓エリア開発番号, 大規模番号_居住区エリア) > 0
	増加値 += 30
;漁船があると食料生産がある
SIF 海改造度:6:0 > 0
	増加値 += 40
;牧場はそこそこの食料生産がある
SIF MATCH(開拓エリア開発番号, 大規模番号_居住区エリア) > 0
	増加値 += 50
FOR LOCAL, 0, 家畜設定上限
	IF 現在設定家畜:LOCAL != ""
		;家畜がいる場合更に増える
		増加値 += 5
	ENDIF
NEXT

RETURNF 増加値

		PRINTBUTTON @"[3]ふたなり玉なし　　　:{COST_性別定数}ZP（1キャラ分）", 3
	ELSEIF OPTION変数:ふたなり玉設定 == 2
		PRINTBUTTON @"[4]ふたなり玉あり　　　:{COST_性別定数}ZP（1キャラ分）", 4
	ENDIF
	PRINTL
ENDIF
PRINTBUTTON "[999]戻る", 999
$INPUT_LOOP3
BINPUT
LOCAL:1 = RESULT
SELECTCASE LOCAL:1
	CASE 999
		RETURN 0
	CASE 1 TO 4
		SELECTCASE LOCAL:1


@ZP_素質変化_複数人モード()
#DIM キャラ番号

TRYCALLFORM ZP_素質変化_固有処理_{NO:キャラ番号}(キャラ番号)
SIF RESULT == -1
	RETURN -1

PRINTL ZPを消費して複数人の素質を変化させることが出来ます。
PRINTL （変化出来ないキャラが選択されている場合、そのキャラについてはスキップされます）
PRINTL （ZPが途中で無くなった場合、処理はそこで止まります）
PRINTL どの素質を変化させますか？
PRINTFORML 所持ZP:{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}
DRAWLINE
PRINTBUTTONLC "[1]感覚系素質を強化する", 1
PRINTL
PRINTBUTTONLC "[2]乳を変化させる", 2
PRINTL
PRINTBUTTONLC "[3]男性器を変化させる", 3
PRINTL
PRINTBUTTONLC "[4]性別を変化させる", 4
PRINTL
PRINTBUTTONLC "[5]種族を変化させる", 5
PRINTL
PRINTBUTTONLC "[6]妊娠を可能にさせる", 6
PRINTL
PRINTBUTTONLC "[7]受胎体質を変化させる", 7
PRINTL
PRINTBUTTONLC "[8]発情期素質を変化させる", 8
PRINTL
PRINTBUTTONLC "[9]体格・体型を変化させる", 9
PRINTL
IF あなた特殊能力:ハーレム >= 2
	;ハーレム一人前以上だと他者にハーレムの心得を付与可能
	PRINTBUTTONLC "[10]ハーレムの心得を取得させる", 10
	PRINTL
ENDIF
PRINTBUTTONLC "[30]弱点コマンドを追加する", 30
PRINTL
DRAWLINE
PRINTBUTTONLC "[100]素質［長乳］を消去する", 100
PRINTL
DRAWLINE
PRINTBUTTONLC "[101]性知識の成長を禁止する（消費：20ZP）", 101
PRINTL

DRAWLINE
PRINTL
PRINTBUTTONLC "[999]戻る", 999
PRINTL

$INPUT_LOOP
BINPUT
SELECTCASE RESULT
	CASE 1
		CALL 敏感素質変化(キャラ番号)
		RESTART
	CASE 2
		CALL バスト素質変化(キャラ番号)
		RESTART
	CASE 3
		CALL 男性器素質変化(キャラ番号)
		RESTART
	CASE 4
		CALL 性別素質変化(キャラ番号)
		RESTART
	CASE 5
		CALL 種族素質変化(キャラ番号)
		RESTART
	CASE 6
		CALL 妊娠不可素質変化(キャラ番号)
		RESTART
	CASE 7
		CALL 受胎体質素質変化(キャラ番号)
		RESTART
	CASE 8
		CALL 発情期素質設定(キャラ番号)
		RESTART
	CASE 9
		CALL 体格・体型素質設定(キャラ番号)
		RESTART
	CASE 10
		CALL ハーレムの心得素質設定(キャラ番号)
		RESTART
	CASE 20
		CALL フレーバー素質再設定(キャラ番号)
		RESTART
	CASE 30
		CALL 弱点コマンド追加(キャラ番号)
		RESTART
	CASE 100
		PRINTL
		DRAWLINE
		PRINTFORML %NAME表示(キャラ番号)%の素質［長乳］を消去し、取得に必要なコマンド実行回数をリセットします。
		PRINTL もう一度条件を満たせば素質の再取得が可能です。
		PRINTL 
		PRINTL 素質［長乳］を消去しますか？
		PRINTBUTTONLC "[0] 消去する", 0
		PRINTBUTTONLC "[1] 消去しない", 1
		PRINTL
		PRINTL
		BINPUT
		PRINTL
		IF RESULT == 0
			CFLAG:キャラ番号:おっぱい引っぱりカウント = 0
			TALENT:キャラ番号:長乳 = 0
			PRINTW 素質［長乳］を消去しました。
		ENDIF
		RESTART
	CASE 101
		PRINTL
		DRAWLINE
		IF CFLAG:キャラ番号:性知識成長禁止
			PRINTFORML 0ZPを消費し、%NAME表示(キャラ番号)%の性知識の成長を解禁します。
			PRINTL 再び禁止する際はまたZPが必要になります。
			PRINTL 
			PRINTL 性知識の成長を解禁しますか？
			PRINTBUTTONLC "[0] 解禁する", 0
			PRINTBUTTONLC "[1] 解禁しない", 1
			PRINTL
			PRINTL
			BINPUT
			PRINTL
			IF RESULT == 0
				CFLAG:キャラ番号:性知識成長禁止 = 0
				PRINTW 性知識の成長を解禁しました。
			ENDIF
		ELSE
			IF FLAG:ZP所持量 < 20
				PRINTW ZPが足りません。
				RESTART
			ENDIF
			PRINTFORML 20ZPを消費し、%NAME表示(キャラ番号)%の性知識の成長を禁止します。
			PRINTL 成長の解禁はいつでも可能です。
			PRINTL ※禁止していても固有のキャライベントなどで成長することがあります。
			PRINTL 
			PRINTL 性知識の成長を禁止しますか？
			PRINTBUTTONLC "[0] 禁止する", 0
			PRINTBUTTONLC "[1] 禁止しない", 1
			PRINTL
			PRINTL
			BINPUT
			PRINTL
			IF RESULT == 0
				CFLAG:キャラ番号:性知識成長禁止 = 1
				PRINTW 性知識の成長を禁止しました。
				FLAG:ZP所持量 -= 20
			ENDIF
		ENDIF
		RESTART
	CASE 995
		RESTART
	CASE 996
		RETURN 1
	CASE 997
		RETURN 2
	CASE 998
		CALL キャラメイク設定
		RESTART
	CASE 999
		RETURN -1
ENDSELECT

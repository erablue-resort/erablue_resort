		ENDSELECT
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		BINPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SELECTCASE LOCAL:1
					CASE 3
						SIF TALENT:(汎用キャラ配列:LOCAL):性別 == 3 && フレーバー素質:(汎用キャラ配列:LOCAL):ふたなり時_玉ありなし == 1
							CONTINUE
					CASE 4
						SIF TALENT:(汎用キャラ配列:LOCAL):性別 == 3 && フレーバー素質:(汎用キャラ配列:LOCAL):ふたなり時_玉ありなし == 2
							CONTINUE
					CASEELSE
						SIF TALENT:(汎用キャラ配列:LOCAL):性別 == LOCAL:1
							CONTINUE
				ENDSELECT
				必要COST_計算値 = COST_性別定数
				IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
					PRINTL 必要ZPが不足したので処理を停止しました。
					BREAK
				ENDIF
				必要COST += 必要COST_計算値
				
				元の性別 = TALENT:(汎用キャラ配列:LOCAL):性別
				PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: %GET_TALENTNAME(2, TALENT:(汎用キャラ配列:LOCAL):性別, , 汎用キャラ配列:LOCAL), 8, LEFT% > 
				SELECTCASE LOCAL:1
					CASE 3
						PRINTFORML %GET_TALENTNAME(2, 3, , 汎用キャラ配列:LOCAL)%（玉なし）
						TALENT:(汎用キャラ配列:LOCAL):性別 = 3
						IF フレーバー素質:(汎用キャラ配列:LOCAL):素質表示設定 == 0
							フレーバー素質:(汎用キャラ配列:LOCAL):素質表示設定 = 1
							フレーバー素質:(汎用キャラ配列:LOCAL):陰毛濃さ = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):乳首大きさ = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):乳輪大きさ = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):性器種類 = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):クリ大きさ = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):ほくろ位置 = 0
						ENDIF
						フレーバー素質:(汎用キャラ配列:LOCAL):ふたなり時_玉ありなし = 1
					CASE 4
						PRINTFORML %GET_TALENTNAME(2, 3, , 汎用キャラ配列:LOCAL)%（玉あり）
						TALENT:(汎用キャラ配列:LOCAL):性別 = 3
						IF フレーバー素質:(汎用キャラ配列:LOCAL):素質表示設定 == 0
							フレーバー素質:(汎用キャラ配列:LOCAL):素質表示設定 = 1
							フレーバー素質:(汎用キャラ配列:LOCAL):陰毛濃さ = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):乳首大きさ = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):乳輪大きさ = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):性器種類 = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):クリ大きさ = 0
							フレーバー素質:(汎用キャラ配列:LOCAL):ほくろ位置 = 0
						ENDIF
						フレーバー素質:(汎用キャラ配列:LOCAL):ふたなり時_玉ありなし = 2
					CASEELSE
						PRINTFORML %GET_TALENTNAME(2, LOCAL:1, , 汎用キャラ配列:LOCAL)%
						TALENT:(汎用キャラ配列:LOCAL):性別 = LOCAL:1
				ENDSELECT
				
				;性転換後処理
				SIF !TALENT:(汎用キャラ配列:LOCAL):性転換 && 元の性別 == 2
					TALENT:(汎用キャラ配列:LOCAL):処女 = 1
				CALL ZP_SHOP_性別特徴変換(汎用キャラ配列:LOCAL, 元の性別, TALENT:(汎用キャラ配列:LOCAL):性別)
				IF RESULT == 0
					SETBIT 変更位置, 0
					SETBIT 変更位置, 1
					SETBIT 変更位置, 2
					SETBIT 変更位置, 3
					IF 身長固定キャラ(汎用キャラ配列:LOCAL)
						CLEARBIT 変更位置, 0
					; ELSE
					; 	;身長任意設定
					; 	CALL 性別変化時_身長任意設定(汎用キャラ配列:LOCAL)
					; 	SIF RESULT == 1
					; 		CLEARBIT 変更位置, 0
					ENDIF
					IF バスト固定キャラ(汎用キャラ配列:LOCAL)
						CLEARBIT 変更位置, 1
					ENDIF
					SIF 変更位置
						CALL SET_BODYSIZE(汎用キャラ配列:LOCAL, 変更位置)
				ENDIF
				;性転換が0なら元の性別(ふたなりは-3)を代入し、再度元の性別やふたなりになった場合は-をかけて非表示に
				IF !TALENT:(汎用キャラ配列:LOCAL):性転換
					IF TALENT:(汎用キャラ配列:LOCAL):性別 == 2 && (元の性別 == 1 || (元の性別 == 3 && 素質切り替えOPTION記憶:ふたなり_女性))
						TALENT:(汎用キャラ配列:LOCAL):性転換 = 1
					ELSEIF TALENT:(汎用キャラ配列:LOCAL):性別 == 1 && 元の性別 == 2
						TALENT:(汎用キャラ配列:LOCAL):性転換 = 2
					ELSE
						TALENT:(汎用キャラ配列:LOCAL):性転換 = 元の性別 * -1
					ENDIF
				ELSEIF TALENT:(汎用キャラ配列:LOCAL):性転換 < 0 && TALENT:(汎用キャラ配列:LOCAL):性転換 > -3 && TALENT:(汎用キャラ配列:LOCAL):性別 != TALENT:(汎用キャラ配列:LOCAL):性転換 * -1 && (TALENT:(汎用キャラ配列:LOCAL):性別 == 1 || TALENT:(汎用キャラ配列:LOCAL):性別 == 2)
					TALENT:(汎用キャラ配列:LOCAL):性転換 *= -1
				ELSEIF TALENT:(汎用キャラ配列:LOCAL):性転換 > 0
					TALENT:(汎用キャラ配列:LOCAL):性転換 *= -1
				ENDIF
				;ふたなり、その他の場合は何に変化しても元女・元男はつかない
				;元性別も処理しておく
				CFLAG:(汎用キャラ配列:LOCAL):元性別保存 = TALENT:(汎用キャラ配列:LOCAL):性別
			NEXT
			FLAG:ZP所持量 -= 必要COST
			
			IF 必要COST <= 0
				PRINTW 変更条件を満たすキャラが存在しません。
			ELSE
				PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
			ENDIF
		ENDIF

		RETURN 0
ENDSELECT




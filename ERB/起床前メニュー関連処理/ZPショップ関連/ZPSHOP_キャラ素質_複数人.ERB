PRINTBUTTON "　[8] ありに変更", 8
PRINTFORML  …  {COST_TO_発情期}ZP（1キャラ分）
PRINTL
PRINTBUTTON "　[999] 戻る", 999
PRINTL
PRINTL

BINPUT
LOCAL:1 = RESULT
SELECTCASE LOCAL:1
	CASE 100
		PRINTFORML 発情期を なし に変更します。よろしいですか？
		PRINTL ※特殊発情は種族に付随するものを除きリセットされます。
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		BINPUT
		
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SIF TALENT:(汎用キャラ配列:LOCAL):発情期あり < 0
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):性別 == 0
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):妊娠不可 == 2
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):射精不可 == 2
					CONTINUE
				必要COST_計算値 = 1
				IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
					PRINTL 必要ZPが不足したので処理を停止しました。
					BREAK
				ENDIF
				必要COST += 必要COST_計算値
				PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%
				TALENT:(汎用キャラ配列:LOCAL):発情期あり = -1
				IF CFLAG:(汎用キャラ配列:LOCAL):発情期フラグ < 0 && GETBIT(TALENT:(汎用キャラ配列:LOCAL):発情期あり, 3) && TALENT:(汎用キャラ配列:LOCAL):性別 == 3
					;女性器ないキャラがふたなり化妊娠中の時は戻さない
					IF GETBIT(CFLAG:(汎用キャラ配列:LOCAL):元性別保存, 0) != 0 || TALENT:(汎用キャラ配列:LOCAL):妊娠 == 0
						TALENT:(汎用キャラ配列:LOCAL):性別 = CFLAG:(汎用キャラ配列:LOCAL):元性別保存
					ENDIF
				ENDIF
				IF CFLAG:(汎用キャラ配列:LOCAL):発情期フラグ < 0 && GETBIT(TALENT:(汎用キャラ配列:LOCAL):発情期あり, 8) && TALENT:(汎用キャラ配列:LOCAL):性別 == 1
					;女性器ないキャラが女体化妊娠中の時は戻さない
					IF GETBIT(CFLAG:(汎用キャラ配列:LOCAL):元性別保存, 0) != 0 || TALENT:(汎用キャラ配列:LOCAL):妊娠 == 0
						TALENT:(汎用キャラ配列:LOCAL):性別 = CFLAG:(汎用キャラ配列:LOCAL):元性別保存
					ENDIF
				ENDIF
			NEXT
			FLAG:ZP所持量 -= 必要COST
			IF 必要COST <= 0
				PRINTW 変更条件を満たすキャラが存在しません。
			ELSE
				PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
			ENDIF
		ENDIF
	CASE 0
		PRINTL 発情期を あり に変更します。よろしいですか？
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0] はい", 0
		PRINTBUTTONLC "[1] いいえ", 1
		BINPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SIF 発情期存在判定(汎用キャラ配列:LOCAL)
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):性別 == 0
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):妊娠不可 == 2
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):射精不可 == 2
					CONTINUE
				必要COST_計算値 = COST_TO_発情期
				IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
					PRINTL 必要ZPが不足したので処理を停止しました。
					BREAK
				ENDIF
				必要COST += 必要COST_計算値
				PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%
				TALENT:(汎用キャラ配列:LOCAL):発情期あり = 1
			NEXT
			FLAG:ZP所持量 -= 必要COST
			IF 必要COST <= 0
				PRINTW 変更条件を満たすキャラが存在しません。
			ELSE
				PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
			ENDIF
		ENDIF
	CASE 999
		RETURN 0
	CASEELSE
		SELECTCASE LOCAL:1 % 100
			CASE 1
				PRINT 欲情ブースト（大）
			CASE 2
				PRINT 母乳体質化
			CASE 3
				PRINT ふたなり化
			CASE 4
				PRINT 危険日周期短縮
			CASE 5
				PRINT 体力自動回復
			CASE 6
				PRINT 過敏体質（快楽・苦痛＋）
			CASE 7
				PRINT 陥没乳首常時勃起
			CASE 8
				PRINT 女体化
		ENDSELECT
		IF LOCAL:1 > 100
			PRINTL を なし に変更します。よろしいですか？
		ELSE
			PRINTL を あり に変更します。よろしいですか？
		ENDIF
		IF LOCAL:1 == 8
			PRINTL ※ふたなり化の発情がありの場合、そちらが優先されます。
		ENDIF
		PRINTFORML 使用ZP： {必要COST}
		PRINTBUTTONLC "[0] はい", 0
		PRINTBUTTONLC "[1] いいえ", 1
		BINPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SIF 発情期存在判定(汎用キャラ配列:LOCAL)
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):性別 == 0
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):妊娠不可 == 2
					CONTINUE
				SIF TALENT:(汎用キャラ配列:LOCAL):射精不可 == 2
					CONTINUE
				IF LOCAL:1 > 100
					SIF GETBIT(TALENT:(汎用キャラ配列:LOCAL):発情期あり, LOCAL:1 % 100) == 0
						CONTINUE
				ELSE
					SIF GETBIT(TALENT:(汎用キャラ配列:LOCAL):発情期あり, LOCAL:1 % 100)
						CONTINUE
				ENDIF
				必要COST_計算値 = COST_TO_発情期
				IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
					PRINTL 必要ZPが不足したので処理を停止しました。
					BREAK
				ENDIF
				必要COST += 必要COST_計算値
				PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: 
				SELECTCASE LOCAL:1 % 100
					CASE 1
						PRINT 欲情ブースト（大）
					CASE 2
						PRINT 母乳体質化
					CASE 3
						PRINT ふたなり化
					CASE 4
						PRINT 危険日周期短縮
					CASE 5
						PRINT 体力自動回復
					CASE 6
						PRINT 過敏体質（快楽・苦痛＋）
					CASE 7
						PRINT 陥没乳首常時勃起
					CASE 8
						PRINT 女体化
				ENDSELECT
				IF LOCAL:1 > 100
					PRINT 削除
				ELSE
					PRINT 追加
				ENDIF
				IF LOCAL:1 == 103 && CFLAG:(汎用キャラ配列:LOCAL):発情期フラグ < 0 && GETBIT(TALENT:(汎用キャラ配列:LOCAL):発情期あり, 3) && TALENT:(汎用キャラ配列:LOCAL):性別 == 3
					;女性器ないキャラがふたなり化妊娠中の時は戻さない
					IF GETBIT(CFLAG:(汎用キャラ配列:LOCAL):元性別保存, 0) != 0 || TALENT:(汎用キャラ配列:LOCAL):妊娠 == 0
						TALENT:(汎用キャラ配列:LOCAL):性別 = CFLAG:(汎用キャラ配列:LOCAL):元性別保存
					ENDIF
				ENDIF
				IF LOCAL:1 == 108 && CFLAG:(汎用キャラ配列:LOCAL):発情期フラグ < 0 && GETBIT(TALENT:(汎用キャラ配列:LOCAL):発情期あり, 8) && TALENT:(汎用キャラ配列:LOCAL):性別 == 1
					;女性器ないキャラが女体化妊娠中の時は戻さない
					IF GETBIT(CFLAG:(汎用キャラ配列:LOCAL):元性別保存, 0) != 0 || TALENT:(汎用キャラ配列:LOCAL):妊娠 == 0
						TALENT:(汎用キャラ配列:LOCAL):性別 = CFLAG:(汎用キャラ配列:LOCAL):元性別保存
					ENDIF
				ENDIF
				INVERTBIT TALENT:(汎用キャラ配列:LOCAL):発情期あり, LOCAL % 100
			NEXT
			FLAG:ZP所持量 -= 必要COST
			IF 必要COST <= 0
				PRINTW 変更条件を満たすキャラが存在しません。
			ELSE
				PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
			ENDIF
		ENDIF

ENDSELECT


		RETURN 1
	CASE 997
		RETURN 2
	CASE 998
		CALL キャラメイク設定
		RESTART
	CASE 999
		RETURN -1
ENDSELECT



@敏感素質変化_複数人()
#DIM 対象キャラ
#DIM CONST COST_TO_敏感 = 300
#DIM CONST COST_TO_通常 = 100
#DIM CONST COST_TO_鈍感 = 300
#DIM 必要COST
#DIM 必要COST_計算値
#DIM 素質番号
#DIMS 段階名

DRAWLINE
PRINTL ZPを消費してキャラに敏感系素質を付与することが出来ます。
PRINTL どの部位を敏感化しますか？
PRINTFORML 所持ZP:{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}
DRAWLINE
FOR LOCAL:1 , 101, 106
	PRINTFORM %TALENTNAME:(LOCAL:1)%　　
	PRINTBUTTON @"[{LOCAL:1 * 10}]鈍感まで上昇", LOCAL:1 * 10
	PRINT 　　　
	PRINTBUTTON @"[{LOCAL:1 * 10 + 1}]通常まで上昇", LOCAL:1 * 10 + 1
	PRINT 　　　
	PRINTBUTTON @"[{LOCAL:1 * 10 + 2}]敏感まで上昇", LOCAL:1 * 10 + 2
	PRINTL
NEXT

PRINTBUTTON @"[241] [即イキ]を取得する", 241
PRINTFORML 　　　必要ZP:{COST_TO_敏感 * 2}（1キャラ分）

PRINTBUTTON @"[242] [早イキ]を取得する", 242
PRINTFORML 　　　必要ZP:{COST_TO_敏感}（1キャラ分）

PRINTBUTTON @"[243] イキやすさ素質を削除する", 243
PRINTFORML 　　　必要ZP:{COST_TO_通常}（1キャラ分）

PRINTBUTTON @"[244] [遅イキ]を取得する", 244
PRINTFORML 　　　必要ZP:{COST_TO_通常 / 2}（1キャラ分）

PRINTBUTTON @"[250] [ＥＤ]を取得する", 250
PRINTFORML 　　　必要ZP:{COST_TO_通常}（1キャラ分）

PRINTBUTTON @"[251] [ＥＤ]を削除する", 251
PRINTFORML 　　　必要ZP:{COST_TO_通常}（1キャラ分）

PRINTL
PRINTBUTTON "[999]戻る", 999
$INPUT_LOOP2
BINPUT
LOCAL:1 = RESULT
SELECTCASE LOCAL:1
	CASE 999
		RETURN 0
	CASE IS > 1000
		;1010~はそれぞれの素質変化
		SELECTCASE LOCAL:1 % 10
			CASE 0
				;鈍感まで上げ
				段階名 = 鈍感
			CASE 1
				;通常まで上げ
				段階名 = 通常
			CASE 2
				;敏感まで上げ
				段階名 = 敏感
		ENDSELECT
		PRINTFORML %TALENTNAME:(LOCAL:1 / 10)%を%段階名%まで上昇させますか？
		PRINTL ※既にそれ以上の素質を持つ場合は変動しません。
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				必要COST_計算値 = 0
				SELECTCASE LOCAL:1 % 10
					CASE 0
						;鈍感まで上げ
						SIF TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10) >= -1
							CONTINUE
						必要COST_計算値 += COST_TO_鈍感
					CASE 1
						;通常まで上げ
						SIF TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10) >= 0
							CONTINUE
						SIF TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10) == -2
							必要COST_計算値 += COST_TO_鈍感
						必要COST_計算値 += COST_TO_通常
					CASE 2
						;敏感まで上げ
						SIF TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10) >= 1
							CONTINUE
						SIF TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10) == -2
							必要COST_計算値 += COST_TO_鈍感 + COST_TO_通常
						SIF TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10) == -1
							必要COST_計算値 += COST_TO_通常
						必要COST_計算値 += COST_TO_敏感
				ENDSELECT
				IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
					PRINTL 必要ZPが不足したので処理を停止しました。
					BREAK
				ENDIF
				必要COST += 必要COST_計算値
				IF TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10) == 0
					PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: 通常 > 
				ELSE
					PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: %GET_TALENTNAME(LOCAL:1 / 10, TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10), , 汎用キャラ配列:LOCAL)% > 
				ENDIF
				IF LOCAL:1 % 10 == 1
					PRINTL 通常
				ELSE
					PRINTFORML %GET_TALENTNAME(LOCAL:1 / 10, LOCAL:1 % 10 - 1, , 汎用キャラ配列:LOCAL)%
				ENDIF
				TALENT:(汎用キャラ配列:LOCAL):(LOCAL:1 / 10) = LOCAL:1 % 10 - 1
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF
		RETURN 0
	CASE 241
		素質番号 = 241
		PRINTFORML ［即イキ］を持たないキャラに取得させますか？
		PRINTFORML ※他のイキやすさ素質を上書きします
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				必要COST_計算値 = COST_TO_敏感 * 2
				IF TALENT:(汎用キャラ配列:LOCAL):イキやすさ != 2
					IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
						PRINTL 必要ZPが不足したので処理を停止しました。
						BREAK
					ENDIF
					IF TALENT:(汎用キャラ配列:LOCAL):イキやすさ == 0
						PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: 通常 > 
					ELSE
						PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: %GET_TALENTNAME(素質番号, TALENT:(汎用キャラ配列:LOCAL):素質番号, , 汎用キャラ配列:LOCAL)% > 
					ENDIF
					PRINTL 即イキ
					TALENT:(汎用キャラ配列:LOCAL):素質番号 = 2
					必要COST += 必要COST_計算値
				ENDIF
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF
		RETURN 0
	CASE 242
		素質番号 = 242
		PRINTFORML {必要COST}ZPを支払い、［早イキ］を取得しますか？
		PRINTFORML ※他のイキやすさ素質を上書きします
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				必要COST_計算値 = COST_TO_敏感
				IF TALENT:(汎用キャラ配列:LOCAL):イキやすさ != 1
					IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
						PRINTL 必要ZPが不足したので処理を停止しました。
						BREAK
					ENDIF
					IF TALENT:(汎用キャラ配列:LOCAL):イキやすさ == 0
						PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: 通常 > 
					ELSE
						PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: %GET_TALENTNAME(素質番号, TALENT:(汎用キャラ配列:LOCAL):素質番号, , 汎用キャラ配列:LOCAL)% > 
					ENDIF
					PRINTL 早イキ
					TALENT:(汎用キャラ配列:LOCAL):素質番号 = 1
					必要COST += 必要COST_計算値
				ENDIF
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF
		RETURN 0
	CASE 243
		素質番号 = 243
		PRINTFORML {必要COST}ZPを支払い、イキやすさ素質を削除しますか？
		PRINTFORML ※他のイキやすさ素質を上書きします
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				必要COST_計算値 = COST_TO_通常
				IF TALENT:(汎用キャラ配列:LOCAL):イキやすさ != 0
					IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
						PRINTL 必要ZPが不足したので処理を停止しました。
						BREAK
					ENDIF
					PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: %GET_TALENTNAME(素質番号, TALENT:(汎用キャラ配列:LOCAL):素質番号, , 汎用キャラ配列:LOCAL)% > 
					PRINTL 通常
					TALENT:(汎用キャラ配列:LOCAL):素質番号 = 0
					必要COST += 必要COST_計算値
				ENDIF
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF
		RETURN 0
	CASE 244
		素質番号 = 244
		必要COST = COST_TO_通常 / 2
		PRINTFORML {必要COST}ZPを支払い、［遅イキ］を取得しますか？
		PRINTFORML ※他のイキやすさ素質を上書きします
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				必要COST_計算値 = COST_TO_通常 / 2
				IF TALENT:(汎用キャラ配列:LOCAL):イキやすさ != -1
					IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
						PRINTL 必要ZPが不足したので処理を停止しました。
						BREAK
					ENDIF
					IF TALENT:(汎用キャラ配列:LOCAL):イキやすさ == 0
						PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: 通常 > 
					ELSE
						PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: %GET_TALENTNAME(素質番号, TALENT:(汎用キャラ配列:LOCAL):素質番号, , 汎用キャラ配列:LOCAL)% > 
					ENDIF
					PRINTL 遅イキ
					TALENT:(汎用キャラ配列:LOCAL):素質番号 = -1
					必要COST += 必要COST_計算値
				ENDIF
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF
		RETURN 0
	CASE 250
		必要COST = COST_TO_通常
		PRINTFORML {必要COST}ZPを支払い、[ＥＤ]を取得しますか？
		PRINTFORML ※ペニスを所持するキャラにのみ適用されます
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			必要COST_計算値 = COST_TO_通常
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SIF !GETBIT(TALENT:(汎用キャラ配列:LOCAL):性別, 1)
					CONTINUE
				IF TALENT:(汎用キャラ配列:LOCAL):ＥＤ != 1
					IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
						PRINTL 必要ZPが不足したので処理を停止しました。
						BREAK
					ENDIF
					PRINTFORML %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%
					TALENT:(汎用キャラ配列:LOCAL):ＥＤ = 1
					必要COST += 必要COST_計算値
				ENDIF
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF
		RETURN 0
	CASE 251
		必要COST = COST_TO_通常
		PRINTFORML {必要COST}ZPを支払い、[ＥＤ]を削除しますか？
		PRINTFORML ※ペニスを所持するキャラにのみ適用されます
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			必要COST_計算値 = COST_TO_通常
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SIF !GETBIT(TALENT:(汎用キャラ配列:LOCAL):性別, 1)
					CONTINUE
				IF TALENT:(汎用キャラ配列:LOCAL):ＥＤ != 0
					IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
						PRINTL 必要ZPが不足したので処理を停止しました。
						BREAK
					ENDIF
					PRINTFORML %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%
					TALENT:(汎用キャラ配列:LOCAL):ＥＤ = 0
					必要COST += 必要COST_計算値
				ENDIF
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF
		RETURN 0
	CASEELSE
		REUSELASTLINE 
		GOTO INPUT_LOOP2
ENDSELECT

@バスト素質変化_複数人()
#DIM CONST COST_胸定数 = 20
#DIM 必要COST
#DIM 必要COST_計算値

DRAWLINE
PRINTL ZPを消費してキャラの乳の大きさなどを変化させることができます。
PRINTL 任意の大きさを選択してください
PRINTFORML 所持ZP:{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}
DRAWLINE
FOR LOCAL:1 , -2, 4
	PRINTBUTTON @"[{LOCAL:1}]%GET_TALENTNAME(205, LOCAL:1), 20, LEFT%にする", LOCAL:1
	PRINTL
NEXT
IF 素質切り替えOPTION記憶:陥没乳首_なし == 0
	PRINTL
	PRINTBUTTON @"[10] 陥没乳首素質を付与する", 10
	PRINTFORML :{COST_胸定数}ZP（1キャラ分）
	PRINTBUTTON @"[11] 陥没乳首素質を削除する", 11
	PRINTFORML :{COST_胸定数}ZP（1キャラ分）
ENDIF
PRINTL
PRINTBUTTON "[999]戻る", 999
$INPUT_LOOP3
BINPUT
LOCAL:1 = RESULT
SELECTCASE LOCAL:1
	CASE 999
		RETURN 0
	CASE 10
		PRINTFORML 陥没乳首素質を付与しますか？
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SIF TALENT:(汎用キャラ配列:LOCAL):陥没乳首
					CONTINUE
				必要COST_計算値 = COST_胸定数
				IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
					PRINTL 必要ZPが不足したので処理を停止しました。
					BREAK
				ENDIF
				必要COST += 必要COST_計算値
				PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%
				TALENT:(汎用キャラ配列:LOCAL):陥没乳首 = 1
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF

		RETURN 0
	CASE 11
		PRINTFORML 陥没乳首素質を削除しますか？
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SIF TALENT:(汎用キャラ配列:LOCAL):陥没乳首 == 0
					CONTINUE
				必要COST_計算値 = COST_胸定数
				IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
					PRINTL 必要ZPが不足したので処理を停止しました。
					BREAK
				ENDIF
				必要COST += 必要COST_計算値
				PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%
				TALENT:(汎用キャラ配列:LOCAL):陥没乳首 = 0
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF
	CASE -2 TO 3
		;バスト変化
		PRINTFORML バストサイズを%GET_TALENTNAME(205, LOCAL:1)%に変更しますか？
		PRINTFORML （所持ZP：{FLAG:ZP所持量}.{(ZP小数点以下所持量 % 1000) / 100}{(ZP小数点以下所持量 % 100) / 10}{(ZP小数点以下所持量 % 10)}）
		PRINTBUTTONLC "[0]はい", 0
		PRINTBUTTONLC "[1]いいえ", 1
		INPUT
		IF RESULT == 0
			必要COST = 0
			FOR LOCAL, 0, キャラクタ数上限
				SIF 汎用キャラ配列:LOCAL < 0
					BREAK
				SIF TALENT:(汎用キャラ配列:LOCAL):バストサイズ == LOCAL:1
					CONTINUE
				必要COST_計算値 = ABS(TALENT:(汎用キャラ配列:LOCAL):バストサイズ - LOCAL:1) * COST_胸定数
				IF 必要COST + 必要COST_計算値 > FLAG:ZP所持量
					PRINTL 必要ZPが不足したので処理を停止しました。
					BREAK
				ENDIF
				必要COST += 必要COST_計算値
				PRINTFORM %GET_NAME(汎用キャラ配列:LOCAL, 1, 50), 50, LEFT%: %GET_TALENTNAME(205, TALENT:(汎用キャラ配列:LOCAL):バストサイズ, , 汎用キャラ配列:LOCAL), 15, LEFT% > 
				PRINTFORML %GET_TALENTNAME(205, LOCAL:1, , 汎用キャラ配列:LOCAL)%
				TALENT:(汎用キャラ配列:LOCAL):バストサイズ = LOCAL:1
			NEXT
			FLAG:ZP所持量 -= 必要COST
			PRINTFORMW 以上のキャラについて処理を実行しました。（消費ZP:{必要COST}）
		ENDIF

		RETURN 0
ENDSELECT



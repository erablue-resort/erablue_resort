@客室テーマ変更()

DRAWLINE
PRINTL 希望のテーマを選択してください。
DRAWLINE
FOR LOCAL, 1, VARSIZE("客室テーマ")
	SIF 客室テーマ:LOCAL < 1
		CONTINUE
	; TSTR:ツールチップ受渡 = 
	; CALLFORM 客室テーマ_%ERDNAME(客室テーマ, 客室テーマ:LOCAL)%
	PRINTBUTTON @"[{LOCAL}] %ERDNAME(客室テーマ, LOCAL)%", LOCAL
	PRINTL
NEXT
PRINTL
PRINTBUTTON "[999] 戻る", 999
PRINTL
PRINTL
BINPUT
PRINTL
PRINTL
SELECTCASE RESULT
	CASE 999
		RETURN 0
	CASEELSE
		客室テーマ:設定テーマ = RESULT
		PRINTFORMW 客室のテーマを「%ERDNAME(客室テーマ, RESULT)%」に変更しました。
ENDSELECT


@客室テーマ_簡素な部屋(動作モード)
#DIMS 動作モード

SELECTCASE 動作モード
	CASE "部屋説明"
		TSTR:ツールチップ受渡 = 
		TSTR:ツールチップ受渡 += "　特に変わったところのない一般的な客室。<br>"
		TSTR:ツールチップ受渡 += "<br>"
		TSTR:ツールチップ受渡 += "<br>"
		TSTR:ツールチップ受渡 += "　効果：なし<br>"
ENDSELECT



@アメニティ変更(配置番号)
#DIM 配置番号

DRAWLINE
PRINTL 設置するアメニティを選択してください。
PRINT 設定中アメニティ：
IF 配置アメニティ:配置番号 > 0
	TSTR:コマンド名受渡 = 
	CALLFORM アメニティ_%ERDNAME(アメニティ, 配置アメニティ:配置番号)%("名前取得", アメニティ:(配置アメニティ:配置番号))
	PRINTFORML %TSTR:コマンド名受渡%
ELSE
	PRINTL ----------
ENDIF
DRAWLINE
FOR LOCAL, 1, VARSIZE("アメニティ")
	SIF アメニティ:LOCAL < 1
		CONTINUE
	SIF MATCH(配置アメニティ, LOCAL)
		CONTINUE
	TSTR:コマンド名受渡 = 
	CALLFORM アメニティ_%ERDNAME(アメニティ, LOCAL)%("名前取得", アメニティ:LOCAL)
	PRINTBUTTON @"[{LOCAL}] %TSTR:コマンド名受渡%", LOCAL
	PRINTL
NEXT
PRINTL
IF 配置アメニティ:配置番号 > 0
	PRINTBUTTON "[998] 設定中の設備を外す", 998
	PRINTL
ELSE
	SETCOLOR カラーパレット("グレーアウト")
	PRINTPLAIN [998] 設定中の設備を外す
	RESETCOLOR
ENDIF
PRINTBUTTON "[999] 戻る", 999
PRINTL
PRINTL
BINPUT
PRINTL
PRINTL
SELECTCASE RESULT
	CASE 999
		RETURN 0
	CASE 998
		TSTR:コマンド名受渡 = 
		CALLFORM アメニティ_%ERDNAME(アメニティ, 配置アメニティ:配置番号)%("名前取得", アメニティ:(配置アメニティ:配置番号))
		PRINTFORMW アメニティ「%TSTR:コマンド名受渡%」を解除しました。
		配置アメニティ:配置番号 = 0
	CASEELSE
		配置アメニティ:配置番号 = RESULT
		TSTR:コマンド名受渡 = 
		CALLFORM アメニティ_%ERDNAME(アメニティ, 配置アメニティ:配置番号)%("名前取得", アメニティ:(配置アメニティ:配置番号))
		PRINTFORMW アメニティ「%TSTR:コマンド名受渡%」を設置しました。
ENDSELECT


@アメニティ_入浴セット系列(動作モード, Lv指定 = 1)
#DIMS 動作モード
#DIM Lv指定

SELECTCASE 動作モード
	CASE "名前取得"
		SELECTCASE Lv指定
			CASE 1
				TSTR:コマンド名受渡 = 入浴セット
		ENDSELECT	
ENDSELECT


@客室設備変更(配置番号)
#DIM 配置番号

DRAWLINE
PRINTL 設置する設備を選択してください。
PRINT 設定中設備：
IF 配置客室設備:配置番号 > 0
	TSTR:コマンド名受渡 = 
	TSTR:ツールチップ受渡 = 
	CALLFORM 客室設備_%ERDNAME(客室設備, 配置客室設備:配置番号)%("名前取得", 客室設備:(配置客室設備:配置番号))
	IF TSTR:ツールチップ受渡 != ""
		HTML_PRINT @"<nonbutton  title='%TSTR:ツールチップ受渡%'>%TSTR:コマンド名受渡%</nonbutton>", 1
		PRINTL
	ELSE
		PRINTFORML %TSTR:コマンド名受渡%
	ENDIF
ELSE
	PRINTL ----------
ENDIF
DRAWLINE
FOR LOCAL, 1, VARSIZE("客室設備")
	SIF 客室設備:LOCAL < 1
		CONTINUE
	SIF MATCH(配置客室設備, LOCAL)
		CONTINUE
	TSTR:コマンド名受渡 = 
	TSTR:ツールチップ受渡 = 
	CALLFORM 客室設備_%ERDNAME(客室設備, LOCAL)%("名前取得", 客室設備:LOCAL)
	IF TSTR:ツールチップ受渡 != ""
		HTML_PRINT @"<button value='{LOCAL}' title='%TSTR:ツールチップ受渡%'>[{LOCAL}] %TSTR:コマンド名受渡%</button>", 1
		PRINTL
	ELSE
		HTML_PRINT @"<button value='{LOCAL}'>[{LOCAL}] %TSTR:コマンド名受渡%</button>"
	ENDIF
NEXT
PRINTL
IF 配置客室設備:配置番号 > 0
	PRINTBUTTON "[998] 設定中の設備を外す", 998
	PRINTL
ELSE
	SETCOLOR カラーパレット("グレーアウト")
	PRINTPLAIN [998] 設定中の設備を外す
	RESETCOLOR
	PRINTL
ENDIF
PRINTBUTTON "[999] 戻る", 999
PRINTL
PRINTL
BINPUT
PRINTL
PRINTL
SELECTCASE RESULT
	CASE 999
		RETURN 0
	CASE 998
		TSTR:コマンド名受渡 = 
		TSTR:ツールチップ受渡 = 
		CALLFORM 客室設備_%ERDNAME(客室設備, 配置客室設備:配置番号)%("名前取得", 客室設備:(配置客室設備:配置番号))
		PRINTFORMW 客室設備「%TSTR:コマンド名受渡%」を解除しました。
		配置客室設備:配置番号 = 0
	CASEELSE
		配置客室設備:配置番号 = RESULT
		TSTR:コマンド名受渡 = 
		TSTR:ツールチップ受渡 = 
		CALLFORM 客室設備_%ERDNAME(客室設備, 配置客室設備:配置番号)%("名前取得", 客室設備:(配置客室設備:配置番号))
		DRAWLINE
		PRINTFORML 客室設備「%TSTR:コマンド名受渡%」を設置しました。
		IF TSTR:ツールチップ受渡 != ""
			DRAWLINE
			HTML_PRINT TSTR:ツールチップ受渡
			DRAWLINE
		ENDIF
		WAIT
ENDSELECT


@客室設備_ベッド_通常系列(動作モード, Lv指定 = 1)
#DIMS 動作モード
#DIM Lv指定

SELECTCASE Lv指定
	CASE 1
		SELECTCASE 動作モード
			CASE "名前取得"
				TSTR:コマンド名受渡 = 簡素なベッド
				TSTR:ツールチップ受渡 = 一般家庭で使われている普通のベッド。<br>
				TSTR:ツールチップ受渡 += "寝心地は少し硬めだが、むしろこれが落ち着くという人もいる。<br>"
				;価格を返す
				RETURN 10000
		ENDSELECT
	CASE 2
		SELECTCASE 動作モード
			CASE "名前取得"
				TSTR:コマンド名受渡 = ふかふかベッド
				TSTR:ツールチップ受渡 = 上質な綿をたっぷり使ったふかふかのベッド。<br>
				TSTR:ツールチップ受渡 += "ちょっとお高めの宿屋でよく使われている。<br>"
				TSTR:ツールチップ受渡 += "手触りと寝心地が良く、ぐっすり眠れると評判のベッド。<br>"
				;価格を返す
				RETURN 50000
		ENDSELECT
	CASE 3
		SELECTCASE 動作モード
			CASE "名前取得"
				TSTR:コマンド名受渡 = 魔法のベッド
				TSTR:ツールチップ受渡 = 状態維持の魔法が掛かったベッド。<br>
				TSTR:ツールチップ受渡 += "一度干せば一週間は干したてのような温もりとふかふか感が持続する。<br>"
				TSTR:ツールチップ受渡 += "特に長期連泊のお客様に評判が良い。<br>"
				;価格を返す
				RETURN 150000
		ENDSELECT
	CASE 4
		SELECTCASE 動作モード
			CASE "名前取得"
				TSTR:コマンド名受渡 = 豪華なベッド
				TSTR:ツールチップ受渡 = 金細工の装飾と最高級シルクのシーツに包まれた一級品のベッド。<br>
				TSTR:ツールチップ受渡 += "見た目だけではなく肌触り・寝心地も最上級の一品。<br>"
				TSTR:ツールチップ受渡 += "ちょっとした王侯貴族の気分が味わえるともっぱらの評判である。<br>"
				;価格を返す
				RETURN 500000
		ENDSELECT
	CASE 5
		SELECTCASE 動作モード
			CASE "名前取得"
				TSTR:コマンド名受渡 = 至極のベッド
				TSTR:ツールチップ受渡 = 科学、魔法、錬金術とあらゆる技術を駆使して作られた至高のベッド。<br>
				TSTR:ツールチップ受渡 += "どんな不眠症の人間でも一度横になれば10秒で夢の中へと誘われるという。<br>"
				TSTR:ツールチップ受渡 += "このベッドで寝るためにわざわざ足を運ぶ観光客も多い。<br>"
				;価格を返す
				RETURN 2000000
		ENDSELECT
ENDSELECT

RETURN -1


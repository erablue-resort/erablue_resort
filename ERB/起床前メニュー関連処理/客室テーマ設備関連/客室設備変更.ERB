
@客室設備変更(配置番号)
#DIM 配置番号

DRAWLINE
PRINTL 設置する設備を選択してください。
PRINT 設定中設備：
IF 配置客室設備:配置番号 > 0
	TSTR:コマンド名受渡 = 
	CALLFORM 客室設備_%ERDNAME(客室設備, 配置客室設備:配置番号)%("名前取得", 客室設備:(配置客室設備:配置番号))
	PRINTFORML %TSTR:コマンド名受渡%
ELSE
	PRINTL ----------
ENDIF
DRAWLINE
FOR LOCAL, 1, VARSIZE("客室設備")
	SIF 客室設備:LOCAL < 1
		CONTINUE
	SIF MATCH(配置客室設備, LOCAL)
		CONTINUE
	TSTR:コマンド名受渡 = 
	CALLFORM 客室設備_%ERDNAME(客室設備, LOCAL)%("名前取得", 客室設備:LOCAL)
	PRINTBUTTON @"[{LOCAL}] %TSTR:コマンド名受渡%", LOCAL
	PRINTL
NEXT
PRINTL
IF 配置客室設備:配置番号 > 0
	PRINTBUTTON "[998] 設定中の設備を外す", 998
	PRINTL
ELSE
	SETCOLOR カラーパレット("グレーアウト")
	PRINTPLAIN [998] 設定中の設備を外す
	RESETCOLOR
ENDIF
PRINTBUTTON "[999] 戻る", 999
PRINTL
PRINTL
BINPUT
PRINTL
PRINTL
SELECTCASE RESULT
	CASE 999
		RETURN 0
	CASE 998
		TSTR:コマンド名受渡 = 
		CALLFORM 客室設備_%ERDNAME(客室設備, 配置客室設備:配置番号)%("名前取得", 客室設備:(配置客室設備:配置番号))
		PRINTFORMW 客室設備「%TSTR:コマンド名受渡%」を解除しました。
		配置客室設備:配置番号 = 0
	CASEELSE
		配置客室設備:配置番号 = RESULT
		TSTR:コマンド名受渡 = 
		CALLFORM 客室設備_%ERDNAME(客室設備, 配置客室設備:配置番号)%("名前取得", 客室設備:(配置客室設備:配置番号))
		PRINTFORMW 客室設備「%TSTR:コマンド名受渡%」を設置しました。
ENDSELECT


@客室設備_ベッド_通常系列(動作モード, Lv指定 = 1)
#DIMS 動作モード
#DIM Lv指定

SELECTCASE Lv指定

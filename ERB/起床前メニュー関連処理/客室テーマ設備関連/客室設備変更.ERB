@客室設備_家具_テーブル系列(動作モード, Lv指定 = 1)
#DIMS 動作モード
#DIM Lv指定

SELECTCASE 動作モード
	CASE "名前取得"
		SELECTCASE Lv指定
			CASE 1
				TSTR:コマンド名受渡 = 普通のテーブル
		ENDSELECT	
ENDSELECT

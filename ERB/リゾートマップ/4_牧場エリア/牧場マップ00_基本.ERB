
@大規模エリア建設条件_牧場エリア(建築位置)
#DIM 建築位置
;一個まで
SIF MATCH(開拓エリア開発番号, 大規模番号_牧場エリア) > 0
	RETURN 0
;居住区が先
SIF MATCH(開拓エリア開発番号, 大規模番号_居住区エリア) < 1
	RETURN 0

RETURN 1

@大規模エリア解説文章_牧場エリア

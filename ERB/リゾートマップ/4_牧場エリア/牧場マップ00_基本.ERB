@DRAW_MAP_BG_4_0(SLICED, 表示文字列)
#DIMS REF 表示文字列
#DIMS SLICED
#DIM 改行フラグ

SELECTCASE SLICED
	;ふつうの
	CASEELSE
		表示文字列 += @"%SLICED%"
ENDSELECT

改行フラグ = 0


@エリア来訪時イベント_4

IF 牧場初来訪イベントフラグ == 0
	DRAWLINE
	PRINTL ［初来訪：牧場エリア］
	DRAWLINE
	PRINTW
	PRINTFORMW %CALLNAME:PLAYER%は島を開拓し、空いたエリアを開拓した牧場を訪れた。
	PRINTFORMW 豊かな自然の中で家畜たちがのんびりと戯れており、動物と触れ合いに来た観光客の姿も見える。
	PRINTFORMW 牧場を経営すればリゾートで使う食材も賄えるだろうし、特別な家畜を飼えば質の良い食物素材を手に入れることも可能だろう。
	PRINTL
	PRINTFORMW また、他の世界から卵などを持ってくればここで世話をして成長させることも出来そうだ。（※未実装です）
	PRINTFORMW 知能の高い動物なら定住者と同じ扱いにして、リゾートの発展に寄与してもらおう。
	PRINTL
	SETCOLOR カラーパレット("黄")
	IF STRCOUNT(所持制服文字列, @"汎用/普通のオーバーオール_") == 0 && STRCOUNT(所持エロ衣装文字列, @"エロ/普通のオーバーオール_") == 0
		PRINTFORMW 牧場エリアの完成により通常衣装「普通のオーバーオール」を入手した。
		CALL 制服登録処理("普通のオーバーオール")
	ENDIF
	IF STRCOUNT(所持制服文字列, @"汎用/裸ミニスカオーバーオール_") == 0 && STRCOUNT(所持エロ衣装文字列, @"エロ/裸ミニスカオーバーオール_") == 0
		PRINTFORMW 牧場エリアの完成によりエロ衣装「裸ミニスカオーバーオール」を入手した。
		CALL エロ衣装登録処理("裸ミニスカオーバーオール")
	ENDIF
	RESETCOLOR
	牧場初来訪イベントフラグ = 1
ENDIF



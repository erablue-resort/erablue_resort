

@家畜情報_お牛さま(動作モード)
#DIMS 動作モード
#DIMS 入手名

SELECTCASE 動作モード
	CASE "出現条件"
		;出現する場合は１を返す
		RETURN 1
	CASE "基礎情報"
		;フレーバーの解説
		詳細文文字列受け渡し変数 = 丑神宮で飼われているのと同じ品種の乳牛。<br>
		詳細文文字列受け渡し変数 += "濃厚かつさっぱりした風味の牛乳を採取することが出来る。<br>"
		詳細文文字列受け渡し変数 += "肉用牛としても一定以上の品質が期待できるコスパの良い家畜。<br>"

		;特殊効果の解説
		詳細文文字列受け渡し変数２ = 月曜日の終了時に「お手頃牛肉」「普通の牛肉」「高級牛肉」からランダムで１つ入手する。<br>
		RETURN 3000
	CASE "特殊効果"
		;月曜のみ
		SIF GET_DAY() != "月"
			RETURN 0

		RSTR:その他報告_記録文字列 += "　　家畜：お牛さまから"

		SELECTCASE RAND:3
			CASE 0
				入手名 = お手頃牛肉
			CASE 1
				入手名 = 普通の牛肉
			CASE 2
				入手名 = 高級牛肉
		ENDSELECT

		CALL 素材入手処理(入手名, 1)
		RSTR:その他報告_記録文字列 += @"%入手名%"
		RSTR:その他報告_記録文字列 += "を手に入れた！<br>"
ENDSELECT




@家畜情報_ツノモン（デジモンシリーズ）(動作モード, 家畜番号 = -1)
#DIMS 動作モード
#DIMS 入手名
#DIM 家畜番号

SELECTCASE 動作モード
	CASE "出現条件"
		;出現する場合は１を返す
		;デジタマからの進化なので出現しない
		RETURN 0
	CASE "基礎情報"
		;フレーバーの解説
		詳細文文字列受け渡し変数 = 幼年期デジモンの一種。丸い身体で元気に動き回る。<br>
		詳細文文字列受け渡し変数 += "５日間飼うことでランダムなデジモンに進化する。<br>"
		詳細文文字列受け渡し変数 += "（ワクチン種のデジモンに進化しやすい）<br>"
		詳細文文字列受け渡し変数 += "進化前に切り替えると期間がリセットされるので注意。<br>"

		;特殊効果の解説
		詳細文文字列受け渡し変数２ = ５日間飼うことで別の家畜へ変化する。
		IF 家畜番号 >= 0
			詳細文文字列受け渡し変数２ += @"（現在{家畜_記録変数:家畜番号}日経過）"
		ENDIF
		詳細文文字列受け渡し変数２ += "<br>"
		詳細文文字列受け渡し変数２ += "※開発中のため、進化未実装です。何日飼っても進化しません。<br>"
		RETURN 1000
	CASE "特殊効果"
		;一日終了時レポート処理_その他報告で呼ばれる
		;５日カウント
		家畜_記録変数:家畜番号 ++
		IF 家畜_記録変数:家畜番号 >= 5
			;進化する
			
			; RSTR:その他報告_記録文字列 += "　　家畜：コロモンが進化して家畜："


			; RSTR:その他報告_記録文字列 += @"%入手名%に進化した！<br>"
			; レポート強調フラグ:その他報告 = 1
		ENDIF
ENDSELECT


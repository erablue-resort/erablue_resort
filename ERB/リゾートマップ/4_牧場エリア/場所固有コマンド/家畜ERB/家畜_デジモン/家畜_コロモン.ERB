

@家畜情報_コロモン（デジモンシリーズ）(動作モード, 家畜番号 = -1)
#DIMS 動作モード
#DIMS 入手名
#DIM 家畜番号
#DIM 候補数
#DIM 進化先No


SELECTCASE 動作モード
	CASE "出現条件"
		;出現する場合は１を返す
		;デジタマからの進化なので出現しない
		RETURN 0
	CASE "基礎情報"
		;フレーバーの解説
		詳細文文字列受け渡し変数 = 幼年期デジモンの一種。丸い身体で元気に動き回る。<br>
		詳細文文字列受け渡し変数 += "５日間飼うことでランダムなデジモンに進化する。<br>"
		詳細文文字列受け渡し変数 += "（ワクチン種のデジモンに進化しやすい）<br>"
		詳細文文字列受け渡し変数 += "進化前に切り替えると期間がリセットされるので注意。<br>"

		;特殊効果の解説
		詳細文文字列受け渡し変数２ = ５日間飼うことで別の家畜へ変化する。
		IF 家畜番号 >= 0
			詳細文文字列受け渡し変数２ += @"（現在{家畜_記録変数:家畜番号}日経過）"
		ENDIF
		詳細文文字列受け渡し変数２ += "<br>"
		RETURN 1000
	CASE "通常_一日終了時効果"
		;一日終了時レポート処理_その他報告で呼ばれる
		;５日カウント
		家畜_記録変数:家畜番号 ++
		IF 家畜_記録変数:家畜番号 >= 5
			;進化する
			RSTR:その他報告_記録文字列 += "　　家畜：コロモン（デジモンシリーズ）が進化しそうだ……！<br>"
			レポート強調フラグ:その他報告 = 1
		ENDIF
	CASE "重要_一日終了時効果"
		;レポート閉じた後に一つずつ呼ばれる
		IF 家畜_記録変数:家畜番号 >= 5
			;進化する処理
			家畜_記録変数:家畜番号 = 0

			;進化先決定
			IF RAND:2
				;50%で特定種のデジモンへ
				候補数 = DT_SELECT("ランダムCSVデータベース", "ランダムキャラ設定 = 'デジモン' And フリー文字列１ = 'ワクチン種'")
			ELSE
				;それ以外は全部から抽選
				候補数 = DT_SELECT("ランダムCSVデータベース", "ランダムキャラ設定 = 'デジモン'")
			ENDIF
			IF 候補数 < 1
				DRAWLINE
				PRINTFORMW コロモンは進化出来なかった……
				RETURN 0
			ENDIF

			進化先No = DT_CELL_GET("ランダムCSVデータベース", RESULT:(RAND:候補数 + 1), "CSV番号", 1)

			DRAWLINE
			PRINTFORMW コロモンは%CSVCALLNAME(進化先No)%に進化した！
			DRAWLINE
			CALL ランダムキャラ加入確認_デジモンシリーズ(進化先No)
		ENDIF
ENDSELECT


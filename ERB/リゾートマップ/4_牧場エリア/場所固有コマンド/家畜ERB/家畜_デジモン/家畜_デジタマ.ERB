

@家畜情報_デジタマ（デジモンシリーズ）(動作モード, 家畜番号 = -1)
#DIMS 動作モード
#DIMS 入手名
#DIM 家畜番号

SELECTCASE 動作モード
	CASE "出現条件"
		;出現する場合は１を返す
		RETURN 1
	CASE "基礎情報"
		;フレーバーの解説
		詳細文文字列受け渡し変数 = 全てのデジモンシリーズの元となる卵。<br>
		詳細文文字列受け渡し変数 += "５日間飼うことでランダムな幼年期デジモンに進化する。<br>"
		詳細文文字列受け渡し変数 += "進化前に切り替えると期間がリセットされるので注意。<br>"

		;特殊効果の解説
		詳細文文字列受け渡し変数２ = ５日間飼うことで別の家畜へ変化する。
		IF 家畜番号 >= 0
			詳細文文字列受け渡し変数２ += @"（現在{家畜_記録変数:家畜番号}日経過）"
		ENDIF
		詳細文文字列受け渡し変数２ += "<br>"
		RETURN 10
	CASE "特殊効果"
		;一日終了時レポート処理_その他報告で呼ばれる
		;５日カウント
		家畜_記録変数:家畜番号 ++
		IF 家畜_記録変数:家畜番号 >= 5
			;孵化する
			
			RSTR:その他報告_記録文字列 += "　　家畜：デジタマが孵化して家畜："

			SELECTCASE RAND:3
				CASE 0
					;ワクチン系列
					入手名 = コロモン
				CASE 1
					;データ系列
					入手名 = ツノモン
				CASE 2
					;ウィルス系列
					入手名 = パグモン
			ENDSELECT

			RSTR:その他報告_記録文字列 += @"%入手名%に進化した！<br>"
			レポート強調フラグ:その他報告 = 1
			家畜_記録変数:家畜番号 = 0
			現在設定家畜:家畜番号 = %入手名%（デジモンシリーズ）
		ENDIF
ENDSELECT


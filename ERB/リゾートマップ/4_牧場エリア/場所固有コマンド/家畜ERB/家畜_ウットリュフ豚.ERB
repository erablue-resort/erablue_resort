

@家畜情報_ウットリュフ豚(動作モード, 家畜番号 = -1)
#DIMS 動作モード
#DIMS 入手名
#DIM 家畜番号

SELECTCASE 動作モード
	CASE "出現条件"
		;出現する場合は１を返す
		RETURN 1
	CASE "基礎情報"
		;フレーバーの解説
		詳細文文字列受け渡し変数 = ウットリュフと呼ばれるキノコを背中に生やした豚。<br>
		詳細文文字列受け渡し変数 += "肉にもキノコの風味が染み込んでおり、ただ焼くだけでも美味しい。<br>"
		詳細文文字列受け渡し変数 += "十分に育った後は背中のキノコも食べることが出来る。<br>"
		;登場イベ：Oh My リュミエール♪

		;特殊効果の解説
		詳細文文字列受け渡し変数２ = 水曜日の終了時に「ただの豚肉」「質の良い豚肉」「とろける豚肉」からランダムで１つ入手する。<br>
		RETURN 1500
	CASE "特殊効果"
		;一日終了時レポート処理_その他報告で呼ばれる
		;水曜のみ
		SIF GET_DAY() != "水"
			RETURN 0

		RSTR:その他報告_記録文字列 += "　　家畜：ウットリュフ豚から"

		SELECTCASE RAND:3
			CASE 0
				入手名 = ただの豚肉
			CASE 1
				入手名 = 質の良い豚肉
			CASE 2
				入手名 = とろける豚肉
		ENDSELECT

		CALL 素材入手処理(入手名, 1)
		RSTR:その他報告_記録文字列 += @"%入手名%"
		RSTR:その他報告_記録文字列 += "を手に入れた！<br>"
ENDSELECT


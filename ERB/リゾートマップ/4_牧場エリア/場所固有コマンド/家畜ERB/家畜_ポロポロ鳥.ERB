

@家畜情報_ポロポロ鳥(動作モード)
#DIMS 動作モード
#DIMS 入手名

SELECTCASE 動作モード
	CASE "出現条件"
		;出現する場合は１を返す
		RETURN 1
	CASE "基礎情報"
		;フレーバーの解説
		詳細文文字列受け渡し変数 = 渡り鳥を家畜化した品種。<br>
		詳細文文字列受け渡し変数 += "卵も肉も食用として優れており、観光客の食事用にも十分な味を持つ。<br>"
		詳細文文字列受け渡し変数 += "特に骨を煮込んで作ったスープは絶品。<br>"
		;登場イベ：ビストロフェードラッヘ

		;特殊効果の解説
		詳細文文字列受け渡し変数２ = 金曜日の終了時に「普通の鳥肉」「新鮮な鳥肉」「脂の乗った鳥肉」からランダムで１つ入手する。<br>
		RETURN 1000
	CASE "特殊効果"
		;金曜のみ
		SIF GET_DAY() != "金"
			RETURN 0

		RSTR:その他報告_記録文字列 += "　　家畜：ポロポロ鳥から"

		SELECTCASE RAND:3
			CASE 0
				入手名 = 普通の鳥肉
			CASE 1
				入手名 = 新鮮な鳥肉
			CASE 2
				入手名 = 脂の乗った鳥肉
		ENDSELECT

		CALL 素材入手処理(入手名, 1)
		RSTR:その他報告_記録文字列 += @"%入手名%"
		RSTR:その他報告_記録文字列 += "を手に入れた！<br>"
ENDSELECT


;****************************************
;サイド領域の複数人一枚絵を登録するための関数
;****************************************
;・使い方
;「XXXX」を任意の文字列に書き換え、キャラの組み合わせと表示条件を入れる
;「XXXX」は既存の関数と被らないこと
;キャラの組み合わせは既存の関数と被らないこと、同じ組み合わせがないかどうか事前にチェックしてください
;処理的に、組み合わせのキャラが全員同じ場所にいないと条件は読まれません
;画像のサイズはおおよそ650*650程度が限度です
;****************************************

;--------------------------------------------------
;登録データ
;--------------------------------------------------
@複数人一枚絵_登録データ_ユウカ_ノア(動作モード, 指定キャラ)
#DIMS 動作モード
#DIM REF 指定キャラ
#DIM ザーメンキス前フラグ

SELECTCASE 動作モード
	CASE "初期登録"
		;キャラの組み合わせを指定、5キャラまで指定可能
		指定キャラ:0 = キャラ検索("[セミナー会計]早瀬ユウカ")
		指定キャラ:1 = キャラ検索("[セミナー書記]生塩ノア")
		; 指定キャラ:2 = キャラ検索("")
		; 指定キャラ:3 = キャラ検索("")
		; 指定キャラ:4 = キャラ検索("")
	CASE "画像指定"
		;表示条件を分岐しつつ画像名を指定する

		$再ロール
		SELECTCASE RAND:49
			CASE 0 TO 3
				;以下はキャラ0とキャラ1が同時パイズリしている時の例
				IF MODE_確認_完全一致("パイズリ系", 指定キャラ:0, PLAYER) >= 0 && MODE_確認_完全一致("パイズリ系", 指定キャラ:1, PLAYER) >= 0
					SELECTCASE RAND:3
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルパイズリ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルパイズリ1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルパイズリ2
					;CASE 3
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルパイズリ3
					;CASE 4
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルパイズリ4
					;CASE 5
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルパイズリ5
					ENDSELECT
				;ELSEIF MODE_確認_完全一致("パイズリ系", 指定キャラ:0, MASTER) >= 0
				;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_パイズリ
				ELSEIF MODE_確認_完全一致("パイズリ系", 指定キャラ:1, MASTER) >= 0					
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_パイズリ
					;CASE 1
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_パイズリ1
					ENDSELECT
				ELSE
					GOTO 再ロール
				ENDIF
			CASE 4 TO 7
				IF MODE_確認_完全一致("フェラチオ系", 指定キャラ:0, PLAYER) >= 0 && MODE_確認_完全一致("フェラチオ系", 指定キャラ:1, PLAYER) >= 0
					SELECTCASE RAND:5
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルフェラチオ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルフェラチオ1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルフェラチオ2
					CASE 3
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルフェラチオ3
					CASE 4
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルフェラチオ4
					;CASE 5
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブルフェラチオ5
					ENDSELECT
				;ELSEIF MODE_確認_完全一致("フェラチオ系", 指定キャラ:0, MASTER) >= 0 &&  MODE_存在判定_完全一致("足コキ", 指定キャラ:1, PLAYER)
				;	SELECTCASE RAND:1
				;	CASE 0
				;		RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_フェラチオと足コキ
				;	ENDSELECT
				ELSEIF MODE_確認_完全一致("フェラチオ系", 指定キャラ:0, MASTER) >= 0
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_フェラチオ
					;CASE 1
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_フェラチオ1
					ENDSELECT
				ELSEIF MODE_確認_完全一致("フェラチオ系", 指定キャラ:1, MASTER) >= 0			
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_フェラチオ
					;CASE 1
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_フェラチオ1
					ENDSELECT
				ELSE
					GOTO 再ロール
				ENDIF
			CASE 8 TO 11
				IF MODE_確認_完全一致("手コキ系", 指定キャラ:0, PLAYER) >= 0 && MODE_確認_完全一致("手コキ系", 指定キャラ:1, PLAYER) >= 0
					SELECTCASE RAND:4
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブル手コキ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブル手コキ1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブル手コキ2
					CASE 3
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブル手コキ3
					;CASE 4
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブル手コキ4
					;CASE 5
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_ダブル手コキ5
					ENDSELECT
				;ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:0, MASTER) >= 0 && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:0)
				;	SELECTCASE RAND:1
				;	CASE 0 
				;		RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_手コキとキス   
				;	ENDSELECT
				ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:0, MASTER) >= 0 && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:1)
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_手コキとキス
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_手コキとキス1
					;CASE 2
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_手コキとキス2
					ENDSELECT
				ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:1, MASTER) >= 0 && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:0)
					SELECTCASE RAND:1 
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_手コキとキスR
					ENDSELECT
				ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:0, MASTER) >= 0
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_手コキ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_手コキ1
					ENDSELECT

				ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:1, MASTER) >= 0			
					SELECTCASE RAND:3
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_手コキ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_手コキ1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_手コキ2
					ENDSELECT					
				ELSE
					GOTO 再ロール
				ENDIF
			CASE 12 TO 15
				IF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:0)) && (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:1)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:1)) 
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_後背位
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_後背位1
					;CASE 2
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_後背位2
					ENDSELECT
				ELSEIF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:0)) && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:1)	
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_後背位とキス
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_後背位とキス1
					ENDSELECT
				ELSEIF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:1)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:1)) && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:0)	
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_後背位とキスR
					;CASE 1
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_後背位とキスR1
					ENDSELECT
				ELSEIF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:0)) && !MODE_存在判定_順不同("Ｖ挿入系", 指定キャラ:1, MASTER) 			
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_後背位
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_後背位1
					;CASE 2
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_後背位2
					ENDSELECT
				
				ELSEIF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:1)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:1)) && !MODE_存在判定_順不同("Ｖ挿入系", 指定キャラ:0, MASTER) 
					SELECTCASE RAND:3
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_後背位
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_後背位1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ノア_後背位2
					ENDSELECT

				ELSE
					GOTO 再ロール
				ENDIF
			CASE 16 TO 19
				;IF CFLAG:(指定キャラ:0):うふふ && CFLAG:(指定キャラ:1):うふふ
					IF TCVAR:(指定キャラ:0):膣内精液量 && TCVAR:(指定キャラ:1):膣内精液量
						SELECTCASE RAND:7
						CASE 0
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_征服							
						CASE 1
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_征服1
						CASE 2
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_征服2
						CASE 3
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_征服3
						CASE 4
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_征服4
						CASE 5
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ユウカ_ノア/ユウカ_ノア_征服5
						CASE 6

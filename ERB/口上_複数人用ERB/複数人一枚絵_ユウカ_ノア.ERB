				ELSEIF (MODE_存在判定_完全一致("正常位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面立位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("駅弁", MASTER, 指定キャラ:0)) && MODE_存在判定_完全一致("乳首吸い系", MASTER, 指定キャラ:1)			

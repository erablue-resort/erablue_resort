;****************************************
;サイド領域の複数人一枚絵を登録するための関数
;****************************************
;・使い方
;「XXXX」を任意の文字列に書き換え、キャラの組み合わせと表示条件を入れる
;「XXXX」は既存の関数と被らないこと
;キャラの組み合わせは既存の関数と被らないこと、同じ組み合わせがないかどうか事前にチェックしてください
;処理的に、組み合わせのキャラが全員同じ場所にいないと条件は読まれません
;画像のサイズはおおよそ650*650程度が限度です
;****************************************

;--------------------------------------------------
;登録データ
;--------------------------------------------------
@複数人一枚絵_登録データ_こころ_こいし(動作モード, 指定キャラ)
#DIMS 動作モード
#DIM REF 指定キャラ
#DIM ザーメンキス前フラグ

SELECTCASE 動作モード
	CASE "初期登録"
		;キャラの組み合わせを指定、5キャラまで指定可能
		指定キャラ:0 = キャラ検索("[能面で感情的な面霊気]秦こころ")
		指定キャラ:1 = キャラ検索("[閉じた恋の瞳]古明地こいし")
		; 指定キャラ:2 = キャラ検索("")
		; 指定キャラ:3 = キャラ検索("")
		; 指定キャラ:4 = キャラ検索("")
	CASE "画像指定"
		;表示条件を分岐しつつ画像名を指定する

		$再ロール
		SELECTCASE RAND:13
			CASE 0
				;以下はキャラ0とキャラ1が同時パイズリしている時の例
				IF MODE_確認_完全一致("パイズリ系", 指定キャラ:0, PLAYER) >= 0 && MODE_確認_完全一致("パイズリ系", 指定キャラ:1, PLAYER) >= 0
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルパイズリ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルパイズリ1
					;CASE 2
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルパイズリ2
					;CASE 3
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルパイズリ3
					;CASE 4
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルパイズリ4
					ENDSELECT
				;ELSEIF MODE_確認_完全一致("パイズリ系", 指定キャラ:0, MASTER) >= 0
				;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_パイズリ
				;ELSEIF MODE_確認_完全一致("パイズリ系", 指定キャラ:1, MASTER) >= 0
				;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_パイズリ
				ELSE
					GOTO 再ロール
				ENDIF
			CASE 1
				IF MODE_確認_完全一致("フェラチオ系", 指定キャラ:0, PLAYER) >= 0 && MODE_確認_完全一致("フェラチオ系", 指定キャラ:1, PLAYER) >= 0
					SELECTCASE RAND:3
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルフェラチオ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルフェラチオ1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルフェラチオ2
					;CASE 3
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブルフェラチオ3
					ENDSELECT
				ELSEIF MODE_確認_完全一致("フェラチオ系", 指定キャラ:0, MASTER) >= 0
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_フェラチオ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_フェラチオ1
					ENDSELECT
				ELSEIF MODE_確認_完全一致("フェラチオ系", 指定キャラ:1, MASTER) >= 0			
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_フェラチオ
					ENDSELECT
				ELSE
					GOTO 再ロール
				ENDIF
			CASE 2
				IF MODE_確認_完全一致("手コキ系", 指定キャラ:0, PLAYER) >= 0 && MODE_確認_完全一致("手コキ系", 指定キャラ:1, PLAYER) >= 0
					SELECTCASE RAND:3
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブル手コキ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブル手コキ1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブル手コキ2
					;CASE 3
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブル手コキ3
					;CASE 4
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ダブル手コキ4
					ENDSELECT
				ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:0, MASTER) >= 0 && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:0)
					SELECTCASE RAND:1
					CASE 0 
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_手コキとキス   
					ENDSELECT
				ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:0, MASTER) >= 0 && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:1)
					SELECTCASE RAND:1 
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_手コキとキス
					ENDSELECT
				ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:0, MASTER) >= 0
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_手コキ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_手コキ1
					ENDSELECT

				ELSEIF MODE_確認_完全一致("手コキ系", 指定キャラ:1, MASTER) >= 0			
					SELECTCASE RAND:2 
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_手コキ
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_手コキ1
					ENDSELECT					
				ELSE
					GOTO 再ロール
				ENDIF
			CASE 3
				IF ( GETBIT(FLAG:モード管理, モードビット_同時) && コマンド履歴:0 == 208 ) || (CSTR:(指定キャラ:0):着せ替え服 == "全裸" && CSTR:(指定キャラ:1):着せ替え服 == "全裸")
					SELECTCASE RAND:3
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_まとめて全裸にする
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_まとめて全裸にする1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_まとめて全裸にする2
					;CASE 3
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_まとめて全裸にする3
					ENDSELECT
				ELSEIF  CSTR:(指定キャラ:0):着せ替え服 == "全裸"				
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_全裸にする
					;CASE 1
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_全裸にする1
					;CASE 2
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_全裸にする2
					ENDSELECT
				;ELSEIF  CSTR:(指定キャラ:1):着せ替え服 == "全裸"				
				;	SELECTCASE RAND:1
				;	CASE 0
				;		RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_全裸にする
				;	ENDSELECT
				ELSE
					GOTO 再ロール
				ENDIF
			CASE 4
				IF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:0)) && (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:1)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:1)) 
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_後背位
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_後背位1
					ENDSELECT
				ELSEIF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:0)) && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:1)	
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_後背位とキス
					ENDSELECT
				ELSEIF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:0)) && !MODE_存在判定_順不同("Ｖ挿入系", 指定キャラ:1, MASTER) 			
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_後背位
					;CASE 1
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_後背位1
					;CASE 2
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_後背位2
					ENDSELECT
				
				ELSEIF (MODE_存在判定_完全一致("後背位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("立ちバック", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("背面座位", MASTER, 指定キャラ:1)|| MODE_存在判定_完全一致("背面駅弁", MASTER, 指定キャラ:1)) && !MODE_存在判定_順不同("Ｖ挿入系", 指定キャラ:0, MASTER) 
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_後背位
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_後背位1
					ENDSELECT

				ELSE
					GOTO 再ロール
				ENDIF
			CASE 5
				;IF CFLAG:(指定キャラ:0):うふふ && CFLAG:(指定キャラ:1):うふふ
					IF TCVAR:(指定キャラ:0):膣内精液量 && TCVAR:(指定キャラ:1):膣内精液量
						SELECTCASE RAND:6
						CASE 0
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_征服							
						CASE 1
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_征服1
						CASE 2
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_征服2
						CASE 3
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_征服3
						CASE 4
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_征服4
						CASE 5
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_征服5
						ENDSELECT
					ELSEIF TCVAR:(指定キャラ:0):膣内精液量
						SELECTCASE RAND:1
						CASE 0
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_征服
						ENDSELECT
					ELSEIF TCVAR:(指定キャラ:1):膣内精液量
						SELECTCASE RAND:1
						CASE 0
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_征服						
						ENDSELECT
					ELSE
						GOTO 再ロール
					ENDIF
				
				;ENDIF
			CASE 6
				IF (MODE_存在判定_完全一致("正常位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面立位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("駅弁", MASTER, 指定キャラ:0)) && (MODE_存在判定_完全一致("正常位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("対面立位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("対面座位", MASTER, 指定キャラ:1)|| MODE_存在判定_完全一致("駅弁", MASTER, 指定キャラ:1)) 
					SELECTCASE RAND:3
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_正常位
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_正常位1
					CASE 2
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_正常位2
					ENDSELECT
				ELSEIF (MODE_存在判定_完全一致("正常位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面立位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("駅弁", MASTER, 指定キャラ:0)) && MODE_存在判定_順不同("キス系", MASTER, 指定キャラ:1)			
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_正常位とキス
					ENDSELECT
				ELSEIF (MODE_存在判定_完全一致("正常位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面立位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("駅弁", MASTER, 指定キャラ:0)) && MODE_存在判定_完全一致("乳首吸い系", MASTER, 指定キャラ:0)			
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_正常位と乳首吸い
					ENDSELECT
				
				ELSEIF (MODE_存在判定_完全一致("正常位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面立位", MASTER, 指定キャラ:0) || MODE_存在判定_完全一致("対面座位", MASTER, 指定キャラ:0)|| MODE_存在判定_完全一致("駅弁", MASTER, 指定キャラ:0)) && !MODE_存在判定_順不同("Ｖ挿入系", 指定キャラ:1, MASTER) 			
					SELECTCASE RAND:2
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_正常位
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_正常位1
					;CASE 2
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_正常位2
					ENDSELECT
				ELSEIF (MODE_存在判定_完全一致("正常位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("対面立位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("対面座位", MASTER, 指定キャラ:1)|| MODE_存在判定_完全一致("駅弁", MASTER, 指定キャラ:1))  && MODE_存在判定_完全一致("クンニ", MASTER, 指定キャラ:0)
					SELECTCASE RAND:2 
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_正常位とクンニR
					CASE 1
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_正常位とクンニR1
					ENDSELECT

				ELSEIF (MODE_存在判定_完全一致("正常位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("対面立位", MASTER, 指定キャラ:1) || MODE_存在判定_完全一致("対面座位", MASTER, 指定キャラ:1)|| MODE_存在判定_完全一致("駅弁", MASTER, 指定キャラ:1))  && !MODE_存在判定_順不同("Ｖ挿入系", 指定キャラ:0, MASTER) 
					SELECTCASE RAND:1
					CASE 0
						RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_正常位
					;CASE 1
					;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_正常位1
					ENDSELECT

				ELSE
					GOTO 再ロール
				ENDIF
			CASE 7
				IF コマンド履歴:0 == 20 && MODE_存在判定_順不同("キス系", 指定キャラ:0, 指定キャラ:1)
					IF SELECTCOM_NAME履歴:0 == "ザーメンキス"
						SELECTCASE RAND:1
						CASE 0
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_ザーメンシェア

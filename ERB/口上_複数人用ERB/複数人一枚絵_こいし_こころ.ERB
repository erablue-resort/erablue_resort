						;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_キス2
						;CASE 3
						;	RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_こいし_キス3
						ENDSELECT
					ENDIF
				ELSEIF MODE_存在判定_完全一致("キス系", MASTER, 指定キャラ:0)
					SELECTCASE RAND:1
						CASE 0
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こころ_キス
					ENDSELECT
				;ELSEIF MODE_存在判定_完全一致("キス系", MASTER, 指定キャラ:1)
				;	SELECTCASE RAND:1
				;		CASE 0
				;			RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/こころ_こいし/こいし_キス

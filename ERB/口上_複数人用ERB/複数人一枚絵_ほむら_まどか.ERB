						CASE 3
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ほむら_まどか/ほむら_まどか_征服3
						CASE 4
							RESULTS = %CSTR:(指定キャラ:0):画像フォルダ%/ほむら_まどか/ほむら_まどか_征服4


;--------------------------------------------------3218
;专属奥义
;--------------------------------------------------
@固有奥義_3218(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義威力表示

    隊列番号 = キャラ隊列検索(キャラ番号)

    ;アビ汎用変数:必要奥義ゲージ量 = 200
    ;アビ汎用変数:消費奥義ゲージ量 = 200
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = 戦術的鎮圧
    ENDIF
    奥義威力 = 0
    奥義威力表示 = 350
    SELECTCASE RAND:3
        CASE 0
        アビ汎用文字列:実行時メッセージ１ = 「私が耐えてる間に攻撃して。」
        CASE 1
        アビ汎用文字列:実行時メッセージ１ = 「私に任せなって。」
        CASE 2
        アビ汎用文字列:実行時メッセージ１ = 「無駄だよ。」
    ENDSELECT
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力表示}％
            詳細文文字列受け渡し変数 += @"<br> ランダムな敵2体に［攻撃力✕{奥義威力表示}％］の自属性ダメージを2回与える。"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                詳細文文字列受け渡し変数 += @"<br> さらに麻痺を付与（1ターン）"
            ENDIF
            ;詳細文文字列受け渡し変数 += @"<br>ヒフミの最大HPの160％のバリアを与える。味方を援護する。"
            
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
        CASE "奥義追加効果"
    
            CALL アビ対象選択テンプレート_敵ランダムＸ体_重複無し(2)
			アビ汎用変数:効果割合 = 奥義威力表示
            アビ汎用文字列:ダメージ種類 = 奥義ダメージ
			CALL アビテンプレート_ダメージ処理_自属性
            CALL アビテンプレート_ダメージ処理_自属性
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                アビ汎用文字列:バフ・デバフ枠 = 麻痺
                アビ汎用文字列:バフ・デバフ対象能力 = 麻痺
                アビ汎用変数:効果量 = 100
                アビ汎用変数:持続ターン = 1
                CALL アビテンプレート_不利効果_デバフ効果セット
            ENDIF

            CALL アビ汎用変数文字列リセット
            CALL アビ対象選択テンプレート_自己のみ
            アビ汎用文字列:バフ・デバフ対象能力 = バリア
            CALL バフ込み数値算出("回復力")
            アビ汎用変数:効果量 = RESULT  * 205 / 100
            アビ汎用変数:持続ターン = 3
            CALL アビテンプレート_有利効果_バフ効果セット
ENDSELECT

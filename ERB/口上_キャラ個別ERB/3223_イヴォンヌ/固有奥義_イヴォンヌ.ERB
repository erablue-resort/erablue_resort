
@固有奥義_3223(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 奥義威力
#DIM 隊列番号
#DIMS 奥義名

隊列番号 = キャラ隊列検索(キャラ番号)
アビ汎用変数:必要奥義ゲージ量 = 200
アビ汎用変数:消費奥義ゲージ量 = 200

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	奥義名 = アイスシューター+
	奥義威力 = 1000
ELSE
	奥義名 = アイスシューター
	奥義威力 = 800
ENDIF

;奥義威力を0にした場合、通常の奥義処理は行われず奥義追加効果のみが行われる。
;全体攻撃にしたい時や、攻撃しない奥義を作る場合は0に設定のこと

SELECTCASE ARGS
	CASE "奥義名"
		TSTR:コマンド名受渡 = %奥義名%
		IF 隊列番号 > -1
			SIF BATTLE_STATE:隊列番号:奥義ゲージ < 200
				RETURN 1
		ENDIF
	CASE "奥義説明文"
		詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％
		詳細文文字列受け渡し変数 += @"<br>対象が氷結Lv2以上の場合、追加で［攻撃力✕600％］の水属性ダメージを与える"
		詳細文文字列受け渡し変数 += @"<br>◆奥義ゲージ200％の時のみ奥義発動可能"
		RETURN 奥義威力
	CASE "奥義前効果"
		;対象決定の後、ダメージよりも前に発生する効果。基本の奥義ダメージ部分は記載する必要はない。
		;奥義威力が0だとここの部分もスキップされる
	CASE "奥義追加効果"
		;ここに奥義効果を記述する。基本の奥義ダメージ部分は記載する必要はない。
		;基本的にアビテンプレートの関数を使用すること
		;テンプレート使用の例は固有アビリティ_キャラ名.ERBに記載
		
		IF DT_CELL_GET("戦闘効果データベース", デバフ番号取得_枠("氷結", アビテンプレート用_対象保存:0), "効果量_固定値") / 50 > 1
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_指定(奥義対象指定先)
			アビ汎用文字列:ダメージ種類 = 奥義ダメージ
			アビ汎用変数:効果割合 = 600
			CALL アビテンプレート_ダメージ処理_水属性
		ENDIF
ENDSELECT

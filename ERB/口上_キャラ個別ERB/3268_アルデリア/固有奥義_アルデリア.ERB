
@固有奥義_3268(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 奥義威力
#DIM 威力値
#DIM 効果値
#DIMS 奥義名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	奥義名 = もふもふパーティー+
	威力値 = 70
ELSE
	奥義名 = もふもふパーティー
	威力値 = 45
ENDIF
奥義威力 = 0

;奥義威力を0にした場合、通常の奥義処理は行われず奥義追加効果のみが行われる。
;全体攻撃にしたい時や、攻撃しない奥義を作る場合は0に設定のこと

SELECTCASE ARGS
	CASE "奥義名"
		TSTR:コマンド名受渡 = %奥義名%
	CASE "奥義説明文"
		詳細文文字列受け渡し変数 = 奥義威力：{威力値}％
		詳細文文字列受け渡し変数 += @"<br>ランダムな敵に［攻撃力✕{威力値}％］の自属性ダメージを10回与える。"
		RETURN 奥義威力
	CASE "奥義前効果"
		;対象決定の後、ダメージよりも前に発生する効果。基本の奥義ダメージ部分は記載する必要はない。
		;奥義威力が0だとここの部分もスキップされる
	CASE "奥義追加効果"
		;ここに奥義効果を記述する。基本の奥義ダメージ部分は記載する必要はない。
		;基本的にアビテンプレートの関数を使用すること
		;テンプレート使用の例は固有アビリティ_キャラ名.ERBに記載
		
		FOR LOCAL, 0, 10
			;敵対心は無視「しない」と明示（ヘイトに影響される）
			アビ汎用変数:敵対心無視オプション = 0
			CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性
		NEXT
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_味方全体_生者のみ
		アビ汎用変数:効果割合 = 20
		CALL アビテンプレート_回復処理_MAXでも回復
ENDSELECT


@固有アビ_3268_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値
#DIM 効果値
#DIM タゲ候補, 10

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = ドリーラッシュ+
	消費ＭＰ = 100
	威力値 = 250
	効果値 = 30
ELSE
	アビ名 = ドリーラッシュ
	消費ＭＰ = 100
	威力値 = 170
	効果値 = 20
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［攻撃力✕{威力値}％］の土属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>対象が腐敗状態の場合、追加で［{効果値}％］（5ターン）の防御力減少効果を与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_土属性
		
		IF デバフ番号取得_枠("腐敗", アビテンプレート用_対象保存:0) > -1
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = ドリーラッシュ
			アビ汎用文字列:バフ・デバフ対象能力 = 防御力
			アビ汎用変数:効果割合 = 効果値
			アビ汎用変数:持続ターン = 5
			CALL アビテンプレート_不利効果_デバフ効果セット
			
			;腐敗(対象能力ではなく枠)条件だとアビ対象選択テンプレートのデバフ条件が使えないので独自処理
			VARSET LOCAL
			VARSET タゲ候補, -1
			FOR LOCAL:1, 10, 20
				SIF アビテンプレート用_対象保存:0 == LOCAL:1
					CONTINUE
				IF デバフ番号取得_枠("腐敗", LOCAL:1) > -1
					タゲ候補:LOCAL = LOCAL:1
					LOCAL ++
				ENDIF
			NEXT
			IF LOCAL
				アビテンプレート用_対象保存:0 = タゲ候補:(RAND:LOCAL)
				CALL アビテンプレート用_表示メッセージ変換処理
				CALL アビ汎用変数文字列リセット
				アビ汎用変数:効果割合 = 威力値
				CALL アビテンプレート_ダメージ処理_土属性

				CALL アビ汎用変数文字列リセット
				アビ汎用文字列:バフ・デバフ枠 = ドリーラッシュ
				アビ汎用文字列:バフ・デバフ対象能力 = 防御力
				アビ汎用変数:効果割合 = 効果値
				アビ汎用変数:持続ターン = 5
				CALL アビテンプレート_不利効果_デバフ効果セット

				CALL アビ汎用変数文字列リセット
				CALL アビ対象選択テンプレート_味方単体_最小ＨＰ
				アビ汎用変数:効果割合 = 20
				CALL アビテンプレート_回復処理_MAXでも回復
			ENDIF
		ENDIF

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_味方単体_最小ＨＰ
		アビ汎用変数:効果割合 = 20
		CALL アビテンプレート_回復処理_MAXでも回復
ENDSELECT



@固有アビ_3268_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = イラプション・コラム+
	消費ＭＰ = 100
	威力値 = 140
ELSE
	アビ名 = イラプション・コラム
	消費ＭＰ = 100
	威力値 = 100
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵全体に［攻撃力✕{威力値}％］の土属性ダメージを与える。
		詳細文文字列受け渡し変数 += "<br>［222］（通常枠・3ターン）の腐敗効果を与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵全体_生者のみ
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_土属性
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 腐敗
		アビ汎用文字列:バフ・デバフ対象能力 = 毒
		アビ汎用文字列:バフ・デバフ名 = 腐敗
		アビ汎用文字列:バフ・デバフアイコン = デバフ_腐敗
		アビ汎用変数:効果量 = 222
		アビ汎用変数:持続ターン = 3
		CALL アビテンプレート_不利効果_デバフ効果セット
ENDSELECT

;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
;・使い方
;「XXXX」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;　口上と同じ感覚で使う為に書式を統一しているが、ステータス画面で表示されるので
;　基本的にWAIT系列は使わないことを推奨
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3268(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ 特性：『友の面影』 □-----------------------------------------------------------------
KSTR:(K++) = 　ドリーラッシュ使用時、最もＨＰが少ない味方を20％回復
KSTR:(K++) = 　奥義使用時、味方全体のＨＰを20％回復
KSTR:(K++) = 　
KSTR:(K++) = □ 特性：『山頂サーフィン』 □------------------------------------------------------------
KSTR:(K++) = 　ドリーラッシュ使用時に対象が腐敗状態の場合、
KSTR:(K++) = 　腐敗状態の敵が他にもいたときその内の一体にドリーラッシュをもう1回発動

CALL 口上変数表示(対象キャラ, 1)




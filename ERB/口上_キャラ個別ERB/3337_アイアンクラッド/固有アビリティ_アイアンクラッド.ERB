@K3337_固有アビリティ_負傷(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIMS アビ名
#DIM 消費ＭＰ

	アビ名 = 負傷
	消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>効果はない。"
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>戦闘終了後、デッキから取り除かれる。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>効果はない。"
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>戦闘終了後、デッキから取り除かれる。"
		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;カスケード
			ELSEIF 特殊呼び出し == "カスケード"
				;カスケードならただ意味がないだけ
			;通常
			ELSE
				;行動を消費しない
				アビテンプレート用_行動消費無しフラグ = 1
				アビ汎用文字列:途中表示メッセージ１ = 負傷は使用できないカードだ！
			ENDIF

			;効果なし
			CALL アビテンプレート_何もしない

			;これは使用しても捨て札に送られない
;			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@固有アビ_3337_11(呼び出し引数, キャラ番号)
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIMS 山札の残りカード配列, 100
#DIM LCOUNT
#DIM 山札枚数
#DIM 残り山札枚数
#DIM シャッフルRAND1
#DIM シャッフルRAND2
#DIMS 山札確認文言
#DIMS 加工文言
#DIM BR判定

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;「山札の確認/凍った目」
	IF 0
	;レベルアップすると順番通り見られるようになる
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_凍った目, "レア", 0)
		アビ名 = 山札の確認・凍った目
	;山札の確認は初期習得
	ELSE
		アビ名 = 山札の確認
	ENDIF

	;消費MPは固定でゼロ
	消費ＭＰ = 0

	;現在ターン数は戦闘開始時には１になり、戦闘が終了するとゼロになる
	;なので戦闘状態にあるかどうかの判定に使えるはず……
	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			;非戦闘中
			IF 現在ターン数 == 0
				詳細文文字列受け渡し変数 += @"<br>戦闘中に使用すると、山札を確認できる。"
			;戦闘中
			ELSE
				詳細文文字列受け渡し変数 += @"<br>山札を確認できる。"
			ENDIF
			;共通テキスト
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_凍った目, "レア", 0)
				詳細文文字列受け渡し変数 += @"<br>表示される順番は山札の並び順通りとなる。"
			ELSE
				詳細文文字列受け渡し変数 += @"<br>表示される順番はランダム。"
			ENDIF
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>（戦闘中使用する場合、戦闘ログを表示することを推奨）"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ効果"
			;ターンを消費しない
			アビテンプレート用_行動消費無しフラグ = 1

			;デッキの内容を表示
			;まず初期化
			残り山札枚数 = 0
			VARSET 山札の残りカード配列

			VARSIZE K3337_山札
			山札枚数 = RESULT:0

			;山札を何枚引いたかの番号から、山札の総数をチェック
			;20枚のデッキから12枚引いてる場合、12～20をチェックする感じやね。
			FOR LCOUNT, K3337_山札何枚引いたかな, 山札枚数
				;とりあえずカラかどうかはチェックしつつ
				IF K3337_山札:LCOUNT != 0
					;あとでシャッフルするかもなので配列に入れる
					山札の残りカード配列:LCOUNT '= K3337_Battle_手札名取得(キャラ番号, LCOUNT, "山札")
					残り山札枚数 += 1
				ENDIF
			NEXT

			;具体的に山札の残りカードを文章にする
			IF 1 > 残り山札枚数
				;山札枚数がゼロならシャッフル工程は飛ばして文言確定
				山札確認文言 '= "……ちょうどゼロ枚……"
			;山札枚数が1以上の場合
			ELSE
				VARSIZE 山札の残りカード配列
				残り山札枚数 = RESULT:0

				IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_凍った目, "レア", 0)
					;凍った目なら何もしない
				ELSE
					;低レベルのうちはシャッフル
					FOR LCOUNT, 0, 残り山札枚数
						;「RANDで得られた数そのいち」番目と、「RANDで得られた数そのに」番目の内容を交換するのを繰り返す
						;まあ１番目はLCOUNTでいいか……
						シャッフルRAND1 = LCOUNT
						シャッフルRAND2 = RAND:残り山札枚数
						SWAP 山札の残りカード配列:シャッフルRAND1, 山札の残りカード配列:シャッフルRAND2
					NEXT
				ENDIF

				山札確認文言 '= ""
				BR判定 = 1
				;文字列にシュート
				FOR LCOUNT, 0, 残り山札枚数
					;カラなら次
					SIF 山札の残りカード配列:LCOUNT == ""
						CONTINUE

					加工文言 '= ""
					;まだ何もテキストが挿入されていないなら
					IF 山札確認文言 == ""
						;そのまま
					;改行直後であるなら
					ELSEIF BR判定 == 1
						;そのまま
					;そうでない場合（＝その行の項目が２個目以後の場合）
					ELSE
						;スペースを挟み、アビとアビの間を開ける
						加工文言 += "　"
					ENDIF

					;テキストを挿入
					加工文言 += @"%山札の残りカード配列:LCOUNT%"
					;「ツインストライク」など長い文言があるので半角にする
					加工文言 = %TOHALF(加工文言)%

					;項目を５個並べたら改行をシュートし判定をリセット
					IF BR判定 == 5
						加工文言 += "<br>"
						BR判定 = 0
					ENDIF

					山札確認文言 += 加工文言
					;挿入できたら挿入する判定をプラス
					BR判定 += 1
				NEXT
			ENDIF

			アビ汎用文字列:途中表示メッセージ１ = 山札に残っているカードは……
			アビ汎用文字列:途中表示メッセージ２ = %山札確認文言%
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_凍った目, "レア", 0)
				アビ汎用文字列:途中表示メッセージ３ = ……のようだ（順番通り表示）。
			ELSE
				アビ汎用文字列:途中表示メッセージ３ = ……のようだ（順番はランダム）。
			ENDIF

			;効果自体はなにもない。
			CALL アビテンプレート_何もしない
	ENDSELECT



@固有アビ_3337_12(呼び出し引数, キャラ番号)
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ

	;ポーションのハブになるスキル
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;レベル10未満の場合
	IF キャラレベル < K3337_固有アビ_習得Lv_ポーション
		;空っぽ！　にすると、初期状態で習得しない。
		アビ名 = 
	;非戦闘中＝ポーションを取得してない場合
	;現在ターン数は戦闘開始時には１になり、戦闘が終了するとゼロになる
	;なので戦闘状態にあるかどうかの判定に使えるはず……
	ELSEIF 現在ターン数 == 0
		アビ名 = スパイアのポーション
	;ポーションを取得している場合
	ELSE
		アビ名 = %K3337_ポーション_種類%
	ENDIF

	;消費MPは固定でゼロ
	消費ＭＰ = 0

	;カラか非戦闘中かの場合
	IF アビ名 == "" || アビ名 == "スパイアのポーション"
		SELECTCASE 呼び出し引数
			CASE "アビ名"
				TSTR:コマンド名受渡 = %アビ名%
			CASE "アビ説明文"
				詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
				詳細文文字列受け渡し変数 += @"<br>戦闘開始時、候補の中からランダムで特殊なポーション（＝固有アビリティ）を取得する。"
				詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
				詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない。"
				詳細文文字列受け渡し変数 += @"<br>ポーション候補は下記の通り。"
				IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポーション, "ポーション", 2)
					詳細文文字列受け渡し変数 += @"<br>・魔花のブラッドポーション：味方単体のHPを割合回復する。"
					詳細文文字列受け渡し変数 += @"<br>・ポーションっぽい岩：土属性の大ダメージを与える。"
					詳細文文字列受け渡し変数 += @"<br>・エリクサー：味方全体のデバフを[3]解除する。"
				ELSE
					詳細文文字列受け渡し変数 += @"<br>・ブラッドポーション：味方単体のHPを割合回復する。"
					詳細文文字列受け渡し変数 += @"<br>・ポーションっぽい石：土属性の中ダメージを与える。"
					詳細文文字列受け渡し変数 += @"<br>・アッシュウォーター：味方単体のデバフを[3]解除する。"
				ENDIF
				;説明文では消費ＭＰを返すよ
				RETURN 消費ＭＰ
			CASE "アビ効果"
				;解説のためだけのアビなので効果なし
				;まー一応ターンを消費しないフラグだけ立てておく
				アビテンプレート用_行動消費無しフラグ = 1

				;効果自体はなにもない。
				CALL アビテンプレート_何もしない
		ENDSELECT
	;戦闘中
	ELSE
		;ポーションを呼び出す
		TRYCALLFORM K3337_固有アビリティ_%K3337_ポーション_種類%(呼び出し引数, キャラ番号)
	ENDIF


@K3337_Battle_ポーションセット(キャラ番号)
#DIM キャラ番号
#DIM キャラレベル

	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;ポーションは配列に……まあ、してもいいんだけど、少なくともアイクラはポーションひとつの設計。
	IF 0
	;レベルが10未満だとポーションを持てない
	ELSEIF キャラレベル < K3337_固有アビ_習得Lv_ポーション
	;2ではアッシュウォーターって名前になっているが1では「エリクサー」。
	ELSEIF !RAND:3
		K3337_ポーション_種類 '= "アッシュウォーター"
	;ポーションっぽい石は別にアイクラ専用ではないが、「らしい」ので……
	ELSEIF !RAND:2
		K3337_ポーション_種類 '= "ポーションっぽい石"
	;こちらはアイクラ専用
	ELSE
		K3337_ポーション_種類 '= "ブラッドポーション"
	ENDIF

	RETURN 0




@K3337_固有アビリティ_ブラッドポーション(呼び出し引数, キャラ番号)
#DIMS 呼び出し引数
#DIM キャラ番号
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM キャラレベル

	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;Lv10から使用可能
	;対象のHPを20％回復。ノーコストでターン消費なし。
	;マルチプレイだと仲間にも使えるぜ！
	;アイクラの行動の中で唯一の回復・蘇生……「未だ倒れず」もまあいいけど……
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポーション, "ポーション", 2)
		アビ名 = 魔花のブラッドポーション
		威力値 = 40
	ELSE
		アビ名 = ブラッドポーション
		威力値 = 20
	ENDIF
	消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>味方単体に［対象の最大ＨＰ✕{威力値}％］のＨＰ回復を与える。"
			詳細文文字列受け渡し変数 += @"<br>対象を蘇生可能。"
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>味方単体に［対象の最大ＨＰ✕{威力値}％］のＨＰ回復を与える。"
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない。"
			;レリック：マジックフラワーをゲット！
			;……まあホントは回復量50％上昇だから30％回復なんだけどな。
			SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポーション, "ポーション", 2)
				詳細文文字列受け渡し変数 += @"<br>絶滅したと思われた花、レリック『マジックフラワー』の力により回復力を増した。"
		CASE "アビ効果"
			;ターン消費なし
			アビテンプレート用_行動消費無しフラグ = 1

			;対象は味方単体（死んでてもいい）
			CALL アビ対象選択テンプレート_味方単体

			;回復量は固定（乱数幅はゼロ）
			アビ汎用文字列:回復側使用能力値 = 回復対象_最大ＨＰ
			アビ汎用変数:効果割合 = 威力値
			アビ汎用変数:数値乱数幅 = 0

			;蘇生可能
			アビ汎用変数:蘇生可能オプション = 1

			;MAXでも回復できちゃうのは原作でも無駄遣い可能だから
			CALL アビテンプレート_回復処理_MAXでも回復

			;使用済みということで名前を変更
			K3337_ポーション_種類 '= "カラ"
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_ポーションっぽい石(呼び出し引数, キャラ番号)
#DIMS 呼び出し引数
#DIM キャラ番号
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM キャラレベル

	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;Lv10から使用可能
	;本当はアイクラ独自のポーションと言うわけでもないが……
	;毎戦闘ゲットできる追加ダメージでけっこう有能。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポーション, "ポーション", 2)
		アビ名 = ポーションっぽい岩
		威力値 = 250
	ELSE
		アビ名 = ポーションっぽい石
		威力値 = 150
	ENDIF
	消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の土属性のダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の土属性のダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない。"
			詳細文文字列受け渡し変数 += @"<br>レリック『石化したカエル』の力で得た、ポーション瓶っぽい形をした投げやすい岩。"
		CASE "アビ効果"
			;ターン消費なし
			アビテンプレート用_行動消費無しフラグ = 1

			;対象は敵単体
			CALL アビ対象選択テンプレート_敵単体
			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_土属性

			;使用済みということで名前を変更
			K3337_ポーション_種類 '= "カラ"

	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT


@K3337_固有アビリティ_アッシュウォーター(呼び出し引数, キャラ番号)
#DIMS 呼び出し引数
#DIM キャラ番号
#DIMS アビ名
#DIM 消費ＭＰ
#DIM キャラレベル
#DIM 回復回数

	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;Lv10から使用可能
	;手札の中の任意のカードを廃棄することができるポーション。
	;基本的には、弱いカードや、「状態異常」カードを廃棄するのに使用された。
	;……が、それはちょっと使いにくいので、デバフ効果を削除するようにする。
	;「負傷」カードを削除できないのは……まあ……山札や捨て札から削除してもいいけどねえ。まあええか……
	;/
	;1では「エリクサー」という名前で一切の回復効果がないので残念だったりしたもんだ。
	;2では「アッシュウォーター」という名前に変わっている。
	;多分同じもので、時代が進んで呼ばれ方が変わっただけって気はするんだけど……
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポーション, "ポーション", 2)
		アビ名 = エリクサー
	ELSE
		アビ名 = アッシュウォーター
	ENDIF
	回復回数 = 3
	消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポーション, "ポーション", 2)
				詳細文文字列受け渡し変数 += @"<br>味方全体に[{回復回数}]のデバフ消去を与える。"
			ELSE
				詳細文文字列受け渡し変数 += @"<br>味方単体に[{回復回数}]のデバフ消去を与える。"
			ENDIF
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポーション, "ポーション", 2)
				詳細文文字列受け渡し変数 += @"<br>味方全体に[{回復回数}]のデバフ消去を与える。"
			ELSE
				詳細文文字列受け渡し変数 += @"<br>味方単体に[{回復回数}]のデバフ消去を与える。"
			ENDIF
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない。"
			;……という設定はない。
			詳細文文字列受け渡し変数 += @"<br>レリック『カロンの遺灰』を溶かした液体。"
			詳細文文字列受け渡し変数 += @"<br>燃え盛る炎の中で、死と復活を永遠に繰り返す。"
		CASE "アビ効果"
			;ターン消費なし
			アビテンプレート用_行動消費無しフラグ = 1

			;対象は味方単体・全体
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポーション, "ポーション", 2)
				CALL アビ対象選択テンプレート_味方全体_生者のみ
			ELSE
				CALL アビ対象選択テンプレート_味方単体
			ENDIF

			;3回。ほんとはFORとかやった方がいい気がするけどこれでええやろ……
			CALL アビテンプレート_有利効果_デバフ消去()
			CALL アビテンプレート_有利効果_デバフ消去()
			CALL アビテンプレート_有利効果_デバフ消去()

			;使用済みということで名前を変更
			K3337_ポーション_種類 '= "カラ"

	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT




@K3337_固有アビリティ_カラ(呼び出し引数, キャラ番号)
#DIMS 呼び出し引数
#DIM キャラ番号
#DIMS アビ名
#DIM 消費ＭＰ

	;ポーションを使い切りました。
	アビ名 = （スパイアのポーション）
	消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>効果はない。"
			詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
			詳細文文字列受け渡し変数 += @"<br>ポーションは使い切った。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ効果"
			;ターン消費なし
			アビテンプレート用_行動消費無しフラグ = 1
			アビ汎用文字列:途中表示メッセージ１ = ポーションはすでに使ってしまった！

			;効果自体はなにもなし
			CALL アビテンプレート_何もしない

	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



;--------------------------------------------------
;戦闘能力の固有処理説明
;--------------------------------------------------
;口上と同じ感覚で使う為に書式を統一しているが、ステータス画面で表示されるので
;基本的にWAIT系列は使わないことを推奨
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3337(対象キャラ)
#DIM 対象キャラ
#DIM キャラレベル

	キャラレベル = 基礎BATTLE_STATE:対象キャラ:Lv

	CALL 口上変数初期化

	;この「スパイアの登頂者」はほかのスレスパ系キャラでも共通させたいところである
	;『アセンダー』とも表現されるが……
	KSTR:(K++) = □ 特性：『スパイアの登頂者』 □---------------------------------------------------------
	KSTR:(K++) = 　毎ターン、「デッキからカードをドロー」する。
	KSTR:(K++) = 　手札＝アビリティが毎ターン変化する。
	KSTR:(K++) = 　デッキに残っているカード（次のターンに引きうるカード）を確認することができる。
	IF キャラレベル >= K3337_固有アビ_習得Lv_ブラックブラッド
		KSTR:(K++) = 　
		KSTR:(K++) = □ 特性：『ブラックブラッド』 □---------------------------------------------------------
		KSTR:(K++) = 　戦闘中、自分の行動後、HPがわずかに回復する。
		KSTR:(K++) = 　アイアンクラッドの黒く怒りに燃える血が生命力を賦活する。
	ELSE
		KSTR:(K++) = 　
		KSTR:(K++) = □ 特性：『バーニングブラッド』 □-------------------------------------------------------
		KSTR:(K++) = 　戦闘中、自分の行動後、HPがわずかに回復する。
		KSTR:(K++) = 　アイアンクラッドの煮えたぎる血が生命力をもたらす。
	ENDIF
	IF キャラレベル >= K3337_固有アビ_習得Lv_ポーション
		KSTR:(K++) = 　
		KSTR:(K++) = □ 特性：『白き獣の像』 □---------------------------------------------------------------
		KSTR:(K++) = 　戦闘開始時、ランダムで固有のポーションを獲得し、自由に使うことができる。
		KSTR:(K++) = 　ポーションを獲得できるレリック、『白き獣の像』を所持しているようだ。
	ENDIF
	KSTR:(K++) = 　
	;ネタメモ：サイレントは「錬金術」、他キャラは「薬瓶のホルスター」や「繊細な葉」など、ポーション関連のレリックを持たせる

	CALL 口上変数表示(対象キャラ, 1)




@K3337_固有アビリティ_かがり火(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 高揚量

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;原作では、ターンごとのエナジーを１（２）増やす、というもの。
	;「行動回数を増やす」レベルの強力なバフだが、使用したターンに隙ができてしまい、若干使いにくく、使用したぶんの元を取るまで多少のターンがかかる。
	;MP回復……にしてもいいんだけど、あまりよくないな、とおもったので、高揚効果にする。
	;もちろん、踏み倒せれば効果は大きいぜ。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_かがり火, "レア", 2)
		アビ名 = かがり火UG+
		消費ＭＰ = 40
		高揚量 = 25
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_かがり火, "レア", 1)
		アビ名 = かがり火UG
		消費ＭＰ = 40
		高揚量 = 20
	ELSE
		アビ名 = かがり火
		消費ＭＰ = 40
		高揚量 = 15
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に［{高揚量}］（独自枠・永続・消去不可）の高揚効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない（使用すると廃棄される）。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に［{高揚量}］（独自枠・永続・消去不可）の高揚効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない（使用すると廃棄される）。"
		CASE "アビ効果"
			;特殊呼び出しは影響なし

			;対象は自分
			CALL アビ対象選択テンプレート_自己のみ

			;高揚を付与
			CALL アビ汎用変数文字列リセット
			アビ汎用変数:消去不可オプション = 1
			アビ汎用文字列:バフ・デバフ対象能力 = 高揚
			アビ汎用文字列:バフ・デバフ枠 = かがり火
			アビ汎用変数:効果量 = 高揚量
			アビ汎用変数:持続ターン = -1
			CALL アビテンプレート_有利効果_バフ効果セット

			;廃棄する（正確にはパワーなので廃棄とは違うんだけど）
			CALL K3337_Battle_廃棄登録(キャラ番号, K3337_固有アビ_かがり火, 1)

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_ヘル・レイザー(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;「ストライク」を自動発動する。
	;実はストライク率がそんなに高くないので、派手さと比べるとそんなに……
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ヘル・レイザー, "レア", 2)
		アビ名 = ヘル・レイザーUG+
		消費ＭＰ = 80
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ヘル・レイザー, "レア", 1)
		アビ名 = ヘル・レイザーUG
		消費ＭＰ = 90
	ELSE
		アビ名 = ヘル・レイザー
		消費ＭＰ = 100
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に永続・消去不可の[ヘル・レイザー]状態を付与する。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない（使用すると廃棄される）。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に永続・消去不可の[ヘル・レイザー]状態を付与する。"
			詳細文文字列受け渡し変数 += @"<br>＞「ストライク」と名の付くアビリティが通常使用不可になる"
			詳細文文字列受け渡し変数 += @"<br>＞ターン終了時、手札内の「ストライク」と名の付くアビリティを自動使用する"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない（使用すると廃棄される）。"
		CASE "アビ効果"
			;特殊呼び出しは影響なし

			;対象は自分
			CALL アビ対象選択テンプレート_自己のみ

			;ヘルレイザーバフそのものには効果がない
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = ヘル・レイザー
			アビ汎用文字列:バフ・デバフ対象能力 = ヘル・レイザー
			アビ汎用変数:効果量 = 0
			アビ汎用変数:持続ターン = -1
			アビ汎用変数:消去不可オプション = 1
			アビ汎用変数:特殊表示オプション = 1
			CALL アビテンプレート_有利効果_バフ効果セット

			;廃棄する（正確にはパワーなので廃棄とは違うんだけど）
			CALL K3337_Battle_廃棄登録(キャラ番号, K3337_固有アビ_ヘル・レイザー, 1)

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@固有行動直後処理_バフ・デバフ_ヘル・レイザー(効果番号)
#DIM 効果番号
#DIM キャラ番号
#DIMS 呼び出し引数
#DIMS 特殊呼び出し文
#DIMS アビ名
#DIM LCOUNT_手札番号
#DIM temp_手札番号
#DIMS ヘルレイザーズ

	;変数、定数の設定
	キャラ番号 = GETCHARA(3337)
	呼び出し引数 '= "アビ効果"
	ヘルレイザーズ '= ""

	;まず呼び出しテキストを作成
	;手札の走査：手札は10枚まで
	FOR LCOUNT_手札番号, 0, K3337_手札枚数限界
		;その手札番号がゼロなら＝手札にないなら
		IF K3337_手札:LCOUNT_手札番号 == 0
			;次の手札番号へ
			CONTINUE
		;以下、「ストライク」が手札にあればそれを発動する
		;いったん、「ストライク系なら何もせず次へ行く」処理
		ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_ストライク
		ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_ポンメルストライク
		ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_セットアップストライク
		ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_ツインストライク
		ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_パーフェクトストライク
		;「～ストライク」でなければ
		ELSE
			;次の手札番号へ
			CONTINUE
		ENDIF

		temp_手札番号 = LCOUNT_手札番号 + 1
		ヘルレイザーズ += K3337_Battle_手札名取得(キャラ番号, temp_手札番号) + "！　"
	NEXT

	;テキストが入ってきたら、手札にストライクがあると判断
	IF ヘルレイザーズ != ""
		アビ汎用文字列:途中表示メッセージ１ '= @"追撃、ヘル・レイザー！"
		;ここには「ストライクUG+！　ツインストライクUG！　パーフェクトストライク！　」……という具合で入ってくるはず。
		アビ汎用文字列:途中表示メッセージ２ '= @"%ヘルレイザーズ%"

		;アビリティの実発動
		;手札の走査：手札は10枚まで
		;もう一回回すのちょっとよくねえなとは思うよ
		FOR LCOUNT_手札番号, 0, K3337_手札枚数限界
			;その手札番号がゼロなら＝手札にないなら
			IF K3337_手札:LCOUNT_手札番号 == 0
				;何もしない
			;以下、「ストライク」が手札にあればそれを発動する
			;いったん、「ストライク系なら何もせず次へ行く」処理
			ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_ストライク
			ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_ポンメルストライク
			ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_セットアップストライク
			ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_ツインストライク
			ELSEIF K3337_手札:LCOUNT_手札番号 == K3337_固有アビ_パーフェクトストライク
			ELSE
				;「～ストライク」でなければ次の番号へ
				CONTINUE
			ENDIF

			;ヘルレイザーとして呼び出す
			;ただし、手札アビリティは1～10なので、LCOUNTは＋１で呼び出す
			特殊呼び出し文 '= "ヘル・レイザー"
			temp_手札番号 = LCOUNT_手札番号 + 1
			アビ名 '= K3337_Battle_手札名取得(キャラ番号, temp_手札番号)
			TRYCALLFORM K3337_固有アビリティ_%アビ名%(呼び出し引数, キャラ番号, temp_手札番号, 特殊呼び出し文)
		NEXT
	ENDIF




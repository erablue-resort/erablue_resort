;固有アビ11、12は固定なので下の方でね。



@K3337_Battle_手札(呼び出し引数, キャラ番号, 手札番号)
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM キャラレベル
#DIM 手札番号
#DIMS アビ名
#DIM 消費ＭＰ

	;消費MPは実際には呼び出し先のものになるが、ひとまずここではゼロにしておく
	消費ＭＰ = 0

	;現在ターン数は戦闘開始時には１になり、戦闘が終了するとゼロになる
	;なので戦闘状態にあるかどうかの判定に使えるはず……
	IF 現在ターン数 == 0
		SELECTCASE 呼び出し引数
			CASE "アビ名"
				IF 0
				ELSEIF 手札番号 == 1
					アビ名 '= @"「手札」"
				ELSEIF 手札番号 == 2
					アビ名 '= @"アタックカード1"
				ELSEIF 手札番号 == 3
					アビ名 '= @"アタックカード2"
				ELSEIF 手札番号 == 4
					アビ名 '= @"防御スキルカード1"
				ELSEIF 手札番号 == 5
					アビ名 '= @"特殊スキルカード"
				ELSEIF 手札番号 == 6
					アビ名 '= @"パワーカード"
				ELSEIF 手札番号 == 7
					アビ名 '= @"その他"
				ELSE
					アビ名 '= @"「手札」"
				ENDIF
				TSTR:コマンド名受渡 = %アビ名%

			CASE "アビ説明文"
				キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv
				IF 0
				ELSEIF 手札番号 == 1
					$K3337_バトルシステム_手札の説明
					詳細文文字列受け渡し変数 = 消費ＭＰ：？
					詳細文文字列受け渡し変数 += @"<br>アイアンクラッドの固有アビリティは、毎ターン「ドロー」され変化する…"
					詳細文文字列受け渡し変数 += @"<br>（各アビリティの概要については、アビリティ２以下の説明文を参照）"
					詳細文文字列受け渡し変数 += @"<br>レベルに応じてドローできるカード（固有アビリティ）の種類が増える。"
					詳細文文字列受け渡し変数 += @"<br>戦闘開始時「山札」が作られる。"
					詳細文文字列受け渡し変数 += @"<br>ターン開始時、山札から一定枚数（通常は５枚）のカードをドローする。"
					詳細文文字列受け渡し変数 += @"<br>手札は最大で10枚まで。"
					詳細文文字列受け渡し変数 += @"<br>ターン終了時、手札は捨て札に送られる。"
					詳細文文字列受け渡し変数 += @"<br>山札を引ききると、捨て札をシャッフルし、山札にする。"
				ELSEIF 手札番号 == 2
					詳細文文字列受け渡し変数 = アタックカード1：
					詳細文文字列受け渡し変数 += @"<br>いずれも自属性攻撃で、自身の攻撃力に依存する。"
					IF キャラレベル >= K3337_固有アビ_習得Lv_ストライク
						詳細文文字列受け渡し変数 += @"<br>・ストライク"
						詳細文文字列受け渡し変数 += @"<br>　小威力の単体攻撃。"
					ELSE
						;同じことを繰り返すだけなので関数にしちゃう
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_強打
						IF キャラレベル >= K3337_固有アビ_習得Lv_古代の牙
							詳細文文字列受け渡し変数 += @"<br>・破砕"
							詳細文文字列受け渡し変数 += @"<br>　特大威力の単体攻撃。防御デバフが付与される。"
						ELSE
							詳細文文字列受け渡し変数 += @"<br>・強打"
							詳細文文字列受け渡し変数 += @"<br>　中威力の単体攻撃。防御デバフが付与される。"
						ENDIF
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_ポンメルストライク
						詳細文文字列受け渡し変数 += @"<br>・ポンメルストライク"
						詳細文文字列受け渡し変数 += @"<br>　中威力の単体攻撃。"
						詳細文文字列受け渡し変数 += @"<br>　次のターン、ドローが１（２）枚増える（次ターン、アビリティが増える）。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_セットアップストライク
						詳細文文字列受け渡し変数 += @"<br>・セットアップストライク"
						詳細文文字列受け渡し変数 += @"<br>　小威力の単体攻撃。攻撃バフが付与される。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_アッパーカット
						詳細文文字列受け渡し変数 += @"<br>・アッパーカット"
						詳細文文字列受け渡し変数 += @"<br>　中威力の単体攻撃。攻防デバフを与える。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_ツインストライク
						詳細文文字列受け渡し変数 += @"<br>・ツインストライク"
						詳細文文字列受け渡し変数 += @"<br>　小威力×２回の単体攻撃。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF

				ELSEIF 手札番号 == 3
					詳細文文字列受け渡し変数 = アタックカード2：
					詳細文文字列受け渡し変数 += @"<br>いずれも自属性攻撃で、自身の攻撃力に依存する。"
					IF キャラレベル >= K3337_固有アビ_習得Lv_サンダークラップ
						詳細文文字列受け渡し変数 += @"<br>・サンダークラップ"
						詳細文文字列受け渡し変数 += @"<br>　小威力の全体攻撃。防御デバフを与える。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_ヘモキネシス
						詳細文文字列受け渡し変数 += @"<br>・ヘモキネシス"
						詳細文文字列受け渡し変数 += @"<br>　大威力の単体攻撃。MPのほか、HPを消費する。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_パーフェクトストライク
						詳細文文字列受け渡し変数 += @"<br>・パーフェクトストライク"
						詳細文文字列受け渡し変数 += @"<br>　中威力の単体攻撃。"
						詳細文文字列受け渡し変数 += @"<br>　手札にある「ストライク」と名のついたカードに応じてダメージが増加する。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_旋風刃
						詳細文文字列受け渡し変数 += @"<br>・旋風刃"
						詳細文文字列受け渡し変数 += @"<br>　中威力の全体攻撃。現在MP割合が大きいほど大ダメージ。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_脳天割り
						詳細文文字列受け渡し変数 += @"<br>・脳天割り"
						詳細文文字列受け渡し変数 += @"<br>　特大威力の単体攻撃。消費が重い。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_八つ裂き
						詳細文文字列受け渡し変数 += @"<br>・八つ裂き"
						詳細文文字列受け渡し変数 += @"<br>　小威力の単体攻撃。この戦闘で攻撃を受けた回数ぶん、追撃が発生する。"
						詳細文文字列受け渡し変数 += @"<br>　自身の固有アビリティでHPを失った際も追撃回数が増加する。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
				ELSEIF 手札番号 == 4
					詳細文文字列受け渡し変数 = 防御スキルカード：
					IF キャラレベル >= K3337_固有アビ_習得Lv_防御
						詳細文文字列受け渡し変数 += @"<br>・防御"
						詳細文文字列受け渡し変数 += @"<br>　自身に防御バフを与える。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_受け流し
						詳細文文字列受け渡し変数 += @"<br>・受け流し"
						詳細文文字列受け渡し変数 += @"<br>　自身に防御バフを与える。"
						詳細文文字列受け渡し変数 += @"<br>　次のターン、ドローが１（２）枚増える（次ターン、アビリティが増える）。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_武装
						詳細文文字列受け渡し変数 += @"<br>・武装"
						詳細文文字列受け渡し変数 += @"<br>　自身に累積する攻防バフを与える。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_やせ我慢
						詳細文文字列受け渡し変数 += @"<br>・やせ我慢"
						詳細文文字列受け渡し変数 += @"<br>　自身にバリアを与える。デッキに「負傷」カードを2枚混ぜる。"
						詳細文文字列受け渡し変数 += @"<br>　（負傷カードは効果のないペナルティアビリティ）"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_不動
						詳細文文字列受け渡し変数 += @"<br>・不動"
						詳細文文字列受け渡し変数 += @"<br>　自身に特大のバリアを与える。"
						詳細文文字列受け渡し変数 += @"<br>　１戦闘で１回しか使えない。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_セカンドウィンド
						詳細文文字列受け渡し変数 += @"<br>・セカンドウィンド"
						詳細文文字列受け渡し変数 += @"<br>　味方全体にバリアを与える。"
						詳細文文字列受け渡し変数 += @"<br>　バリアの強度は手札の「非アタックカード」の枚数に依存する。"
						詳細文文字列受け渡し変数 += @"<br>　カウントされたカードは廃棄される。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
				ELSEIF 手札番号 == 5
					詳細文文字列受け渡し変数 = 特殊スキルカード：
					IF キャラレベル >= K3337_固有アビ_習得Lv_バトルトランス
						詳細文文字列受け渡し変数 += @"<br>・バトルトランス"
						詳細文文字列受け渡し変数 += @"<br>　カードを３（４）枚引く（アビリティがドロー枚数分増える）。"
						詳細文文字列受け渡し変数 += @"<br>　ターンを消費しない。1ターンに1回しか使えない。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_カスケード
						詳細文文字列受け渡し変数 += @"<br>・カスケード"
						詳細文文字列受け渡し変数 += @"<br>　山札の上から３（４、６）枚のアビリティを即座に使用する。"
						詳細文文字列受け渡し変数 += @"<br>　カスケード以外のアビリティはＭＰを消費しない。"
						詳細文文字列受け渡し変数 += @"<br>　対象が必要な場合、ランダムで決定される。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
				ELSEIF 手札番号 == 6
					詳細文文字列受け渡し変数 = パワーカード：
					詳細文文字列受け渡し変数 += @"<br>いずれも１戦闘で１回しか使えず、自身に永続・消去不可のバフを与える。"
					IF キャラレベル >= K3337_固有アビ_習得Lv_悪魔化
						詳細文文字列受け渡し変数 += @"<br>・悪魔化"
						詳細文文字列受け渡し変数 += @"<br>　自身に「悪魔化」バフを付与する。"
						詳細文文字列受け渡し変数 += @"<br>　悪魔化：ターン開始時、自身に累積する攻撃バフを付与する状態。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_かがり火
						詳細文文字列受け渡し変数 += @"<br>・かがり火"
						詳細文文字列受け渡し変数 += @"<br>　自身に「かがり火」バフを付与する。"
						詳細文文字列受け渡し変数 += @"<br>　かがり火：ターン終了時、自身の奥技ゲージを増加する状態。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_真紅の衣
						詳細文文字列受け渡し変数 += @"<br>・真紅の衣"
						詳細文文字列受け渡し変数 += @"<br>　自身に「真紅の衣」バフを付与する。"
						詳細文文字列受け渡し変数 += @"<br>　真紅の衣：ターン開始時、自身のHPを一定割合消費し、それに応じた強度のバリアを得る状態。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
					IF キャラレベル >= K3337_固有アビ_習得Lv_ヘル・レイザー
						詳細文文字列受け渡し変数 += @"<br>・ヘル・レイザー"
						詳細文文字列受け渡し変数 += @"<br>　自身に「ヘル・レイザー」バフを付与する。"
						詳細文文字列受け渡し変数 += @"<br>　ヘル・レイザー：「ストライク」と名の付くアビリティが使えなくなる状態。"
						詳細文文字列受け渡し変数 += @"<br>　　ターン終了時、手札にある「ストライク」アビリティが、追撃としてすべて自動発動する。"
						詳細文文字列受け渡し変数 += @"<br>　　自動発動する「ストライク」アビリティはMPを消費しない。対象が必要な場合、ランダムで決定される。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF

				ELSEIF 手札番号 == 7
					詳細文文字列受け渡し変数 = その他：
					詳細文文字列受け渡し変数 += @"<br>戦闘中のみ生成されるなど、特殊なカード。"
					;やせ我慢の関連カードであるためやせ我慢を参照する
					IF キャラレベル >= K3337_固有アビ_習得Lv_やせ我慢
						詳細文文字列受け渡し変数 += @"<br>・負傷"
						詳細文文字列受け渡し変数 += @"<br>　効果なし。使用してもターンを消費しない。"
					ELSE
						CALL K3337_Battle_手札_未ピックテキスト()
					ENDIF
				ELSE
					GOTO K3337_バトルシステム_手札の説明
				ENDIF
				;説明文では消費ＭＰを返すよ
				RETURN 消費ＭＰ
			CASE "アビ効果"
				;解説のためだけのアビなので効果なし
				;以下おまじない

				;ターン消費なし
				アビテンプレート用_行動消費無しフラグ = 1
				;効果なし
				CALL アビテンプレート_何もしない

		ENDSELECT
	ELSE
		;名称を取得し、アビリティを発動する
		アビ名 '= K3337_Battle_手札名取得(キャラ番号, 手札番号)
		TRYCALLFORM K3337_固有アビリティ_%アビ名%(呼び出し引数, キャラ番号, 手札番号)
	ENDIF

	;通常はゼロが返る
	;ただし、呼び出し先で何らかの値（たとえば消費MP）を返してきた場合、それを返す
	;（そして帰った先でまた値を返すワケ）
	RETURN RESULT



@K3337_Battle_手札_未ピックテキスト()
	;同じことを繰り返すだけなので……
	詳細文文字列受け渡し変数 += @"<br>・？？？"
	詳細文文字列受け渡し変数 += @"<br>　まだこのカードはピックしていない……"



@K3337_固有アビリティ_ストライク(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;アビリティ名称について
	;基本名称「ストライク」
	;リゾートにおいてランクアップは通常「ストライク+」「ストライク++」になるが、スレスパはカードをアップグレードすることができ、「ストライク+」といった名称に変更される。
	;それだと、素と+の２段階しかないので、「UG」……「アップグレード」をつけることにする。
	IF 0
	;エンシェント強化アリ
	;消費がゼロになり、さらに行動消費もなくなる。消費ゼロがそこにまでかかるんですか？
	;まあ、ヘルレイザーがあるし、そもそも消費が安いので消費ゼロ・行動消費なしは美味しいのかというとぉ……
	;あと実はテスカタラ（栄養満点のスープ）とオロバス（古代の牙）は両立しないんだけど……
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_古代の牙, "エンシェント", 0)
		アビ名 = 残り火のストライク
		消費ＭＰ = 0
		威力値 = 150
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ストライク, "スターター", 2)
		アビ名 = ストライクUG+
		消費ＭＰ = 2
		威力値 = 130
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ストライク, "スターター", 1)
		アビ名 = ストライクUG
		消費ＭＰ = 2
		威力値 = 120
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ストライク, "スターター", 0)
		アビ名 = ストライク
		消費ＭＰ = 2
		威力値 = 110
;	ELSE
;		;空っぽ！　にすると、初期状態で習得しない
;		;……のだが、都合上、レベル制限は「デッキリスト」側でやるので、こちらでは無意味。
;		;以後のアビリティでは省略するね。
;		アビ名 = 
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	IF 特殊呼び出し != ""
		;消費MPはゼロに上書きしておく（必要ないらしいけど）（おまじない）
		消費ＭＰ = 0
		;おまじない
		アビテンプレート用_アビ封印用フラグ = 0
	;「ヘルレイザー」効果中は封印（使えてもいいんだけど無駄というかもったいないので）
	ELSEIF K3337_Battle_ヘルレイザーなう()
		;使用不可フラグを立てる
		;（「ヘルレイザーで呼び出された場合」は、上の特殊呼び出しに引っかかってここには来ないはずだな）
		アビテンプレート用_アビ封印用フラグ = 1
	ENDIF

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			;強化されていたら行動を消費しなくなる
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_古代の牙, "エンシェント", 0)
				詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
				詳細文文字列受け渡し変数 += @"<br>（使用後は捨て札に送られるため、同一ターンに複数回使用はできない）"
			ENDIF
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			;強化されていたら行動を消費しなくなる
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_古代の牙, "エンシェント", 0)
				詳細文文字列受け渡し変数 += @"<br>使用してもターンを消費しない。"
				詳細文文字列受け渡し変数 += @"<br>（使用後は捨て札に送られるため、同一ターンに複数回使用はできない）"
			ENDIF
			CALL K3337_Battle_ストライク_ヘルレイザー説明文(キャラレベル)
			;強化されていたらフレーバー追記
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_古代の牙, "エンシェント", 0)
				詳細文文字列受け渡し変数 += @"<br>エンシェント『テスカタラ』から授かったレリック『栄養満点のスープ』により、潰えぬ残り火の宿ったストライク。"
			ENDIF
		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;ヘルレイザーで呼び出されていた場合
			ELSEIF 特殊呼び出し == "ヘル・レイザー"
				;追撃で発動するのは「～ストライク」のみ
				;対象は選べない（原作再現）
				;まー本当は引いた時点で即座に使用されるんだけどそれは面倒ゆえ……
				;敵対心は……原作にはない要素だが、まあ影響されてええやろ
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;カスケードでも同様
			ELSEIF 特殊呼び出し == "カスケード"
				;カスケードは「段々になった滝」、転じて数珠つなぎとか連鎖とかそういう意味になったらしい。
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;通常
			ELSE
				;敵単体を選択
				CALL アビ対象選択テンプレート_敵単体

				;強化されていたら行動を消費しなくなる
				SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_古代の牙, "エンシェント", 0)
					アビテンプレート用_行動消費無しフラグ = 1
			ENDIF

			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_強打(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM 防御ダウン_効果割合
#DIM 防御ダウン_持続ターン
#DIM 防御ダウン_付与率

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;威力のわりに消費が重い、弱いアビリティとして設定（原作でもそう）
	;原作では超強力に変化するイベントがある
	;それまではかなり弱いカードなのだが、「コスト低下、防御ダウン持続２倍、威力が３倍になる」というすさまじいカードに化ける。
	;（防御ダウンは正確には「被ダメージ５０％アップ」だがその再現は難しいか）
	;……さすがにそれはまずいのでマイルドにはする。
	;ランダムドローであるのと合わせて、アイアンクラッドの固有アビ中最強のアビリティとして設定。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_古代の牙, "エンシェント", 2)
		アビ名 = 破砕UG+
		消費ＭＰ = 12
		威力値 = 340
		防御ダウン_効果割合 = 25
		防御ダウン_持続ターン = 7
		防御ダウン_付与率 = 100
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_古代の牙, "エンシェント", 0)
		アビ名 = 破砕
		消費ＭＰ = 12
		威力値 = 300
		防御ダウン_効果割合 = 25
		防御ダウン_持続ターン = 5
		防御ダウン_付与率 = 100
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_強打, "スターター", 2)
		アビ名 = 強打UG+
		消費ＭＰ = 25
		威力値 = 150
		防御ダウン_効果割合 = 20
		防御ダウン_持続ターン = 3
		防御ダウン_付与率 = 80
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_強打, "スターター", 1)
		アビ名 = 強打UG
		消費ＭＰ = 23
		威力値 = 140
		防御ダウン_効果割合 = 15
		防御ダウン_持続ターン = 3
		防御ダウン_付与率 = 80
	ELSE
		アビ名 = 強打
		消費ＭＰ = 20
		威力値 = 130
		防御ダウン_効果割合 = 15
		防御ダウン_持続ターン = 2
		防御ダウン_付与率 = 80
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>［{防御ダウン_効果割合}％］（A枠・{防御ダウン_持続ターン}ターン）の防御力減少効果を与える。成功率{防御ダウン_付与率}％。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>［{防御ダウン_効果割合}％］（A枠・{防御ダウン_持続ターン}ターン）の防御力減少効果を与える。成功率{防御ダウン_付与率}％。"
			;破砕に化けている場合はフレーバー文追加
			SIF キャラレベル >= K3337_固有アビ_習得Lv_古代の牙
				詳細文文字列受け渡し変数 += @"<br>エンシェント『オロバス』から授かったレリック『古代の牙』により、強打が昇格した破砕の一撃。"
		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;カスケード
			ELSEIF 特殊呼び出し == "カスケード"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;通常
			ELSE
				;敵単体を選択
				CALL アビ対象選択テンプレート_敵単体
			ENDIF

			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性

			;防御デバフ
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 防御力A
			アビ汎用文字列:バフ・デバフ対象能力 = 防御力
			アビ汎用変数:効果割合 = 防御ダウン_効果割合
			アビ汎用変数:持続ターン = 防御ダウン_持続ターン
			アビ汎用変数:基礎成功確率 = 防御ダウン_付与率
			CALL アビテンプレート_不利効果_デバフ効果セット

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_ポンメルストライク(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM 追加ドロー枚数

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;アイアンクラッドの誇る超優秀なカード
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポンメルストライク, "コモン", 2)
		アビ名 = ポンメルストライクUG+
		消費ＭＰ = 12
		威力値 = 160
		追加ドロー枚数 = 2
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ポンメルストライク, "コモン", 1)
		アビ名 = ポンメルストライクUG
		消費ＭＰ = 12
		威力値 = 150
		追加ドロー枚数 = 2
	ELSE
		アビ名 = ポンメルストライク
		消費ＭＰ = 10
		威力値 = 140
		追加ドロー枚数 = 1
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	IF 特殊呼び出し != ""
		消費ＭＰ = 0
		アビテンプレート用_アビ封印用フラグ = 0
	;「ヘルレイザー」効果中は封印
	ELSEIF K3337_Battle_ヘルレイザーなう()
		;使用不可フラグを立てる
		アビテンプレート用_アビ封印用フラグ = 1
	ENDIF

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>次のターン、ドローが{追加ドロー枚数}増える。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>次のターン、ドローが{追加ドロー枚数}枚増える。"
			詳細文文字列受け渡し変数 += @"<br>（次のターンのアビリティ枠数が増える）"
			CALL K3337_Battle_ストライク_ヘルレイザー説明文(キャラレベル)
		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;ヘルレイザーで呼び出された場合
			ELSEIF 特殊呼び出し == "ヘル・レイザー"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;カスケードで呼び出された場合
			ELSEIF 特殊呼び出し == "カスケード"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;通常
			ELSE
				;敵単体を選択
				CALL アビ対象選択テンプレート_敵単体
			ENDIF

			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性

			;ドロー枚数を増やす
			CALL K3337_Battle_ターン開始時ドロー増減処理(キャラ番号, 追加ドロー枚数)

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT




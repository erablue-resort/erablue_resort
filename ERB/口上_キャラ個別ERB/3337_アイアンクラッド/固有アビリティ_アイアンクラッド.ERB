@K3337_固有アビリティ_八つ裂き(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIM キャラ隊列位置
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM 追撃威力値
#DIM HP消費割合
#DIM LCOUNT

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;「特殊反応_被ダメ時_八つ裂き衝動」によって攻撃回数が増加する
	;ヘモキネシス、真紅の衣にも反応
	;連撃は今これを書いてる時点では最大20、威力50*20＝1000、というアホみたいな数字にはなるけど、20回殴られて、だからなあ。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_八つ裂き, "レア", 2)
		;イベント「シンビオート」で蝕みがエンチャントされた八つ裂き……という設定
		;追撃威力が爆増するがHPを消費
		アビ名 = 蝕まれし八つ裂き
		消費ＭＰ = 45
		威力値 = 50
		追撃威力値 = 50
		HP消費割合 = 20
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_八つ裂き, "レア", 1)
		アビ名 = 八つ裂きUG
		消費ＭＰ = 43
		威力値 = 50
		追撃威力値 = 35
		HP消費割合 = 0
	ELSE
		アビ名 = 八つ裂き
		消費ＭＰ = 40
		威力値 = 50
		追撃威力値 = 30
		HP消費割合 = 0
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>[八つ裂き衝動]のスタック数に応じた回数、［{追撃威力値}％］の自属性ダメージで追撃を行う。"
			;一定レベル以上だと追加文言
			SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_八つ裂き, "レア", 2)
				詳細文文字列受け渡し変数 += @"<br>攻撃後、最大HPの{HP消費割合}％のHPを失い、[八つ裂き衝動]が1スタック蓄積する。"
			詳細文文字列受け渡し変数 += @"<br>[八つ裂き衝動]現在値：{K3337_八つ裂きカウント}"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>[八つ裂き衝動]のスタック数に応じた回数、［{追撃威力値}％］の自属性ダメージで追撃を行う。"
			;一定レベル以上だと追加文言
			SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_八つ裂き, "レア", 2)
				詳細文文字列受け渡し変数 += @"<br>攻撃後、最大HPの{HP消費割合}％のHPを失い、[八つ裂き衝動]が1スタック蓄積する。"
			詳細文文字列受け渡し変数 += @"<br>[八つ裂き衝動]現在値：{K3337_八つ裂きカウント}"
			詳細文文字列受け渡し変数 += @"<br>　"
			詳細文文字列受け渡し変数 += @"<br>[八つ裂き衝動]のスタックは、攻撃を受けるか、HPを消費する固有アビリティを使用すると加算される。"
			SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_八つ裂き, "レア", 2)
				詳細文文字列受け渡し変数 += @"<br>時を経た肉塊によって蝕まれ、邪悪な力を付与された、八つ裂く怒り。"
		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;カスケードで呼び出された場合
			ELSEIF 特殊呼び出し == "カスケード"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;通常
			ELSE
				;敵単体を選択
				CALL アビ対象選択テンプレート_敵単体
			ENDIF

			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性

			;追撃。同じ敵へ連撃。
			IF K3337_八つ裂きカウント > 0
				アビ汎用変数:効果割合 = 追撃威力値
				FOR LCOUNT, 0, K3337_八つ裂きカウント
					CALL アビテンプレート_ダメージ処理_自属性
				NEXT
			ENDIF

			;蝕まれていたらHPを消費する
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_八つ裂き, "レア", 2)
				キャラ隊列位置 = キャラ隊列検索(キャラ番号)
				;殴った後で自身にダメージ
				BATTLE_STATE:キャラ隊列位置:ＨＰ -= BATTLE_STATE:キャラ隊列位置:最大ＨＰ * HP消費割合 / 100
				SIF BATTLE_STATE:キャラ隊列位置:ＨＰ < 0
					BATTLE_STATE:キャラ隊列位置:ＨＰ = 0
				;八つ裂き衝動をスタック
				CALL K3337_Battle_八つ裂きカウント加算()
			ENDIF

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT




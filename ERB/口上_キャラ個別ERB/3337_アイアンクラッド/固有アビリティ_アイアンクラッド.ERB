	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_武装(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 攻撃バフ_効果割合
#DIM 攻撃バフ_累積最大
#DIM 防御バフ_効果割合
#DIM 防御バフ_累積最大

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;原作だと、戦闘中、他のカードをパワーアップさせる……という効果だが、管理が難しい。
	;永続・累積の攻防バフを与える……って形にする。
	;基本的には消えないバフなんだけど、スレスパ2だと消してくるやつおるんよな……
	;永続だが消去不可は付けない。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_武装, "コモン", 2)
		アビ名 = 武装UG+
		消費ＭＰ = 12
		攻撃バフ_効果割合 = 7
		防御バフ_効果割合 = 7
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_武装, "コモン", 1)
		アビ名 = 武装UG
		消費ＭＰ = 12
		攻撃バフ_効果割合 = 5
		防御バフ_効果割合 = 5
	ELSE
		アビ名 = 武装
		消費ＭＰ = 12
		攻撃バフ_効果割合 = 3
		防御バフ_効果割合 = 3
	ENDIF
	攻撃バフ_累積最大 = 30
	防御バフ_累積最大 = 30

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に、［累積{攻撃バフ_効果割合}％/最大{攻撃バフ_累積最大}％］（累積枠・永続）の攻撃力上昇効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>自身に、［累積{防御バフ_効果割合}％/最大{防御バフ_累積最大}％］（累積枠・永続）の防御力上昇効果を与える。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に、［累積{攻撃バフ_効果割合}％/最大{攻撃バフ_累積最大}％］（累積枠・永続）の攻撃力上昇効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>自身に、［累積{防御バフ_効果割合}％/最大{防御バフ_累積最大}％］（累積枠・永続）の防御力上昇効果を与える。"
		CASE "アビ効果"
			;特殊呼び出しは影響なし

			;対象は自分だけ
			CALL アビ対象選択テンプレート_自己のみ

			;攻撃
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 攻撃力_累積枠
			アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
			アビ汎用変数:効果割合 = 攻撃バフ_効果割合
			アビ汎用変数:累積上限_割合 = 攻撃バフ_累積最大
			アビ汎用変数:持続ターン = -1
			CALL アビテンプレート_有利効果_累積バフ効果セット

			;防御
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 防御力_累積枠
			アビ汎用文字列:バフ・デバフ対象能力 = 防御力
			アビ汎用変数:効果割合 = 防御バフ_効果割合
			アビ汎用変数:累積上限_割合 = 防御バフ_累積最大
			アビ汎用変数:持続ターン = -1
			CALL アビテンプレート_有利効果_累積バフ効果セット

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_やせ我慢(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM バリア_効果割合
#DIM バリア_持続ターン
#DIM 算出回復力

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;返して……
	;……「負傷」を混ぜる代わりに、強力なブロックを張るカード。
	;ここでは差別化のためバリアを付与する。
	;本来は手札に負傷を生成するが、捨て札に（正確には次回のシャッフルで）負傷を混ぜることにする。
	;スレスパ2では削除されてしまった……
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_やせ我慢, "コモン", 2)
		アビ名 = やせ我慢UG+
		消費ＭＰ = 12
		バリア_効果割合 = 180
		バリア_持続ターン = 2
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_やせ我慢, "コモン", 1)
		アビ名 = やせ我慢UG
		消費ＭＰ = 12
		バリア_効果割合 = 160
		バリア_持続ターン = 2
	ELSE
		アビ名 = やせ我慢
		消費ＭＰ = 12
		バリア_効果割合 = 150
		バリア_持続ターン = 2
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に[回復力✕{バリア_効果割合}％]（通常枠・{バリア_持続ターン}ターン）のバリア効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>捨て札に「負傷」カードを2枚混ぜる。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に[回復力✕{バリア_効果割合}％]（通常枠・{バリア_持続ターン}ターン）のバリア効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>捨て札に「負傷」カードを2枚混ぜる。"
			詳細文文字列受け渡し変数 += @"<br>（次のシャッフル時から、効果のない固有アビリティ「負傷」が2枚、追加で山札に混ぜられる）"
		CASE "アビ効果"
			;特殊呼び出しは影響なし

			;対象は自分だけ
			CALL アビ対象選択テンプレート_自己のみ

			;バリア数値は回復力に依存
			CALL バフ込み数値算出("回復力")
			算出回復力 = RESULT

			;バリア発生
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = バリア
			アビ汎用文字列:バフ・デバフ対象能力 = バリア
			アビ汎用変数:効果量 = 算出回復力 * バリア_効果割合 / 100
			アビ汎用変数:持続ターン = バリア_持続ターン
			CALL アビテンプレート_有利効果_バフ効果セット

			;負傷2枚を追加カードにセット
			CALL K3337_Battle_追加カード登録(キャラ番号, K3337_固有アビ_負傷, 2)

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_不動(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")

@K3337_固有アビリティ_セカンドウィンド(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM バリア_効果割合
#DIM バリア_持続ターン
#DIM 算出回復力
#DIM バリア強度
#DIM LCOUNT
#DIM バリア強度_カスケード時

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;原作では「手札のアタック以外のカードを廃棄し、その枚数だけバリアを張る」というカード。
	;こちらでも同様のことをする。
	;他防御系固有アビとの差別化として、バリアは全体化する。
	;やせ我慢と相性が特に良いわけではないのは申し訳ないところ。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_セカンドウィンド, "アンコモン", 2)
		アビ名 = セカンドウィンドUG+
		消費ＭＰ = 15
		バリア_効果割合 = 70
		バリア_持続ターン = 2
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_セカンドウィンド, "アンコモン", 1)
		アビ名 = セカンドウィンドUG
		消費ＭＰ = 12
		バリア_効果割合 = 60
		バリア_持続ターン = 2
	ELSE
		アビ名 = セカンドウィンド
		消費ＭＰ = 10
		バリア_効果割合 = 50
		バリア_持続ターン = 2
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0
	
	バリア強度_カスケード時 = 3

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>味方全体に[回復力✕{バリア_効果割合}％✕強度＋１]（通常枠・{バリア_持続ターン}ターン）のバリア効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>[強度]は、手札内の「アタックでないカード」の枚数から１を引いた数と等しい倍率となる。"
			詳細文文字列受け渡し変数 += @"<br>カウント対象のカードは廃棄される（戦闘中使用不可になる）。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>味方全体に[回復力✕{バリア_効果割合}％✕強度＋１]（通常枠・{バリア_持続ターン}ターン）のバリア効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>[強度]は、手札内の「アタックでないカード」の枚数から１を引いた数と等しい倍率となる。"
			詳細文文字列受け渡し変数 += @"<br>（セカンドウィンド自体はカウント対象外であるため、１引いた数となる）"
			詳細文文字列受け渡し変数 += @"<br>カウント対象のカードは廃棄される（戦闘中使用不可になる）。"
			SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_カスケード, "レア", 0)
				詳細文文字列受け渡し変数 += @"<br>固有アビリティ「カスケード」で使用された場合、カードは廃棄されず、強度は{バリア強度_カスケード時}倍固定になる。"
		CASE "アビ効果"
			;対象は味方全体
			CALL アビ対象選択テンプレート_味方全体_生者のみ

			;バリア数値は回復力に依存
			CALL バフ込み数値算出("回復力")
			算出回復力 = RESULT

			;バリア強度の算出＆廃棄

			バリア強度 = 0
			;カスケードでの使用時は、仕様上ちょっとめんどいので固定かつ廃棄されない
			;（デメリット効果を勝手に使われたらしんどいしね）
			;（まあHP減少系効果は発動しちゃうんだけど）
			IF 特殊呼び出し == "カスケード"
				バリア強度 = バリア強度_カスケード時
			;通常
			ELSE
				;手札をチェック
				;手札は10枚まで
				FOR LCOUNT, 0, K3337_手札枚数限界
					;その手札番号がゼロなら＝カラなら
					IF K3337_手札:LCOUNT == 0
						;なにもしない
					;対象がこのカード自身であるなら
					ELSEIF K3337_手札:LCOUNT == K3337_固有アビ_セカンドウィンド
						;なにもしない
					;対象がアタックであるなら
					ELSEIF K3337_Battle_IS_アタック(K3337_手札:LCOUNT)
						;なにもしない
					;非アタックなら
					ELSE
						;バリア強度をプラス
						バリア強度 += 1
						;そのカードを廃棄
						CALL K3337_Battle_廃棄登録(キャラ番号, K3337_手札:LCOUNT, 1)
					ENDIF
				NEXT
			ENDIF

			;バリア発生
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = バリア
			アビ汎用文字列:バフ・デバフ対象能力 = バリア
			;回復力×バリア効果割合×強度+1（一応ゼロにはならないようにしておくね）
			アビ汎用変数:効果量 = 算出回復力 * バリア_効果割合 / 100 * バリア強度 + 1
			アビ汎用変数:持続ターン = バリア_持続ターン
			CALL アビテンプレート_有利効果_バフ効果セット

	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_バトルトランス(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM ドロー枚数
#DIM LCOUNT

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;即座に3(4)枚ドローする。
	;その都合上、使用してもターンを消費しない。
	;このターン１回以上使用していたら効果が無効化される。
	;本来は無消費だが、さすがにそれは使い得すぎるので、ある程度MP消費させる。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_バトルトランス, "アンコモン", 2)
		アビ名 = バトルトランスUG+
		消費ＭＰ = 30
		ドロー枚数 = 4
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_バトルトランス, "アンコモン", 1)
		アビ名 = バトルトランスUG
		消費ＭＰ = 30
		ドロー枚数 = 3
	ELSE
		アビ名 = バトルトランス
		消費ＭＰ = 40
		ドロー枚数 = 3
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0


	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>即座にカードを{ドロー枚数}枚ドローする（固有アビリティを増やす）。"
			詳細文文字列受け渡し変数 += @"<br>使用後、このアビリティは捨て札に送られる（固有アビリティ欄から削除される）。"
			詳細文文字列受け渡し変数 += @"<br>このアビリティでは行動回数を消費しない。"
			詳細文文字列受け渡し変数 += @"<br>このアビリティは同一ターンに複数回使っても効果を発揮しない（MPは消費する）"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>即座にカードを{ドロー枚数}枚ドローする（固有アビリティを増やす）。"
			詳細文文字列受け渡し変数 += @"<br>使用後、このアビリティは捨て札に送られる（固有アビリティ欄から削除される）。"
			詳細文文字列受け渡し変数 += @"<br>このアビリティでは行動回数を消費しない。"
			詳細文文字列受け渡し変数 += @"<br>このアビリティは同一ターンに複数回使っても効果を発揮しない（MPは消費する）"
			;カスケード習得済みなら注釈
			IF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_カスケード, "レア", 0)
				詳細文文字列受け渡し変数 += @"<br>固有アビリティ「カスケード」で使用された場合、次のターン、ドローが{ドロー枚数}枚増える。"
				詳細文文字列受け渡し変数 += @"<br>（次のターンのアビリティ枠数が増える）"
			ENDIF
		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;すでにこのターンバットラを使っていた場合
			ELSEIF K3337_バトルトランス使用制限 > 0
				;効果なし。使用制限。

				;カスケード中でなければ追加文言
				SIF 特殊呼び出し != "カスケード"
					アビ汎用文字列:途中表示メッセージ１ = すでにこのターン、バトルトランスを発動している！

			;カスケード
			ELSEIF 特殊呼び出し == "カスケード"
				;……カスケードで面倒なことになりそうなので、カスケードでは効果を変更する。
				;（カスケードそのものには干渉しないが、ヘル・レイザーに影響する場合がある）
				;次ターンのドロー枚数を増やす
				CALL K3337_Battle_ターン開始時ドロー増減処理(キャラ番号, ドロー枚数)
			;通常
			ELSE
				;行動を消費しない
				アビテンプレート用_行動消費無しフラグ = 1
				;対象は自分だけ……つって、まあバフ効果もないんだが。
				CALL アビ対象選択テンプレート_自己のみ

				アビ汎用文字列:途中表示メッセージ１ = バトルトランス、ドロー！

				;カードをドロー
				CALL K3337_Battle_カードドロー(キャラ番号, ドロー枚数)
			ENDIF

			;使用回数＋１
			K3337_バトルトランス使用制限 += 1

			;一般的な効果自体はなにもなし
			CALL アビテンプレート_何もしない

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_カスケード(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM ドロー枚数
#DIM LCOUNT
#DIMS カスケードアビ名
#DIM 山札枚数
#DIM temp_手札番号

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;X枚デッキをめくってそれを全部ノーコストで使う……というオマツリなカード
	;疑似的なX回行動でコストも踏み倒されるという強力さ。
	;……しかし、対象はランダムだし、発動してほしくない・しても意味がないものが選出されることもあるのであんまり安定しない。
	;/
	;アイクラの最大の大技として設定。
	;挙動は、「手札をすべて捨てる→X枚ドロー→手札を全部使う」
	;この都合で他のアビリティに色々干渉する。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_カスケード, "レア", 2)
		アビ名 = カスケードUG+CX
		消費ＭＰ = 300
		ドロー枚数 = 6
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_カスケード, "レア", 1)
		アビ名 = カスケードUG
		消費ＭＰ = 300
		ドロー枚数 = 4
	ELSE
		アビ名 = カスケード
		消費ＭＰ = 300
		ドロー枚数 = 3
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>山札の上から{ドロー枚数}枚を即座に使用する。"
			詳細文文字列受け渡し変数 += @"<br>その際、MPは消費されない。対象選出が必要な場合、対象はランダムになる。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>山札の上から{ドロー枚数}枚を即座に使用する。"
			詳細文文字列受け渡し変数 += @"<br>その際、MPは消費されない。対象選出が必要な場合、対象はランダムになる。"
			詳細文文字列受け渡し変数 += @"<br>手札に応じた効果のあるアビリティは効果値が固定される。"
			;追撃は発動させない。さすがにやばすぎるため。原作ではするけど……
			SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ヘル・レイザー, "レア", 0)
				詳細文文字列受け渡し変数 += @"<br>発動したターン、ヘル・レイザー状態によるストライクの追撃は発動しない。"
			;ケミカルXになってたらフレーバー文言追加
			SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_カスケード, "レア", 2)
				詳細文文字列受け渡し変数 += @"<br>砂糖やスパイス、その他美味しい物体に、『ケミカルX』が混入してしまったようだ。"
		CASE "アビ効果"

			;カスケード専用の仮領域に、特殊なドローを行う。
			;この配列：カスケードドローと、変数：カスケードドロー済み枚数は、ターン開始時にリセットする
			;（カスケード中にカスケードが発動してもいいように）（廃棄しまくったり、将来的にデッキをスリム化したりで「やれる」可能性があるため）
			;一応要素数は100確保してるので配列的には大丈夫だと思う……が、発動数に限界は与える

			;バランス上の問題で、手札全てを捨て札に送る……ヘルレイザーは発動すんなよ！
			FOR LCOUNT, 0, K3337_手札枚数限界
				;手札の番号をゼロにする＝カラにする
				K3337_手札:LCOUNT = 0
			NEXT

			;発動限界として、90枚時点でのドローまで＝96枚までとする
			IF 91 > K3337_カスケードドロー済み枚数
				;カスケードドロー……カスケード配列にカードをin！
				FOR LCOUNT, 0, ドロー枚数
					;山札がまだ残っているかを確認
					VARSIZE K3337_山札
					山札枚数 = RESULT:0

					;山札にカードが残っていなかったらシャッフル処理
					;残っていない判定は「山札枚数以上に引いた」または「ゼロが入ってきた」場合
					;多分運用上ゼロが入ってきたときだけになる気がするな……
					;/
					;1枚のカスケードでは1回だけしかシャッフルされないが、そこまで再現するのは厳しいため……
					IF (K3337_山札何枚引いたかな > 山札枚数) || (K3337_山札:K3337_山札何枚引いたかな == 0)
						CALL K3337_Battle_デッキシャッフル(キャラ番号)
					ENDIF

					;カスケード配列のX番目に山札のY番目のカードを加え、XとYを+1
					K3337_カスケードドロー:K3337_カスケードドロー済み枚数 = K3337_山札:K3337_山札何枚引いたかな
					K3337_山札何枚引いたかな += 1
					K3337_カスケードドロー済み枚数 += 1
				NEXT
			ENDIF

			;特殊呼び出し：カスケード中なら
			IF 特殊呼び出し == "カスケード"
				;カスケード中に呼び出した場合はドローだけで終了
				;カスケードは本来連鎖が強いんだがシステムの都合でちょっと違う形になる
				;本当はカスケードが2枚以上ないと起こらないけど許してくれ

			;特殊呼び出し中でなければ
			ELSE
				;カスケードの発動処理を行う
				VARSIZE K3337_カスケードドロー
				山札枚数 = RESULT:0

				;まだカラならメッセージを入れる
				;連鎖で発動した場合は「さらに連鎖！」で済ませる
				IF アビ汎用文字列:途中表示メッセージ１ == ""
					アビ汎用文字列:途中表示メッセージ１ = 連鎖、カスケード・ドロー！

					;メッセージの作成のため初期化
					アビ汎用文字列:途中表示メッセージ２ '= ""
					アビ汎用文字列:途中表示メッセージ３ '= ""

					;メッセージを制作、都合上１回目のカスケードでのみ作成される
					FOR LCOUNT, 0, 山札枚数
						カスケードアビ名 '= K3337_Battle_手札名取得(キャラ番号, LCOUNT, "カスケード")

						;対象がカスケードだったらば、メッセージ３に「さらに連鎖！」を入れる
						SIF カスケードアビ名 == "カスケード"
							アビ汎用文字列:途中表示メッセージ３ = さらに連鎖！　カスケード！
						;アビ名が取得できたらば
						SIF カスケードアビ名 != ""
							アビ汎用文字列:途中表示メッセージ２ += カスケードアビ名 + "！　"
					NEXT
				ENDIF

				;手札番号は何番でもいいが１にしておく
				手札番号 = 1

				;アビリティ群の発動
				FOR LCOUNT, 0, 山札枚数
					;カラなら抜ける
					IF K3337_カスケードドロー:LCOUNT == 0
						BREAK
					;ドローしたアビリティを「カスケード呼び出し」する
					ELSE
						;アビリティ名を取得
						カスケードアビ名 '= K3337_Battle_手札名取得(キャラ番号, LCOUNT, "カスケード")
						;カスケードとして呼び出し
						TRYCALLFORM K3337_固有アビリティ_%カスケードアビ名%("アビ効果", キャラ番号, 手札番号, "カスケード")
					ENDIF
				NEXT
			ENDIF

			;一般的・定型的なえらぶるリゾート内の効果はない
			CALL アビテンプレート_何もしない

			;最初に手札をすべて捨ててるのでこれはいい
;			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_悪魔化(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 悪魔化筋力

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;自身に「攻撃力が累積で上昇し続ける」効果を付与する。
	;バフのターン開始時効果なので、この固有アビ自体はあまり意味がない。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_悪魔化, "レア", 2)
		アビ名 = 悪魔化UG+
		消費ＭＰ = 40
		悪魔化筋力 = K3337_固有アビ_悪魔化_累積値3
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_悪魔化, "レア", 1)
		アビ名 = 悪魔化UG
		消費ＭＰ = 40
		悪魔化筋力 = K3337_固有アビ_悪魔化_累積値2
	ELSE
		アビ名 = 悪魔化
		消費ＭＰ = 40
		悪魔化筋力 = K3337_固有アビ_悪魔化_累積値1
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に永続・消去不可の[悪魔化]状態を付与する。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない（使用すると廃棄される）。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に永続・消去不可の[悪魔化]状態を付与する。"
			詳細文文字列受け渡し変数 += @"<br>＞ターン開始時、自身に［累積{悪魔化筋力}％/最大{K3337_固有アビ_悪魔化_累積限界}％］（累積枠・永続・消去不可）の攻撃力上昇効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない（使用すると廃棄される）。"
		CASE "アビ効果"
			;特殊呼び出しは影響なし

			;対象は自分
			CALL アビ対象選択テンプレート_自己のみ

			;悪魔化バフそのものには効果がない
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 悪魔化
			アビ汎用文字列:バフ・デバフ対象能力 = 悪魔化
			アビ汎用変数:効果量 = 0
			アビ汎用変数:持続ターン = -1
			アビ汎用変数:消去不可オプション = 1
			アビ汎用変数:特殊表示オプション = 1
			CALL アビテンプレート_有利効果_バフ効果セット

			;廃棄する（正確にはパワーなので廃棄とは違うんだけど）
			CALL K3337_Battle_廃棄登録(キャラ番号, K3337_固有アビ_悪魔化, 1)

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@バフ・デバフ特殊表示_悪魔化(隊列番号, バフ・デバフ行数)
#DIM 隊列番号
#DIM バフ・デバフ行数
#DIM キャラ番号

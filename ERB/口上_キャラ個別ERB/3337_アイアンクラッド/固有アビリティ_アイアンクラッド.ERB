			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に[回復力✕{バリア_効果割合}％]（通常枠・{バリア_持続ターン}ターン）のバリア効果を与える。"

@K3337_固有アビリティ_真紅の衣(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM バリア強度
#DIM バリア持続

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;HPを若干失う代わりにバリアを張る
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_真紅の衣, "レア", 2)
		アビ名 = 真紅の衣UG+
		消費ＭＰ = 50
		バリア強度 = K3337_固有アビ_真紅の衣_バリア値3
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_真紅の衣, "レア", 1)
		アビ名 = 真紅の衣UG
		消費ＭＰ = 50
		バリア強度 = K3337_固有アビ_真紅の衣_バリア値2
	ELSE
		アビ名 = 真紅の衣
		消費ＭＰ = 50
		バリア強度 = K3337_固有アビ_真紅の衣_バリア値1
	ENDIF

	バリア持続 = 1

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に永続・消去不可の[真紅の衣]状態を付与する。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない（使用すると廃棄される）。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>自身に永続・消去不可の[真紅の衣]状態を付与する。"
			詳細文文字列受け渡し変数 += @"<br>＞ターン開始時、最大HPの{K3337_固有アビ_真紅の衣_消費HP割合}％のHPを失う。"
			詳細文文字列受け渡し変数 += @"<br>＞ターン開始時、自身に[HP消費量✕{バリア強度}％]（通常枠・{バリア持続}ターン）のバリア効果を与える。"
			;自傷ダメージなので八つ裂きがちょっと蓄積
			SIF キャラレベル >= K3337_固有アビ_習得Lv_八つ裂き
				詳細文文字列受け渡し変数 += @"<br>使用時、[八つ裂き衝動]が1スタック蓄積する。"
			詳細文文字列受け渡し変数 += @"<br>戦闘中1回しか使用できない（使用すると廃棄される）。"
		CASE "アビ効果"
			;特殊呼び出しは影響なし

			;対象は自分
			CALL アビ対象選択テンプレート_自己のみ

			;真紅の衣バフそのものには効果がない
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 真紅の衣
			アビ汎用文字列:バフ・デバフ対象能力 = 真紅の衣
			アビ汎用変数:効果量 = 0
			アビ汎用変数:持続ターン = -1
			アビ汎用変数:消去不可オプション = 1
			アビ汎用変数:特殊表示オプション = 1
			CALL アビテンプレート_有利効果_バフ効果セット

			;廃棄する（正確にはパワーなので廃棄とは違うんだけど）
			CALL K3337_Battle_廃棄登録(キャラ番号, K3337_固有アビ_真紅の衣, 1)

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT




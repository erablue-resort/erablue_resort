			アビ汎用変数:持続ターン = 攻防ダウン_持続ターン
			アビ汎用変数:基礎成功確率 = 攻防ダウン_付与率
			CALL アビテンプレート_不利効果_デバフ効果セット

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_ツインストライク(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM 攻撃回数

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;2連撃。ストライクの倍は強いが普通。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ツインストライク, "コモン", 2)
		アビ名 = ツインストライクUG+
		消費ＭＰ = 12
		威力値 = 100
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ツインストライク, "コモン", 1)
		アビ名 = ツインストライクUG
		消費ＭＰ = 12
		威力値 = 90
	ELSE
		アビ名 = ツインストライク
		消費ＭＰ = 10
		威力値 = 80
	ENDIF

	;ランクアップしても固定でええか、ソードブーメランとかになるのも違うし……
	攻撃回数 = 2

	;何らかの特殊呼び出しを受けている場合
	IF 特殊呼び出し != ""
		消費ＭＰ = 0
		アビテンプレート用_アビ封印用フラグ = 0
	;「ヘルレイザー」効果中は封印
	ELSEIF K3337_Battle_ヘルレイザーなう()
		;使用不可フラグを立てる
		アビテンプレート用_アビ封印用フラグ = 1
	ENDIF

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを{攻撃回数}回与える。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを{攻撃回数}回与える。"
			CALL K3337_Battle_ストライク_ヘルレイザー説明文(キャラレベル)
		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;ヘルレイザーで呼び出された場合
			ELSEIF 特殊呼び出し == "ヘル・レイザー"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;カスケードで呼び出された場合
			ELSEIF 特殊呼び出し == "カスケード"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;通常
			ELSE
				;敵単体を選択
				CALL アビ対象選択テンプレート_敵単体
			ENDIF

			アビ汎用変数:効果割合 = 威力値
			;2回攻撃……まあこれでええか！
			CALL アビテンプレート_ダメージ処理_自属性
			CALL アビテンプレート_ダメージ処理_自属性

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_サンダークラップ(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM 防御ダウン_効果割合
#DIM 防御ダウン_持続ターン
#DIM 防御ダウン_付与率

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;低威力・低消費の全体攻撃。防御をダウンさせる。
	;原作では、強打やアッパーカットと同じ防御ダウン枠で、これを打てば延長できるんだけど……
	;こちらではその仕様は面倒なわりに使いづらいので、B枠で重ね掛けができるように。
	;ただし効果ターンは短い。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_サンダークラップ, "コモン", 2)
		アビ名 = サンダークラップUG+
		消費ＭＰ = 20
		威力値 = 150
		防御ダウン_効果割合 = 20
		防御ダウン_持続ターン = 2
		防御ダウン_付与率 = 100
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_サンダークラップ, "コモン", 1)
		アビ名 = サンダークラップUG
		消費ＭＰ = 16
		威力値 = 140
		防御ダウン_効果割合 = 20
		防御ダウン_持続ターン = 2
		防御ダウン_付与率 = 80
	ELSE
		アビ名 = サンダークラップ
		消費ＭＰ = 14
		威力値 = 130
		防御ダウン_効果割合 = 15
		防御ダウン_持続ターン = 2
		防御ダウン_付与率 = 80
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>［{防御ダウン_効果割合}％］（B枠・{防御ダウン_持続ターン}ターン）の防御力減少効果を与える。成功率{防御ダウン_付与率}％。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>［{防御ダウン_効果割合}％］（B枠・{防御ダウン_持続ターン}ターン）の防御力減少効果を与える。成功率{防御ダウン_付与率}％。"
		CASE "アビ効果"
			;特殊呼び出し
			;カスケードで呼んでも全体なのでターゲット選択はカット

			CALL アビ対象選択テンプレート_敵全体_生者のみ

			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性

			;防御デバフ
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 防御力B
			アビ汎用文字列:バフ・デバフ対象能力 = 防御力
			アビ汎用変数:効果割合 = 防御ダウン_効果割合
			アビ汎用変数:持続ターン = 防御ダウン_持続ターン
			アビ汎用変数:基礎成功確率 = 防御ダウン_付与率
			CALL アビテンプレート_不利効果_デバフ効果セット

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_ヘモキネシス(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIM キャラ隊列位置
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM HP消費割合

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;HPを消費する代わりに消費が低く、高火力。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ヘモキネシス, "アンコモン", 2)
		アビ名 = ヘモキネシスUG+
		消費ＭＰ = 6
		威力値 = 250
		HP消費割合 = 10
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_ヘモキネシス, "アンコモン", 1)
		アビ名 = ヘモキネシスUG
		消費ＭＰ = 6
		威力値 = 225
		HP消費割合 = 10
	ELSE
		アビ名 = ヘモキネシス
		消費ＭＰ = 5
		威力値 = 200
		HP消費割合 = 10
	ENDIF

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ} ＋ 消費ＨＰ：最大ＨＰの{HP消費割合}％
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>使用時、最大HPの{HP消費割合}％のHPを失う。"
			;自傷ダメージなので八つ裂きがちょっと蓄積
			SIF キャラレベル >= K3337_固有アビ_習得Lv_八つ裂き
				詳細文文字列受け渡し変数 += @"<br>使用時、[八つ裂き衝動]が1スタック蓄積する。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ} ＋ 消費ＨＰ：最大ＨＰの{HP消費割合}％
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>使用時、最大HPの{HP消費割合}％のHPを失う。"
			;自傷ダメージなので八つ裂きがちょっと蓄積
			SIF キャラレベル >= K3337_固有アビ_習得Lv_八つ裂き
				詳細文文字列受け渡し変数 += @"<br>使用時、[八つ裂き衝動]が1スタック蓄積する。"

		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;カスケード
			ELSEIF 特殊呼び出し == "カスケード"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			;通常
			ELSE
				;敵単体を選択
				CALL アビ対象選択テンプレート_敵単体
			ENDIF

			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性

			;殴った後で自身にダメージ
			キャラ隊列位置 = キャラ隊列検索(キャラ番号)
			BATTLE_STATE:キャラ隊列位置:ＨＰ -= BATTLE_STATE:キャラ隊列位置:最大ＨＰ * HP消費割合 / 100
			SIF BATTLE_STATE:キャラ隊列位置:ＨＰ < 0
				BATTLE_STATE:キャラ隊列位置:ＨＰ = 0

			;八つ裂き衝動をスタック
			CALL K3337_Battle_八つ裂きカウント加算()

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_パーフェクトストライク(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 基礎威力値
#DIM 加算威力値
#DIM 総合威力値
#DIM ストライク枚数
#DIM カスケード威力値
#DIM LCOUNT

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;ストライク枚数のカウント
	ストライク枚数 = 0

	;手札は10枚まで
	FOR LCOUNT, 0, K3337_手札枚数限界
		;その手札番号がゼロなら＝手札にないなら
		IF K3337_手札:LCOUNT == 0
			;何もしない
		;その手札番号がストライク系なら
		ELSEIF K3337_Battle_IS_ストライク(K3337_手札:LCOUNT)
			;ストライク枚数をカウント
			ストライク枚数 += 1
		;「～ストライク」でなければ
		ELSE
			;次の番号へ
			CONTINUE
		ENDIF
	NEXT

	;「ストライク」の枚数でダメージが向上するカード
	;使いやすいかと言えば否なんだけど結構頼る場面はある……
	;本当は「デッキ内のストライクカード全てを加算」するんだが、それでは差別化が難しいし、デッキ構築の都合上「ピックしてる感」も出せない……
	;こちらでは「手札内のストライク」をカウントする。
	;この際、このアビリティもカウントするので、ストライク枚数は最低でも１。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_パーフェクトストライク, "アンコモン", 2)
		アビ名 = ﾊﾟｰﾌｪｸﾄｽﾄﾗｲｸUG+
		消費ＭＰ = 28
		基礎威力値 = 150
		加算威力値 = 60
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_パーフェクトストライク, "アンコモン", 1)
		アビ名 = ﾊﾟｰﾌｪｸﾄｽﾄﾗｲｸUG
		消費ＭＰ = 22
		基礎威力値 = 150
		加算威力値 = 50
	ELSE
		アビ名 = パーフェクトストライク
		消費ＭＰ = 20
		基礎威力値 = 150
		加算威力値 = 40
	ENDIF

	総合威力値 = 基礎威力値 + (加算威力値 * ストライク枚数)
	;カスケードは処理の都合で威力固定に。ストライク2枚分。
	カスケード威力値 =  基礎威力値 + (加算威力値 * 2)


	;何らかの特殊呼び出しを受けている場合
	IF 特殊呼び出し != ""
		消費ＭＰ = 0
		アビテンプレート用_アビ封印用フラグ = 0
	;「ヘルレイザー」効果中は封印
	ELSEIF K3337_Battle_ヘルレイザーなう()
		;使用不可フラグを立てる
		アビテンプレート用_アビ封印用フラグ = 1
	ENDIF

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{基礎威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>手札内の「ストライク」アビリティにひとつに付き、威力が［{加算威力値}％］上昇する（現在：［{総合威力値}％］）。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵単体に［{基礎威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>手札内の「ストライク」アビリティにひとつに付き、威力が［{加算威力値}％］上昇する（現在：［{総合威力値}％］）。"
			CALL K3337_Battle_ストライク_ヘルレイザー説明文(キャラレベル)
			SIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_カスケード, "レア", 0)
				詳細文文字列受け渡し変数 += @"<br>固有アビリティ「カスケード」で使用された場合、威力は［{カスケード威力値}％］固定になる。"
		CASE "アビ効果"
			;特殊呼び出し
			IF 0
			;ヘルレイザーで呼び出された場合
			ELSEIF 特殊呼び出し == "ヘル・レイザー"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
				;威力値は通常計算
				アビ汎用変数:効果割合 = 総合威力値
			;カスケードで呼び出された場合
			ELSEIF 特殊呼び出し == "カスケード"
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
				;威力値は特殊計算
				アビ汎用変数:効果割合 = カスケード威力値
			;通常
			ELSE
				;敵単体を選択
				CALL アビ対象選択テンプレート_敵単体
				;威力値は通常計算
				アビ汎用変数:効果割合 = 総合威力値
			ENDIF

			CALL アビテンプレート_ダメージ処理_自属性

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT



@K3337_固有アビリティ_旋風刃(呼び出し引数, キャラ番号, 手札番号, 特殊呼び出し = "")
#DIMS 呼び出し引数
#DIM キャラ番号
#DIM 手札番号
#DIMS 特殊呼び出し
#DIM キャラレベル
#DIMS アビ名
#DIM 消費ＭＰ
#DIM 威力値
#DIM キャラ隊列位置
#DIM 現在MP割合

	;変数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;現在MPの割合が高いほど大ダメージ。
	;ただしMP残量に単純に比例するわけではなく、数値は大きくなりがち。消費は重い。
	IF 0
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_旋風刃, "アンコモン", 2)
		アビ名 = 旋風刃UG+
		消費ＭＰ = 50
		威力値 = 35
	ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_旋風刃, "アンコモン", 1)
		アビ名 = 旋風刃UG
		消費ＭＰ = 50
		威力値 = 30
	ELSE
		アビ名 = 旋風刃
		消費ＭＰ = 50
		威力値 = 25
	ENDIF

	;割合を取得
	;平方根を取るので、数値を大きく１万倍にしておく（eraは少数を扱えないからね）
	;たとえばルート2は1.414213……だが、141が取れるように。
	;MP残量割合と平方根は下記の通りになる。
	;＞1(100)～16(200)～25(500)～50(707)～75(866)～90(948)～100(1000)
	キャラ隊列位置 = キャラ隊列検索(キャラ番号)
	現在MP割合 = (BATTLE_STATE:キャラ隊列位置:ＭＰ * 100  * 10000) / BATTLE_STATE:キャラ隊列位置:最大ＭＰ
	現在MP割合 = SQRT(現在MP割合)

	;最低威力として50を加算しつつ、基礎威力と算出した割合を足す
	;結果として威力は下記の通りの幅を取る。ただし上記の平方根を絡めた勾配で、MPが50％残っていれば８割ほどのダメージは出る。
	;　素が50～300（MP50％だと、226％ほど）
	;　UGが50～350（同、262％ほど）
	;　UG+が50～400（同、297％ほど）
	威力値 = 50 + (威力値 * 現在MP割合) / 100

	;何らかの特殊呼び出しを受けている場合
	SIF 特殊呼び出し != ""
		消費ＭＰ = 0

	SELECTCASE 呼び出し引数
		CASE "アビ名"
			TSTR:コマンド名受渡 = %アビ名%
		CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵全体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>MP残量の割合が高いほど威力が向上する。"
			;説明文では消費ＭＰを返すよ
			RETURN 消費ＭＰ
		CASE "アビ説明文_詳細"
			詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
			詳細文文字列受け渡し変数 += @"<br>敵全体に［{威力値}％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>MP残量の割合が高いほど威力が向上する。"
			詳細文文字列受け渡し変数 += @"<br>威力の上昇率は、MP残量割合の平方根に比例する。"
		CASE "アビ効果"
			;特殊呼び出し
			;カスケードで呼んでも全体なのでターゲット選択はカット
			CALL アビ対象選択テンプレート_敵全体_生者のみ

			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性

			CALL K3337_Battle_手札を捨て札に送る(手札番号)
	ENDSELECT

	;通常はゼロを返すよ
	RETURN RESULT




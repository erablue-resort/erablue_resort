@K3337_Battle_アップグレードLv(習得Lv, カードレアリティ, アプグレ度合い)
#FUNCTION
#DIM 習得Lv
#DIMS カードレアリティ
#DIM アプグレ度合い
#DIM 必要Lv

	必要Lv = 習得Lv

	;レアリティでランクアップが異なる
	IF 0
	ELSEIF カードレアリティ == "スターター"
		$K3337_UGLv_スターター
		;基本的には、UG+、UG、習得直後の３段階
		IF 0
		ELSEIF アプグレ度合い >= 2
			必要Lv += 10
		ELSEIF アプグレ度合い >= 1
			必要Lv += 5
		ENDIF
	ELSEIF カードレアリティ == "コモン"
		IF 0
		ELSEIF アプグレ度合い >= 2
			必要Lv += 15
		ELSEIF アプグレ度合い >= 1
			必要Lv += 5
		ENDIF
	ELSEIF カードレアリティ == "アンコモン"
		$K3337_UGLv_アンコモン
		IF 0
		ELSEIF アプグレ度合い >= 2
			必要Lv += 20
		ELSEIF アプグレ度合い >= 1
			必要Lv += 10
		ENDIF
	ELSEIF カードレアリティ == "レア"
		;レア群はそもそも習得レベルが高いからなあ……この辺は調整がいるのう
		IF 0
		ELSEIF アプグレ度合い >= 2
			必要Lv += 25
		ELSEIF アプグレ度合い >= 1
			必要Lv += 15
		ENDIF
	ELSEIF カードレアリティ == "エンシェント"
		IF 0
		ELSEIF アプグレ度合い >= 2
			必要Lv += 20
		ELSEIF アプグレ度合い >= 1
			必要Lv += 20
		ENDIF
	ELSEIF カードレアリティ == "イベント"
		GOTO K3337_UGLv_アンコモン
		;まあアンコモン扱いでいいか……
	ELSEIF カードレアリティ == "ポーション"
		GOTO K3337_UGLv_アンコモン
		;まあアンコモン扱いでいいか……
	ELSE
		;なんか事故ったらスターター扱い
		GOTO K3337_UGLv_スターター
	ENDIF

	;必要レベルは0～80の間に補正
	必要Lv = LIMIT(必要Lv, 0, 80)

	RETURNF 必要Lv



@K3337_Battle_IS_アタック(チェック対象)
#FUNCTION
#DIM チェック対象
#DIM りたあん

	;対象の番号のカードがアタックであるかを確認

	;基本は1を返す
	りたあん = 1

	SELECTCASE チェック対象
		CASE K3337_固有アビ_ストライク
			;アタックであるなら、なにもしない。以下同様。
		CASE K3337_固有アビ_強打
		CASE K3337_固有アビ_ポンメルストライク
		CASE K3337_固有アビ_セットアップストライク
		CASE K3337_固有アビ_アッパーカット
		CASE K3337_固有アビ_ツインストライク
		CASE K3337_固有アビ_サンダークラップ
		CASE K3337_固有アビ_ヘモキネシス
		CASE K3337_固有アビ_パーフェクトストライク
		CASE K3337_固有アビ_旋風刃
		CASE K3337_固有アビ_脳天割り
		CASE K3337_固有アビ_八つ裂き
		CASEELSE
			;アタック系でなければゼロにする
			りたあん = 0
	ENDSELECT

	RETURNF りたあん



@K3337_Battle_IS_ストライク(チェック対象)
#FUNCTION
#DIM チェック対象
#DIM りたあん

	;対象の番号のカードがアタックであるかを確認

	;基本は1を返す
	りたあん = 1

	SELECTCASE チェック対象
		CASE K3337_固有アビ_ストライク

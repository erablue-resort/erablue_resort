			;テキストが含まれるか……で判定するのはさすがに負荷あるしアウト。
		CASE K3337_固有アビ_ポンメルストライク
		CASE K3337_固有アビ_セットアップストライク
		CASE K3337_固有アビ_ツインストライク
		CASE K3337_固有アビ_パーフェクトストライク
		CASEELSE
			;ストライク系でなければゼロにする
			りたあん = 0
	ENDSELECT

	RETURNF りたあん






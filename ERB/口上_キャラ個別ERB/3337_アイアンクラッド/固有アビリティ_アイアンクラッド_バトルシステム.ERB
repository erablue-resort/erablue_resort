@固有戦闘開始時処理_キャラ_3337
#DIM キャラ番号
#DIM 隊列番号
#DIM 隊列
#DIM キャラレベル

	;変数、定数の設定
	キャラ番号 = GETCHARA(3337)
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv
	隊列番号 = キャラ隊列検索(キャラ番号)
	SIF 隊列番号 < 0 || 隊列番号 > 3
		RETURN

	;デッキリストの初期化、シャッフル、カードドロー、ポーション取得

	;初手ドロー枚数の増減をリセット
	;初期ドローを増やす可能性があるので、別で持っておく
	;（そのうち「レリック」を実装するかもしれんし……）
	;（ポンメルストライクなどで「次ターンドロー」の効果がある場合この変数を操作するよ）
	;この変数はERHで持ってるのでグローバルに使う
	K3337_ドロー枚数_規定 = 5
;	K3337_ドロー枚数_追加 = 0
	CALL K3337_Battle_ターン開始時ドロー増減処理(キャラ番号, 0, "リセット")

	;初期デッキ内容をセット
	CALL K3337_Battle_初期デッキセット(キャラ番号)
	;デッキ内容をシャッフル
	CALL K3337_Battle_デッキシャッフル(キャラ番号)
	;デッキからドロー、アビリティをセット
	CALL K3337_Battle_カードドロー(キャラ番号, K3337_ドロー枚数_規定)
	;ポーションをドロー
	CALL K3337_Battle_ポーションセット(キャラ番号)



	;==============================
	;以下はアイクラ独自要素
	;==============================

	;バーニング/ブラックブラッドの設定
	;最大HPに対する、低倍率の再生効果。消去不可で永続。
	CALL アビ汎用変数文字列リセット
	CALL アビ対象選択テンプレート_自己のみ
	アビ汎用変数:消去不可オプション = 1
	アビ汎用文字列:バフ・デバフ対象能力 = 再生

	;Lv一定以上で「ブラックブラッド」になり効果量増加
	;原作では、「戦闘終了時、HPを回復」。バランス的にはえらぶるでは毎ターン回復がよろしかろうという感じ。
	;原作の初期最大HPは80、回復量は6/12＝7.5/15％回復……になるんだけど、さすがにそれは効果が大きいかなということで。
	IF キャラレベル >= K3337_固有アビ_習得Lv_ブラックブラッド
		アビ汎用文字列:バフ・デバフ枠 = ブラックブラッド
		アビ汎用変数:効果割合 = 6
	ELSE
		アビ汎用文字列:バフ・デバフ枠 = バーニングブラッド
		アビ汎用変数:効果割合 = 4
	ENDIF
	アビ汎用変数:持続ターン = -1
	CALL アビテンプレート_有利効果_バフ効果セット

	;八つ裂き用の被ダメージ回数カウント
	;初期化は初期デッキ設定関数にて。
	;八つ裂きを覚えてからカウントを開始する
	IF キャラレベル >= K3337_固有アビ_習得Lv_八つ裂き
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用変数:消去不可オプション = 1
		アビ汎用文字列:バフ・デバフ枠 = 八つ裂き衝動
		アビ汎用文字列:バフ・デバフ対象能力 = 特殊反応_被ダメ時
		アビ汎用文字列:バフ・デバフ名 = 八つ裂き衝動
		アビ汎用変数:特殊表示オプション = 1
		アビ汎用変数:持続ターン = -1
		CALL アビテンプレート_有利効果_バフ効果セット
	ENDIF



@バフ・デバフ特殊表示_八つ裂き衝動(隊列番号, バフ・デバフ行数)
#DIM 隊列番号
#DIM バフ・デバフ行数
VARSET LOCALS

	PRINTFORML 八つ裂き衝動
	PRINTFORML ダメージを受けた際、固有アビリティ「八つ裂き」の追撃回数が1増える状態［永続/消去不可］
	PRINTFORML （現在値：{K3337_八つ裂きカウント}/蓄積上限：{K3337_固有アビ_八つ裂きカウント限界}）



@特殊反応_被ダメ時_八つ裂き衝動(バフ番号, 攻撃者隊列, 被ダメ記録順)
#DIM 被ダメ記録順
#DIM 攻撃者隊列
#DIM バフ番号

	;八つ裂き用のカウントを増やす関数を呼ぶ
	;ヘモキネシスとかで同じシステム使うからね
	CALL K3337_Battle_八つ裂きカウント加算()



@K3337_Battle_八つ裂きカウント加算()
#DIM キャラ番号
#DIM キャラレベル

	キャラ番号 = GETCHARA(3337)
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;八つ裂きを習得するレベルである　かつ　八つ裂きカウント限界に到達してない……なら、カウントをプラス。
	;リセットは初期デッキ製作関数にて。
	;一応、カウントは制限しておく。
	SIF (キャラレベル >= K3337_固有アビ_習得Lv_八つ裂き) && (K3337_固有アビ_八つ裂きカウント限界 > K3337_八つ裂きカウント)
		K3337_八つ裂きカウント += 1



@固有ターン開始時処理_キャラ_3337
#DIM キャラ番号
#DIM ドロー枚数
#DIM LCOUNT
#DIM キャラレベル
#DIM キャラ隊列位置
#DIM パワー付与状態
#DIM 悪魔化_筋力
#DIM 真紅の衣_バリア値
#DIM 真紅の衣_バリア倍率

	;変数、定数の設定
	キャラ番号 = GETCHARA(3337)
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv
	キャラ隊列位置 = キャラ隊列検索(キャラ番号)

	;手札を捨てる
	FOR LCOUNT, 0, K3337_手札枚数限界
		;手札番号をゼロにする＝カラにする
		K3337_手札:LCOUNT = 0
	NEXT

	;デッキからドロー、アビリティをセット
	ドロー枚数 = K3337_ドロー枚数_規定 + K3337_ドロー枚数_追加
	;ドロー枚数はゼロから10までとする
	ドロー枚数 = LIMIT(ドロー枚数, 0, K3337_手札枚数限界)
	CALL K3337_Battle_カードドロー(キャラ番号, ドロー枚数)

	;ターン開始時の追加（減少）ドローをリセット
	CALL K3337_Battle_ターン開始時ドロー増減処理(キャラ番号, 0, "リセット")

	;==============================
	;以下はアイクラ独自要素
	;==============================
	;まあサイレントとか他キャラ作るかわからんけど

	;カスケード関連をリセット
	VARSET K3337_カスケードドロー
	K3337_カスケードドロー済み枚数 = 0

	;バトルトランス封印フラグを解除
	K3337_バトルトランス使用制限 = 0

	;[悪魔化]状態
	パワー付与状態 = バフ番号取得_枠("悪魔化", キャラ隊列位置)
	IF パワー付与状態 > -1
		;累積する量を取得
		IF 0
		ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_悪魔化, "レア", 2)
			悪魔化_筋力 = K3337_固有アビ_悪魔化_累積値3
		ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_悪魔化, "レア", 1)
			悪魔化_筋力 = K3337_固有アビ_悪魔化_累積値2
		ELSE
			悪魔化_筋力 = K3337_固有アビ_悪魔化_累積値1
		ENDIF

		;永続・消去不可・累積攻撃バフ
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 攻撃力_累積枠
		アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
		アビ汎用変数:効果割合 = 悪魔化_筋力
		アビ汎用変数:累積上限_割合 = K3337_固有アビ_悪魔化_累積限界
		アビ汎用変数:持続ターン = -1
		アビ汎用変数:消去不可オプション = 1
		CALL アビテンプレート_有利効果_累積バフ効果セット
	ENDIF

	;[真紅の衣]状態
	パワー付与状態 = バフ番号取得_枠("真紅の衣", キャラ隊列位置)
	IF パワー付与状態 > -1
		;バリア基礎値を算出
		;コレ書いてる時点では5％
		真紅の衣_バリア値 = BATTLE_STATE:キャラ隊列位置:最大ＨＰ * K3337_固有アビ_真紅の衣_消費HP割合 / 100

		;算出したぶん、HPを消費
		BATTLE_STATE:キャラ隊列位置:ＨＰ -= 真紅の衣_バリア値
		SIF BATTLE_STATE:キャラ隊列位置:ＨＰ < 0
			BATTLE_STATE:キャラ隊列位置:ＨＰ = 0
		;八つ裂き衝動をスタック
		CALL K3337_Battle_八つ裂きカウント加算()

		;これ書いてる時点では、倍率は200/250/300％。まあ最大HPの10％、12.5％、15％のバリアを毎ターン張る、という感じ
		IF 0
		ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_真紅の衣, "レア", 2)
			真紅の衣_バリア倍率 = K3337_固有アビ_真紅の衣_バリア値3
		ELSEIF キャラレベル >= K3337_Battle_アップグレードLv(K3337_固有アビ_習得Lv_真紅の衣, "レア", 1)
			真紅の衣_バリア倍率 = K3337_固有アビ_真紅の衣_バリア値2
		ELSE
			真紅の衣_バリア倍率 = K3337_固有アビ_真紅の衣_バリア値1
		ENDIF
		真紅の衣_バリア値 = 真紅の衣_バリア値 * 真紅の衣_バリア倍率 / 100

		;バリア発生
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = バリア
		アビ汎用文字列:バフ・デバフ対象能力 = バリア
		アビ汎用変数:効果量 = 真紅の衣_バリア値
		アビ汎用変数:持続ターン = 1
		CALL アビテンプレート_有利効果_バフ効果セット
	ENDIF



@K3337_Battle_初期デッキセット(キャラ番号)
#DIM キャラ番号
#DIM キャラレベル
#DIM リストNO

	;初期デッキリストをセットする
	;レベルに応じて初期デッキを変更する
	;デッキ関連の初期処理も兼ねる

	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;デッキや手札配列、変数をリセット
	VARSET K3337_初期カードリスト
	VARSET K3337_山札
	VARSET K3337_手札
	VARSET K3337_追加生成カード
	VARSET K3337_廃棄済みカード
	K3337_山札何枚引いたかな = 0
	K3337_八つ裂きカウント = 0
	VARSET K3337_カスケードドロー
	K3337_カスケードドロー済み枚数 = 0
	リストNO = 0

	;スターター部分のセット
	;Lvが上昇するとスターターの比率が下がる

	;とりあえずこの３枚は固定
	K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ストライク
	K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_強打
	K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_防御

	IF 0
	ELSEIF キャラレベル >= 80
		;Lv80以上ならストライク・防御は追加しない
		;残り火のストライクが１枚になっちゃうんだけども……
	ELSEIF キャラレベル >= 60
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ストライク
	ELSEIF キャラレベル >= 40
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_防御
	ELSEIF キャラレベル >= 20
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_防御
	ELSE
		;低レベルのうちは、アビリティ枠を埋めるという意味でも少し多めのストライク・防御
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_防御
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_防御
	ENDIF

	;レベルに応じて「ピック」が増え、デッキが拡充されていく
	SIF キャラレベル >= K3337_固有アビ_習得Lv_ポンメルストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ポンメルストライク
	;2枚目を追加
	SIF キャラレベル >= (K3337_固有アビ_習得Lv_ポンメルストライク + 10)
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ポンメルストライク
	SIF キャラレベル >= K3337_固有アビ_習得Lv_セットアップストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_セットアップストライク
	SIF キャラレベル >= K3337_固有アビ_習得Lv_アッパーカット
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_アッパーカット
	SIF キャラレベル >= K3337_固有アビ_習得Lv_ツインストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ツインストライク
	SIF キャラレベル >= K3337_固有アビ_習得Lv_サンダークラップ
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_サンダークラップ
	SIF キャラレベル >= K3337_固有アビ_習得Lv_ヘモキネシス
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ヘモキネシス
	SIF キャラレベル >= K3337_固有アビ_習得Lv_パーフェクトストライク
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_パーフェクトストライク
	SIF キャラレベル >= K3337_固有アビ_習得Lv_旋風刃
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_旋風刃
	SIF キャラレベル >= K3337_固有アビ_習得Lv_脳天割り
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_脳天割り
	SIF キャラレベル >= K3337_固有アビ_習得Lv_八つ裂き
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_八つ裂き
	SIF キャラレベル >= K3337_固有アビ_習得Lv_受け流し
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_受け流し
	SIF キャラレベル >= K3337_固有アビ_習得Lv_武装
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_武装
	SIF キャラレベル >= K3337_固有アビ_習得Lv_やせ我慢
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_やせ我慢
	SIF キャラレベル >= K3337_固有アビ_習得Lv_不動
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_不動
	SIF キャラレベル >= K3337_固有アビ_習得Lv_セカンドウィンド
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_セカンドウィンド
	SIF キャラレベル >= K3337_固有アビ_習得Lv_バトルトランス
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_バトルトランス
	;2枚目を追加
	SIF キャラレベル >= (K3337_固有アビ_習得Lv_バトルトランス + 10)
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_バトルトランス
	SIF キャラレベル >= K3337_固有アビ_習得Lv_カスケード
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_カスケード
	SIF キャラレベル >= K3337_固有アビ_習得Lv_悪魔化
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_悪魔化
	SIF キャラレベル >= K3337_固有アビ_習得Lv_かがり火
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_かがり火
	SIF キャラレベル >= K3337_固有アビ_習得Lv_ヘル・レイザー
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_ヘル・レイザー
	SIF キャラレベル >= K3337_固有アビ_習得Lv_真紅の衣
		K3337_初期カードリスト:(リストNO++) = K3337_固有アビ_真紅の衣

	;スタイルチェンジとかで「ピックしない」ものを操作したりするならここのタイミングだな……



@K3337_Battle_デッキシャッフル(キャラ番号)
#DIM キャラ番号
#DIM LCOUNT
#DIM LCOUNT2
#DIM デッキリスト枚数
#DIM 山札枚数
#DIM セット候補カード
#DIM 廃棄済みチェック配列, 100
#DIM シャッフルRAND1
#DIM シャッフルRAND2
#DIM DYNAMIC 山札temp配列, 100

	;デッキを形成し、ランダムでシャッフルする。
	;他でも使うので本当にシャッフルするだけ

	;山札配列やその枚数、「何枚目まで引いたか」をリセット
	;本命の「K3337_山札」は広域変数で、広域変数はダイナミックにできないらしいので、いったんtemp配列に突っ込むよん
	VARSET K3337_山札
	VARSET 山札temp配列
	山札枚数 = 0
	K3337_山札何枚引いたかな = 0

	;廃棄のチェック用に、廃棄済みカードをチェック用配列に転写
	VARSET 廃棄済みチェック配列
	ARRAYCOPY "K3337_廃棄済みカード", "廃棄済みチェック配列"

	;手札に既に存在しているカードのチェック用
	;廃棄済みチェック配列に一時的に手札のカードを突っ込む
	FOR LCOUNT, 0, K3337_手札枚数限界
		;その手札番号がゼロなら
		IF K3337_手札:LCOUNT == 0
			;とりあえず次に行く
			CONTINUE
		ELSE
			;既に手札にあるカードは、デッキからその枚数分減らす……ために、「廃棄」扱いにする
			廃棄済みチェック配列:(K3337_手札:LCOUNT) += 1
		ENDIF
	NEXT

	;まず初期カードリストを山札に加えていく
	;初期カードリスト配列の要素数を取得
	VARSIZE K3337_初期カードリスト
	デッキリスト枚数 = RESULT:0

	FOR LCOUNT, 0, デッキリスト枚数
		セット候補カード = K3337_初期カードリスト:LCOUNT
		;カードリスト配列のLCOUNT番目がゼロ＝存在しないなら
		IF セット候補カード == 0
			;なんもしな～い
		;そのカードが廃棄されているかチェック
		;ストライクなら１、強打なら２……と定数を設定している
		;ここでは「廃棄済みカード配列の『ストライク』番目」を見ており、それが1以上＝『ストライク』番目のカードが1枚以上廃棄されている、という挙動
		ELSEIF 廃棄済みチェック配列:セット候補カード > 0
			;『ストライク』番目が廃棄されている場合ここに来る＝山札にセットしない
			;排除すべき枚数の残数を減らす
			廃棄済みチェック配列:セット候補カード -= 1
		ELSE
			;山札tempにカードを加える
			山札temp配列:山札枚数 = セット候補カード
			山札枚数++
		ENDIF
	NEXT

	;追加で生成されたカードを追加する
	VARSIZE K3337_追加生成カード
	デッキリスト枚数 = RESULT:0

	;基本は上のと同じね
	FOR LCOUNT, 0, デッキリスト枚数
		セット候補カード = K3337_追加生成カード:LCOUNT
		;追加生成カード配列のLCOUNT番目がゼロ＝存在しないなら
		IF セット候補カード == 0
			;何もしない
		ELSEIF 廃棄済みチェック配列:セット候補カード > 0
			廃棄済みチェック配列:セット候補カード -= 1
		ELSE
			;山札tempにカードを加える
			山札temp配列:山札枚数 = セット候補カード
			山札枚数++
		ENDIF
	NEXT

	;シャッフルするでよ
	VARSIZE 山札temp配列
	デッキリスト枚数 = RESULT:0
	FOR LCOUNT, 0, デッキリスト枚数
		;「RANDで得られた数そのいち」番目と、「RANDで得られた数そのに」番目の内容を交換するのを繰り返す
		;まあ１番目はLCOUNTでいいか……
		シャッフルRAND1 = LCOUNT
		シャッフルRAND2 = RAND:デッキリスト枚数
		SWAP 山札temp配列:シャッフルRAND1, 山札temp配列:シャッフルRAND2
	NEXT

	;本命の山札にシュート
	LCOUNT2 = 0
	FOR LCOUNT, 0, デッキリスト枚数
		;山札tempがゼロかどうかをチェック
		IF 山札temp配列:LCOUNT != 0
			;ゼロでなければ＝なんかカードがあればカードを登録
			K3337_山札:LCOUNT2 = 山札temp配列:LCOUNT
			;本命山札のカウントを次の番号に
			LCOUNT2 += 1
		ENDIF
	NEXT

	RETURN



@K3337_Battle_カードドロー(キャラ番号, ドロー枚数)
#DIM キャラ番号
#DIM ドロー枚数
#DIM LCOUNT_ドロー枚数
#DIM LCOUNT_手札番号
#DIM 山札枚数

	;山札から、「ドロー枚数」ぶんカードを引く処理
	FOR LCOUNT_ドロー枚数, 0, ドロー枚数
		;手札は10枚まで
		FOR LCOUNT_手札番号, 0, K3337_手札枚数限界
			;その手札番号がゼロなら＝カラなら＝手札がまだ空いているなら
			IF K3337_手札:LCOUNT_手札番号 == 0

				;実際にドローするとき、デッキが残っているかを確認
				;山札がまだ残っているかを確認
				VARSIZE K3337_山札
				山札枚数 = RESULT:0

				;山札にカードが残っていなかったらシャッフル処理
				;残っていない判定は「山札枚数以上に引いた」または「ゼロが入ってきた」場合
				;多分運用上ゼロが入ってきたときだけになる気がするな……
				IF (K3337_山札何枚引いたかな > 山札枚数) || (K3337_山札:K3337_山札何枚引いたかな == 0)
					CALL K3337_Battle_デッキシャッフル(キャラ番号)
				ENDIF

				;山札のX番目のカードを手札に加え、Xを+1する
				K3337_手札:LCOUNT_手札番号 = K3337_山札:K3337_山札何枚引いたかな
				K3337_山札何枚引いたかな += 1
				
				;ドローできたら次のドロー処理へ進むためぶれいくする
				BREAK
			ENDIF
		NEXT
	NEXT

	;手札が満杯で引けなかった場合、原作では「手札が満杯だ……」ってメッセージが出るが、んまあ、まあいいか……

	RETURN 0



@K3337_Battle_ターン開始時ドロー増減処理(キャラ番号, 増減変動数, 初期化フラグ = "")
#DIM キャラ番号
#DIM 増減変動数
#DIMS 初期化フラグ

	;次ターンのカードが１枚増える、などの処理
	;マイナスを入れてもいいようにする

	;初期化される場合
	;戦闘開始時や、ターン開始時にカードをドローした場合ゼロにする
	IF 初期化フラグ == "リセット"
		;追加ドロー枚数を初期化する
		K3337_ドロー枚数_追加 = 0
	;加減算の場合
	ELSE
		;カードドロー枚数の追加分を操作する
		;いちおう、増減の最大・最低は±10枚としておく
		;（手札は0～10枚だが、「次のターンドローが10枚マイナスになったあとで、4枚プラスになっても、ま～だマイナス６で、ドローができない」……みたいな状況がありえるため。あるかな。ないかも。
		K3337_ドロー枚数_追加 += 増減変動数
		K3337_ドロー枚数_追加 = LIMIT(K3337_ドロー枚数_追加, -10, 10)
	ENDIF

	RETURN 0




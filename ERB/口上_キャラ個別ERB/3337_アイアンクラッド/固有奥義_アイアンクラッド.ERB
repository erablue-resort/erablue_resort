;--------------------------------------------------
;●アイアンクラッド口上＠erablue_resort用
;　――固有奥義
;--------------------------------------------------

;--------------------------------------------------
;●ライセンス/更新履歴/概要/使用フラグ
;--------------------------------------------------
;　いずれもアイアンクラッド口上_readme.txt記載に従う
;--------------------------------------------------

@固有奥義_3337(ARGS, キャラ番号)
#DIM キャラ番号
#DIM キャラレベル
#DIM 奥義威力
#DIMS 奥義名
#DIM 攻撃回数
#DIM 最大攻撃回数
#DIM 最小攻撃回数
#DIM 単発威力

	;原作的なことを言うと「手札のアタックカードを、強力なアタックカード『巨大な岩』に変化させる」というアビリティなんだけど
	;シナジーとかもまあまあ死ぬというちょっと困るカードでもある……再現はしないでおく。
	;まー「原始の力」ではなく「プライマルフォース」ということで。

	;変数、定数の設定
	キャラレベル = 基礎BATTLE_STATE:キャラ番号:Lv

	;「原始の力」の英語版名称が「Primal Force」
	IF 0
	;男性キャラなので、陥落でなく一定以上のレベルで強化されるように
	ELSEIF 陥落チェック(キャラ番号) || キャラレベル >= K3337_固有アビ_習得Lv_陥落奥義
		奥義名 = ﾌﾟﾗｲﾏﾙﾌｫｰｽ･ﾘﾐｯﾄﾌﾞﾚｲｸ
		;巨大な岩UG
		単発威力 = 200
	ELSE
		奥義名 = プライマルフォース
		;巨大な岩
		単発威力 = 160
	ENDIF

	;威力は固定。特殊処理をするので「奥技威力」はゼロ
	奥義威力 = 0
	攻撃回数 = 0

	最小攻撃回数 = 2
	最大攻撃回数 = 4


	;基本は「（キャラ名）の奥義：（奥義名）！」と表示される。
	;たまに変なメッセージにしようかな……と思ったけどコメントアウトしておきます
;	SIF !RAND:10
;		アビ汎用文字列:実行時メッセージ１ = アイアンクラッドの奥技：ゲンシパワー　キンジラレタチカラ！

	SELECTCASE ARGS
		CASE "奥義名"
			TSTR:コマンド名受渡 = %奥義名%
		CASE "奥義説明文"
			詳細文文字列受け渡し変数 = 奥義威力：{単発威力}％✕{最小攻撃回数}～{最大攻撃回数}
			詳細文文字列受け渡し変数 += @"<br>ランダムな敵を対象に、自属性の[{単発威力}％]奥義ダメージを{最小攻撃回数}～{最大攻撃回数}回与える。"
			詳細文文字列受け渡し変数 += @"<br>対象は攻撃1回ごとにランダムで、攻撃対象は重複することがある。"
			RETURN 奥義威力
		CASE "奥義説明文_詳細"
			詳細文文字列受け渡し変数 = 奥義威力：{単発威力}％✕{最小攻撃回数}～{最大攻撃回数}
			詳細文文字列受け渡し変数 += @"<br>ランダムな敵を対象に、自属性の[{単発威力}％]奥義ダメージを{最小攻撃回数}～{最大攻撃回数}回与える。"
			詳細文文字列受け渡し変数 += @"<br>対象は攻撃1回ごとにランダムで、攻撃対象は重複することがある。"
			IF !RAND:10
				詳細文文字列受け渡し変数 += @"<br>――ゲンシパワー　キンジラレタ　ウホホウホ。"
			ELSE
				;強化版だと「巨大な岩＋」に変更
				IF 陥落チェック(キャラ番号) || キャラレベル >= K3337_固有アビ_習得Lv_陥落奥義
					詳細文文字列受け渡し変数 += @"<br>原始の力を発揮し、その辺にある巨大な岩＋を思いっきり投げつける！"
				ELSE
					詳細文文字列受け渡し変数 += @"<br>原始の力を発揮し、その辺にある巨大な岩を思いっきり投げつける！"
				ENDIF
			ENDIF
		CASE "奥義前効果"
			;対象決定の後、ダメージよりも前に発生する効果。基本の奥義ダメージ部分は記載する必要はない。

			;処理の都合上、ここから奥義ダメージまでにリセットを噛ませてないため
			;必要な場合を除きここでリセット
			CALL アビ汎用変数文字列リセット
		CASE "奥義追加効果"
			;ここに奥義効果を記述する。基本の奥義ダメージ部分は記載する必要はない。

			アビ汎用文字列:ダメージ種類 = 奥義ダメージ
			アビ汎用変数:効果割合 = 単発威力
			攻撃回数 = RAND(最小攻撃回数, 最大攻撃回数 + 1)

			;複数回攻撃。ヘイトには影響される
			FOR LOCAL, 0, 攻撃回数
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
				CALL アビテンプレート_ダメージ処理_自属性
			NEXT

	ENDSELECT



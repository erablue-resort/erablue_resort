@戦闘初期ステータス設定_3337(キャラ番号)
#DIM キャラ番号

	;ここは弄らないこと
	基礎BATTLE_STATE:キャラ番号:ステータスタイプ保存 = -1
	基礎BATTLE_STATE:キャラ番号:Lv = 1
	;ここまで弄らないこと

	;初期ステータスを登録
	;ステータスのバランスは「@初期ステータス設定_テンプレート適用」を参考
	;/
	;攻撃型と防御型を足して２で割るイメージ……以下、「攻撃型の数値/防御型の数値、設定理由」。
	;最大HP：180/250、防御型には劣るがかなり高い設定。
	;最大MP：120/80、明確な弱点として「最大MPが低い」設定。
	;攻撃力：120/90、防御力をガッと削る代わりに、攻撃型よりも高い。
	;防御力：80/130、ガッと削る。明確な弱点２。
	;回復力：80/110、防御型に劣るがやや高めの値。
	;行動速度：110/90、攻撃型と同じ。
	;DA,TA：10.5/8.3、ここは攻撃型と同じ。アイクラはどちらかと言えば連撃ができる方（ソードブーメランとかツインストライクとか）。
	;ゲージ上昇効率：100/100、標準。
	;被ダメ時上昇効率：100/150、防御型には劣るがやや高め。
	;命中：100/95、攻撃型と同じ。
	;回避：5/0、防御型と同じ。
	;クリティカル率：0/0、原作にはクリティカルないしね。
	;CTダメージ率：150/150、原作にはクリティカルないしね。
	;敵対心：100/100、原作では「タンク」というアビリティがあったりするんだが……まあ、いいかな。

	基礎BATTLE_STATE:キャラ番号:Lv = 1
	基礎BATTLE_STATE:キャラ番号:最大ＨＰ = 240
	基礎BATTLE_STATE:キャラ番号:最大ＭＰ = 75
	基礎BATTLE_STATE:キャラ番号:攻撃力 = 130
	基礎BATTLE_STATE:キャラ番号:防御力 = 65
	基礎BATTLE_STATE:キャラ番号:回復力 = 100
	基礎BATTLE_STATE:キャラ番号:行動速度 = 110
	基礎BATTLE_STATE:キャラ番号:DA率 = 10
	基礎BATTLE_STATE:キャラ番号:TA率 = 5
	基礎BATTLE_STATE:キャラ番号:ゲージ上昇効率 = 100
	基礎BATTLE_STATE:キャラ番号:ゲージ上昇効率_被ダメ時 = 120
	基礎BATTLE_STATE:キャラ番号:ゲージ最大値 = 100
	基礎BATTLE_STATE:キャラ番号:命中率 = 100
	基礎BATTLE_STATE:キャラ番号:回避率 = 0
	基礎BATTLE_STATE:キャラ番号:クリティカル率 = 0
	基礎BATTLE_STATE:キャラ番号:クリティカルダメージ率 = 150
	基礎BATTLE_STATE:キャラ番号:敵対心 = 100

	;ステータス画面に表示されるステータスタイプ（通常、「バランス」や「攻撃」などのように表示される部分）
	;空白のままだと「固有」と表示される
	;/
	;ちょっといい名前思いつかなかったので「固有」にしておく。
	基礎BATTLE_STATE_STR:キャラ番号:固有ステータスタイプ名 = 固有


@戦闘ステータスレベルアップ設定_3337(キャラ番号, 上昇レベル)
#DIM キャラ番号
#DIM 上昇レベル
#DIM 計算後レベル

	計算後レベル = 基礎BATTLE_STATE:キャラ番号:Lv + 上昇レベル

	;基礎上昇量を登録
	;上昇量は「@レベルアップ処理」を参考

	;攻撃型と防御型のあいのこ。
	;基本的な方針は初期ステータスの通り。
	基礎BATTLE_STATE:キャラ番号:最大ＨＰ += 48 * 上昇レベル
	基礎BATTLE_STATE:キャラ番号:最大ＭＰ += 14 * 上昇レベル
	基礎BATTLE_STATE:キャラ番号:攻撃力 += 25 * 上昇レベル
	基礎BATTLE_STATE:キャラ番号:防御力 += 12 * 上昇レベル
	基礎BATTLE_STATE:キャラ番号:回復力 += 20 * 上昇レベル
	基礎BATTLE_STATE:キャラ番号:行動速度 += 22 * 上昇レベル
	IF 基礎BATTLE_STATE:キャラ番号:Lv < 20 && 計算後レベル >= 20
		基礎BATTLE_STATE:キャラ番号:DA率 += 3
		基礎BATTLE_STATE:キャラ番号:TA率 += 1
		基礎BATTLE_STATE:キャラ番号:命中率 += 5
		基礎BATTLE_STATE:キャラ番号:回避率 += 1
	ENDIF
	IF 基礎BATTLE_STATE:キャラ番号:Lv < 40 && 計算後レベル >= 40
		基礎BATTLE_STATE:キャラ番号:DA率 += 3
		基礎BATTLE_STATE:キャラ番号:TA率 += 1
		基礎BATTLE_STATE:キャラ番号:命中率 += 5
		基礎BATTLE_STATE:キャラ番号:回避率 += 1
	ENDIF
	IF 基礎BATTLE_STATE:キャラ番号:Lv < 60 && 計算後レベル >= 60
		基礎BATTLE_STATE:キャラ番号:DA率 += 3
		基礎BATTLE_STATE:キャラ番号:TA率 += 1
		基礎BATTLE_STATE:キャラ番号:命中率 += 5
		基礎BATTLE_STATE:キャラ番号:回避率 += 1
	ENDIF
	IF 基礎BATTLE_STATE:キャラ番号:Lv < 80 && 計算後レベル >= 80
		基礎BATTLE_STATE:キャラ番号:DA率 += 3
		基礎BATTLE_STATE:キャラ番号:TA率 += 1
		基礎BATTLE_STATE:キャラ番号:命中率 += 5
		基礎BATTLE_STATE:キャラ番号:回避率 += 1
	ENDIF



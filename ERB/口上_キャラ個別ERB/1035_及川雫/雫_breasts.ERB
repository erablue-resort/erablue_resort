;-------------------------------------------------
;COM6_胸愛撫
;相手の乳房を優しく愛撫するコマンド。
;-------------------------------------------------
@KOJO_COM_X_6(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

IF PLAYER == MASTER
	;相手があなたの時
	IF TALENT:対象キャラ:母乳体質
	;母乳体質持ち
		IF TALENT:対象キャラ:恋慕
			SELECTCASE CUP:対象キャラ:快Ｂ
				;各部位の累積が10000で絶頂
				CASE IS > 10000
					;即絶頂
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「ああっ！　だめぇっ、%CALLNAME:PLAYER%さんっ！　出ちゃいますからぁっ_H_」
							KSTR:(K++) = 雫は膨らみきった胸を震わせ、限界を迎えようとしていた。
						CASE 1
							KSTR:(K++) = 「ん"っ！　もぉ……っ、お乳、すごいことに、なってますぅっ_H__H_」
						CASE 2
							KSTR:(K++) = 「ひゃっ、やぁっ！　そこ、だめぇっ……イっちゃう、イっちゃいますぅっ！」
					ENDSELECT
				CASE IS > 6000
					;かなり感じている
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「あっ、はぁっ……%CALLNAME:PLAYER%さんの手、とっても……気持ちいいですぅ_H_」
						CASE 1
							KSTR:(K++) = 「んんっ……お胸の奥が、ジンジンして……もぉ～、へんな気分ですぅ……っ」
						CASE 2
							KSTR:(K++) = 「ふぁっ……お乳、張ってきちゃって……だめですぅ、もっと、触ってください……_H_」
					ENDSELECT
				CASE IS > 3000
					;人並みに感じている
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「んっ……ふふっ、なんだか牛さんになった気分ですー」
						CASE 1
							KSTR:(K++) = 「はっ……%CALLNAME:PLAYER%さんに撫でられると、お胸があったかくなりますぅ」
						CASE 2
							KSTR:(K++) = 「%CALLNAME:PLAYER%さん、やさしいですー……もっと、いっぱいいいですよぉ」
					ENDSELECT
				CASEELSE
					;まだ快楽に慣れていない
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「ひゃっ……ちょっと、くすぐったいですねー」
						CASE 1
							KSTR:(K++) = 「もぉ～、%CALLNAME:PLAYER%さんってば、お胸ばっかり触ってぇ……」
						CASE 2
							KSTR:(K++) = 「んっ……私のお胸、重たくないですかー？」
					ENDSELECT
			ENDSELECT
		ELSEIF TALENT:対象キャラ:セフレ
			SELECTCASE CUP:対象キャラ:快Ｂ
				CASE IS > 10000
					;即絶頂
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「ああっ！　%CALLNAME:PLAYER%さんっ！　お乳、絞ってぇっ、出してぇっ_H_」
						CASE 1
							KSTR:(K++) = 「ん"っ！　だめぇっ、そこ、っ、イっちゃう、イっちゃいますぅっ！」
						CASE 2
							KSTR:(K++) = 「もぉ、だめぇっ！　限界ですぅっ、お乳、出ちゃいますからぁっ_H_」
					ENDSELECT
				CASE IS > 6000
					;かなり感じている
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「はっ、ああっ……%CALLNAME:PLAYER%さんのお手々、すごく……気持ちいいですぅっ_H_」
						CASE 1
							KSTR:(K++) = 「んんっ……お胸、どんどん大きくなって……搾ってもらわないと、辛いですぅ……っ」
						CASE 2
							KSTR:(K++) = 「ふぁっ……もっと、いっぱいいじってくださいっ……お乳、張ってて……っ」
					ENDSELECT
				CASE IS > 3000
					;人並みに感じている
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「んっ……搾乳の時間ですかー？　ふふっ、やさしくしてくださいね」
						CASE 1
							KSTR:(K++) = 「はっ……%CALLNAME:PLAYER%さんに触られるの、好きですー……」
						CASE 2
							KSTR:(K++) = 「%CALLNAME:PLAYER%さんの手、大きくて……お胸にぴったりですねぇ」
					ENDSELECT
				CASEELSE
					;まだ快楽に慣れていない
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「ふふっ、私のお胸で遊んでるんですかー？」
						CASE 1
							KSTR:(K++) = 「んっ……お胸、張ってきちゃいましたー」
						CASE 2
							KSTR:(K++) = 「もぉ～……そんなに揉まれたら、変な感じになっちゃいますよぉ」
					ENDSELECT
			ENDSELECT
		ELSE
			SELECTCASE CUP:対象キャラ:快Ｂ
				CASE IS > 10000
					;即絶頂
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「あ"っ！　だめっ、そんな、私っ、こんなので、ああっ_H_」
						CASE 1
							KSTR:(K++) = 「んっ、ひゃあっ！　イく、イっちゃう、お胸でっ、ああっ！」
						CASE 2
							KSTR:(K++) = 「無理っ、もぉ、無理ですぅっ！　出ちゃう、お乳出ちゃいますぅっ_H_」
					ENDSELECT
				CASE IS > 6000
					;かなり感じている
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「あっ、はぁっ……だめ、そんなに激しく、っ_H_」
						CASE 1
							KSTR:(K++) = 「んんっ……だめですぅ、お胸、おかしくなっちゃう……っ」
						CASE 2
							KSTR:(K++) = 「ふぁっ……お乳、張って……苦しい、気持ちいいですぅっ……_H_」
					ENDSELECT
				CASE IS > 3000
					;人並みに感じている
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「んっ……や、あの、そんなに揉まれたら……」
						CASE 1
							KSTR:(K++) = 「はっ……胸の奥が、なんだか、ドキドキして……」
						CASE 2
							KSTR:(K++) = 「や、ちょっと……っ。なんだか、変ですぅ……」
					ENDSELECT
				CASEELSE
					;まだ快楽に慣れていない
					SELECTCASE RAND:3
						CASE 0
							KSTR:(K++) = 「ひゃっ……ちょっと、くすぐったいですねー」
						CASE 1
							KSTR:(K++) = 「もぉ～……あんまり触らないでくださいー」
						CASE 2
							KSTR:(K++) = 「んっ……私のお胸、気になるんですかー？」
					ENDSELECT
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
CALL 口上変数表示(対象キャラ, 0)



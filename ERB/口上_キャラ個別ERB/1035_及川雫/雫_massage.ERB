;--------------------------------------------------
;マッサージ終了時
;--------------------------------------------------
@KOJO_EVENT_マッサージ終了_1035(対象キャラ)
#DIM 対象キャラ
;「マッサージを終える」ボタンを押した時のみ
;うふふに移行するパターンや体力０で終えた場合は呼び出されない

;TCVAR:対象キャラ:エロマッサージ施術フラグ が１の時、そのマッサージ中にエロマッサージを行った扱い
;０ならエロしてない

CALL 口上変数初期化
IF TCVAR:対象キャラ:エロマッサージ施術フラグ
	;エロマッサージを行った
	SELECTCASE RAND:3
		CASE 0
			KSTR:(K++) = 「ふぁ……すごかったですー……体の奥までほぐされちゃいましたー……」
			KSTR:(K++) = 雫は頬を染めたまま、とろんとした目で%CSTR:LOCAL:二人称%を見上げた。
		CASE 1
			KSTR:(K++) = 「はぁ……マッサージって……こういうこともするんですねー……知らなかったですー」
		CASE 2
			KSTR:(K++) = 「ん……体がぽかぽかですー。なんだか……恥ずかしいところまでほぐされちゃいましたー」
	ENDSELECT
			;KSTR:(K++) = 「%CSTR:LOCAL:二人称%……すごく気持ちよかったですー。……えっちなマッサージも、ですけどー」
			;KSTR:(K++) = 「うし様にはこんなマッサージしないですよー？ ……当たり前ですけどー」
			;KSTR:(K++) = 雫は体の力が抜けきった様子で、ベッドの上でぼんやりしていた。
			;KSTR:(K++) = 「また来てもいいですかー？ ……マッサージのために、ですよー？ えへへ……」
			;KSTR:(K++) = 「体がとろとろですー……立てるかなー……」
ELSE
	;エロマッサージを行っていない
	SELECTCASE RAND:3
		CASE 0
			KSTR:(K++) = 「ふぅ……すっごく楽になりましたー。%CSTR:LOCAL:二人称%、上手ですねー」
			KSTR:(K++) = 雫は気持ちよさそうに伸びをして、にっこりと笑った。
		CASE 1
			KSTR:(K++) = 「ありがとうございますー。肩のこりが取れて、おっぱいも軽くなった気がしますー」
		CASE 2
			KSTR:(K++) = 「はぁ～……極楽ですー。牧場のお仕事で溜まった疲れが全部取れましたー」
	ENDSELECT
			;KSTR:(K++) = 「%CSTR:LOCAL:二人称%のマッサージ、うし様にもしてあげてほしいくらいですー」
			;KSTR:(K++) = 「体がふわふわですー。このまま寝ちゃいそうですー……すぅ……」
			;KSTR:(K++) = 雫はすっかりリラックスした様子で、穏やかな笑顔を浮かべた。
			;KSTR:(K++) = 「またお願いしますねー。%CSTR:LOCAL:二人称%のマッサージ、%CSTR:LOCAL:一人称%のお気に入りですー」
			;KSTR:(K++) = 「んー……もうちょっとだけこのまま横になっていいですかー？ ……zzz」
ENDIF

CALL 口上変数表示(対象キャラ, 0)



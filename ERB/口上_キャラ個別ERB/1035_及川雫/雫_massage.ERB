;マッサージコマンド実行後に表示される文章
;該当のキャラが「TARGET」の時に呼ばれる
;****************************************

;--------------------------------------------------
;マッサージ開始時（マッサージ来店時）
;--------------------------------------------------
@KOJO_EVENT_マッサージ来店_念入り_1035(対象キャラ)
#DIM 対象キャラ

;キャラが自動でマッサージに来たとき、念入りにマッサージを選んだときの口上
;この選択肢を選んだ時、この口上を表示してからマッサージモードに遷移する

CALL 口上変数初期化

SELECTCASE RAND:3
	CASE 0
		KSTR:(K++) = 「あっ、%CSTR:LOCAL:二人称%……今日はマッサージお願いしに来ましたー」
		KSTR:(K++) = 雫はのんびりとした足取りで部屋に入り、ぺこりとお辞儀した。
	CASE 1
		KSTR:(K++) = 「%CSTR:LOCAL:二人称%、念入りにお願いしますー。最近お仕事がんばりすぎちゃってー……」
	CASE 2
		KSTR:(K++) = 「えへへ……%CSTR:LOCAL:二人称%のマッサージ、気持ちいいって聞いたのでー。楽しみですー」
ENDSELECT
		;KSTR:(K++) = 「%CSTR:LOCAL:二人称%にほぐしてもらえるんですかー？ やったですー」
		;KSTR:(K++) = 「牧場のお仕事で体ばきばきなんですー。しっかりお願いしますねー」
		;KSTR:(K++) = 雫はベッドの上にぽすんと座り、%CSTR:LOCAL:二人称%を待っている。
		;KSTR:(K++) = 「おっぱいが重くて肩こりがすごいんですー……助けてくださいー」
		;KSTR:(K++) = 「うし様にもマッサージしてあげたことありますよー。でも今日は%CSTR:LOCAL:一人称%がしてもらう番ですー」

CALL 口上変数表示(対象キャラ, 0)



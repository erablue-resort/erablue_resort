
@固有奥義_3386(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力

#DIM 奥義対象数



    隊列番号 = キャラ隊列検索(キャラ番号)
	;アビ汎用変数:必要奥義ゲージ量 = 70
	;アビ汎用変数:消費奥義ゲージ量 = 70
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = ガトリング★シンフォニア
    ENDIF
    奥義威力 = 0
    SELECTCASE RAND:1
        CASE 0
        アビ汎用文字列:実行時メッセージ１ = 「お楽しみタイムです★せ～のっどるるる～ん★」
    ENDSELECT
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            ;詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％<br>
            詳細文文字列受け渡し変数 = <br>最大3敵に攻撃力の［200~400］％のダメージを与える。
            詳細文文字列受け渡し変数 += @"<br>このダメージは、敵の位置番号が大きいほどダメージが増加する。"
            詳細文文字列受け渡し変数 += @"<br>さらに、番号最小の敵の被ダメージを3ターン［10％］増加させる。"
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
              ; --- 效果处理 ---
            ; CALL アビ対象選択テンプレート_味方全体
            ; CALL アビ汎用変数文字列リセット
            ; アビ汎用文字列:バフ・デバフ枠 = まどろみの庭
            ; アビ汎用文字列:バフ・デバフ対象能力 = 高揚
            ; アビ汎用変数:効果割合 = 20
            ; アビ汎用変数:持続ターン = 3
            ; CALL アビテンプレート_有利効果_バフ効果セット    
            CASE "奥義追加効果"
               ;奥義対象数 = 0
               ;FOR LOCAL, 0,9
               ;    ;敵が居ないマスはスキップ
               ;    SIF 敵BATTLE_STATE_STR:LOCAL:エネミー名 == ""
               ;        CONTINUE
               ;    ;敵が死亡済の場合はスキップ
               ;    SIF 敵BATTLE_STATE:LOCAL:ＨＰ < 1
               ;        CONTINUE
               ;    ;SIF バフ・デバフ効果検索("バフ", "能力", "潜伏", 戦闘行動キャラ) > -1
               ;    SIF バフ存在判定("潜伏", LOCAL + 10) 
               ;        CONTINUE
               ;    ;敵なので番号に+10して保存
               ;    奥義対象数 ++
               ;NEXT
               ;奥義対象数 = MIN(奥義対象数, 3)
               ;WSTR:(K++) = {奥義対象数}名敌人

                CALL アビ対象選択テンプレート_敵ランダムＸ体_重複無し(3)
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = ガトリング★シンフォニア
                アビ汎用文字列:バフ・デバフ対象能力 = 特殊反応_被ダメ時
                アビ汎用変数:持続ターン = 1               
                CALL アビテンプレート_不利効果_デバフ効果セット
                VARSET アビテンプレート用_表示メッセージ格納:0:0

                FOR LOCAL, 0, 10
                    ;敵が居ないマスはスキップ
                    SIF 敵BATTLE_STATE_STR:LOCAL:エネミー名 == ""
                        CONTINUE
                    ;敵が死亡済の場合はスキップ
                    SIF 敵BATTLE_STATE:LOCAL:ＨＰ < 1
                        CONTINUE
                    ;IF バフ存在判定_枠("どるるる～ん★",LOCAL) > 0     
                    ;    WSTR:(K++) = AAA             
                    ;    CALL アビ対象選択テンプレート_指定(LOCAL)
                    ;    CALL アビ汎用変数文字列リセット
                    ;    ;アビ汎用変数:効果割合 = 200 + 20 * LOCAL
                    ;    アビ汎用変数:効果量 = 0 + 200 * LOCAL
                    ;    CALL アビテンプレート_ダメージ処理_自属性
                    ;ENDIF
                    ;IF バフ存在判定_枠("どるるる～ん★",LOCAL ) <= 0  
                    ;    WSTR:(K++) = BBB             
                    ;    CALL アビ対象選択テンプレート_指定(LOCAL)
                    ;    CALL アビ汎用変数文字列リセット
                    ;    ;アビ汎用変数:効果割合 = 200 + 20 * LOCAL
                    ;    アビ汎用変数:効果量 = 0 + 200 * LOCAL
                    ;    CALL アビテンプレート_ダメージ処理_自属性
                    ;ENDIF

                    IF デバフ存在判定_枠("ガトリング★シンフォニア",LOCAL + 10) > 0     
                        CALL アビ対象選択テンプレート_指定(LOCAL + 10)
                        CALL アビ汎用変数文字列リセット
                        アビ汎用変数:効果割合 = 200 + 20 * LOCAL      
                        アビ汎用文字列:ダメージ種類 = 奥義ダメージ           
                        CALL アビテンプレート_ダメージ処理_自属性
                    ENDIF
                    IF 戦闘中カウント:隊列番号:0 < 1
                        戦闘中カウント:隊列番号:0 = 1
                        CALL アビ汎用変数文字列リセット
                        アビ汎用文字列:バフ・デバフ枠 = 被ダメージ上昇
                        アビ汎用文字列:バフ・デバフ対象能力 = 被ダメージ
                        アビ汎用変数:効果割合 = 10
                        アビ汎用変数:持続ターン = 3
                        アビ汎用変数:基礎成功確率 = 100
                        CALL アビテンプレート_不利効果_デバフ効果セット
                    ENDIF
                NEXT

                ;FOR LOCAL, 0,9
                ;    ;敵が居ないマスはスキップ
                ;    SIF 敵BATTLE_STATE_STR:LOCAL:エネミー名 == ""
                ;       CONTINUE
                ;    ;敵が死亡済の場合はスキップ
                ;    SIF 敵BATTLE_STATE:LOCAL:ＨＰ < 1
                ;       CONTINUE
                ;    ;SIF バフ・デバフ効果検索("バフ", "能力", "潜伏", 戦闘行動キャラ) > -1
                ;    SIF バフ存在判定_枠("ガトリング★シンフォニア",LOCAL + 10) <= 0 
                ;       CONTINUE                  
                ;    ;敵なので番号に+10して保存
                ;    CALL アビ対象選択テンプレート_指定(LOCAL + 10)
                ;    CALL アビ汎用変数文字列リセット
                ;    ;アビ汎用変数:効果割合 = 200 + 20 * LOCAL
                ;    アビ汎用変数:効果割合 = 0 + 200 * LOCAL
                ;    アビ汎用文字列:ダメージ種類 = 奥義ダメージ
;
                ;    CALL アビテンプレート_ダメージ処理_自属性
;
                ;    
                ;NEXT
                戦闘中カウント:隊列番号:0 = 0
               
    ENDSELECT

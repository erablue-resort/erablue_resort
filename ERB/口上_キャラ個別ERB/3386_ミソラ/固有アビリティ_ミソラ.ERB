
;--------------------------------------------------
; 技能 1: 
;--------------------------------------------------
@固有アビ_3386_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値
#DIM 効果数値２
#DIM クールタイム

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF INRANGE(隊列番号, 0, 3) && 戦闘中カウント:隊列番号:1
        クールタイム = MAX(0, 2 + 戦闘中カウント:隊列番号:1 - 現在ターン数)
        SIF クールタイム > 0
            アビテンプレート用_アビ封印用フラグ = 1
    ELSE
        クールタイム = 0
    ENDIF


    アビ名 = どるるる～ん★
    消費ＭＰ = 0 
    効果数値 = 120


    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}
            詳細文文字列受け渡し変数 += @"<br>最大3敵に攻撃力の［150~300］％のダメージを与える。"  
            詳細文文字列受け渡し変数 += @"<br>このダメージは、敵の位置番号が大きいほどダメージが増加する。"  
            SIF クールタイム > 0
		    	詳細文文字列受け渡し変数 += @"<br>（残り{クールタイム}ターン）"
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_敵ランダムＸ体_重複無し(3)
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = どるるる～ん★
            アビ汎用文字列:バフ・デバフ対象能力 = 特殊反応_被ダメ時
            アビ汎用変数:持続ターン = 1
            CALL アビテンプレート_不利効果_デバフ効果セット
            VARSET アビテンプレート用_表示メッセージ格納:0:0

            FOR LOCAL, 0, 10
                ;敵が居ないマスはスキップ
                SIF 敵BATTLE_STATE_STR:LOCAL:エネミー名 == ""
                    CONTINUE
                ;敵が死亡済の場合はスキップ
                SIF 敵BATTLE_STATE:LOCAL:ＨＰ < 1
                    CONTINUE
                ;IF バフ存在判定_枠("どるるる～ん★",LOCAL) > 0     
                ;    WSTR:(K++) = AAA             
                ;    CALL アビ対象選択テンプレート_指定(LOCAL)
                ;    CALL アビ汎用変数文字列リセット
                ;    ;アビ汎用変数:効果割合 = 200 + 20 * LOCAL
                ;    アビ汎用変数:効果量 = 0 + 200 * LOCAL
                ;    CALL アビテンプレート_ダメージ処理_自属性
                ;ENDIF
                ;IF バフ存在判定_枠("どるるる～ん★",LOCAL ) <= 0  
                ;    WSTR:(K++) = BBB             
                ;    CALL アビ対象選択テンプレート_指定(LOCAL)
                ;    CALL アビ汎用変数文字列リセット
                ;    ;アビ汎用変数:効果割合 = 200 + 20 * LOCAL
                ;    アビ汎用変数:効果量 = 0 + 200 * LOCAL
                ;    CALL アビテンプレート_ダメージ処理_自属性
                ;ENDIF

                IF デバフ存在判定_枠("どるるる～ん★",LOCAL + 10) > 0     
                    CALL アビ対象選択テンプレート_指定(LOCAL + 10)
                    CALL アビ汎用変数文字列リセット
                    アビ汎用変数:効果割合 = 150 + 15 * LOCAL                 
                    CALL アビテンプレート_ダメージ処理_自属性

                    IF バフ存在判定_枠("PSI★チャージ",隊列番号) > 0 && 戦闘中カウント:隊列番号:0 == 0
                        戦闘中カウント:隊列番号:0 += 1
                        アビ汎用変数:効果割合 = 20
                        アビ汎用文字列:バフ・デバフ枠 = 防御力B
                        アビ汎用文字列:バフ・デバフ対象能力 = 防御力
                        アビ汎用変数:持続ターン = 3
                        CALL アビテンプレート_不利効果_デバフ効果セット
                    ENDIF
                ENDIF                
            NEXT
            戦闘中カウント:隊列番号:0 = 0
            戦闘中カウント:隊列番号:1 = 現在ターン数

    ENDSELECT
    RETURN RESULT


;--------------------------------------------------
; 技能 2: 
;--------------------------------------------------
@固有アビ_3386_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値
#DIM 効果数値２
#DIM クールタイム1

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF INRANGE(隊列番号, 0, 3) && 戦闘中カウント:隊列番号:2
        クールタイム1 = MAX(0, 2 + 戦闘中カウント:隊列番号:2 - 現在ターン数)
        SIF クールタイム1 > 0
            アビテンプレート用_アビ封印用フラグ = 1
    ELSE
        クールタイム1 = 0
    ENDIF

    アビ名 = えい★えい★おー！
    消費ＭＰ = 50 
    効果数値 = 220

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>
            詳細文文字列受け渡し変数 += @"味方全体の攻撃力を［A枠/30％/2ターン］アップ,クリティカル率を［A枠/40％/2ターン］アップ"
            SIF クールタイム1 > 0
		    	詳細文文字列受け渡し変数 += @"<br>（残り{クールタイム1}ターン）"
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_味方全体_生者のみ
            CALL アビ汎用変数文字列リセット

            アビ汎用変数:効果割合 = 30
            アビ汎用文字列:バフ・デバフ枠 = 攻撃力A
            アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
            アビ汎用変数:持続ターン = 2
            CALL アビテンプレート_有利効果_バフ効果セット

            CALL アビ汎用変数文字列リセット
            アビ汎用変数:効果割合 = 40
            アビ汎用文字列:バフ・デバフ枠 = クリティカル率A
            アビ汎用文字列:バフ・デバフ対象能力 = クリティカル率
            アビ汎用変数:持続ターン = 2
            CALL アビテンプレート_有利効果_バフ効果セット


            戦闘中カウント:隊列番号:2 = 現在ターン数

    ENDSELECT
    RETURN RESULT




;--------------------------------------------------
; 战斗开始时处理 (常驻Buff等)
;--------------------------------------------------
@固有戦闘開始時処理_キャラ_3386
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数

    キャラ番号 = GETCHARA(3386)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0


    CALL アビ対象選択テンプレート_自己のみ
    CALL アビ汎用変数文字列リセット
    CALL バフ込み数値算出("回復力")
	アビ汎用変数:効果量 = RESULT * 20 / 100
    アビ汎用文字列:バフ・デバフ枠 = PSI★チャージ
    アビ汎用文字列:バフ・デバフ対象能力 = 再生
    アビ汎用変数:持続ターン = 3
    CALL アビテンプレート_有利効果_バフ効果セット


    RETURN 0



;--------------------------------------------------
; 回合开始时处理 (回复/CD/动态Buff更新)
;--------------------------------------------------
@固有行動開始時処理_キャラ_3386
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数

    キャラ番号 = GETCHARA(3386)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0
   

戦闘中カウント:隊列番号:3 += 1
IF 戦闘中カウント:隊列番号:3 % 5 == 0 ;  
    
    
    CALL アビ対象選択テンプレート_自己のみ
    CALL アビ汎用変数文字列リセット
    CALL バフ込み数値算出("回復力")
	アビ汎用変数:効果量 = RESULT * 20 / 100
    アビ汎用文字列:バフ・デバフ枠 = PSI★チャージ
    アビ汎用文字列:バフ・デバフ対象能力 = 再生
    アビ汎用変数:持続ターン = 3
    CALL アビテンプレート_有利効果_バフ効果セット

    RETURN 0
ENDIF








;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3386(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ バンキッシュ・バレット □-------------------------------------------------------------------
KSTR:(K++) = 　戦闘開始時自分に【PSI★チャージ】状態（3ターン）を付与する。
KSTR:(K++) = 　【PSI★チャージ】状態中はHPが毎ターン回復し、【どるるる～ん★】使用する際、最近の敵1キャラの防御力を小ダウンさせる。
KSTR:(K++) = 　ミソラは5回行動すると【PSI★チャージ】状態を再び獲得する。

CALL 口上変数表示(対象キャラ, 1)

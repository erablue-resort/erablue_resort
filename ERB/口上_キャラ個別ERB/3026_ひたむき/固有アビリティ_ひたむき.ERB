;--------------------------------------------------
; ナギサ 专属技能
;--------------------------------------------------
;--------------------------------------------------
; 技能 1: 
;--------------------------------------------------
@固有アビ_3026_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値
#DIM 効果数値２

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
        アビ名 = かもんたー
        消費ＭＰ = 120 
    ELSE 
        アビ名 = カウンター
        消費ＭＰ = 60 
    ENDIF

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
                詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>1Tの間、自身に［カウンター］を1回付与する。
                IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                    詳細文文字列受け渡し変数 += @"<br>（通常枠・1ターン・1回）の単体かばう効果を与える。"
                ENDIF
            ENDIF
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45 ;45
                CALL アビ汎用変数文字列リセット
                CALL アビ対象選択テンプレート_自己のみ
                アビ汎用文字列:バフ・デバフ枠 = 単体かばう
                アビ汎用文字列:バフ・デバフ対象能力 = 単体かばう
                アビ汎用変数:持続回数 = 1
                CALL アビテンプレート_有利効果_バフ効果セット
            ELSE 
            ENDIF

            CALL アビ対象選択テンプレート_自己のみ
            アビ汎用文字列:バフ・デバフ枠 = カウンター
            アビ汎用文字列:バフ・デバフ対象能力 = カウンター
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                アビ汎用変数:効果割合 = 330 
            ELSE 
                アビ汎用変数:効果割合 = 250 
            ENDIF

            アビ汎用変数:持続回数 = 1
            アビ汎用変数:持続ターン = 1
            CALL アビテンプレート_有利効果_バフ効果セット


    ENDSELECT
    RETURN RESULT

;--------------------------------------------------
; 技能 2: 
;--------------------------------------------------
@固有アビ_3026_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値
#DIM 効果数値２
#DIM キクル隊列
#DIM クールタイム1


    隊列番号 = キャラ隊列検索(キャラ番号)
    キャラ番号 = GETCHARA(3172)
    
    消費ＭＰ = BATTLE_STATE:戦闘行動キャラ:ＭＰ 
    効果数値 = 消費ＭＰ / 5 + 40

    IF INRANGE(隊列番号, 0, 3) && 戦闘中カウント:隊列番号:1
        クールタイム1 = MAX(0, 5 + 戦闘中カウント:隊列番号:1 - 現在ターン数)
        SIF クールタイム1 > 0
            アビテンプレート用_アビ封印用フラグ = 1
    ELSE
        クールタイム1 = 0
    ENDIF

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
        アビ名 = みっちゃくら
    ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 1 ;25
        アビ名 = チャクラ
    ENDIF

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"

            詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>全ＭＰを消費する,消費するＭＰによるに効果を増加。
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                詳細文文字列受け渡し変数 += @"<br>味方単体に［回復力✕{効果数値}％］のＨＰ回復を与える。"
                詳細文文字列受け渡し変数 += @"<br>対象がキクルの場合,［30％］（通常枠・3ターン）の高揚効果を与える。"
            ELSE              
                詳細文文字列受け渡し変数 += @"<br>自身に［回復力✕{効果数値}％］のＨＰ回復を与える。"
            ENDIF    
            SIF クールタイム1 > 0
		    	詳細文文字列受け渡し変数 += @"（剩余{クールタイム1}回合）"
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---
            CALL アビ汎用変数文字列リセット
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                CALL アビ対象選択テンプレート_味方単体_生者のみ
            ELSE 
                CALL アビ対象選択テンプレート_自己のみ
            ENDIF          
            アビ汎用変数:効果割合 = 効果数値 
            CALL アビテンプレート_回復処理_MAXでも回復

            キクル隊列 = キャラ隊列検索(キャラ検索("[メブキの街のエース]キクル・マダン"))
            IF アビテンプレート用_対象保存:0 == キクル隊列
                CALL アビ対象選択テンプレート_指定(アビテンプレート用_対象保存:0)
                CALL アビ汎用変数文字列リセット
                アビ汎用変数:効果量 = 30
                アビ汎用文字列:バフ・デバフ枠 = 高揚
                アビ汎用文字列:バフ・デバフ対象能力 = 高揚
                アビ汎用変数:持続ターン = 3
                CALL アビテンプレート_有利効果_バフ効果セット
            ENDIF
            戦闘中カウント:隊列番号:1 = 現在ターン数

    ENDSELECT
    RETURN RESULT



;--------------------------------------------------
; 战斗开始时处理 (常驻Buff等)
;--------------------------------------------------
@固有戦闘開始時処理_キャラ_3026
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数

    キャラ番号 = GETCHARA(3026)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0



    RETURN 0


;--------------------------------------------------
; 回合开始时处理 (回复/CD/动态Buff更新)
;--------------------------------------------------
@固有行動開始時処理_キャラ_3026
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数
#DIM 味方番号
#DIM ＭＡＸ数値
#DIM ＤＭＧキャラ
#DIM 対象指定
    キャラ番号 = GETCHARA(3026)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0

    CALL アビ汎用変数文字列リセット
    CALL アビ対象選択テンプレート_自己のみ
    アビ汎用変数:効果割合 = 25
    CALL アビテンプレート_ＭＰ回復処理_MAXでも回復


;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3026(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ 特性：武道家向いてない □------------------------------------------------------------
KSTR:(K++) = 　命中率が低く、攻撃力が低下する。回復力が高い。
KSTR:(K++) = □ 特性：魔素親和 □-------------------------------------------------------------------
KSTR:(K++) = 　最大MPは低いが、毎ターンMPが回復する。敵に狙われる確率が通常の3倍となる。
CALL 口上変数表示(対象キャラ, 1)

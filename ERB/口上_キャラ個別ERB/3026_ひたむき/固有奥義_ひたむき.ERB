@固有奥義_3026(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義实威力

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = ひたむきゃのん
    ENDIF
    奥義威力 = 150 + BATTLE_STATE:戦闘行動キャラ:ＭＰ / 2
    ;奥義实威力 = 772
    ;アビ汎用文字列:実行時メッセージ１ = 「炮手、支援を。」
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"
            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％<br>
            詳細文文字列受け渡し変数 += "既存のMPによる奥義威力増加"
            RETURN 奥義威力
        CASE "奥義説明文_詳細"

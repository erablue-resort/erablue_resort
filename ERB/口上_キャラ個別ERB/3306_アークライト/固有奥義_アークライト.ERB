
@固有奥義_3306(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 奥義威力
#DIM 威力値
#DIMS 奥義名
#DIM タゲ保存,2

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	奥義名 = 轟雷裂+
	威力値 = 700
ELSE
	奥義名 = 轟雷裂
	威力値 = 500
ENDIF
奥義威力 = 0

;奥義威力を0にした場合、通常の奥義処理は行われず奥義追加効果のみが行われる。
;全体攻撃にしたい時や、攻撃しない奥義を作る場合は0に設定のこと

SELECTCASE ARGS
	CASE "奥義名"
		TSTR:コマンド名受渡 = %奥義名%
	CASE "奥義説明文"
		詳細文文字列受け渡し変数 = 奥義威力：{威力値}％　自属性横一列攻撃。
		詳細文文字列受け渡し変数 += @"<br>対象に、［20+対象の感電Lv✕3％］（B枠・3ターン）の防御力減少効果を与える。"
		RETURN 奥義威力
	CASE "奥義前効果"
		;対象決定の後、ダメージよりも前に発生する効果。基本の奥義ダメージ部分は記載する必要はない。
		;奥義威力が0だとここの部分もスキップされる
	CASE "奥義追加効果"
		;ここに奥義効果を記述する。基本の奥義ダメージ部分は記載する必要はない。
		;基本的にアビテンプレートの関数を使用すること
		;テンプレート使用の例は固有アビリティ_キャラ名.ERBに記載
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:ダメージ種類 = 奥義ダメージ
		CALL アビ対象選択テンプレート_敵横列
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_自属性

		ARRAYCOPY "アビテンプレート用_対象保存", "タゲ保存"
		REPEAT 2
			SIF 敵BATTLE_STATE:((タゲ保存:COUNT) - 10):ＨＰ < 1
				CONTINUE
			LOCAL = DT_CELL_GET("戦闘効果データベース", デバフ番号取得_枠("感電", タゲ保存:COUNT), "効果量_固定値") / 2
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_指定(タゲ保存:COUNT)
			アビ汎用文字列:バフ・デバフ枠 = 防御力B
			アビ汎用文字列:バフ・デバフ対象能力 = 防御力
			アビ汎用変数:効果割合 = 20 + LOCAL * 3
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		REND
ENDSELECT

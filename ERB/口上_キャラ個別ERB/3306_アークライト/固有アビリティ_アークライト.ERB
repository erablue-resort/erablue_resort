
@固有アビ_3306_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値,3

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 疾風迅雷+
	消費ＭＰ = 100
	威力値 = 160
	威力値:1 = 320
	威力値:2 = 40
ELSE
	アビ名 = 疾風迅雷
	消費ＭＰ = 100
	威力値 = 80
	威力値:1 = 220
	威力値:2 = 30
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［攻撃力✕{威力値}％］の自属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>対象が感電Lv2以上の場合、追加で［攻撃力✕{威力値:1}％］の光属性ダメージを与え、"
		詳細文文字列受け渡し変数 += @"<br>味方全体に［{威力値:2}］のＭＰ回復を与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_自属性

		IF DT_CELL_GET("戦闘効果データベース", デバフ番号取得_枠("感電", アビテンプレート用_対象保存:0), "効果量_固定値") / 2 > 1
			戦闘中カウント:戦闘行動キャラ:0 ++
			アビ汎用変数:効果割合 = 威力値:1
			CALL アビテンプレート_ダメージ処理_光属性

			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_味方全体_生者のみ
			アビ汎用変数:効果量 = 威力値:2
			CALL アビテンプレート_ＭＰ回復処理_MAXでも回復
			
			IF 戦闘中カウント:戦闘行動キャラ:0 > 2
				戦闘中カウント:戦闘行動キャラ:0 = 0
				CALL アビ汎用変数文字列リセット
				CALL アビ対象選択テンプレート_味方全体_生者のみ
				アビ汎用文字列:バフ・デバフ枠 = 荒野の吟遊者
				アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
				アビ汎用変数:効果割合 = 30
				アビ汎用変数:持続ターン = 3
				CALL アビテンプレート_有利効果_バフ効果セット
			ENDIF

		ENDIF
ENDSELECT



@固有アビ_3306_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値
#DIM タゲ保存

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 雷鳴+
	消費ＭＰ = 100
	威力値 = 280
ELSE
	アビ名 = 雷鳴
	消費ＭＰ = 100
	威力値 = 190
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［攻撃力✕{威力値}％］の自属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>味方全体に［10］のＭＰ回復を与える。"
		詳細文文字列受け渡し変数 += @"<br>◆対象が感電Lv2以上の場合、2回発動する。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_自属性

		タゲ保存 = アビテンプレート用_対象保存:0
		
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_味方全体_生者のみ
		アビ汎用変数:効果量 = 10
		CALL アビテンプレート_ＭＰ回復処理_MAXでも回復

		IF DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("感電", タゲ保存), "効果量_固定値") / 2 > 1
			CALL アビ汎用変数文字列リセット
			IF 敵BATTLE_STATE:(タゲ保存 - 10):ＨＰ < 1
				CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
				SIF RESULT == -1
					CALL アビ対象選択テンプレート_指定(タゲ保存)
			ELSE
				CALL アビ対象選択テンプレート_指定(タゲ保存)
			ENDIF
			アビ汎用変数:効果割合 = 威力値
			CALL アビテンプレート_ダメージ処理_自属性
			
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_味方全体_生者のみ
			アビ汎用変数:効果量 = 10
			CALL アビテンプレート_ＭＰ回復処理_MAXでも回復
		ENDIF
		
ENDSELECT

@固有戦闘開始時処理_キャラ_3306

;バフ付け文章は出さないので1を入れておく
アビテンプレート用_アビ名表示済フラグ = 1

CALL アビ汎用変数文字列リセット
CALL アビ対象選択テンプレート_自己のみ
アビ汎用文字列:バフ・デバフ枠 = 衆生智慧
アビ汎用文字列:バフ・デバフ対象能力 = 弱体耐性
アビ汎用変数:効果量 = 50
アビ汎用変数:持続ターン = -1
アビ汎用変数:特殊表示オプション = -1
CALL アビテンプレート_有利効果_パッシブバフ効果セット

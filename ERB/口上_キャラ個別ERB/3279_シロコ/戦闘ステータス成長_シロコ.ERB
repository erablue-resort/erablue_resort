
@戦闘初期ステータス設定_3279(キャラ番号)
#DIM キャラ番号

;ここは弄らないこと
基礎BATTLE_STATE:キャラ番号:ステータスタイプ保存 = -1
基礎BATTLE_STATE:キャラ番号:Lv = 1
;ここまで弄らないこと

;初期ステータスを登録
;ステータスのバランスは「@初期ステータス設定_テンプレート適用」を参考 ステータス設定

基礎BATTLE_STATE:キャラ番号:最大ＨＰ = 180
基礎BATTLE_STATE:キャラ番号:最大ＭＰ = 120
基礎BATTLE_STATE:キャラ番号:攻撃力 = 120
基礎BATTLE_STATE:キャラ番号:防御力 = 80
基礎BATTLE_STATE:キャラ番号:回復力 = 80
基礎BATTLE_STATE:キャラ番号:行動速度 = 110
基礎BATTLE_STATE:キャラ番号:DA率 = 10
基礎BATTLE_STATE:キャラ番号:TA率 = 5
基礎BATTLE_STATE:キャラ番号:ゲージ上昇効率 = 100
基礎BATTLE_STATE:キャラ番号:ゲージ上昇効率_被ダメ時 = 100
基礎BATTLE_STATE:キャラ番号:ゲージ最大値 = 100
基礎BATTLE_STATE:キャラ番号:命中率 = 100
基礎BATTLE_STATE:キャラ番号:回避率 = 5
基礎BATTLE_STATE:キャラ番号:クリティカル率 = 27
基礎BATTLE_STATE:キャラ番号:クリティカルダメージ率 = 150
基礎BATTLE_STATE:キャラ番号:敵対心 = 100
;ステータス画面に表示されるステータスタイプ（通常、バランスや攻撃などのように表示される部分）
;空白のままだと「固有」と表示される
基礎BATTLE_STATE_STR:キャラ番号:固有ステータスタイプ名 = 攻撃·連撃

@戦闘ステータスレベルアップ設定_3279(キャラ番号, 上昇レベル)
#DIM キャラ番号
#DIM 上昇レベル
#DIM 計算後レベル

計算後レベル = 基礎BATTLE_STATE:キャラ番号:Lv + 上昇レベル

;基礎上昇量を登録
;上昇量は「@レベルアップ処理」を参考
;特定のレベルを境に上昇するステータス
基礎BATTLE_STATE:キャラ番号:最大ＨＰ += 36 * 上昇レベル
基礎BATTLE_STATE:キャラ番号:最大ＭＰ += 24 * 上昇レベル
基礎BATTLE_STATE:キャラ番号:攻撃力 += 24 * 上昇レベル
基礎BATTLE_STATE:キャラ番号:防御力 += 16 * 上昇レベル
基礎BATTLE_STATE:キャラ番号:回復力 += 16 * 上昇レベル
基礎BATTLE_STATE:キャラ番号:行動速度 += 22 * 上昇レベル
IF 基礎BATTLE_STATE:キャラ番号:Lv < 20 && 計算後レベル >= 20
    基礎BATTLE_STATE:キャラ番号:DA率 += 3
    基礎BATTLE_STATE:キャラ番号:TA率 += 1
    基礎BATTLE_STATE:キャラ番号:命中率 += 5
    基礎BATTLE_STATE:キャラ番号:回避率 += 2
ENDIF
IF 基礎BATTLE_STATE:キャラ番号:Lv < 40 && 計算後レベル >= 40
    基礎BATTLE_STATE:キャラ番号:DA率 += 3
    基礎BATTLE_STATE:キャラ番号:TA率 += 1
    基礎BATTLE_STATE:キャラ番号:命中率 += 5
    基礎BATTLE_STATE:キャラ番号:回避率 += 2
ENDIF
IF 基礎BATTLE_STATE:キャラ番号:Lv < 60 && 計算後レベル >= 60
    基礎BATTLE_STATE:キャラ番号:DA率 += 3
    基礎BATTLE_STATE:キャラ番号:TA率 += 1
    基礎BATTLE_STATE:キャラ番号:命中率 += 5
    基礎BATTLE_STATE:キャラ番号:回避率 += 2
ENDIF
IF 基礎BATTLE_STATE:キャラ番号:Lv < 80 && 計算後レベル >= 80
    基礎BATTLE_STATE:キャラ番号:DA率 += 3
    基礎BATTLE_STATE:キャラ番号:TA率 += 1
    基礎BATTLE_STATE:キャラ番号:命中率 += 5
    基礎BATTLE_STATE:キャラ番号:回避率 += 2
ENDIF


;--------------------------------------------------3218
;专属奥义
;--------------------------------------------------
@固有奥義_3279(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義威力表示

    隊列番号 = キャラ隊列検索(キャラ番号)

    ;アビ汎用変数:必要奥義ゲージ量 = 200
    ;アビ汎用変数:消費奥義ゲージ量 = 200
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = ドローン召喚：火力支援
    ENDIF
    奥義威力 = 760
    奥義威力表示 = 760
    SELECTCASE RAND:3
        CASE 0
        アビ汎用文字列:実行時メッセージ１ = 「…… 状態、良好。行くよ。」
        CASE 1
        アビ汎用文字列:実行時メッセージ１ = 「…… ユニット起動。」
        CASE 2
        アビ汎用文字列:実行時メッセージ１ = 「ドローン作動開始。」
    ENDSELECT
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力表示}％
            ;詳細文文字列受け渡し変数 += @"<br> ランダムな敵2体に［攻撃力✕{奥義威力表示}％］の自属性ダメージを2回与える。"
            ;IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
            ;    詳細文文字列受け渡し変数 += @"<br> さらに麻痺を付与（1ターン）"
            ;ENDIF
            ;詳細文文字列受け渡し変数 += @"<br>ヒフミの最大HPの160％のバリアを与える。味方を援護する。"
            
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
        CASE "奥義追加効果"
ENDSELECT

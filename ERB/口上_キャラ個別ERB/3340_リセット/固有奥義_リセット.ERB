
@固有奥義_3340(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力

    隊列番号 = キャラ隊列検索(キャラ番号)
	アビ汎用変数:必要奥義ゲージ量 = 70
	アビ汎用変数:消費奥義ゲージ量 = 70
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = クラウゼンの手
    ENDIF
    奥義威力 = 0
    ;SELECTCASE RAND:3
    ;    CASE 0
    ;    アビ汎用文字列:実行時メッセージ１ = 「悠久を思うといい。」
    ;    CASE 1
    ;    アビ汎用文字列:実行時メッセージ１ = 「今、共にある時間を賛美しよう。」
    ;    CASE 2
    ;    アビ汎用文字列:実行時メッセージ１ = 「語らうことに異存はないとも。」
    ;ENDSELECT
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％<br>
            詳細文文字列受け渡し変数 += @"<br>自身を除く味方1人に［10］の無属性ダメージを与える,弱体状態を解除，［40％］（C枠・3ターン）の弱体耐性上昇効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>◆奥義ゲージ70％の時奥義発動可能"
            
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
              ; --- 效果处理 ---
            ; CALL アビ対象選択テンプレート_味方全体
            ; CALL アビ汎用変数文字列リセット
            ; アビ汎用文字列:バフ・デバフ枠 = まどろみの庭
            ; アビ汎用文字列:バフ・デバフ対象能力 = 高揚
            ; アビ汎用変数:効果割合 = 20
            ; アビ汎用変数:持続ターン = 3
            ; CALL アビテンプレート_有利効果_バフ効果セット    
            CASE "奥義追加効果"
                CALL アビ対象選択テンプレート_味方単体_生者のみ_自己以外

				CALL アビ汎用変数文字列リセット
				アビ汎用変数:効果量 = 10
				CALL アビテンプレート_ダメージ処理_無属性

				CALL アビ汎用変数文字列リセット
				CALL アビテンプレート_有利効果_デバフ全て消去()

                アビ汎用文字列:バフ・デバフ枠 = クラウゼンの手
                アビ汎用文字列:バフ・デバフ対象能力 = 弱体耐性
				アビ汎用変数:効果割合 = 40
				アビ汎用変数:持続ターン = 3
                CALL アビテンプレート_有利効果_バフ効果セット      
				
				

    ENDSELECT

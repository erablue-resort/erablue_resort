;--------------------------------------------------
; ナギサ 专属技能
;--------------------------------------------------
;--------------------------------------------------
; 技能 1: 
;--------------------------------------------------
@固有アビ_2401_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM クールタイム

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        アビ名 = 狂花
        消費ＭＰ = 50 ;修改500
    ENDIF

    IF バフ番号取得_枠("狂花", 戦闘行動キャラ) > -1
        アビテンプレート用_アビ封印用フラグ = 1
    ENDIF

    IF INRANGE(隊列番号, 0, 3) && 戦闘中カウント:隊列番号:0
        クールタイム = MAX(0, 10 + 戦闘中カウント:隊列番号:0 - 現在ターン数)
        SIF クールタイム > 0
            アビテンプレート用_アビ封印用フラグ = 1
    ELSE
        クールタイム = 0
    ENDIF

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
                詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>制御を失ったマナが体内で高速循環し肉体を補強する「狂花」になってしまう。
                詳細文文字列受け渡し変数 += @"<br>MPが毎ターン消耗し,尽くしたときに解除する。"
                詳細文文字列受け渡し変数 += @"<br>このアビリティでは行動回数を消費しない。"
            ENDIF
            SIF クールタイム > 0
		    	詳細文文字列受け渡し変数 += @"（剩余{クールタイム}回合）"
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_自己のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 狂花
            アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
            アビ汎用変数:効果割合 = 150
            アビ汎用変数:持続ターン = -1
            アビ汎用変数:消去不可オプション = 1
            CALL アビテンプレート_有利効果_バフ効果セット
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_自己のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 狂花_与ダメージ
            アビ汎用文字列:バフ・デバフ対象能力 = 与ダメージ
            アビ汎用変数:効果割合 = 50
            アビ汎用変数:持続ターン = -1
            アビ汎用変数:消去不可オプション = 1
            CALL アビテンプレート_有利効果_バフ効果セット

            CALL アビ対象選択テンプレート_自己のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 狂花_被ダメージ
            アビ汎用文字列:バフ・デバフ対象能力 = 被ダメージ
            アビ汎用変数:効果割合 = 50
            アビ汎用変数:持続ターン = -1
            アビ汎用変数:消去不可オプション = 1
            CALL アビテンプレート_有利効果_パッシブバフ効果セット
            ; --- 效果处理 ---

            CALL アビ対象選択テンプレート_自己のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 狂花_ダメージ補正_アビリティダメージ
            アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_アビリティダメージ
            アビ汎用変数:効果割合 = 50
            アビ汎用変数:持続ターン = -1
            アビ汎用変数:消去不可オプション = 1
            CALL アビテンプレート_有利効果_バフ効果セット
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_自己のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 狂花_クリティカルダメージ率
            アビ汎用文字列:バフ・デバフ対象能力 = クリティカルダメージ率
            アビ汎用変数:効果割合 = 25
            アビ汎用変数:持続ターン = -1
            アビ汎用変数:消去不可オプション = 1
            CALL アビテンプレート_有利効果_バフ効果セット


            アビテンプレート用_行動消費無しフラグ = 1
            戦闘中カウント:隊列番号:0 = 現在ターン数
    ENDSELECT
    RETURN RESULT

;--------------------------------------------------
; 技能 2: 
;--------------------------------------------------
@固有アビ_2401_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値
#DIM 効果数値２
#DIM クールタイム

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 40
        アビ名 = 大旋風
        消費ＭＰ = 160 ;修改500
        効果数値 = 330
        効果数値２ = 120
    ELSE
        アビ名 = 爆砕
        消費ＭＰ = 80 ;修改500
        効果数値 = 180
        効果数値２ = 80
    ENDIF

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
                詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}
                詳細文文字列受け渡し変数 += @"<br>敵単体に［攻撃力✕{効果数値}％］のダメージを与える。"
                詳細文文字列受け渡し変数 += @"<br>敵全体に［攻撃力✕{効果数値２}％］のダメージを与える。"
            ENDIF
            
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---
            
            CALL アビ対象選択テンプレート_敵単体
            CALL アビ汎用変数文字列リセット
            アビ汎用変数:効果割合 = 効果数値
            CALL アビテンプレート_ダメージ処理_自属性

            CALL アビ対象選択テンプレート_敵全体_生者のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用変数:効果割合 = 効果数値２ 
            CALL アビテンプレート_ダメージ処理_自属性

    ENDSELECT
    RETURN RESULT



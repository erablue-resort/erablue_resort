;--------------------------------------------------
; 回合开始时处理 (回复/CD/动态Buff更新)
;--------------------------------------------------
@固有行動開始時処理_キャラ_2401
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数
#DIM 味方番号
#DIM ＭＡＸ数値
#DIM ＤＭＧキャラ
#DIM 対象指定
#DIM キクル隊列

    キャラ番号 = GETCHARA(2401)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0

    ; --- 特性: 狂花发动---
    IF バフ番号取得_枠("狂花", 隊列番号) > -1
        IF BATTLE_STATE:隊列番号:ＭＰ > BATTLE_STATE:隊列番号:最大ＭＰ * 6 / 10
            
            WSTR:(K++) = 「フルでいくのらー」
            アビテンプレート用_アビ名 = 狂花
            BATTLE_STATE:隊列番号:ＭＰ -= BATTLE_STATE:隊列番号:最大ＭＰ * 1 / 10

            キクル隊列 = キャラ隊列検索(キャラ検索("[メブキの街のエース]キクル・マダン"))
            IF INRANGE(キクル隊列, 0, 3)
                CALL アビ対象選択テンプレート_指定(キクル隊列)          
            ELSE 
                CALL アビ対象選択テンプレート_味方全体_生者のみ_自己以外
            ENDIF
            CALL アビ汎用変数文字列リセット
            アビ汎用変数:効果割合 = 40 
            CALL アビテンプレート_ダメージ処理_自属性

            CALL アビ対象選択テンプレート_敵全体_生者のみ
            アビ汎用変数:効果割合 = 55 
            CALL アビテンプレート_ダメージ処理_自属性
            
        ELSE 
           ; WSTR:(K++) = 「狂花」は解除された
            アビテンプレート用_アビ名 = 「狂花」解除
            行動不能フラグ = 1

            CALL アビ対象選択テンプレート_自己のみ
            アビ汎用変数:消去不可バフデバフ削除オプション = 1
            CALL アビテンプレート_不利効果_バフ消去("狂花")
            CALL アビテンプレート_不利効果_バフ消去("狂花_与ダメージ")
            CALL アビテンプレート_不利効果_バフ消去("狂花_被ダメージ")
            CALL アビテンプレート_不利効果_バフ消去("狂花_ダメージ補正_アビリティダメージ")
            CALL アビテンプレート_不利効果_バフ消去("狂花_クリティカルダメージ率")

            CALL アビ汎用変数文字列リセット
            CALL アビ対象選択テンプレート_自己のみ
            アビ汎用文字列:バフ・デバフ枠 = 睡眠
            アビ汎用文字列:バフ・デバフ対象能力 = 睡眠
            アビ汎用変数:効果割合 = 100
            アビ汎用変数:基礎成功確率 = 100
            アビ汎用変数:弱体耐性貫通オプション = 1
            アビ汎用変数:持続ターン = 10
            CALL アビテンプレート_不利効果_デバフ効果セット
        ENDIF
    ENDIF

    



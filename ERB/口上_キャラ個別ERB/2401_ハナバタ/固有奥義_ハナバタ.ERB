
;--------------------------------------------------
; Unknown 专属奥义
;--------------------------------------------------
@固有奥義_2401(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義实威力

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = 打上花火
    ENDIF
    奥義威力 = 400
    奥義实威力 = 400
    ;アビ汎用文字列:実行時メッセージ１ = 「炮手、支援を。」
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"
            詳細文文字列受け渡し変数 = 奥義威力：{奥義实威力}％<br>
            詳細文文字列受け渡し変数 += "さらに敵全体に攻撃力×250％分のダメージ/［60％］の封印効果を与える,成功率75％。"
            RETURN 奥義威力
        CASE "奥義説明文_詳細"
            ;詳細文文字列受け渡し変数 += @"先降低敌方单体的防御力［{効果数値}％／独立槽］，然后造成奥义伤害。"
        CASE "奥義前効果"
            ; --- 效果处理 ---           
            ;CALL アビ汎用変数文字列リセット
           

           ; CALL アビ対象選択テンプレート_敵縦列
           ; アビ汎用変数:効果割合 = 772
           ; CALL アビテンプレート_ダメージ処理_自属性
            ; --- 效果处理 ---
        CASE "奥義追加効果"
            CALL アビ対象選択テンプレート_敵全体_生者のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 封印
            アビ汎用文字列:バフ・デバフ対象能力 = 封印
            アビ汎用変数:効果割合 = 60
            アビ汎用変数:持続ターン = 1
            アビ汎用変数:基礎成功確率 = 75
            CALL アビテンプレート_不利効果_デバフ効果セット

            CALL アビ対象選択テンプレート_敵全体_生者のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用変数:効果割合 = 250
            アビ汎用文字列:ダメージ種類 = 奥義ダメージ
            ;FOR LOCAL, 0, 3
                CALL アビテンプレート_ダメージ処理_自属性
            ;NEXT
    ENDSELECT

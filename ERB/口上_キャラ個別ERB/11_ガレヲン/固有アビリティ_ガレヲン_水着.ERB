#DIM ガレヲン隊列

ガレヲン隊列 = キャラ隊列検索(GETCHARA(11))

IF 行動不能フラグ == 1 && INRANGE(ガレヲン隊列, 0, 3) && 探索中カウント:ガレヲン隊列:1 < 4
	探索中カウント:ガレヲン隊列:1 += 1
ENDIF



@『金』の爛夏固有ターン終了時処理_キャラ
#DIM ガレヲン隊列

ガレヲン隊列 = キャラ隊列検索(GETCHARA(11))

IF 探索中カウント:ガレヲン隊列:1 > 0
	WSTR:(K++) = 《破潰。（usubut…）》
	アビテンプレート用_アビ名 = 夏風に安らぎを
	
	CALL アビ汎用変数文字列リセット
	CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
	アビ汎用変数:効果割合 = 200
	CALL アビテンプレート_ダメージ処理_風属性
	
	CALL アビ汎用変数文字列リセット
	アビ汎用変数:効果量 = 1
	CALL アビテンプレート_不利効果_バフ消去
	
	探索中カウント:ガレヲン隊列:1 = 0
ENDIF

IF 探索中カウント:ガレヲン隊列:0 == 1
	アビテンプレート用_アビ名 = 巌迫の慈愛
	
	CALL アビ汎用変数文字列リセット
	CALL アビ対象選択テンプレート_自己のみ
	CALL アビテンプレート_有利効果_ウェポンバースト
	
	探索中カウント:ガレヲン隊列:0 = 0
ENDIF



@『金』の爛夏探索欄表示_キャラ(レイヤー番号, 隊列番号)
#DIM 隊列番号
#DIM レイヤー番号

IF バフ番号取得_枠("豊穣の基石", 隊列番号) > -1
	GSETBRUSH レイヤー番号, 0xFFFFC805
	GDRAWTEXT レイヤー番号, @"○", 120, 90
	GDRAWTEXT レイヤー番号, @"☩", 120, 90
ENDIF



@バフ・デバフ特殊表示_豊穣の基石(隊列番号, バフ・デバフ行数)
#DIM 隊列番号
#DIM バフ・デバフ行数
VARSET LOCALS

PRINTFORML 豊穣の基石
PRINTFORML TA率・通常攻撃与ダメージが上昇し、通常攻撃時に追撃を行う状態（消去不可）
PRINTFORML 持続ターン：{DT_CELL_GET("戦闘効果データベース", バフ・デバフ行数, "持続ターン")}



@バフ・デバフ特殊表示_金の至愛(隊列番号, バフ・デバフ行数)
#DIM 隊列番号
#DIM バフ・デバフ行数
VARSET LOCALS

PRINTFORML 金の至愛
PRINTFORML 攻撃力・TA率・通常攻撃与ダメージが上昇している状態（消去不可）
PRINTFORML 持続ターン：{DT_CELL_GET("戦闘効果データベース", バフ・デバフ行数, "持続ターン")}




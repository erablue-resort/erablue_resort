
@固有アビ_3303_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値
#DIM タゲ保存,アビ対象最大数

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 出征+
	消費ＭＰ = 100
	威力値 = 240
ELSE
	アビ名 = 出征
	消費ＭＰ = 100
	威力値 = 150
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵縦一列に［{威力値}％］の火属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>［累積10％最大40％］（累積枠・5ターン）の攻撃力減少効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>対象が既に累積攻撃力減少状態の場合、追加で［150％］の自属性ダメージを与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵縦列
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_火属性

		ARRAYCOPY "アビテンプレート用_対象保存", "タゲ保存"
		VARSET LOCAL
		FOR LOCAL, 0, アビ対象最大数
			SIF アビテンプレート用_対象保存:LOCAL < 0
				CONTINUE
			IF 敵BATTLE_STATE:((アビテンプレート用_対象保存:LOCAL) - 10):ＨＰ < 1 || デバフ番号取得_枠("攻撃力累積", アビテンプレート用_対象保存:LOCAL) < 0
				アビテンプレート用_対象保存:LOCAL = -1
			ELSE
				LOCAL:1 = 1
			ENDIF
		NEXT
		IF LOCAL:1
			CALL アビ汎用変数文字列リセット
			アビ汎用変数:効果割合 = 150
			CALL アビテンプレート_ダメージ処理_自属性
		ENDIF
		ARRAYCOPY "タゲ保存", "アビテンプレート用_対象保存"
		CALL アビ汎用変数文字列リセット
		アビ汎用変数:効果割合 = 10
		アビ汎用変数:累積上限_割合 = 40
		アビ汎用文字列:バフ・デバフ枠 = 攻撃力累積
		アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
		アビ汎用変数:持続ターン = 5
		CALL アビテンプレート_不利効果_累積デバフ効果セット

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 突陣の意志_被ダメ
		アビ汎用文字列:バフ・デバフ対象能力 = 被ダメージ
		アビ汎用変数:効果割合 = 50
		アビ汎用変数:持続ターン = 1
		アビ汎用変数:消去不可オプション = 1
		CALL アビテンプレート_有利効果_バフ効果セット

		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 突陣の意志_敵対心
		アビ汎用文字列:バフ・デバフ対象能力 = 敵対心
		アビ汎用変数:効果量 = 300
		アビ汎用変数:持続ターン = 1
		アビ汎用変数:消去不可オプション = 1
		CALL アビテンプレート_有利効果_バフ効果セット
ENDSELECT



@固有アビ_3303_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値,2

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 前線支援+
	消費ＭＰ = 100
	威力値 = 180
	威力値:1 = 80
ELSE
	アビ名 = 前線支援
	消費ＭＰ = 100
	威力値 = 120
	威力値:1 = 60
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［{威力値}％］の自属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>［累積10％最大40％］（累積枠・5ターン）の攻撃力減少効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>対象が既に累積攻撃力減少状態の場合、追加で［150％］の自属性ダメージを与える。"
		詳細文文字列受け渡し変数 += @"<br>最もＨＰが少ない味方に［回復力✕{威力値:1}％］のＨＰ回復を与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_自属性
		
		SIF アビテンプレート用_キャンセルフラグ
			RETURN
		IF 敵BATTLE_STATE:((アビテンプレート用_対象保存:0) - 10):ＨＰ > 0 && デバフ番号取得_枠("攻撃力累積", アビテンプレート用_対象保存:0) > -1
			アビ汎用変数:効果割合 = 150
			CALL アビテンプレート_ダメージ処理_自属性
		ENDIF
		
		CALL アビ汎用変数文字列リセット
		アビ汎用変数:効果割合 = 10
		アビ汎用変数:累積上限_割合 = 40
		アビ汎用文字列:バフ・デバフ枠 = 攻撃力累積
		アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
		アビ汎用変数:持続ターン = 5
		CALL アビテンプレート_不利効果_累積デバフ効果セット

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_味方単体_最小ＨＰ
		アビ汎用変数:効果割合 = 威力値:1
		CALL アビテンプレート_回復処理_MAXでも回復

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 突陣の意志_被ダメ
		アビ汎用文字列:バフ・デバフ対象能力 = 被ダメージ
		アビ汎用変数:効果割合 = 50
		アビ汎用変数:持続ターン = 1
		アビ汎用変数:消去不可オプション = 1
		CALL アビテンプレート_有利効果_バフ効果セット

		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 突陣の意志_敵対心
		アビ汎用文字列:バフ・デバフ対象能力 = 敵対心
		アビ汎用変数:効果量 = 300
		アビ汎用変数:持続ターン = 1
		アビ汎用変数:消去不可オプション = 1
		CALL アビテンプレート_有利効果_バフ効果セット
ENDSELECT


@固有被ダメ時処理_キャラ_3303(全滅フラグ)
#DIM 全滅フラグ

SIF 全滅フラグ
	RETURN 0

CALL アビ汎用変数文字列リセット
CALL アビ対象選択テンプレート_自己のみ
アビテンプレート用_アビ名 = アビリティ：鉄で鉄を貫く発動
アビ汎用文字列:バフ・デバフ枠 = 鉄で鉄を貫く
アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
アビ汎用変数:効果割合 = 10
アビ汎用変数:累積上限_割合 = 40
アビ汎用変数:持続ターン = 2
アビ汎用変数:消去不可オプション = 1
CALL アビテンプレート_有利効果_累積バフ効果セット


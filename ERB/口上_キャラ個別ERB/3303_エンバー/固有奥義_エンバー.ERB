
@固有奥義_3303(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 奥義威力
#DIM 威力値,2
#DIMS 奥義名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	奥義名 = 誓約の炎+
	威力値 = 520
	威力値:1 = 25
ELSE
	奥義名 = 誓約の炎
	威力値 = 350
	威力値:1 = 20
ENDIF
奥義威力 = 0

;奥義威力を0にした場合、通常の奥義処理は行われず奥義追加効果のみが行われる。
;全体攻撃にしたい時や、攻撃しない奥義を作る場合は0に設定のこと

SELECTCASE ARGS
	CASE "奥義名"
		TSTR:コマンド名受渡 = %奥義名%
	CASE "奥義説明文"
		詳細文文字列受け渡し変数 = 奥義威力：{威力値}％　自属性縦一列攻撃。
		詳細文文字列受け渡し変数 += @"<br>味方全体に［最大ＨＰ✕{威力値:1}］（通常枠）のバリア効果を与える"
		RETURN 奥義威力
	CASE "奥義前効果"
		;対象決定の後、ダメージよりも前に発生する効果。基本の奥義ダメージ部分は記載する必要はない。
		;奥義威力が0だとここの部分もスキップされる
	CASE "奥義追加効果"
		;ここに奥義効果を記述する。基本の奥義ダメージ部分は記載する必要はない。
		;基本的にアビテンプレートの関数を使用すること
		;テンプレート使用の例は固有アビリティ_キャラ名.ERBに記載
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:ダメージ種類 = 奥義ダメージ
		CALL アビ対象選択テンプレート_敵縦列
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_自属性

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_味方全体_生者のみ
		アビ汎用文字列:バフ・デバフ枠 = バリア
		アビ汎用文字列:バフ・デバフ対象能力 = バリア
		アビ汎用変数:効果量 = BATTLE_STATE:戦闘行動キャラ:最大ＨＰ * 威力値:1 / 100
		CALL アビテンプレート_有利効果_バフ効果セット
ENDSELECT

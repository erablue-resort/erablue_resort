@固有行動開始時処理_キャラ_3384
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数

    キャラ番号 = GETCHARA(3384)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0
   
戦闘中カウント:隊列番号:0 += 1
IF 戦闘中カウント:隊列番号:0 % 3 == 0 ;
      
    CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
    CALL アビ汎用変数文字列リセット   
    アビテンプレート用_アビ名 = 特性：I.F.F
    WSTR:(K++) = 「次の任務は、黒字を期待してくださいね。」  
    アビ汎用変数:効果割合 = 573
    CALL アビテンプレート_ダメージ処理_自属性

    RETURN 0

ENDIF

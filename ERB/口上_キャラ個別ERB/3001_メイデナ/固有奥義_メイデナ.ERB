
;--------------------------------------------------
; セイア 专属奥义
;--------------------------------------------------
@固有奥義_3001(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 効果数値

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
        奥義名 = キュアル
        効果数値 = 200
    ELSE
        奥義名 = キュアルラ
        効果数値 = 150
    ENDIF

    奥義威力 = 0
    ;アビ汎用文字列:実行時メッセージ１ = 「今、共にある時間を賛美しよう。」
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％<br>
            詳細文文字列受け渡し変数 += @"味方全体に［回復力✕{効果数値}％］のＨＰ回復を与える。"			
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
                詳細文文字列受け渡し変数 += @"<br>［1］のデバフ消去を与える。"
            ENDIF
            
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
              ; --- 效果处理 ---
            ; CALL アビ対象選択テンプレート_味方全体
            ; CALL アビ汎用変数文字列リセット
            ; アビ汎用文字列:バフ・デバフ枠 = まどろみの庭
            ; アビ汎用文字列:バフ・デバフ対象能力 = 高揚
            ; アビ汎用変数:効果割合 = 20
            ; アビ汎用変数:持続ターン = 3
            ; CALL アビテンプレート_有利効果_バフ効果セット    
        CASE "奥義追加効果"
            CALL アビ対象選択テンプレート_味方全体_生者のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用変数:効果割合 = 効果数値
            CALL アビテンプレート_回復処理_MAXでも回復
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
                CALL アビテンプレート_有利効果_デバフ消去()
            ENDIF      

    ENDSELECT

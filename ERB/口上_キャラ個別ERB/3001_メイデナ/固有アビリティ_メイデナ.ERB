;--------------------------------------------------
; メイデナ 专属技能
;--------------------------------------------------

;--------------------------------------------------
; 技能 1: ピュリフル
;--------------------------------------------------
@固有アビ_3001_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値

    隊列番号 = キャラ隊列検索(キャラ番号)

    アビ名 = ピュリフル
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 30    
        消費ＭＰ = 80
        効果数値 = 30
    ELSE
        消費ＭＰ = 50
    ENDIF


    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>浄化魔法。味方全体に［2］のデバフ消去を与える。
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 30
                詳細文文字列受け渡し変数 += @"<br>［回復力✕{効果数値}％］のＨＰ回復を与える。"
            ENDIF
            RETURN 消費ＭＰ

        CASE "アビ効果"
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_味方全体_生者のみ
            CALL アビ汎用変数文字列リセット
            ; 净化我方Debuff (消除指定数量)
            アビ汎用変数:効果量 = 2
            CALL アビテンプレート_有利効果_デバフ消去
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 30              
                CALL アビ汎用変数文字列リセット
                アビ汎用変数:効果割合 = 効果数値
                CALL アビテンプレート_回復処理_MAXでも回復
            ENDIF

    ENDSELECT
    RETURN RESULT

;--------------------------------------------------
; 技能 2: シルドマ
;--------------------------------------------------
@固有アビ_3001_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        アビ名 = シルドマ
        消費ＭＰ = 15
    ENDIF


    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
                詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>自身の周りに魔法の盾を発生させる防御魔法。<br>自身に［回復力✕60％］のバリアを与える。成功率75％。
            ENDIF
            RETURN 消費ＭＰ

        CASE "アビ効果"

            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_自己のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ対象能力 = バリア
            CALL バフ込み数値算出("回復力")
            アビ汎用変数:効果量 = RESULT  * 6 / 10
            アビ汎用変数:持続ターン = 5
            アビ汎用変数:基礎成功確率 = 75
            CALL アビテンプレート_有利効果_バフ効果セット
            

    ENDSELECT
    RETURN RESULT



;--------------------------------------------------
; 战斗开始时处理 (常驻Buff等)
;--------------------------------------------------
@固有戦闘開始時処理_キャラ_3001
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数

    キャラ番号 = GETCHARA(3001)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0
    ; --- 特性: 聖ペニスクアカデミーの天使 ---

    CALL アビ対象選択テンプレート_自己のみ
    アビ汎用変数:効果量 = 0
    アビ汎用変数:消去不可オプション = 1
    アビ汎用文字列:バフ・デバフ枠 = 聖ペニスクアカデミーの天使
    アビ汎用文字列:バフ・デバフ対象能力 = 特殊反応_被ダメ時
    アビ汎用変数:持続回数 = -1
    CALL アビテンプレート_有利効果_バフ効果セット

    アビ汎用文字列:バフ・デバフ枠 = 聖ペニスクアカデミーの天使_与ダメージ減少
    アビ汎用文字列:バフ・デバフ対象能力 = 与ダメージ
    アビ汎用変数:効果量 = 100
    アビ汎用変数:消去不可オプション = 1
    アビ汎用変数:持続ターン = -1
    CALL アビテンプレート_不利効果_デバフ効果セット
 
   
        

    RETURN 0


;@バフ・デバフ特殊表示_聖ペニスクアカデミーの天使_回復力(隊列番号, バフ・デバフ行数)
;#DIM 隊列番号
;#DIM バフ・デバフ行数
;VARSET LOCALS
;
;PRINTFORML 2
;PRINTFORML 提升回复力
;PRINTFORML 持続ターン：永続
;
;@バフ・デバフ特殊表示_聖ペニスクアカデミーの天使_与ダメージ(隊列番号, バフ・デバフ行数)
;#DIM 隊列番号
;#DIM バフ・デバフ行数
;VARSET LOCALS
;
;PRINTFORML 1
;PRINTFORML 减少造成伤害
;PRINTFORML 持続ターン：永続
;--------------------------------------------------
; 回合开始时处理 (回复/CD/动态Buff更新)
;--------------------------------------------------
@固有行動開始時処理_キャラ_3001
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数

    キャラ番号 = GETCHARA(3001)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0

    IF バフ番号取得_枠("聖ペニスクアカデミーの天使", 隊列番号) < 0
        ; --- 特性: 聖ペニスクアカデミーの天使 ---

        CALL アビ対象選択テンプレート_自己のみ
        CALL アビ汎用変数文字列リセット
        アビ汎用変数:効果量 = 0
        アビ汎用変数:消去不可オプション = 1
        アビ汎用文字列:バフ・デバフ枠 = 聖ペニスクアカデミーの天使
        アビ汎用文字列:バフ・デバフ対象能力 = 特殊反応_被ダメ時
        アビ汎用変数:持続回数 = -1
        CALL アビテンプレート_有利効果_バフ効果セット

        ; --- 特性: 聖ペニスクアカデミーの天使 ---
        CALL アビ対象選択テンプレート_自己のみ
        CALL アビ汎用変数文字列リセット
        アビ汎用文字列:バフ・デバフ枠 = 聖ペニスクアカデミーの天使_与ダメージ減少
        アビ汎用文字列:バフ・デバフ対象能力 = 与ダメージ
        アビ汎用変数:効果量 = 100
        アビ汎用変数:消去不可オプション = 1
        アビ汎用変数:持続ターン = -1
        CALL アビテンプレート_不利効果_デバフ効果セット
    ENDIF


    RETURN 0

@特殊反応_被ダメ時_聖ペニスクアカデミーの天使(バフ番号, 隊列番号, 被ダメ記録順)
#DIM 被ダメ記録順
#DIM 隊列番号
#DIM バフ番号

#DIM メイデナ隊列
#DIM キクル隊列

隊列番号 = キャラ隊列検索(GETCHARA(3001))

CALL アビ対象選択テンプレート_自己のみ
メイデナ隊列 = キャラ隊列検索(キャラ検索("[つんけん白魔]メイデナ・アンジェ"))
キクル隊列 = キャラ隊列検索(キャラ検索("[メブキの街のエース]キクル・マダン"))
; 施加状态异常: 麻痺
CALL アビ汎用変数文字列リセット
アビ汎用文字列:バフ・デバフ枠 = 麻痺
アビ汎用文字列:バフ・デバフ対象能力 = 麻痺
アビ汎用変数:効果割合 = 100
アビ汎用変数:基礎成功確率 = 60

IF INRANGE(メイデナ隊列, 0, 3) && INRANGE(キクル隊列, 0, 3)
	アビ汎用変数:基礎成功確率 = アビ汎用変数:基礎成功確率 * 1 / 3
ENDIF
アビ汎用変数:持続ターン = 1
CALL アビテンプレート_不利効果_デバフ効果セット




@固有奥義_3267(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 奥義威力
#DIM 威力値
#DIM 隊列番号
#DIMS 奥義名

隊列番号 = キャラ隊列検索(キャラ番号)
アビ汎用変数:必要奥義ゲージ量 = 200
アビ汎用変数:消費奥義ゲージ量 = 200

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	奥義名 = 終の別れ+
	威力値 = 1280
ELSE
	奥義名 = 終の別れ
	威力値 = 850
ENDIF
奥義威力 = 0

;奥義威力を0にした場合、通常の奥義処理は行われず奥義追加効果のみが行われる。
;全体攻撃にしたい時や、攻撃しない奥義を作る場合は0に設定のこと

SELECTCASE ARGS
	CASE "奥義名"
		TSTR:コマンド名受渡 = %奥義名%
		IF 隊列番号 > -1
			SIF BATTLE_STATE:隊列番号:奥義ゲージ < 200
				RETURN 1
		ENDIF
	CASE "奥義説明文"
		詳細文文字列受け渡し変数 = 奥義威力：{威力値}％
		詳細文文字列受け渡し変数 += @"<br>敵全体に自属性の［攻撃力✕{威力値}％］ダメージを与える。"
		詳細文文字列受け渡し変数 += @"<br>自身にダメージカット［100％］（1ターン）効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>◆奥義ゲージ200％の時のみ奥義発動可能"
		RETURN 奥義威力
	CASE "奥義前効果"
		;対象決定の後、ダメージよりも前に発生する効果。基本の奥義ダメージ部分は記載する必要はない。
		;奥義威力が0だとここの部分もスキップされる
	CASE "奥義追加効果"
		;ここに奥義効果を記述する。基本の奥義ダメージ部分は記載する必要はない。
		;基本的にアビテンプレートの関数を使用すること
		;テンプレート使用の例は固有アビリティ_キャラ名.ERBに記載
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:ダメージ種類 = 奥義ダメージ
		CALL アビ対象選択テンプレート_敵全体_生者のみ
		アビ汎用変数:効果割合 = 威力値
		アビ汎用変数:防御無視オプション_割合 = 50
		CALL アビテンプレート_ダメージ処理_自属性

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 被ダメージ減少
		アビ汎用文字列:バフ・デバフ対象能力 = 被ダメージ
		アビ汎用変数:効果割合 = 100
		アビ汎用変数:持続ターン = 1
		CALL アビテンプレート_有利効果_バフ効果セット
ENDSELECT

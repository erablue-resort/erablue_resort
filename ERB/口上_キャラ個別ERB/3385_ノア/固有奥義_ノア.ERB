
;--------------------------------------------------3218
;专属奥义
;--------------------------------------------------
@固有奥義_3385(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義威力表示

    隊列番号 = キャラ隊列検索(キャラ番号)

    ;アビ汎用変数:必要奥義ゲージ量 = 200
    ;アビ汎用変数:消費奥義ゲージ量 = 200
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = 記録はスピードが命ですから
    ENDIF
    奥義威力 = 0
    奥義威力表示 = 0
    SELECTCASE RAND:3
        CASE 0
        アビ汎用文字列:実行時メッセージ１ = 「なるほど…… そこが弱点ですね？」
        CASE 1
        アビ汎用文字列:実行時メッセージ１ = 「へぇ…… これは興味深いですね。」
        CASE 2
        アビ汎用文字列:実行時メッセージ１ = 「ふふ… …今度はこちらを攻めてみましょう」
    ENDSELECT
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力表示}％
            詳細文文字列受け渡し変数 += @"<br> 指定した敵1人に対して集中砲火状態（6ターン）"
            詳細文文字列受け渡し変数 += @"<br>防御力を40％減少（6ターン）"
            
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
        CASE "奥義追加効果"
            CALL アビ対象選択テンプレート_敵単体
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 集中砲火
            アビ汎用文字列:バフ・デバフ対象能力 = 敵対心
            アビ汎用変数:効果量 = 999
            アビ汎用変数:持続ターン = 6
            CALL アビテンプレート_有利効果_バフ効果セット  
            
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 記録はスピードが命ですから
            アビ汎用文字列:バフ・デバフ対象能力 = 防御力
            アビ汎用変数:効果割合 = 40
            アビ汎用変数:持続ターン = 6
            CALL アビテンプレート_不利効果_デバフ効果セット

ENDSELECT

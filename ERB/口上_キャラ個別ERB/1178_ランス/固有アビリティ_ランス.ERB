
;--------------------------------------------------
; 战斗开始时处理 (常驻Buff等)
;--------------------------------------------------
@固有戦闘開始時処理_キャラ_1178
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数
#DIM ランス隊列
#DIM リセット隊列

    キャラ番号 = GETCHARA(1178)
    SIF キャラ番号 < 0
        RETURN 0

    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0

    
    リセット隊列 = キャラ隊列検索(キャラ検索("[ランスとパステルの娘]リセット・カラー"))
    ;ランス隊列 = キャラ隊列検索(キャラ検索("[鬼畜戦士]ランス"))
    SIF INRANGE(リセット隊列, 0, 3)
        WSTR:(K++) = 「111」
    ;SIF INRANGE(ランス隊列, 0, 3)
    ;    WSTR:(K++) = 「222」

    IF INRANGE(リセット隊列, 0, 3)
        WSTR:(K++) = 「2」

        CALL アビ対象選択テンプレート_自己のみ
        CALL アビ汎用変数文字列リセット
        アビ汎用変数:効果割合 = 30
        アビ汎用変数:持続ターン = -1
        アビ汎用変数:消去不可オプション = 1

        アビ汎用文字列:バフ・デバフ枠 = お父さん応援_攻撃力
        アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
        CALL アビテンプレート_有利効果_バフ効果セット

        アビ汎用文字列:バフ・デバフ枠 = お父さん応援_クリティカル率
        アビ汎用文字列:バフ・デバフ対象能力 = クリティカル率
        CALL アビテンプレート_有利効果_バフ効果セット

        アビ汎用文字列:バフ・デバフ枠 = お父さん応援_高揚
        アビ汎用文字列:バフ・デバフ対象能力 = 高揚
        CALL アビテンプレート_有利効果_バフ効果セット

    ENDIF


    RETURN 0


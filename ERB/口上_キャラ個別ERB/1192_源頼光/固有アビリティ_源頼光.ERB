@固有アビ_1192_3(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM CD
#DIM CTNOW

CTNOW = 2
隊列番号 = キャラ隊列検索(キャラ番号)

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 雷神の顕 A＋
	消費ＭＰ = 70
	CD = 3
	IF 隊列番号 > -1
		LOCAL = 戦闘中カウント:隊列番号:CTNOW + CD - 現在ターン数
		SIF 戦闘中カウント:隊列番号:CTNOW != 0 && 現在ターン数 < (戦闘中カウント:隊列番号:CTNOW + CD)
			アビ名 += @" CT:{LOCAL}"

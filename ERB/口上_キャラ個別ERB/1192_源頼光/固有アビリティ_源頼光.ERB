@固有アビ_1192_4(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名

アビ名 = バスターブレイブチェイン（狂）
消費ＭＰ = 40

SELECTCASE RAND:4
CASE 0
	アビ汎用文字列:実行時メッセージ１ = 「承知いたしました」
CASE 1
	アビ汎用文字列:実行時メッセージ１ = 「あらあら、まあまあ」
CASE 2
	アビ汎用文字列:実行時メッセージ１ = 「ええ、貴方の刃ですもの」
CASEELSE
	アビ汎用文字列:実行時メッセージ１ = 「いざ、御免！」
ENDSELECT

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
			詳細文文字列受け渡し変数 = 消費ＭＰ：40
			詳細文文字列受け渡し変数 += "<br>敵ランダム1体に［攻撃力✕150％］の自属性ダメージを4回与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"

			CALL アビ対象選択テンプレート_敵ランダムＸ体(1)
			アビ汎用変数:効果割合 = 150
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			FOR LOCAL, 0, 4
				CALL アビテンプレート_ダメージ処理_自属性
			NEXT
ENDSELECT
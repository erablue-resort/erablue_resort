
@固有アビ_3305_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値,3

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 雷槍・逆襲+
	消費ＭＰ = 100
	威力値 = 120
	威力値:1 = 130
	威力値:2 = 350
ELSE
	アビ名 = 雷槍・逆襲
	消費ＭＰ = 100
	威力値 = 80
	威力値:1 = 90
	威力値:2 = 230
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［攻撃力✕{威力値}％］の光属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>自身の雷槍Lvに応じて、追加で［攻撃力✕{威力値:1}✕雷槍Lv％］の光属性ダメージを与える。"
		詳細文文字列受け渡し変数 += @"<br>自身の強雷槍Lvに応じて、追加で［攻撃力✕{威力値:2}✕強雷槍Lv％］の光属性ダメージを与える。"
		詳細文文字列受け渡し変数 += @"<br>自身が強雷槍状態の場合、対象の感電Lvが1上昇［最大Lv10/5ターン/回復不可］"
		詳細文文字列受け渡し変数 += @"<br>自身の雷槍と強雷槍効果を消去する。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_光属性

		LOCAL = DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("雷槍", 戦闘行動キャラ), "効果量_固定値")
		IF LOCAL > 0
			アビ汎用変数:効果割合 = 威力値:1 * LOCAL
			CALL アビテンプレート_ダメージ処理_光属性

			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:消去不可バフデバフ削除オプション = 1
			CALL アビテンプレート_不利効果_バフ消去("雷槍")
		ENDIF

		LOCAL = DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("強雷槍", 戦闘行動キャラ), "効果量_固定値")
		IF LOCAL > 0
			アビ汎用変数:効果割合 = 威力値:2 * LOCAL
			CALL アビテンプレート_ダメージ処理_光属性

			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 感電
			アビ汎用文字列:バフ・デバフ対象能力 = 連続攻撃率
			アビ汎用変数:効果量 = 2
			アビ汎用変数:累積上限_固定値 = 20
			アビ汎用変数:持続ターン = 5
			アビ汎用変数:消去不可オプション = 1
			CALL アビテンプレート_不利効果_累積デバフ効果セット

			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:消去不可バフデバフ削除オプション = 1
			CALL アビテンプレート_不利効果_バフ消去("強雷槍")
		ENDIF
ENDSELECT



@固有アビ_3305_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値,2

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 雷槍・閃撃+
	消費ＭＰ = 100
	威力値 = 180
	威力値:1 = 80
ELSE
	アビ名 = 雷槍・閃撃
	消費ＭＰ = 100
	威力値 = 120
	威力値:1 = 60
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵縦一列に［攻撃力✕{威力値}％］の光属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>自身の雷槍Lvが3上昇［最大Lv9/5ターン/消去不可］"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵縦列
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_光属性
		
		LOCAL = DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("雷槍", 戦闘行動キャラ), "効果量_固定値")
		
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 雷槍
		アビ汎用文字列:バフ・デバフ対象能力 = 雷槍
		アビ汎用変数:効果量 = 3
		アビ汎用変数:累積上限_固定値 = 9
		アビ汎用変数:持続ターン = 5
		アビ汎用変数:消去不可オプション = 1
		CALL アビテンプレート_有利効果_累積バフ効果セット

		LOCAL = DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("雷槍", 戦闘行動キャラ), "効果量_固定値") - LOCAL
		IF LOCAL > 0
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:効果量 = 5 * LOCAL
			CALL アビテンプレート_有利効果_奥義ゲージUP
		ENDIF
ENDSELECT

;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
;・使い方
;「XXXX」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;　口上と同じ感覚で使う為に書式を統一しているが、ステータス画面で表示されるので
;　基本的にWAIT系列は使わないことを推奨
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3305(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ 特性：『配達の効率化』 □-----------------------------------------------------------------
KSTR:(K++) = 　自身の雷槍または強雷槍Lvが上昇した時、自身に［5✕Lv上昇％］の奥義ゲージ増加を与える
KSTR:(K++) = 　
KSTR:(K++) = □ 特性：『婉曲手段』 □------------------------------------------------------------
KSTR:(K++) = 　奥義使用時、対象に［10％］（2T）の被ダメージ上昇効果を与える

CALL 口上変数表示(対象キャラ, 1)




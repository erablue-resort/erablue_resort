
@固有奥義_3305(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 奥義威力
#DIM 威力値
#DIMS 奥義名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	奥義名 = 雷槍・決震+
	威力値 = 600
ELSE
	奥義名 = 雷槍・決震
	威力値 = 500
ENDIF
奥義威力 = 0

;奥義威力を0にした場合、通常の奥義処理は行われず奥義追加効果のみが行われる。
;全体攻撃にしたい時や、攻撃しない奥義を作る場合は0に設定のこと

SELECTCASE ARGS
	CASE "奥義名"
		TSTR:コマンド名受渡 = %奥義名%
	CASE "奥義説明文"
		詳細文文字列受け渡し変数 = 奥義威力：{威力値}％　自属性縦一列攻撃。
		詳細文文字列受け渡し変数 += @"<br>自身の強雷槍Lvが1上昇［最大Lv2/5ターン/消去不可］"
		RETURN 奥義威力
	CASE "奥義前効果"
		;対象決定の後、ダメージよりも前に発生する効果。基本の奥義ダメージ部分は記載する必要はない。
		;奥義威力が0だとここの部分もスキップされる
	CASE "奥義追加効果"
		;ここに奥義効果を記述する。基本の奥義ダメージ部分は記載する必要はない。
		;基本的にアビテンプレートの関数を使用すること
		;テンプレート使用の例は固有アビリティ_キャラ名.ERBに記載
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:ダメージ種類 = 奥義ダメージ
		CALL アビ対象選択テンプレート_敵縦列
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_自属性

		LOCAL = 0
		SIF DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("強雷槍", 戦闘行動キャラ), "効果量_固定値") < 2
			LOCAL = 1
		
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 強雷槍
		アビ汎用文字列:バフ・デバフ対象能力 = 強雷槍
		アビ汎用変数:効果量 = 1
		アビ汎用変数:累積上限_固定値 = 2
		アビ汎用変数:持続ターン = 5
		アビ汎用変数:消去不可オプション = 1
		CALL アビテンプレート_有利効果_累積バフ効果セット

		IF LOCAL
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:効果量 = 5
			CALL アビテンプレート_有利効果_奥義ゲージUP
		ENDIF
ENDSELECT

;****************************************
;コマンド実行後に表示される文章
;該当のキャラが「PLAYER」の時に呼ばれる
;つまり指示モード時、あるいはオートコマンド時の口上
;****************************************
;快楽量での分岐は、口上を喋っているキャラの快楽ではなく、相手に与えた快楽であるということに注意すること！！
;****************************************

;--------------------------------------------------
;COM0_愛撫
;--------------------------------------------------
@KOJO_COMPLAYER_1745_0(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｃ、Ｂ
CALL 口上変数初期化

SELECTCASE MAX(CUP:TARGET:快Ｃ, CUP:TARGET:快Ｂ)
	CASE IS > 10000
		KSTR:(K++) = テオの小さな指先が、確かめるように%CALLNAME:TARGET%の肌を辿り続けている。
		KSTR:(K++) = 「……ここ、すごく熱い。もうすぐだよね……？　ボクにまかせて」
	CASE IS > 6000
		KSTR:(K++) = 「んっ……こうすると、気持ちいい……？」
		KSTR:(K++) = 尻尾をゆらゆらと揺らしながら、テオは%CALLNAME:TARGET%の反応をじっと窺っている。
	CASEELSE
		KSTR:(K++) = テオが少し緊張した手つきで、%CALLNAME:TARGET%の身体をそっと撫でた。
		KSTR:(K++) = 「えっと……こう、かな。気持ちよくなってくれたら、嬉しいんだけど」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM1_クンニ
;--------------------------------------------------
@KOJO_COMPLAYER_1745_1(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｃ
CALL 口上変数初期化

IF MODE_シックスナイン中_完全一致(TARGET, 対象キャラ)
	;シックスナイン
	SELECTCASE CUP:TARGET:快Ｃ
		CASE IS > 10000
			KSTR:(K++) = テオの舌が震えながらも、懸命に%CALLNAME:TARGET%の一番敏感なところを舐め上げている。
			KSTR:(K++) = 「ん、ふ……っ、ボクもっ……でも、キミを先に……んんっ」
		CASE IS > 6000
			KSTR:(K++) = 「はぁ……っ、キミの味、すごく……っ。ボクも頑張るから……」
			KSTR:(K++) = 互いの息遣いが重なる中、テオの耳がびくびくと跳ねている。
		CASEELSE
			KSTR:(K++) = テオはおそるおそる舌を伸ばし、%CALLNAME:TARGET%の秘所に顔を埋めた。
			KSTR:(K++) = 「……っ、変な味じゃない、よ。ボク、ちゃんとするから」
	ENDSELECT
ELSE
	;通常クンニ
	SELECTCASE CUP:TARGET:快Ｃ
		CASE IS > 10000
			KSTR:(K++) = 「ここっ、ここがいいんだ……？　わかった、もっとしてあげる……！」
			KSTR:(K++) = テオの舌先が執拗に同じ場所を舐り、尻尾がぴんと立っている。
		CASE IS > 6000
			KSTR:(K++) = 「ん……っ、反応してくれると、ボクも嬉しい……」
			KSTR:(K++) = テオの耳がぴくぴくと動いて、真剣な顔で%CALLNAME:TARGET%に奉仕し続けている。
		CASEELSE
			KSTR:(K++) = テオが%CALLNAME:TARGET%の脚のあいだに顔を寄せ、ためらいがちに舌を伸ばした。
			KSTR:(K++) = 「えっと、こ、こうすればいい……のかな……？」
	ENDSELECT
ENDIF

CALL 口上変数表示(対象キャラ, 0)


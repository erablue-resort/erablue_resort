;****************************************
;キャラの絶頂後、あなたの射精への反応など
;****************************************
;・使い方
;「1745」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;****************************************

;--------------------------------------------------
;通常絶頂時
;--------------------------------------------------
@KOJO_ORGASM_通常絶頂_1745(対象キャラ)
#DIM 対象キャラ
#DIM 相手キャラ番号
;NOWEX:対象キャラ:Ｃ絶頂, NOWEX:対象キャラ:Ｖ絶頂, NOWEX:対象キャラ:Ａ絶頂, NOWEX:対象キャラ:Ｂ絶頂, NOWEX:対象キャラ:Ｓ絶頂
	;それぞれの絶頂強度が入っている
	;1:絶頂(10000超え)  2:強絶頂(20000超え)  3:超強絶頂(30000超え)  4:最強絶頂(40000超え)  5:究極絶頂(50000超え)

;TCVAR:対象キャラ:うふふ中Ｃ絶頂累積, TCVAR:対象キャラ:うふふ中Ｖ絶頂累積, TCVAR:対象キャラ:うふふ中Ａ絶頂累積, TCVAR:対象キャラ:うふふ中Ｂ絶頂累積, TCVAR:対象キャラ:うふふ中Ｓ絶頂累積
;うふふ終了でリセットされる、絶頂回数を累積カウントする変数
;当然非うふふ中のセクハラなどでは変動しないので注意

CALL 口上変数初期化

相手キャラ番号 = 絶頂相手算出(対象キャラ)

;多部位同時絶頂判定
LOCAL:1 = 0
FOR LOCAL, 0, 5
	SIF NOWEX:対象キャラ:LOCAL
		LOCAL:1 += 1
NEXT
SELECTCASE LOCAL:1
	;多重絶頂
	CASE 2
		;2部位同時絶頂
		IF RAND:3 == 0
			KSTR:(K++) = 「ひっ、あっ_H_ボク、同時にっ……イッちゃ、うぅっ_H__H_」
		ELSEIF RAND:2 == 0
			KSTR:(K++) = 「だ、ダメッ……いっぺんに来てっ……んぅあぁっ_H__H_」
		ELSE
			KSTR:(K++) = 「やだっ、止まんないっ……イクッ、イクぅっ_H__H__H_」
		ENDIF
	CASE 3
		;3部位同時絶頂
		IF RAND:3 == 0
			KSTR:(K++) = 「あ、ぁあっ_H_全部、全部気持ちよくてっ……イッちゃうよぉっ_H__H__H_」
		ELSEIF RAND:2 == 0
			KSTR:(K++) = 「むりっ、むりぃっ_H_からだ中……ビクビクしてっ_H__H__H_」
		ELSE
			KSTR:(K++) = 「ひぅっ_H_ボク、もう……っ、壊れちゃうぅっ_H__H__H_」
		ENDIF
	CASE 4
		;4部位同時絶頂
		IF RAND:2 == 0
			KSTR:(K++) = 「ぁ……ぁあぁあっ_H__H_なにも、考えられなっ……イクゥッ_H__H__H_」
		ELSE
			KSTR:(K++) = 「ひぃっ_H__H_ぜんぶっ、ぜんぶイッちゃっ……あぁああっ_H__H__H_」
		ENDIF
	CASE 5
		;全部位同時絶頂
		KSTR:(K++) = 「っ――――_H__H__H_」
		KSTR:(K++) = テオの全身がびくんと跳ね上がり、尻尾が限界まで膨らんだまま硬直した
	CASEELSE
		;1部位絶頂
		IF NOWEX:対象キャラ:Ｃ絶頂
			;Ｃ絶頂＝おちんちん絶頂
			IF NOWEX:対象キャラ:Ｃ絶頂 == 1
				IF RAND:3 == 0
					KSTR:(K++) = 「んっ……おちんちん、ビクってなってっ_H_イッちゃうぅ_H_」
				ELSEIF RAND:2 == 0
					KSTR:(K++) = 「あっ_H_先っぽから出ちゃっ……イクゥッ_H_」
				ELSE
					KSTR:(K++) = 「ひゃっ_H_おちんちんがっ……気持ちいっ_H_イクッ_H_」
				ENDIF
			;2:強絶頂(20000超え)
			ELSEIF NOWEX:対象キャラ:Ｃ絶頂 == 2
				IF RAND:2 == 0
					KSTR:(K++) = 「やっ、やだっ_H_おちんちん止まんないっ……ビュクビュクってっ_H__H_」
				ELSE
					KSTR:(K++) = 「ぅあっ_H_またイッちゃっ……おちんちんからいっぱい出てるっ_H__H_」
				ENDIF
			;3:超強絶頂(30000超え)
			ELSEIF NOWEX:対象キャラ:Ｃ絶頂 == 3
				KSTR:(K++) = 「っひぃ_H__H_もう出ないのにっ……まだ射精てるっ……あぁっ_H__H__H_」
			;4:最強絶頂(40000超え)
			ELSEIF NOWEX:対象キャラ:Ｃ絶頂 == 4
				KSTR:(K++) = 「あ゛っ_H__H_おちん、ちんっ……壊れ、ちゃっ_H_んぁあああっ_H__H__H_」
			;5:究極絶頂(50000超え)
			ELSEIF NOWEX:対象キャラ:Ｃ絶頂 >= 5
				KSTR:(K++) = 「――っ_H__H__H_」
				KSTR:(K++) = テオのペニスが痙攣するように脈打ち、透明な液をぴゅくぴゅくと零し続けている
			ENDIF
		ELSEIF NOWEX:対象キャラ:Ｖ絶頂
			;Ｖ絶頂（男キャラなので前立腺等の快楽として解釈）
			IF NOWEX:対象キャラ:Ｖ絶頂 == 1
				IF RAND:3 == 0
					KSTR:(K++) = 「ぅあっ_H_なか、奥がっ……イクっ_H_」
				ELSEIF RAND:2 == 0
					KSTR:(K++) = 「んっ……中でなにか……イッちゃっ_H_」
				ELSE
					KSTR:(K++) = 「あっ……お腹の奥がぞくってしてっ……イクゥッ_H_」
				ENDIF
			;2:強絶頂(20000超え)
			ELSEIF NOWEX:対象キャラ:Ｖ絶頂 == 2
				KSTR:(K++) = 「ひっ、ぐっ_H_奥が……ずっとビクビクしてっ……だめぇ_H__H_」
			;3:超強絶頂(30000超え)
			ELSEIF NOWEX:対象キャラ:Ｖ絶頂 == 3
				KSTR:(K++) = 「やっ_H_お腹の中が溶けちゃっ……あぁあっ_H__H__H_」
			;4:最強絶頂(40000超え)
			ELSEIF NOWEX:対象キャラ:Ｖ絶頂 == 4
				KSTR:(K++) = 「んぁああっ_H__H_中がっ、最高にっ……気持ちいいっ_H__H__H_」
			;5:究極絶頂(50000超え)
			ELSEIF NOWEX:対象キャラ:Ｖ絶頂 >= 5
				KSTR:(K++) = 「…………っ_H__H__H_」
				KSTR:(K++) = テオの瞳から光が消え、口元から涎が糸を引いたまま、奥で果て続けている
			ENDIF
		ELSEIF NOWEX:対象キャラ:Ａ絶頂
			;Ａ絶頂
			IF NOWEX:対象キャラ:Ａ絶頂 == 1
				IF RAND:3 == 0
					KSTR:(K++) = 「うっ_H_お尻でっ……イッちゃうっ_H_」
				ELSEIF RAND:2 == 0
					KSTR:(K++) = 「やだっ_H_後ろからイクなんてっ……んぅっ_H_」
				ELSE
					KSTR:(K++) = 「あっ_H_お尻がキュってなってっ……イクッ_H_」
				ENDIF
			;2:強絶頂(20000超え)
			ELSEIF NOWEX:対象キャラ:Ａ絶頂 == 2
				KSTR:(K++) = 「ひぅっ_H_お尻ぃっ…止まんないっ_H__H_」
			;3:超強絶頂(30000超え)
			ELSEIF NOWEX:対象キャラ:Ａ絶頂 == 3
				KSTR:(K++) = 「あ゛っ_H_お尻ばっかりイって……頭おかしくなっちゃ_H__H__H_」
			;4:最強絶頂(40000超え)
			ELSEIF NOWEX:対象キャラ:Ａ絶頂 == 4
				KSTR:(K++) = 「っ、ぁ_H__H_ケツ穴がっ……最高にっ、気持ちよくてっ……あぁっ_H__H__H_」
			;5:究極絶頂(50000超え)
			ELSEIF NOWEX:対象キャラ:Ａ絶頂 >= 5
				KSTR:(K++) = 「…………っ_H__H__H_」
				KSTR:(K++) = テオの尻尾がだらりと力を失い、ぱくぱくと痙攣する後孔から白濁が流れている
			ENDIF
		ELSEIF NOWEX:対象キャラ:Ｂ絶頂
			;Ｂ絶頂
			IF NOWEX:対象キャラ:Ｂ絶頂 == 1
				IF RAND:2 == 0
					KSTR:(K++) = 「んっ_H_む、胸でっ……イッちゃうのっ_H_」
				ELSE
					KSTR:(K++) = 「あっ_H_乳首だけでっ……こんなの……イクぅっ_H_」
				ENDIF
			;2:強絶頂(20000超え)
			ELSEIF NOWEX:対象キャラ:Ｂ絶頂 == 2
				KSTR:(K++) = 「ひぅっ_H_乳首がっ……ずっとビリビリしてっ……イクッ_H__H_」
			;3:超強絶頂(30000超え)
			ELSEIF NOWEX:対象キャラ:Ｂ絶頂 == 3
				KSTR:(K++) = 「やっ_H_胸いじめないでっ……もう何回もイッちゃってっ_H__H__H_」
			;4:最強絶頂(40000超え)
			ELSEIF NOWEX:対象キャラ:Ｂ絶頂 == 4
				KSTR:(K++) = 「あぁっ_H__H_ちくびぃっ……気持ちよすぎてっ……だめぇっ_H__H__H_」
			;5:究極絶頂(50000超え)
			ELSEIF NOWEX:対象キャラ:Ｂ絶頂 >= 5
				KSTR:(K++) = 「…………っ_H__H__H_」
				KSTR:(K++) = テオの乳首がぷっくりと充血したまま、触れてもいないのにぴくぴくと跳ね続けている
			ENDIF
		ELSEIF NOWEX:対象キャラ:Ｓ絶頂
			;Ｓ絶頂（耳・尻尾等の特殊性感帯）
			IF NOWEX:対象キャラ:Ｓ絶頂 == 1
				IF RAND:2 == 0
					KSTR:(K++) = 「うあっ_H_イッちゃっ_H_」
				ELSE
					KSTR:(K++) = 「ぞわぞわってっ……イクっ_H_」
				ENDIF
			;2:強絶頂(20000超え)
			ELSEIF NOWEX:対象キャラ:Ｓ絶頂 == 2
				KSTR:(K++) = 「にゃぁっ_H_そこっ……弱いってっ……イッちゃうぅっ_H__H_」
			;3以上
			ELSEIF NOWEX:対象キャラ:Ｓ絶頂 >= 3
				KSTR:(K++) = 「っ――ぁ_H__H__H_」
				KSTR:(K++) = テオの耳がぺたんと伏せられ、尻尾を丸め込んだまま小さく震えている
			ENDIF
		ENDIF
ENDSELECT

CALL 口上変数表示(対象キャラ, 1)

;--------------------------------------------------
;キャラ射精時
;--------------------------------------------------
@KOJO_ORGASM_射精_1745(対象キャラ)
#DIM 対象キャラ
#DIM 相手キャラ番号
CALL 口上変数初期化

相手キャラ番号 = RFLAG:フィニッシュ相手番号

SELECTCASE RFLAG:フィニッシュ場所
	CASE 0
		;膣内射精（種付け本能）
		SELECTCASE RAND:4
		CASE 0
			KSTR:(K++) = 「っあ_H_イクッ_H_……%CSTR:対象キャラ:二人称%の中にっ……奥に出すっ、出すよぉっ_H__H_」
			KSTR:(K++) = テオの腰がびくんびくんと跳ね、ペニスが奥で精を吐き出している
		CASE 1
			KSTR:(K++) = 「んぅっ_H_だめっ、もう止められなっ……全部っ……中に出ちゃうっ_H__H_」
			KSTR:(K++) = テオの尻尾がぴんと張り詰め、本能のままに最奥へ種を注いでいる
		CASE 2
			KSTR:(K++) = 「あっ_H_赤ちゃんっ……できちゃってもっ……イクゥッ_H_出るっ、いっぱい出るぅっ_H__H_」
			KSTR:(K++) = テオはしがみつき、子種を一滴も零すまいと奥へ奥へと腰を押しつけている
		CASE 3
			KSTR:(K++) = 「っぅ_H_中っ……%CSTR:対象キャラ:二人称%の中きもちよすぎてっ……イクッ_H_射精るっ_H__H_」
			KSTR:(K++) = 小さな身体を震わせながら、テオは獣の本能に従って胎内へ精液を送り込んだ
		ENDSELECT
	CASE 1
		;腸内射精
		SELECTCASE RAND:3
		CASE 0
			KSTR:(K++) = 「ぅあっ_H_お尻の中にっ……出ちゃうっ、イクゥッ_H_」
			KSTR:(K++) = テオのペニスが腸奥でびゅくびゅくと脈打っている
		CASE 1
			KSTR:(K++) = 「んっ_H_きつくてっ……もう……っ、出るっ_H_中に射精ちゃうよぉっ_H_」
		CASE 2
			KSTR:(K++) = 「はぁっ_H_奥がっ……締まってきてっ……イクッ……イクぅっ_H__H_」
		ENDSELECT
	CASE 2
		;口内射精
		SELECTCASE RAND:3
		CASE 0
			KSTR:(K++) = 「やっ_H_お口の中あったかくてっ……出ちゃっ、イクッ_H_」
		CASE 1
			KSTR:(K++) = 「んっ_H_舌がっ……すごくてっ……ボクもうっ……出るぅっ_H_」
		CASE 2
			KSTR:(K++) = 「ぅぁっ_H_ごめっ、なさっ……口にっ……イクッ_H_出ちゃうっ_H_」
			KSTR:(K++) = テオは耳をぴんと逆立て、小さな腰をびくびくと震わせながら口内へ射精している
		ENDSELECT
	CASE 3
		;胸への射精
		SELECTCASE RAND:2
		CASE 0
			KSTR:(K++) = 「あっ_H_胸にっ……かかっちゃっ……イクッ、イクぅっ_H_」
		CASE 1
			KSTR:(K++) = 「んぅっ_H_%CSTR:対象キャラ:二人称%のむねにっ……出るっ……びゅくってしてるっ_H_」
		ENDSELECT
	CASE 5
		;顔への射精
		SELECTCASE RAND:2
		CASE 0
			KSTR:(K++) = 「ひゃっ_H_あっ、ごめっ……顔にっ……止まんないっ_H_」
		CASE 1
			KSTR:(K++) = 「やぁっ_H_出てっ……%CSTR:対象キャラ:二人称%のお顔に……っ、出ちゃうぅっ_H_」
		ENDSELECT
	CASE 6
		;腹への射精
		SELECTCASE RAND:2
		CASE 0
			KSTR:(K++) = 「んっ_H_お腹にっ……びゅくびゅくって、出てるっ……イクッ_H_」
		CASE 1
			KSTR:(K++) = 「あぁっ_H_%CSTR:対象キャラ:二人称%のお腹にっ……いっぱい射精ちゃうっ_H_」
		ENDSELECT
	CASE 7
		;背中への射精
		SELECTCASE RAND:2
		CASE 0
			KSTR:(K++) = 「うぅっ_H_背中にっ……出ちゃっ……イクぅっ_H_」
		CASE 1
			KSTR:(K++) = 「んぁっ_H_%CSTR:対象キャラ:二人称%の背中っ……汚しちゃっ……イクッ_H_」
		ENDSELECT
	CASE 30
		IF CFLAG:対象キャラ:うふふ
			;うふふ中汎用射精
			SELECTCASE RAND:3
			CASE 0
				KSTR:(K++) = 「あっ_H_イクッ……イクぅっ……出ちゃうよぉっ_H__H_」
				KSTR:(K++) = テオのペニスから、精液がぴゅくぴゅくと零れ出している
			CASE 1
				KSTR:(K++) = 「んぅっ_H_もうだめっ……ボクっ……イッちゃっ_H__H_」
				KSTR:(K++) = テオの尻尾がぶわっと膨らみ、全身をがくがくと震わせて果てた
			CASE 2
				KSTR:(K++) = 「ぅあっ_H_っ……気持ちよくてっ……射精ちゃうぅっ_H__H_」
			ENDSELECT
		ELSE
			;非うふふ時の射精、逆セクハラなど
			SELECTCASE RAND:2
			CASE 0
				KSTR:(K++) = 「ひっ……っ、い、いきなりっ……出ちゃっ……出てるっ……_H_」
			CASE 1
				KSTR:(K++) = 「ぁっ……やだっ……こ、こんなところでっ……止まんないっ……_H_」
			ENDSELECT
		ENDIF
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;調教者の射精時
;--------------------------------------------------
@KOJO_ORGASM_被射精_1745(対象キャラ)
#DIM 対象キャラ
#DIM 相手キャラ番号
;RFLAG:フィニッシュ場所
	;どこに出されたか  
;RCVAR:対象キャラ:被射精絶頂の強度
	;１以上だと射精された時にキャラも絶頂
	;現状はフィニッシュ場所が0～3の時しか起こらない
CALL 口上変数初期化

相手キャラ番号 = RFLAG:口上用射精キャラ番号

SELECTCASE RFLAG:フィニッシュ場所
	CASE 0
		;膣内（前立腺・奥への射精として解釈）
		IF RCVAR:対象キャラ:被射精絶頂の強度
			;射精による快楽で絶頂した時
			KSTR:(K++) = 「ひっ_H_中にっ……熱いのがっ……あぁっ_H_ボクもイッちゃうぅっ_H__H_」
		ELSE
			IF RAND:2 == 0
				KSTR:(K++) = 「ぁ……中で……どくどくって、してる……」
				KSTR:(K++) = テオの耳がぴくりと震え、注がれる精液の熱さに身をよじった
			ELSE
				KSTR:(K++) = 「んっ……お腹の中……あったかい……よ……」
			ENDIF
		ENDIF
	CASE 1
		;腸内
		IF RCVAR:対象キャラ:被射精絶頂の強度
			;射精による快楽で絶頂した時
			KSTR:(K++) = 「あ゛っ_H_お尻に出されてっ……ボクもっ……イクゥッ_H__H__H_」
		ELSE
			IF RAND:2 == 0
				KSTR:(K++) = 「ぅ……お尻の中に……出してるの……？　あつい……」
			ELSE
				KSTR:(K++) = 「ん……お腹の中でっ…びくびくって…………」
			ENDIF
		ENDIF
	CASE 2
		;口
		IF RCVAR:対象キャラ:精飲フラグ > 1
		;喜んで飲む
			IF RCVAR:対象キャラ:被射精絶頂の強度
				KSTR:(K++) = 「んぐっ、んくっ_H_……ごくっ……ぁ_H_飲んだらっ……イッちゃったぁ_H__H_」
			ELSE
				KSTR:(K++) = 「んく……んくっ……ごくん。……に、苦いけど……全部飲めた……よ」
			ENDIF
		ELSEIF RCVAR:対象キャラ:精飲フラグ
		;なんとか飲み込む
			IF RCVAR:対象キャラ:被射精絶頂の強度
				KSTR:(K++) = 「んぐっ_H_……っ、飲んだ瞬間……イっちゃっ_H__H_」
			ELSE
				KSTR:(K++) = 「う゛っ……にが……でも……ごくん……の、飲み込んだ、よ……」
			ENDIF
		ELSEIF ABL:対象キャラ:技巧 > 2
		;ティッシュに吐き出す
			KSTR:(K++) = 「ぷっ……はぁ……ごめんね、こっちに出すね……」
		ELSE
		;吐き出してむせる
			KSTR:(K++) = 「げほっ、けほっ……っぅ……ごめっ……むせちゃって……」
		ENDIF
	CASE 3
		;乳内
		IF RCVAR:対象キャラ:被射精絶頂の強度
			KSTR:(K++) = 「ふぁっ_H_む、胸に……かけられてっ……ボクも……イクっ_H__H_」
		ELSE
			KSTR:(K++) = 「ぁ……胸に……精液、あったかい……よ……」
		ENDIF
	CASE 5
		;顔
		KSTR:(K++) = 「ひゃっ……か、顔に……かかっちゃった……目が、開けられない……」
	CASE 6
		;腹
		KSTR:(K++) = 「ぁ……お腹に……とろとろってかかって……あったかい……」
	CASE 7
		;背中
		KSTR:(K++) = 「ひゃうっ……背中に……びゅって……し、しっぽにもかかってる……」
	CASE 30
		IF CFLAG:対象キャラ:うふふ
			;うふふ中汎用射精
			IF RAND:2 == 0
				KSTR:(K++) = 「ぁ……出てる……いっぱい出てる……あつい……よ……」
			ELSE
				KSTR:(K++) = 「んっ……%CALLNAME:PLAYER%の……どくどくって……してる……」
			ENDIF
		ELSE
			;非うふふ時の射精、逆セクハラなど
			IF RAND:2 == 0
				KSTR:(K++) = 「ひっ……ぇっ……いきなりっ……出てるっ……？」
			ELSE
				KSTR:(K++) = 「ぁ……あ……こ、こんなところで……なの……」
			ENDIF
		ENDIF
ENDSELECT

CALL 口上変数表示(対象キャラ, 1)


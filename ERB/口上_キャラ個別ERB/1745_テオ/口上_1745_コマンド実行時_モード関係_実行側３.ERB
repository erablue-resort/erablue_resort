;--------------------------------------------------
;コマンド実行後に表示される文章
;モードを開始したり削除したりするものを記載
;該当のキャラが「PLAYER」の時に呼ばれる
;つまり指示モード時、あるいはオートコマンド時の口上
;--------------------------------------------------
;快楽量での分岐は、口上を喋っているキャラの快楽ではなく、相手に与えた快楽であるということに注意すること
;--------------------------------------------------

;--------------------------------------------------
;COM80_手コキ
;--------------------------------------------------
@KOJO_COMPLAYER_1745_80(対象キャラ)
#DIM 対象キャラ
;取得快楽：なし
CALL 口上変数初期化

SELECTCASE RAND:2
	CASE 0
		KSTR:(K++) = テオが%CALLNAME:TARGET%のおちんちんをそっと両手で包む。「え、えっと……こうやって、握ればいい……？」
	CASE 1
		KSTR:(K++) = テオの小さな手が%CALLNAME:TARGET%のものを恐る恐る上下する。「ん……熱い……ボクの手で足りてるかな……」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM80_1授乳手コキ
;--------------------------------------------------
@KOJO_COMPLAYER_1745_80_1(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｂ
CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｂ
	CASE IS > 10000
		KSTR:(K++) = テオが胸を押しつけながら懸命に手を動かす。「っは……ボクの胸、ぺたんこなのに……それでも気持ちいいの……？」
	CASE IS > 6000
		KSTR:(K++) = テオが身体を擦りつけ、手の動きを速める。「んっ……こうすると、ぴくってなるんだ……_H_」
	CASEELSE
		KSTR:(K++) = テオが自分の胸元を%CALLNAME:TARGET%に押しあてる。耳がぱたぱたと揺れている。「こ、これで……あってるかな……」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM80_2亀頭責め
;--------------------------------------------------
@KOJO_COMPLAYER_1745_80_2(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｃ（ペニス相当）
CALL 口上変数初期化

IF STRFIND(コマンド初回フラグ_PLAYER:対象キャラ:0, @"-80_2-") < 0
	;初回
	KSTR:(K++) = テオの指先が%CALLNAME:TARGET%の先端をつんと触る。「む……ここ、びくってした。弱いところ……？」
ELSEIF NOWEX:TARGET:射精
	KSTR:(K++) = テオの顔にどぷりと精液がかかる。「にゃっ……あ、あつい……いっぱい出たね……」
ELSE
	SELECTCASE RAND:2
		CASE 0
			KSTR:(K++) = テオが親指の腹で先端をくりくり撫でる。「ここ、触るとどくどくするね……_H_」
		CASE 1
			KSTR:(K++) = テオの指が先端の溝をなぞる。「…ここ濡れてきた。気持ちいいの？」
	ENDSELECT
ENDIF

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM81_フェラチオ
;--------------------------------------------------
@KOJO_COMPLAYER_1745_81(対象キャラ)
#DIM 対象キャラ
;取得快楽：なし
CALL 口上変数初期化

IF MODE_存在判定_プレイヤー側("パイズリフェラ", TARGET)
	;パイズリフェラ派生
	KSTR:(K++) = テオが胸を押しあてたまま、先端をちゅぷと口に含む。「んっ……上と下、両方でしてあげるね……」
ELSE
	;通常フェラ
	SELECTCASE RAND:2
		CASE 0
			KSTR:(K++) = テオが%CALLNAME:TARGET%のおちんちんを口に含む。「んぐっ……お、おっきい……口いっぱい……」
		CASE 1
			KSTR:(K++) = テオの小さな舌が%CALLNAME:TARGET%のものを懸命に舐め上げる。「れろ……ちょっとしょっぱい……_H_」
	ENDSELECT
ENDIF

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM81_1イマラチオ
;--------------------------------------------------
@KOJO_COMPLAYER_1745_81_1(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｓ
CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｓ
	CASE IS > 10000
		KSTR:(K++) = テオの喉奥がずぶずぶと犯される。涙を零しながらも尻尾が揺れている。「んぶっ……ごひゅっ……_H__H_」
	CASE IS > 6000
		KSTR:(K++) = テオの口がぐちゅぐちゅと卑猥な音を立てる。「ぅぐっ……のど、おくまで……んっ……_H_」
	CASEELSE
		KSTR:(K++) = テオの喉に先端が押し込まれ、げほっと咳き込む。「んぐっ……！ ごほっ……い、今の、すごかった……」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)


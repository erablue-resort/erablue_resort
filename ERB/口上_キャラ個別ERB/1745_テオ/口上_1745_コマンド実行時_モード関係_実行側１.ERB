;--------------------------------------------------
;コマンド実行後に表示される文章
;モードを開始したり削除したりするものを記載
;該当のキャラが「PLAYER」の時に呼ばれる
;つまり指示モード時、あるいはオートコマンド時の口上
;--------------------------------------------------
;快楽量での分岐は、口上を喋っているキャラの快楽ではなく、相手に与えた快楽であるということに注意すること
;--------------------------------------------------

;--------------------------------------------------
;COM10_乳首吸い
;--------------------------------------------------

@KOJO_COMPLAYER_1745_10(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｂ
;キャラが吸う方

CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｂ
	CASE IS > 10000
		;即絶頂
		KSTR:(K++) = テオが唇を離し、細い糸を引く。「……っは、すごい反応……ボクの口、そんなに気持ちいい……？」
	CASE IS > 6000
		;かなり感じている
		KSTR:(K++) = テオの舌先が乳首の輪郭を丁寧になぞる。「ん……ここ、ぷっくりしてきた……もっと吸ってあげるね」
	CASEELSE
		;通常
		KSTR:(K++) = テオがおずおずと唇を近づけ、そっと乳首を含む。「……こう、でいいのかな……」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM10_1強く吸う
;--------------------------------------------------

@KOJO_COMPLAYER_1745_10_1(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｂ
;キャラが吸う方

CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｂ
	CASE IS > 10000
		;即絶頂
		KSTR:(K++) = テオが歯を軽く立てたまま強く吸い上げる。「んぅっ……ビクってしてる、イっちゃいそうなの……？」
	CASE IS > 6000
		;かなり感じている
		KSTR:(K++) = テオが乳首を深く咥え、頬を窪ませて吸う。「……っぷは、なんかボクまでドキドキしてきちゃった」
	CASEELSE
		;通常
		KSTR:(K++) = テオがぎゅっと乳首を吸い込む。吸う力が少し強くて不器用さが滲む。
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM10_2乳首甘噛み
;--------------------------------------------------

@KOJO_COMPLAYER_1745_10_2(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｂ
;キャラが噛む方

CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｂ
	CASE IS > 10000
		;即絶頂
		KSTR:(K++) = テオの小さな犬歯がコリッと乳首を転がす。「ふぁ……噛むたびにすごく跳ねるね……大丈夫？」
	CASE IS > 6000
		;かなり感じている
		KSTR:(K++) = テオが乳首の先端を甘く噛み、そのまま舌で舐め上げる。「……噛んだ方が、好き？」
	CASEELSE
		;通常
		KSTR:(K++) = テオがおそるおそる歯を立てる。「……痛くない？ ボク、加減がよくわからなくて……」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM10_3頭を撫でる
;--------------------------------------------------
@KOJO_COMPLAYER_1745_10_3(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｂ
;相手の乳を吸っている時、テオが相手の頭を撫でた際の口上

CALL 口上変数初期化

KSTR:(K++) = テオの小さな手が、相手の頭をぎこちなく撫でる。「……えへへ、よしよし。ボクがしてあげたかったんだ」

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM20_キス
;--------------------------------------------------

@KOJO_COMPLAYER_1745_20(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｓ

CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｓ
	CASE IS > 10000
		;即絶頂
		KSTR:(K++) = テオが息を荒くしながら唇を押し当てる。「ん、ぅ……キスだけでこんなに……ボクのせい、だよね……？」
	CASE IS > 6000
		;かなり感じている
		KSTR:(K++) = テオが少し大胆に唇を重ねる。尻尾がゆらゆら揺れている。「……ちゅ、……もう一回、いい？」
	CASEELSE
		;通常
		KSTR:(K++) = テオがそっと顔を近づけ、唇を軽く触れさせた。耳がぺたんと伏せている。「……っ、えと……」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM20_1舌を入れる
;--------------------------------------------------
@KOJO_COMPLAYER_1745_20_1(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｓ

CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｓ
	CASE IS > 10000
		;即絶頂
		KSTR:(K++) = テオの舌がぎこちなく奥まで絡みつく。「ん、んっ……れろ……っ、止まんない、舌……」
	CASE IS > 6000
		;かなり感じている
		KSTR:(K++) = テオがためらいがちに舌先を差し入れる。ざらついた猫舌がぬるりと触れた。「……っぁ、ボクの舌、ざらざらしてて……へんじゃない？」
	CASEELSE
		;通常
		KSTR:(K++) = テオが目をぎゅっと瞑り、舌をちょっとだけ出す。「……した、いれるよ……？」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM20_2耳をふさぐ
;--------------------------------------------------
@KOJO_COMPLAYER_1745_20_2(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｓ

CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｓ
	CASE IS > 10000
		;即絶頂
		KSTR:(K++) = テオの両手が相手の耳をふさぎ、そのまま唇を近づける。「……ボクの音だけ、聞いてて……？」
	CASE IS > 6000
		;かなり感じている
		KSTR:(K++) = テオが手のひらでそっと相手の耳を覆う。「……こうすると心臓の音が聞こえるって、本で読んだの」
	CASEELSE
		;通常
		KSTR:(K++) = テオが両手で相手の耳をぽふっと塞ぐ。「えへへ、だーれだ……って、顔見えてるよね」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM43_オナホール
;--------------------------------------------------
@KOJO_COMPLAYER_1745_43(対象キャラ)
#DIM 対象キャラ
;取得快楽：Ｃ（ペニス相当）
;相手に装着する

CALL 口上変数初期化

SELECTCASE CUP:TARGET:快Ｃ
	CASE IS > 10000
		;即絶頂
		KSTR:(K++) = テオが震える手でオナホールを動かし続ける。「っ……もうパンパンだよ……出していいからね？」
	CASE IS > 6000
		;かなり感じている
		KSTR:(K++) = テオがオナホールをゆっくり前後に動かす。「ここ、ぬるぬるして……気持ちいいところに当たってる？」
	CASEELSE
		;通常
		KSTR:(K++) = テオがおっかなびっくりオナホールを握る。「ボ、ボクでもこれなら……ちゃんとできるかな……」
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)


;--------------------------------------------------
;COM313_ハグする
;--------------------------------------------------
;RFLAG:コマンド結果受渡し変数
	;-1:失敗  0:通常成功  1:大成功

@KOJO_COM_1745_313(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化
SELECTCASE RFLAG:コマンド結果受渡し変数
	CASE -1
		;失敗
		IF RAND:2 == 0
			KSTR:(K++) = 「わわっ……！？　き、急にどうしたんですか……！」
			KSTR:(K++) = テオは驚いて身を固くしている……尻尾が逆立っている。
		ELSE
			KSTR:(K++) = 「ひゃっ……！」
			KSTR:(K++) = テオは反射的に身を引いてしまった……しまった、という顔をしている。
		ENDIF
	CASE 0
		;通常成功
		IF RAND:2 == 0
			KSTR:(K++) = 「あ……えっと……」
			KSTR:(K++) = テオは戸惑いながらも、おずおずと腕を回してハグに応じている……
		ELSE
			KSTR:(K++) = 「……あったかい、ですね」
			KSTR:(K++) = テオは照れくさそうに耳を伏せながらも、小さく%CSTR:対象キャラ:二人称%にしがみついている……
		ENDIF
	CASEELSE
		;大成功
		IF RAND:2 == 0
			KSTR:(K++) = 「……ボク、こうしてると安心します……」
			KSTR:(K++) = テオは%CSTR:対象キャラ:二人称%の胸元に顔を埋め、尻尾をゆっくりと揺らしている……
		ELSE
			KSTR:(K++) = 「えへへ……%CSTR:対象キャラ:二人称%、あったかい……」
			KSTR:(K++) = テオはぎゅっと抱きつき返してきた。その小さな身体から、じんわりとした体温が伝わってくる……
		ENDIF
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)


	IF RAND:2 == 0
		KSTR:(K++) = 「…………」
		KSTR:(K++) = テオは耳をぺたんと伏せ、尻尾を丸めてうつむいている……まだ許す気にはなれないようだ。
	ELSE
		KSTR:(K++) = 「……ボク、まだちょっと……」
		KSTR:(K++) = テオは悲しそうな目で%CSTR:対象キャラ:二人称%を見つめているが、目を逸らしてしまった……
	ENDIF
ELSE
	IF RAND:2 == 0
		KSTR:(K++) = 「……もう、怒ってないですよ」
		KSTR:(K++) = テオはまだ少しぎこちないが、おずおずと%CSTR:対象キャラ:二人称%の方に歩み寄ってきた……
	ELSE
		KSTR:(K++) = 「……しょうがないなぁ」
		KSTR:(K++) = テオは照れくさそうに頬を掻きながら、ぽつりと呟いた。尻尾がそっと揺れ始めている……
	ENDIF
ENDIF

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM356_同行解除
;--------------------------------------------------
;連れ出す、遊びに誘うを解除する
;デートかどうかはCFLAG:対象キャラ:デート == MASTER + 100で取れる

@KOJO_COM_1745_356(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

IF CFLAG:対象キャラ:デート == MASTER + 100
	;デートを終える
	KSTR:(K++) = 「今日は一緒に過ごしてくれてありがとうございます……！」
	KSTR:(K++) = 「ボク、すっごく楽しかったです……！　また誘ってくださいね……！」
	KSTR:(K++) = テオは名残惜しそうにしながらも、満面の笑みで手を振っている……
ELSE
	;同行を終える
	IF RAND:2 == 0
		KSTR:(K++) = 「あ……もうお別れですか？」
		KSTR:(K++) = テオは少し寂しそうに耳を伏せている……
	ELSE
		KSTR:(K++) = 「えっ……もう終わりなんですか？」
		KSTR:(K++) = 「もうちょっとだけ、一緒にいたかったな……」
		KSTR:(K++) = テオは尻尾をしゅんと垂らしている……
	ENDIF
ENDIF

CALL 口上変数表示(対象キャラ, 0)


IF RAND:5 == 0
	KSTR:(K++) = 「よーし……次はここを片付けなきゃ……！」
	KSTR:(K++) = テオは袖を捲り上げて、張り切っている。
ELSEIF RAND:4 == 0
	KSTR:(K++) = 「ボクに出来る事があるなら、何でも言ってください！」
ELSEIF RAND:3 == 0
	KSTR:(K++) = 「えっと……これで合ってますか？」
	KSTR:(K++) = テオは不安そうに確認しながらも、丁寧に雑務をこなしている……
ELSEIF RAND:2 == 0
	KSTR:(K++) = 「ふぅ……結構大変ですけど、こういうのも勉強になりますね！」
ELSE
	KSTR:(K++) = 「%CSTR:対象キャラ:二人称%、ここはボクがやっておきますから……！」
	KSTR:(K++) = テオは健気に雑務に取り組んでいる。尻尾がリズミカルに揺れている……
ENDIF

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM351_連れ出す
;--------------------------------------------------
;RFLAG:コマンド結果受渡し変数が１だと手を繋ぐ方

@KOJO_COM_1745_351(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

IF RFLAG:コマンド結果受渡し変数
	;手をつなぐ
	IF RAND:2 == 0
		KSTR:(K++) = 「て、手……ですか……？」
		KSTR:(K++) = 「……えへへ、ちょっと照れくさいけど……嬉しいです」
		KSTR:(K++) = テオはおずおずと手を差し出し、そっと%CSTR:対象キャラ:二人称%の手を握った……
	ELSE
		KSTR:(K++) = 「あ……っ」
		KSTR:(K++) = テオは驚いた顔をしたが、すぐに嬉しそうに手を握り返してきた……尻尾が揺れている。
	ENDIF
ELSE
	;連れ出す
	IF RAND:4 == 0
		KSTR:(K++) = 「え、ボクも一緒に行っていいんですか……！？」
		KSTR:(K++) = テオは目を輝かせて、嬉しそうに尻尾を振っている。
	ELSEIF RAND:3 == 0
		KSTR:(K++) = 「はいっ！　どこに行くんですか？　ボク、何でも付いていきます！」
	ELSEIF RAND:2 == 0
		KSTR:(K++) = 「%CSTR:対象キャラ:二人称%が案内してくれるんですか？　わぁ……楽しみだなぁ……！」
	ELSE
		KSTR:(K++) = 「お散歩ですか？　ボク、歩くの好きなんです！」
		KSTR:(K++) = テオは嬉しそうに跳ねるような足取りで%CSTR:対象キャラ:二人称%の隣に並んだ。
	ENDIF
ENDIF

CALL 口上変数表示(対象キャラ, 0)


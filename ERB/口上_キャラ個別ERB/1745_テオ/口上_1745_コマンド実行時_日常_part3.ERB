;--------------------------------------------------
;COM380_0_3 庭で一緒に遊ぶ
;--------------------------------------------------
;RFLAG:コマンド結果受渡し変数３
	;１：ボール遊び  ２：模擬戦  ３：散歩
;RFLAG:コマンド結果受渡し変数
	;0未満:失敗  1～9:通常成功  10以上:大成功

@KOJO_COM_1745_380_0_3(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化
SELECTCASE RFLAG:コマンド結果受渡し変数３
	CASE 1
		;ボール遊び
		SELECTCASE RFLAG:コマンド結果受渡し変数
			CASE IS < 0
				;失敗
				KSTR:(K++) = 「あぅ……取れなかった……」
				KSTR:(K++) = テオは悔しそうに耳を伏せている。尻尾がしゅんと垂れている……
			CASE IS >= 10
				;大成功
				KSTR:(K++) = 「やった……！　ボク、今の上手くいきましたよね！？」
				KSTR:(K++) = テオは嬉しそうに飛び跳ねている。尻尾が振れている……
			CASEELSE
				;通常成功
				IF RAND:2 == 0
					KSTR:(K++) = 「えへへ、ボール遊び楽しいですね……！」
					KSTR:(K++) = テオは息を弾ませながらも、目を輝かせている。
				ELSE
					KSTR:(K++) = 「もう一回！　もう一回やりましょう……！」
					KSTR:(K++) = テオは夢中になってボールを追いかけている。獅子族の血がそうさせるのか、動きは素早い……
				ENDIF
		ENDSELECT
	CASE 2
		;模擬戦
		SELECTCASE RFLAG:コマンド結果受渡し変数
			CASE IS < 0
				;失敗
				IF RAND:2 == 0
					KSTR:(K++) = 「くっ……負けちゃいました……」
					KSTR:(K++) = 「でも……次は絶対に負けません……！」
					KSTR:(K++) = テオは悔しそうに拳を握りしめている。その目には闘志が宿っている……
				ELSE
					KSTR:(K++) = 「うぅ……全然敵わないや……」
					KSTR:(K++) = テオは肩で息をしながらも、どこか清々しい表情をしている。
				ENDIF
			CASE IS >= 10
				;大成功
				KSTR:(K++) = 「やった……！　%CSTR:対象キャラ:二人称%から一本取れた……！」
				KSTR:(K++) = テオは信じられないという顔をした後、飛び上がって喜んでいる……！
			CASEELSE
				;通常成功
				IF RAND:2 == 0
					KSTR:(K++) = 「はぁ、はぁ……いい勝負でしたね……！」
				ELSE
					KSTR:(K++) = 「%CSTR:対象キャラ:二人称%、強いんですね……！　ボク、もっと鍛えなきゃ……！」
				ENDIF
		ENDSELECT
	CASE 3
		;散歩
		SELECTCASE RFLAG:コマンド結果受渡し変数
			CASE IS < 0
				;失敗
				KSTR:(K++) = 「あれ……ボク、ちょっと方向がわからなくなっちゃった……」
				KSTR:(K++) = テオは不安そうにきょろきょろしている……
			CASE IS >= 10
				;大成功
				KSTR:(K++) = 「わぁ……ここ、すごく景色がいいですね……！」
				KSTR:(K++) = 「%CSTR:対象キャラ:二人称%と一緒に来れてよかった……えへへ」
				KSTR:(K++) = テオは嬉しそうに尻尾を揺らしながら、辺りの景色に見入っている……
			CASEELSE
				;通常成功
				IF RAND:2 == 0
					KSTR:(K++) = 「お散歩って気持ちいいですね……！　風が気持ちいい……」
					KSTR:(K++) = テオは深呼吸しながら、のんびりと歩いている。
				ELSE
					KSTR:(K++) = 「あっ、見てください！　あの花、綺麗……！」
					KSTR:(K++) = テオは立ち止まって、道端の花に目を奪われている。
				ENDIF
		ENDSELECT
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)


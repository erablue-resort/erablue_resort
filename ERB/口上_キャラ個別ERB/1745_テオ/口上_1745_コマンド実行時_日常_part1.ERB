;****************************************
;コマンド実行後に表示される文章
;該当のキャラが「TARGET」の時に呼ばれる
;****************************************
;・使い方
;「1745」をキャラクター番号に置換、コマンド番号の所に任意のコマンド番号を入れ、中身に処理を記述する
;****************************************
;・わかりづらい変数
;・コマンド実行による各部位の快楽量
	;CUP:対象キャラ:快Ｃ
	;CUP:対象キャラ:快Ｖ
	;CUP:対象キャラ:快Ａ
	;CUP:対象キャラ:快Ｂ
	;CUP:対象キャラ:快Ｓ

;--------------------------------------------------
;COM300_会話
;--------------------------------------------------
;RFLAG:コマンド結果受渡し変数
	;-1:失敗  0:通常成功  1:大成功	-2:会話しすぎで大失敗

@KOJO_COM_1745_300(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化
SELECTCASE RFLAG:コマンド結果受渡し変数
	CASE -1
		;失敗
		IF RAND:2 == 0
			KSTR:(K++) = テオは申し訳なさそうに耳を伏せて、じっと言葉を探している……
		ELSE
			KSTR:(K++) = テオは困ったように尻尾を揺らしながら、会話の糸口を探している……
		ENDIF
	CASE 0
		;通常成功
		IF RAND:4 == 0
			KSTR:(K++) = 「%CSTR:対象キャラ:二人称%の世界の話、すっごく面白いです！」
			KSTR:(K++) = 「ボク、もっと色々教えてもらいたいな……！」
		ELSEIF RAND:3 == 0
			KSTR:(K++) = 「へぇ……そうなんだ！」
			KSTR:(K++) = テオは目を輝かせながら、身を乗り出して話に聞き入っている……
		ELSEIF RAND:2 == 0
			KSTR:(K++) = 「ボクの知らない事って、まだまだいっぱいあるんですね……！」
			KSTR:(K++) = テオは尻尾を振りながら楽しそうに話を聞いている。
		ELSE
			KSTR:(K++) = 「うん、うん……！」
			KSTR:(K++) = 「%CSTR:対象キャラ:二人称%ともっとお話ししたいです……！」
		ENDIF

	CASEELSE
		;大成功
		IF RAND:4 == 0
			KSTR:(K++) = 「すごい……！　ボク、今の話で色々繋がった気がします！」
			KSTR:(K++) = テオは興奮気味に尻尾を大きく振っている。目がきらきらと輝いている……
		ELSEIF RAND:3 == 0
			KSTR:(K++) = 「えへへ……%CSTR:対象キャラ:二人称%と話してると、時間があっという間ですね」
			KSTR:(K++) = テオは照れくさそうに頬を掻きながら笑っている……
		ELSEIF RAND:2 == 0
			KSTR:(K++) = 「ねぇねぇ、今の話もっと詳しく聞かせて！」
			KSTR:(K++) = 「ボク、メモしなきゃ……！　あ、紙とペン……っ！」
		ELSE
			KSTR:(K++) = 「%CSTR:対象キャラ:二人称%って本当に物知りなんですね……」
			KSTR:(K++) = 「ボクも、いつか%CSTR:対象キャラ:二人称%みたいに色んなことを知りたいな……」
			KSTR:(K++) = テオは穏やかに笑いながら、尻尾をゆっくり揺らしている……
		ENDIF
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM301_お茶を淹れる
;--------------------------------------------------
;RFLAG:コマンド結果受渡し変数
	;-1:失敗  0:通常成功  1:大成功
;その場にいる全員が対象だが、口上は対面している相手のみ

@KOJO_COM_1745_301(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化
SELECTCASE RFLAG:コマンド結果受渡し変数
	CASE -1
		;失敗
		KSTR:(K++) = 「あ……ありがとうございます」
		KSTR:(K++) = テオは少し困った顔をしながらも、律儀にお茶を受け取った……
	CASE 0
		;通常成功
		IF RAND:2 == 0
			KSTR:(K++) = 「わぁ……ありがとうございます！」
			KSTR:(K++) = 「%CSTR:対象キャラ:二人称%も一緒に飲みませんか？」
		ELSE
			KSTR:(K++) = 「いい匂い……」
			KSTR:(K++) = テオは嬉しそうに両手でカップを包み込むように持っている。尻尾がゆらゆらと揺れている……
		ENDIF
	CASEELSE
		;大成功
		IF GET_TARGETNUM() > 1 && RAND:3 == 0
			KSTR:(K++) = 「わぁ……！　みんなの分もあるんですか？」
			KSTR:(K++) = 「%TEXTR("すごいです……！/嬉しいな……！")%」
			KSTR:(K++) = テオは尻尾を大きく振りながら、きょろきょろと周りを見回している……
		ELSEIF RAND:2 == 0
			KSTR:(K++) = 「すっごく美味しいです……！」
			KSTR:(K++) = 「ボク、こんなに美味しいお茶飲んだの初めてかも……」
			KSTR:(K++) = テオの尻尾がゆれている。よほど嬉しかったらしい……
		ELSE
			KSTR:(K++) = 「ありがとうございます……！」
			KSTR:(K++) = 「%CSTR:対象キャラ:二人称%がお茶を淹れてくれるなんて……えへへ」
			KSTR:(K++) = テオは照れくさそうに笑いながら、大事そうにカップを両手で抱えている……
		ENDIF
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM302_スキンシップ
;--------------------------------------------------
;RFLAG:コマンド結果受渡し変数
	;-1:失敗  0:通常成功  1:大成功

@KOJO_COM_1745_302(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化
SELECTCASE RFLAG:コマンド結果受渡し変数
	CASE -1
		;失敗
		IF RAND:2 == 0
			KSTR:(K++) = 「ひゃっ……！？」
			KSTR:(K++) = テオは驚いて身を縮こまらせている……
		ELSE
			KSTR:(K++) = 「あ、あの……ちょっとビックリしちゃって……」
			KSTR:(K++) = テオは耳をぺたんと伏せて、おずおずと距離を取っている……
		ENDIF
	CASE 0
		;通常成功
		IF RAND:4 == 0
			KSTR:(K++) = 「え、えっと……」
			KSTR:(K++) = 「こういうの、ちょっと照れくさいけど……嫌じゃないです」
			KSTR:(K++) = テオは耳を少し赤くしながら、おとなしくスキンシップを受け入れている……
		ELSEIF RAND:3 == 0
			KSTR:(K++) = 「ふぁ……っ」
			KSTR:(K++) = テオは少し驚いた顔をしたが、すぐに嬉しそうに尻尾を揺らし始めた……
		ELSEIF RAND:2 == 0
			KSTR:(K++) = 「あ……えへへ」
			KSTR:(K++) = 「%CSTR:対象キャラ:二人称%の手、あったかいですね……」
		ELSE
			KSTR:(K++) = 「ボク、こういうの慣れてなくて……」
			KSTR:(K++) = テオはそう言いながらも、拒む素振りは見せず、小さく尻尾を振っている……
		ENDIF
	CASEELSE
		;大成功
		IF GET_TARGETNUM() > 1 && RAND:3 == 0
			KSTR:(K++) = 「ひゃぅ……！　み、みんなの前で……っ」
			KSTR:(K++) = テオは顔を真っ赤にしながらも、されるがままになっている……尻尾が小刻みに震えている。
		ELSEIF RAND:2 == 0
			KSTR:(K++) = 「えへへ……」
			KSTR:(K++) = 「%CSTR:対象キャラ:二人称%ともっと仲良くなれた気がします……！」
			KSTR:(K++) = テオは満面の笑みで尻尾を大きく振っている……
		ELSE
			KSTR:(K++) = 「……ボクからも、いいですか？」
			KSTR:(K++) = テオはおずおずと手を伸ばし、%CSTR:対象キャラ:二人称%の手にそっと触れた……
		ENDIF
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)

;--------------------------------------------------
;COM303_口説く
;--------------------------------------------------
;RFLAG:コマンド結果受渡し変数
	;-1:失敗  0:通常成功  1:大成功

@KOJO_COM_1745_303(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

SELECTCASE RFLAG:コマンド結果受渡し変数
	CASE -1
		;失敗
		IF RAND:2 == 0
			KSTR:(K++) = 「え……えっと……？」
			KSTR:(K++) = テオは何を言われたのかよく分かっていないようだ……耳がぴくぴくと動いている。
		ELSE
			KSTR:(K++) = 「く、口説くって……ボクを……？」
			KSTR:(K++) = テオは困惑した顔で尻尾をだらんと垂らしている……
		ENDIF
	CASE 0
		;通常成功
		IF RAND:3 == 0
			KSTR:(K++) = 「そ、そういう事言われると……」
			KSTR:(K++) = テオは耳まで真っ赤にしながら、視線を泳がせている……
		ELSEIF RAND:2 == 0
			KSTR:(K++) = 「……えっと、ボク、なんて返したらいいのか分からなくて……」
			KSTR:(K++) = テオはもじもじしながらも、尻尾だけは正直に揺れている……
		ELSE
			KSTR:(K++) = 「%CSTR:対象キャラ:二人称%って、そういう事も言うんですね……」
			KSTR:(K++) = テオは照れ隠しに視線を逸らしながらも、口元がほころんでいる……
		ENDIF
	CASEELSE
		;大成功
		IF RAND:2 == 0
			KSTR:(K++) = 「う……ぅ……っ」
			KSTR:(K++) = テオは顔を両手で覆ってしまった……しかし尻尾は嬉しそうに揺れている。
		ELSE
			KSTR:(K++) = 「ボクなんかを……そんな風に言ってくれるの……？」
			KSTR:(K++) = テオは潤んだ瞳で%CSTR:対象キャラ:二人称%を見上げている……尻尾がぱたぱたと揺れている。
		ENDIF
ENDSELECT

CALL 口上変数表示(対象キャラ, 0)


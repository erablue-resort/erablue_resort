
@固有奥義_3339(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力

    隊列番号 = キャラ隊列検索(キャラ番号)
	;アビ汎用変数:必要奥義ゲージ量 = 70
	;アビ汎用変数:消費奥義ゲージ量 = 70
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = クリミナルプリズン
    ENDIF
    奥義威力 = 0
    SELECTCASE RAND:1
        CASE 0
        アビ汎用文字列:実行時メッセージ１ = 「まかせてくれたまえっ！クリミナルプリズン！」
    ENDSELECT
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％<br>
            詳細文文字列受け渡し変数 += @"<br>敵横列に、敵の防御力を特大ダウン、［1］のスロウ効果を与える。さらに行動速度を小ダウンさせる。"
            
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
              ; --- 效果处理 ---
            ; CALL アビ対象選択テンプレート_味方全体
            ; CALL アビ汎用変数文字列リセット
            ; アビ汎用文字列:バフ・デバフ枠 = まどろみの庭
            ; アビ汎用文字列:バフ・デバフ対象能力 = 高揚
            ; アビ汎用変数:効果割合 = 20
            ; アビ汎用変数:持続ターン = 3
            ; CALL アビテンプレート_有利効果_バフ効果セット    
            CASE "奥義追加効果"
                CALL アビ対象選択テンプレート_敵横列
				CALL アビ汎用変数文字列リセット
				アビ汎用文字列:バフ・デバフ枠 = 行動速度B
				アビ汎用文字列:バフ・デバフ対象能力 = 行動速度
				アビ汎用変数:効果割合 = 10
				アビ汎用変数:持続ターン = 5
				CALL アビテンプレート_不利効果_デバフ効果セット

                CALL アビ汎用変数文字列リセット
				アビ汎用文字列:バフ・デバフ枠 = クリミナルプリズン
				アビ汎用文字列:バフ・デバフ対象能力 = 防御力
				アビ汎用変数:効果量 = 700
				アビ汎用変数:持続ターン = 5
				CALL アビテンプレート_不利効果_デバフ効果セット

                CALL アビ汎用変数文字列リセット
                アビ汎用変数:効果量 = 1
                アビ汎用変数:基礎成功確率 = 100
                CALL アビテンプレート_不利効果_スロウ
    ENDSELECT

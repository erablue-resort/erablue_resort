
;--------------------------------------------------3218
;专属奥义
;--------------------------------------------------
@固有奥義_3280(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義威力表示

    隊列番号 = キャラ隊列検索(キャラ番号)

    ;アビ汎用変数:必要奥義ゲージ量 = 200
    ;アビ汎用変数:消費奥義ゲージ量 = 200
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = 詔令：格物致知
    ENDIF
    奥義威力 = 0
    奥義威力表示 = 0
    SELECTCASE RAND:3
        CASE 0
        アビ汎用文字列:実行時メッセージ１ = 「これで完成なのじゃが……。」
        CASE 1
        アビ汎用文字列:実行時メッセージ１ = 「この辺りでやめるべきかの……？」
        CASE 2
        アビ汎用文字列:実行時メッセージ１ = 「もう少し様子を見たかったのじゃが……。」
    ENDSELECT
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力表示}％
            詳細文文字列受け渡し変数 += @"<br>味方1人に対して、奥義ダメージを80％加算（3ターン間）"
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
        CASE "奥義追加効果"
            CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_味方単体_生者のみ_自己以外
			アビ汎用文字列:バフ・デバフ枠 = 詔令：格物致知
			アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_奥義ダメージ
			アビ汎用変数:効果割合 = 80
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_有利効果_バフ効果セット

ENDSELECT

@固有アビ_17_4(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 42
	アビ名 = ホープスナイプ＋
	消費ＭＰ = 58
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 26
	アビ名 = ホープスナイプ
	消費ＭＰ = 42
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		IF 基礎BATTLE_STATE:キャラ番号:Lv >= 38
			詳細文文字列受け渡し変数 = 消費ＭＰ：58
			詳細文文字列受け渡し変数 += "<br>自身に潜伏効果（独自枠・5ターン・消去不可）を与える。"
			詳細文文字列受け渡し変数 += "<br>自身に［10％］（独自枠・5ターン・消去不可）の追撃上昇効果を与える。"
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 26
			詳細文文字列受け渡し変数 = 消費ＭＰ：42
			詳細文文字列受け渡し変数 += "<br>自身に潜伏効果（独自枠・3ターン・消去不可）を与える。"
			詳細文文字列受け渡し変数 += "<br>味方全体に［10％］（独自枠・3ターン・消去不可）の追撃上昇効果を与える。"
		ENDIF
	CASE "アビ効果"
		IF 基礎BATTLE_STATE:キャラ番号:Lv >= 38
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = ホープスナイプ
			アビ汎用文字列:バフ・デバフ対象能力 = 潜伏
			アビ汎用変数:持続ターン = 5
			CALL アビテンプレート_有利効果_バフ効果セット
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_味方全体
			アビ汎用文字列:バフ・デバフ枠 = ホープスナイプ
			アビ汎用文字列:バフ・デバフ対象能力 = 追撃
			アビ汎用変数:効果割合 = 10
			アビ汎用変数:持続ターン = 5
			CALL アビテンプレート_有利効果_バフ効果セット
			CALL アビテンプレート_有利効果_バフ効果セット
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 26
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = ホープスナイプ
			アビ汎用文字列:バフ・デバフ対象能力 = 潜伏
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_有利効果_バフ効果セット
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_味方全体
			アビ汎用文字列:バフ・デバフ枠 = ホープスナイプ
			アビ汎用文字列:バフ・デバフ対象能力 = 追撃
			アビ汎用変数:効果割合 = 10
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_有利効果_バフ効果セット
		ENDIF
ENDSELECT


 

@固有アビ_17_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
	アビ名 = イーグルアイ＋＋
	消費ＭＰ = 70
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 28
	アビ名 = イーグルアイ＋
	消費ＭＰ = 55
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 14
	アビ名 = イーグルアイ
	消費ＭＰ = 25
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
			詳細文文字列受け渡し変数 = 消費ＭＰ：70
			詳細文文字列受け渡し変数 += "<br>自身に［210％］（独自枠・1回・消去不可）のダメージ補正_奥義ダメージ上昇効果を与える。"
			詳細文文字列受け渡し変数 += "<br>［50％］（独自枠・1回・消去不可）のダメージ補正_チェンバダメージ上昇効果を与える。"
			詳細文文字列受け渡し変数 += "<br>［999％］（独自枠・1回・消去不可）の命中率上昇効果を与える。"
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 28
			詳細文文字列受け渡し変数 = 消費ＭＰ：55
			詳細文文字列受け渡し変数 += "<br>自身に［200％］（独自枠・1回・消去不可）のダメージ補正_奥義ダメージ上昇効果を与える。"
			詳細文文字列受け渡し変数 += "<br>［40％］（独自枠・1回・消去不可）のダメージ補正_チェンバダメージ上昇効果を与える。"
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 14
			詳細文文字列受け渡し変数 = 消費ＭＰ：25
			詳細文文字列受け渡し変数 += "<br>自身に［200％］（独自枠・1回・消去不可）のダメージ補正_奥義ダメージ上昇効果を与える。"
			詳細文文字列受け渡し変数 += "<br>［30％］（独自枠・1回・消去不可）のダメージ補正_チェンバダメージ上昇効果を与える。"
		ENDIF
	CASE "アビ効果"
		IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = 狙撃
			アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_奥義ダメージ
			アビ汎用変数:効果割合 = 210
			アビ汎用変数:持続回数 = 1
			CALL アビテンプレート_有利効果_バフ効果セット
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 狙撃
			アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_チェンバダメージ
			アビ汎用変数:効果割合 = 50
			アビ汎用変数:持続回数 = 1
			CALL アビテンプレート_有利効果_バフ効果セット
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 狙撃
			アビ汎用文字列:バフ・デバフ対象能力 = 命中率
			アビ汎用変数:効果割合 = 999
			アビ汎用変数:持続回数 = 1
			CALL アビテンプレート_有利効果_バフ効果セット
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 28
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = 狙撃
			アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_奥義ダメージ
			アビ汎用変数:効果割合 = 200
			アビ汎用変数:持続回数 = 1
			CALL アビテンプレート_有利効果_バフ効果セット
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 狙撃
			アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_チェンバダメージ
			アビ汎用変数:効果割合 = 40
			アビ汎用変数:持続回数 = 1
			CALL アビテンプレート_有利効果_バフ効果セット
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 14
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = 狙撃
			アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_奥義ダメージ
			アビ汎用変数:効果割合 = 200
			アビ汎用変数:持続回数 = 1
			CALL アビテンプレート_有利効果_バフ効果セット
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 狙撃
			アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_チェンバダメージ
			アビ汎用変数:効果割合 = 30
			アビ汎用変数:持続回数 = 1
			CALL アビテンプレート_有利効果_バフ効果セット
		ENDIF
ENDSELECT


 

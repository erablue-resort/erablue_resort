
@固有アビ_3310_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値,2

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 真紅の影+
	消費ＭＰ = 100
	威力値 = 150
	威力値:1 = 230
ELSE
	アビ名 = 真紅の影
	消費ＭＰ = 100
	威力値 = 110
	威力値:1 = 150
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［攻撃力✕{威力値}％］の自属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>［累積10％最大40％］（累積枠・5ターン）の攻撃力減少効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>対象が既に累積攻撃力減少状態の場合、追加で［攻撃力✕150％］の自属性ダメージと、"
		詳細文文字列受け渡し変数 += @"<br>［攻撃力✕{威力値:1}％］の火属性ダメージを与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		LOCAL = 0
		SIF デバフ番号取得_枠("染まる爪痕", アビテンプレート用_対象保存:0) > -1
			LOCAL = 1

		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_自属性

		SIF アビテンプレート用_キャンセルフラグ
			RETURN
		IF 敵BATTLE_STATE:((アビテンプレート用_対象保存:0) - 10):ＨＰ > 0 && デバフ番号取得_枠("攻撃力累積", アビテンプレート用_対象保存:0) > -1
			アビ汎用変数:効果割合 = 150
			CALL アビテンプレート_ダメージ処理_自属性
			アビ汎用変数:効果割合 = 威力値:1
			CALL アビテンプレート_ダメージ処理_火属性

			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 染まる爪痕
			アビ汎用文字列:バフ・デバフ対象能力 = 染まる爪痕
			アビ汎用変数:持続ターン = 5
			アビ汎用変数:消去不可オプション = 1
			CALL アビテンプレート_不利効果_デバフ効果セット

			アビ汎用文字列:バフ・デバフ枠 = 染まる爪痕_毒
			アビ汎用文字列:バフ・デバフ対象能力 = 毒
			CALL バフ・デバフ測定(戦闘行動キャラ, "攻撃力", BATTLE_STATE:戦闘行動キャラ:攻撃力, 1)
			アビ汎用変数:効果量 = RESULT / 2
			CALL アビテンプレート_不利効果_付随デバフ効果セット("染まる爪痕")

			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 染まる爪痕_被ダメ上昇
			アビ汎用文字列:バフ・デバフ対象能力 = 被ダメージ
			アビ汎用変数:効果割合 = 10
			CALL アビテンプレート_不利効果_付随デバフ効果セット("染まる爪痕")
		ENDIF

		CALL アビ汎用変数文字列リセット
		アビ汎用変数:効果割合 = 10
		アビ汎用変数:累積上限_割合 = 40
		アビ汎用文字列:バフ・デバフ枠 = 攻撃力累積
		アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
		アビ汎用変数:持続ターン = 5
		CALL アビテンプレート_不利効果_累積デバフ効果セット

		IF LOCAL
			IF 敵BATTLE_STATE:((アビテンプレート用_対象保存:0) - 10):ＨＰ > 0
				CALL アビ汎用変数文字列リセット
				アビ汎用変数:効果割合 = 100
				CALL アビテンプレート_ダメージ処理_火属性
			ENDIF
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:効果割合 = 20
			CALL アビテンプレート_回復処理_MAXでも回復
		ENDIF
ENDSELECT



@固有アビ_3310_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値,3

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 刹那の影+
	消費ＭＰ = 100
	威力値 = 360
	威力値:1 = 350
	威力値:2 = 40
ELSE
	アビ名 = 刹那の影
	消費ＭＰ = 100
	威力値 = 240
	威力値:1 = 300
	威力値:2 = 30
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［攻撃力✕{威力値}％］の自属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>［累積10％最大40％］（累積枠・5ターン）の攻撃力減少効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>対象が既に累積攻撃力減少状態かつ、火傷、氷結、感電、劇毒のいずれかの状態の場合、"
		詳細文文字列受け渡し変数 += @"<br>追加で［攻撃力✕{威力値:1}％］の自属性ダメージと、"
		詳細文文字列受け渡し変数 += @"<br>自身に［{威力値:2}％］(4ターン）の攻撃力上昇効果を与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:効果割合 = 威力値
		CALL アビテンプレート_ダメージ処理_自属性
		
		SIF アビテンプレート用_キャンセルフラグ
			RETURN
		LOCAL = 0
		IF デバフ番号取得_枠("攻撃力累積", アビテンプレート用_対象保存:0) > -1 && (デバフ番号取得_枠("火傷", アビテンプレート用_対象保存:0) > -1 || デバフ番号取得_枠("氷結", アビテンプレート用_対象保存:0) > -1 || デバフ番号取得_枠("感電", アビテンプレート用_対象保存:0) > -1 || デバフ番号取得_枠("劇毒", アビテンプレート用_対象保存:0) > -1)
			IF 敵BATTLE_STATE:((アビテンプレート用_対象保存:0) - 10):ＨＰ > 0
				アビ汎用変数:効果割合 = 威力値:1
				CALL アビテンプレート_ダメージ処理_自属性
			ENDIF
			LOCAL = 1
		ENDIF
		
		CALL アビ汎用変数文字列リセット
		アビ汎用変数:効果割合 = 10
		アビ汎用変数:累積上限_割合 = 40
		アビ汎用文字列:バフ・デバフ枠 = 攻撃力累積
		アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
		アビ汎用変数:持続ターン = 5
		CALL アビテンプレート_不利効果_累積デバフ効果セット
		
		IF デバフ番号取得_枠("染まる爪痕", アビテンプレート用_対象保存:0) > -1
			IF 敵BATTLE_STATE:((アビテンプレート用_対象保存:0) - 10):ＨＰ > 0
				CALL アビ汎用変数文字列リセット
				アビ汎用変数:効果割合 = 100
				CALL アビテンプレート_ダメージ処理_火属性
			ENDIF
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:効果割合 = 20
			CALL アビテンプレート_回復処理_MAXでも回復
		ENDIF

		IF LOCAL
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = 刹那の影
			アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
			アビ汎用変数:効果割合 = 威力値:2
			アビ汎用変数:持続ターン = 4
			CALL アビテンプレート_有利効果_バフ効果セット
		ENDIF
ENDSELECT

;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
;・使い方
;「XXXX」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;　口上と同じ感覚で使う為に書式を統一しているが、ステータス画面で表示されるので
;　基本的にWAIT系列は使わないことを推奨
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3310(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ 特性：『爪痕』 □-----------------------------------------------------------------
KSTR:(K++) = 　真紅の影で追加ダメージが発生した時、対象に染まる爪痕（5ターン）効果を与える
KSTR:(K++) = 　染まる爪痕：［攻撃力✕50％］の毒効果と［10％］の被ダメージ上昇効果
KSTR:(K++) = □ 特性：『ざわめく血』 □------------------------------------------------------------
KSTR:(K++) = 　アビリティと奥義使用時に対象が染まる爪痕状態の場合、
KSTR:(K++) = 　追加で［攻撃力✕100％］の火属性ダメージを与え、自身に［回復力✕20％］のＨＰ回復を与える

CALL 口上変数表示(対象キャラ, 1)




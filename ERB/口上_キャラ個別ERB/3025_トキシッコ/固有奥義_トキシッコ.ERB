
;--------------------------------------------------
; Unknown 专属奥义
;--------------------------------------------------
@固有奥義_3025(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義实威力

    隊列番号 = キャラ隊列検索(キャラ番号)
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 65
        奥義名 = ボルテガ
        奥義威力 = 420
    ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 35
        奥義名 = ボルテラ
        奥義威力 = 380
    ELSE 
        奥義名 = ボルテジ
        奥義威力 = 330
    ENDIF

    
    ;奥義实威力 = 772
    ;アビ汎用文字列:実行時メッセージ１ = 「炮手、支援を。」
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"
            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％<br>
            詳細文文字列受け渡し変数 += @"さらに敵全体に攻撃力×220％分のダメージ。"
            詳細文文字列受け渡し変数 += @"<br>3分の1の確率,全員に［攻撃力✕200％］の追加ダメージを与える。"
            RETURN 奥義威力
        CASE "奥義説明文_詳細"
            ;詳細文文字列受け渡し変数 += @"先降低敌方单体的防御力［{効果数値}％／独立槽］，然后造成奥义伤害。"
        CASE "奥義前効果"
            ; --- 效果处理 ---           
            ;CALL アビ汎用変数文字列リセット
           

           ; CALL アビ対象選択テンプレート_敵縦列
           ; アビ汎用変数:効果割合 = 772
           ; CALL アビテンプレート_ダメージ処理_自属性
            ; --- 效果处理 ---
        CASE "奥義追加効果"
            アビ汎用変数:効果割合 = 220 
            CALL アビ対象選択テンプレート_敵全体_生者のみ
            アビ汎用文字列:ダメージ種類 = 奥義ダメージ
            CALL アビテンプレート_ダメージ処理_自属性

            SELECTCASE RAND:3
                CASE 0
                    CALL アビ対象選択テンプレート_敵全体_生者のみ
                    アビ汎用変数:効果割合 = 200 
                    アビ汎用文字列:ダメージ種類 = 奥義ダメージ
                    CALL アビテンプレート_ダメージ処理_自属性

                    CALL アビ対象選択テンプレート_味方全体_生者のみ
                    アビ汎用変数:効果割合 = 200 
                    アビ汎用文字列:ダメージ種類 = 奥義ダメージ
                    CALL アビテンプレート_ダメージ処理_自属性
            
                CASE 1
                    
                CASE 2
			ENDSELECT
    ENDSELECT

;--------------------------------------------------
; 技能 1: 
;--------------------------------------------------
@固有アビ_3025_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値
#DIM 効果数値２
#DIM クールタイム

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF INRANGE(隊列番号, 0, 3) && 戦闘中カウント:隊列番号:0
        クールタイム = MAX(0, 5 + 戦闘中カウント:隊列番号:0 - 現在ターン数)
        SIF クールタイム > 0
            アビテンプレート用_アビ封印用フラグ = 1
    ELSE
        クールタイム = 0
    ENDIF

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 65
        アビ名 = グラウガ
        消費ＭＰ = 200
        効果数値 = 230
    ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 35
        アビ名 = グラウラ
        消費ＭＰ = 150 
        効果数値 = 180
    ELSE 
        アビ名 = グラウル
        消費ＭＰ = 100 
        効果数値 = 120
    ENDIF

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>
            詳細文文字列受け渡し変数 += @"敵単体に［90％］（A枠・3ターン）の回避率減少効果を与える。"           
            詳細文文字列受け渡し変数 += @"<br>［攻撃力✕{効果数値}％］の土属性ダメージを与える。"       
            SIF クールタイム > 0
		    	詳細文文字列受け渡し変数 += @"<br>（剩余{クールタイム}回合）"
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---

            CALL アビ対象選択テンプレート_敵単体
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 回避率A
            アビ汎用文字列:バフ・デバフ対象能力 = 回避率
            アビ汎用変数:効果量 = 90
            アビ汎用変数:持続ターン = 3
            アビ汎用変数:基礎成功確率 = 65
            CALL アビテンプレート_不利効果_デバフ効果セット
                
            CALL アビ汎用変数文字列リセット
            アビ汎用変数:効果量 = 効果数値
            CALL アビテンプレート_ダメージ処理_土属性

            戦闘中カウント:隊列番号:0 = 現在ターン数

    ENDSELECT
    RETURN RESULT


;--------------------------------------------------
; 技能 2: 
;--------------------------------------------------
@固有アビ_3025_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値
#DIM 効果数値２

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 65
        アビ名 = イグニガ
        消費ＭＰ = 160 
        効果数値 = 330
        効果数値２ = 150
    ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 35
        アビ名 = イグニラ
        消費ＭＰ = 120 
        効果数値 = 280
        効果数値２ = 100
    ELSE 
        アビ名 = イグニト
        消費ＭＰ = 80 
        効果数値 = 220
        効果数値２ = 50
    ENDIF
    
    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>
            詳細文文字列受け渡し変数 += @"敵単体に［攻撃力✕{効果数値}％］の火属性ダメージを与える。"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 65 ;65
                詳細文文字列受け渡し変数 += @"<br>敵全体に［攻撃力✕{効果数値２}％］の火属性ダメージを与える。"
            ENDIF
            詳細文文字列受け渡し変数 += @"<br>3分の1の確率,全員に［攻撃力✕150％］の火属性ダメージを与える。"
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---
            アビ汎用変数:効果割合 = 効果数値 
            CALL アビ対象選択テンプレート_敵単体
            CALL アビテンプレート_ダメージ処理_火属性

            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 65 ;65
                CALL アビ対象選択テンプレート_敵全体_生者のみ
                アビ汎用変数:効果割合 = 効果数値２
                CALL アビテンプレート_ダメージ処理_火属性
            ENDIF

            SELECTCASE RAND:3
                CASE 0
                    CALL アビ対象選択テンプレート_味方全体_生者のみ
                    アビ汎用変数:効果割合 = 150 
                    CALL アビテンプレート_ダメージ処理_火属性
                    CALL アビ対象選択テンプレート_敵全体_生者のみ
                    アビ汎用変数:効果割合 = 150 
                    CALL アビテンプレート_ダメージ処理_火属性 
                CASE 1
                    
                CASE 2
            ENDSELECT
    ENDSELECT
    RETURN RESULT


;--------------------------------------------------
; 技能 3: 
;--------------------------------------------------
@固有アビ_3025_3(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM 効果数値
#DIM 効果数値２

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
        アビ名 = コルドラ
        消費ＭＰ = 120 
        効果数値 = 330 
    ELSE 
        アビ名 = コルドス
        消費ＭＰ = 60 
        効果数値 = 220 
    ENDIF
    効果数値２ = 150
    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"

            詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>
            詳細文文字列受け渡し変数 += @"敵単体に［攻撃力✕{効果数値}％］の水属性ダメージを与える。"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                詳細文文字列受け渡し変数 += @"<br>味方全体に［{効果数値２}］のバリアを与える。"
            ENDIF
            詳細文文字列受け渡し変数 += @"<br>3分の1の確率,全員に［攻撃力✕150％］の水属性ダメージを与える。"
            RETURN 消費ＭＰ

        CASE "アビ効果"         
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_敵単体
            CALL アビ汎用変数文字列リセット
            アビ汎用変数:効果割合 = 効果数値
            CALL アビテンプレート_ダメージ処理_水属性

            SELECTCASE RAND:3
                CASE 0
                    CALL アビ対象選択テンプレート_味方全体_生者のみ
                    アビ汎用変数:効果割合 = 150 
                    CALL アビテンプレート_ダメージ処理_水属性

                    CALL アビ対象選択テンプレート_敵全体_生者のみ
                    アビ汎用変数:効果割合 = 150 
                    CALL アビテンプレート_ダメージ処理_水属性  
                CASE 1
                    
                CASE 2
			ENDSELECT	

            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45 ;45
                CALL アビ汎用変数文字列リセット
                CALL アビ対象選択テンプレート_味方全体_生者のみ
                アビ汎用文字列:バフ・デバフ対象能力 = バリア
                アビ汎用変数:効果量 = 効果数値２
                CALL アビテンプレート_有利効果_バフ効果セット
            
            ENDIF


    ENDSELECT
    RETURN RESULT

;--------------------------------------------------
; 战斗开始时处理 (常驻Buff等)
;--------------------------------------------------
@固有戦闘開始時処理_キャラ_3025
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数
#DIM キクル隊列
#DIM トキシッコ隊列

    キャラ番号 = GETCHARA(3025)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0

    トキシッコ隊列 = キャラ隊列検索(キャラ検索("[ものぐさ黒魔]トキシッコ・ダナー"))
    キクル隊列 = キャラ隊列検索(キャラ検索("[メブキの街のエース]キクル・マダン"))
    IF INRANGE(トキシッコ隊列, 0, 3) && INRANGE(キクル隊列, 0, 3)
        CALL アビ対象選択テンプレート_自己のみ
        CALL アビ汎用変数文字列リセット
        アビ汎用文字列:バフ・デバフ枠 = 真面目な黒魔（ほんの少し）
        アビ汎用文字列:バフ・デバフ対象能力 = 命中率
        アビ汎用変数:効果割合 = 25
        アビ汎用変数:持続ターン = -1
        アビ汎用変数:消去不可オプション = 1
        CALL アビテンプレート_有利効果_バフ効果セット
    ENDIF


    RETURN 0


;--------------------------------------------------
; 回合开始时处理 (回复/CD/动态Buff更新)
;--------------------------------------------------
@固有行動開始時処理_キャラ_3025
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数
#DIM 味方番号
#DIM ＭＡＸ数値
#DIM ＤＭＧキャラ
#DIM 対象指定

    キャラ番号 = GETCHARA(3025)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0
    ; --- 特性: 咒名发动---
    IF バフ・デバフ効果検索("デバフ", "能力", "毒", 戦闘行動キャラ) > -1
         CALL アビ対象選択テンプレート_自己のみ
        アビ汎用変数:消去不可バフデバフ削除オプション = 1
        CALL アビテンプレート_有利効果_デバフ全て消去("毒")
    ENDIF
    
   
    


;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3025(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ 呪名：トキシッコ □-------------------------------------------------------------------
KSTR:(K++) = 　命名により能力を付与する「呪名」により毒への耐性を持つ。
KSTR:(K++) = □ ものぐさ黒魔 □-----------------------------------------------------------------------
KSTR:(K++) = 　命中率が低く、攻撃力が高い。キーケルと共に出撃すると、命中率がわずかに上昇する。
CALL 口上変数表示(対象キャラ, 1)


@固有アビ_3302_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値,2

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 焼滅+
	消費ＭＰ = 100
	威力値 = 110
	威力値:1 = 450
ELSE
	アビ名 = 焼滅
	消費ＭＰ = 100
	威力値 = 75
	威力値:1 = 300
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵縦一列に［{威力値}％］の火属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>自身の劫火がLv4の場合、劫火を消去して追加効果"
		詳細文文字列受け渡し変数 += @"<br>・敵全体に［{威力値:1}％］の火属性ダメージを与える。"
		詳細文文字列受け渡し変数 += @"<br>・対象の火傷Lvが1上昇［最大Lv10/5ターン/回復不可］"
		詳細文文字列受け渡し変数 += @"<br>・自身に［70％］の奥義ゲージ増加を与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵縦列
		アビ汎用変数:効果割合 = 威力値
		SIF バフ番号取得("灼熱の心", 戦闘行動キャラ) > -1
			アビ汎用変数:防御無視オプション_割合 = 50
		CALL アビテンプレート_ダメージ処理_火属性

		IF DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("劫火", 戦闘行動キャラ), "効果量_固定値") > 3
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵全体_生者のみ
			SIF バフ番号取得("灼熱の心", 戦闘行動キャラ) > -1
				アビ汎用変数:防御無視オプション_割合 = 50
			アビ汎用変数:効果割合 = 威力値:1
			CALL アビテンプレート_ダメージ処理_火属性

			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 火傷
			アビ汎用文字列:バフ・デバフ対象能力 = 火傷
			アビ汎用変数:効果量 = 50
			アビ汎用変数:累積上限_固定値 = 500
			アビ汎用変数:持続ターン = 5
			アビ汎用変数:消去不可オプション = 1
			CALL アビテンプレート_不利効果_累積デバフ効果セット

			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:効果量 = 70
			CALL アビテンプレート_有利効果_奥義ゲージUP

			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:消去不可バフデバフ削除オプション = 1
			CALL アビテンプレート_不利効果_バフ消去("劫火")
		ELSE
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = 劫火
			アビ汎用文字列:バフ・デバフ対象能力 = 劫火
			アビ汎用変数:効果量 = 1
			アビ汎用変数:累積上限_固定値 = 4
			アビ汎用変数:持続ターン = -1
			アビ汎用変数:消去不可オプション = 1
			CALL アビテンプレート_有利効果_累積バフ効果セット
		ENDIF
ENDSELECT



@固有アビ_3302_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 威力値

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 25
	アビ名 = 烈火+
	消費ＭＰ = 100
	威力値 = 330
ELSE
	アビ名 = 烈火
	消費ＭＰ = 100
	威力値 = 220
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵縦列に［{威力値}％］の火属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>自身に［20％］の奥義ゲージ増加を与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ対象選択テンプレート_敵縦列
		アビ汎用変数:効果割合 = 威力値
		SIF バフ番号取得("灼熱の心", 戦闘行動キャラ) > -1
			アビ汎用変数:防御無視オプション_割合 = 50
		CALL アビテンプレート_ダメージ処理_火属性
		
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用変数:効果量 = 20
		CALL アビテンプレート_有利効果_奥義ゲージUP

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 劫火
		アビ汎用文字列:バフ・デバフ対象能力 = 劫火
		アビ汎用変数:効果量 = 1
		アビ汎用変数:累積上限_固定値 = 4
		アビ汎用変数:持続ターン = -1
		アビ汎用変数:消去不可オプション = 1
		CALL アビテンプレート_有利効果_累積バフ効果セット
ENDSELECT


@固有行動開始時処理_キャラ_3302

戦闘中カウント:戦闘行動キャラ:0 = DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("劫火", 戦闘行動キャラ), "効果量_固定値")


@固有行動直後処理_キャラ_3302

SIF 戦闘中カウント:戦闘行動キャラ:0 > 3
	RETURN
SIF DT_CELL_GET("戦闘効果データベース", バフ番号取得_枠("劫火", 戦闘行動キャラ), "効果量_固定値") != 4
	RETURN
CALL アビ汎用変数文字列リセット
アビテンプレート用_アビ名表示済フラグ = 1
CALL アビ対象選択テンプレート_自己のみ
アビテンプレート用_アビ名 = アビリティ：灼熱の心発動
アビ汎用文字列:バフ・デバフ枠 = 灼熱の心
アビ汎用文字列:バフ・デバフ対象能力 = 灼熱の心
アビ汎用変数:効果量 = 1
アビ汎用変数:持続ターン = 4
アビ汎用変数:消去不可オプション = 1
CALL アビテンプレート_有利効果_バフ効果セット

@固有被ダメ時処理_キャラ_3302(全滅フラグ)
#DIM 全滅フラグ

SIF 全滅フラグ
	RETURN 0
SIF 戦闘中カウント:戦闘行動キャラ:1
	RETURN
SIF BATTLE_STATE:戦闘行動キャラ:ＨＰ * 100 >= BATTLE_STATE:戦闘行動キャラ:最大ＨＰ * 40
	RETURN
戦闘中カウント:戦闘行動キャラ:1 = 1
CALL アビ汎用変数文字列リセット
CALL アビ対象選択テンプレート_自己のみ
アビテンプレート用_アビ名 = アビリティ：再燃発動
アビ汎用文字列:バフ・デバフ枠 = 再燃
アビ汎用文字列:バフ・デバフ対象能力 = 再燃
アビ汎用変数:持続ターン = 2
アビ汎用変数:消去不可オプション = 1
CALL アビテンプレート_有利効果_バフ効果セット

アビ汎用文字列:バフ・デバフ枠 = 再燃_被ダメージ
アビ汎用文字列:バフ・デバフ対象能力 = 被ダメージ
アビ汎用変数:効果割合 = 90
CALL アビテンプレート_有利効果_付随バフ効果セット("再燃")

CALL アビ汎用変数文字列リセット
アビ汎用文字列:バフ・デバフ枠 = 再燃_再生
アビ汎用文字列:バフ・デバフ対象能力 = 再生
アビ汎用変数:効果割合 = 20
CALL アビテンプレート_有利効果_付随バフ効果セット("再燃")


@固有通常攻撃後処理_キャラ_3302(全滅フラグ, 連撃数)
#DIM 連撃数
#DIM 全滅フラグ

VARSET LOCAL
FOR LOCAL:1, 10, 20
	SIF デバフ番号取得_枠("火傷", LOCAL:1) > -1
		LOCAL += DT_CELL_GET("戦闘効果データベース", デバフ番号取得_枠("火傷", LOCAL:1), "効果量_固定値") / 50
NEXT
IF LOCAL
	CALL アビ汎用変数文字列リセット
	CALL アビ対象選択テンプレート_自己のみ
	アビテンプレート用_アビ名 = アビリティ：灼熱の心発動
	アビ汎用文字列:バフ・デバフ枠 = 劫火
	アビ汎用文字列:バフ・デバフ対象能力 = 劫火
	アビ汎用変数:効果量 = LOCAL
	アビ汎用変数:累積上限_固定値 = 4
	アビ汎用変数:持続ターン = -1
	アビ汎用変数:消去不可オプション = 1
	CALL アビテンプレート_有利効果_累積バフ効果セット
ENDIF

;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
;・使い方
;「XXXX」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;　口上と同じ感覚で使う為に書式を統一しているが、ステータス画面で表示されるので
;　基本的にWAIT系列は使わないことを推奨
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3302(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ 特性：『灼熱の心』 □-----------------------------------------------------------------
KSTR:(K++) = 　通常攻撃時に敵全体の火傷Lvの合計値分、自身の劫火Lvが上昇
KSTR:(K++) = 　アビリティ使用時、自身の劫火Lvが1上昇［最大Lv4/永続/消去不可］
KSTR:(K++) = 　劫火Lvが4になった時、自身にアビリティと奥義使用時敵の防御力の50％を無視（4ターン）効果を与える
KSTR:(K++) = 　
KSTR:(K++) = □ 特性：『再燃』 □------------------------------------------------------------
KSTR:(K++) = 　HPが40％未満になった場合に一度だけ自身に、
KSTR:(K++) = 　ダメージカット［90％］（2ターン）効果と［20％］（2ターン）の再生効果を与える

CALL 口上変数表示(対象キャラ, 1)




	CASE IS <= 経験値テーブル:(関係閾値:1)
		;他人
		KSTR:(K++) = 「他にもっといるだろ？」
	CASE IS <= 経験値テーブル:(関係閾値:2)
		;顔見知り
		KSTR:(K++) = 「いや確かにな？　悪い奴じゃねぇよ_2nd_は」
	CASE IS <= 経験値テーブル:(関係閾値:3)
		;気になる人
		KSTR:(K++) = 「だからって気になるなんてことは……」
	CASE IS <= 経験値テーブル:(関係閾値:4)
		;想い人
		KSTR:(K++) = 「……なんだよ、こっちにきた_1st_を良くしてくれたんだぞ、いくらなんでも一切ないのはおかしいだろ……？」
	CASEELSE

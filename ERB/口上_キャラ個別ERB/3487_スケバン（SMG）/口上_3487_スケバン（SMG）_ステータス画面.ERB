
;・使い方
;「3487」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;--------------------------------------------------
;通常画面一言口上
;--------------------------------------------------
@口上_INFO画面_一言コメント_3487(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

;口上と同じ感覚で使う為に書式を統一しているが、通常時の画面で表示されるので
;基本的にWAIT系列は使わないことを推奨
;また、一行のみの表示を想定。二行以上は基本的に禁止
;※うふふ中には表示されません

;以下は分岐の例
;仕事中の一言口上
IF TALENT:対象キャラ:従業員 && TCVAR:対象キャラ:休暇中 == 0 && CFLAG:対象キャラ:現在位置 == 現在仕事:対象キャラ:1 % 10000 && CFLAG:対象キャラ:現在マップ種別 == 現在仕事:対象キャラ:1 / 10000
	SELECTCASE 現在仕事:対象キャラ:1
		CASE 2
			;ロビーで受付中
			STRDATA KSTR:(K++)
				DATA 「い、いらっしゃいませ～」（マスク越しから引き攣った笑顔をが見える）
				DATA 「くそっ、どう考えても配置ミスだろコレ……」
			ENDDATA
		CASE 503
			;バーエリアでバーテンダー中
			STRDATA KSTR:(K++)
				DATA 「あー……すいませんけどカクテルはノンアルしか作れなくて……」
				DATA 「は？　『隣のお客様にグラスをシュッとやるのをやってくれ』？」
				DATA （シュッ）（ﾊﾟﾘｰﾝ）「あっ」
			ENDDATA
		CASE 506
			;図書室で司書中
			STRDATA KSTR:(K++)
				DATA 「なんでリゾートに馬鹿でけぇ図書館があんだよ……」
				DATA 「この本何処だ？　……ここで良いか」
				DATA 「おいコラァ！　誰だ児童書コーナーにこれぶち込んだ奴！？」（手には_COLOR_FF3399_表紙のショッキングピンクが眩しい本_が握られている）
			ENDDATA
		CASE 1503, 15
			;プールで監視員中
			STRDATA KSTR:(K++)
				DATA 「あっちぃなぁ……」（恰好がセーラー服から太ももが眩しいビキニ姿に変わっている）
				DATA 「……なんか今サメが空飛んでた気がするんだが疲れてんのかな_1st_」
				DATA 「嘘じゃねぇよカキが空飛んでたんだって！？　『？　カキは空を飛ぶものだろ？』　くっそ誰か救護班呼んでくれ！」
			ENDDATA
		CASE IS > 10000
			;各種店舗で店番中
			CALLFORMF 空艇港店舗名表示_{空艇港店舗状況:(現在仕事:対象キャラ:1 - 10000):0}(現在仕事:対象キャラ:1 - 10000)
			SELECTCASE REPLACE(TSTR:場所名受渡, "『.*』", "")
				CASE "道具屋"
					STRDATA KSTR:(K++)
						DATA 「い、いらっしゃいませ～」
						DATA 「銃弾は売ってねぇか……」
					ENDDATA
				CASE "土産物屋"
					STRDATA KSTR:(K++)
						DATA 「お勧めの品……この【リゾートまんじゅう】とか……」
						DATA 「お勧めの品……この【リゾートお煎餅】とか……」
					ENDDATA
				CASE "食事処"
					STRDATA KSTR:(K++)
						DATA 「ご注文のンナギの蒲焼きお待ちィ！」
						DATA 「えーと次の注文は……【唐揚げ定食、ヤババババハムート盛り】ィ！？　うっそだろアレ注文した人居るのか！？」
					ENDDATA
				CASE "装飾品店"
					STRDATA KSTR:(K++)
						DATA 「旅のお供に指輪やイヤリングはどうですかー……いや旅のお供ってなんだよ……」
						DATA 「【古びた指輪の再生】？　すいませんけど_1st_バイトなんで詳しいことは……」
					ENDDATA
			ENDSELECT
	ENDSELECT
ENDIF
;この時点で口上が入ってるなら表示へ飛ばす
SIF KSTR:0 != ""
	GOTO 表示位置
;状況で分岐

IF CFLAG:対象キャラ:飲み会
	;飲み会中
	STRDATA KSTR:(K++)
		DATA 「酒？　……ああ！　そりゃあ嗜んでたぜ……」（微妙に目が泳いでいる……
		DATA 「う、うーん……」（酒の匂いだけで顔が赤くなっている）
	ENDDATA
ELSEIF CFLAG:対象キャラ:睡眠
	;睡眠中
	STRDATA KSTR:(K++)
		DATA 「……もう食えねぇよ……ZZZZ……」（安らかな表情を浮かべつつ寝言が聴こえる
		DATA 「違う……違う……人の身体はそっちには曲がら……！」（呻くような寝言が聴こえる
	ENDDATA
ELSEIF CFLAG:対象キャラ:デート
	;デート中
	;デートの相手のキャラ番号 + 100が入っている
	;あなた相手なら「CFLAG:対象キャラ:デート == MASTER + 100」
	KSTR:(K++) = 「……なんだよ」（いつもの勝気な印象はなく何処かしおらしい）
ELSEIF CFLAG:対象キャラ:一緒に遊ぶ
	;一緒に遊ぶ中
	KSTR:(K++) = 「どんくさいかと思ったけど案外やるじゃねぇか」
ELSEIF CFLAG:対象キャラ:同行
	;同行中
	KSTR:(K++) = 「どこ行くんだ？」
ELSEIF CFLAG:PLAYER:隠密 && CFLAG:対象キャラ:隠密
	;一緒に隠密中
	KSTR:(K++) = 「おい、ちょ、ほ、本当にここでスる気か……？」
ELSEIF CFLAG:PLAYER:隠密 && !CFLAG:対象キャラ:隠密
	;あなたが隠れていて、キャラはあなたに気づいていない
	KSTR:(K++) = 「あん？　……気のせいか？」
ELSEIF !CFLAG:PLAYER:隠密 && CFLAG:対象キャラ:隠密
	;キャラの野外オナニー中
	STRDATA KSTR:(K++)
		DATA 「ここならバレねぇよな……_H_」（水音が小さく響いている……）
		DATA 「やばいヤバいヤバイなんでこんなタイミングで人が……！」（衣擦れの音が聞こえる……）
		DATA 「これじゃ_1st_がヘンタイみたいじゃねぇか……__H_」（振動音が聞こえる……）
	ENDDATA
ENDIF
;この時点で口上が入ってるなら表示へ飛ばす
SIF KSTR:0 != ""
	GOTO 表示位置

;最も多い好感度要素で分岐
;簡易版なのでステータス画面のコメントを利用。細かく決めたい場合は後で編集してください
SELECTCASE MAXRAND(CFLAG:対象キャラ:友情度, CFLAG:対象キャラ:信頼度, CFLAG:対象キャラ:恋心度, CFLAG:対象キャラ:性愛度)
	CASE 0
		;友情度
		CALL 口上_ステータス画面_友情コメント_3487(対象キャラ, 1)
	CASE 1
		;信頼度
		CALL 口上_ステータス画面_信頼コメント_3487(対象キャラ, 1)
	CASE 2
		;恋心度
		CALL 口上_ステータス画面_恋心コメント_3487(対象キャラ, 1)
	CASE 3
		;性愛度
		CALL 口上_ステータス画面_性愛コメント_3487(対象キャラ, 1)
ENDSELECT

IF K > 1
	KSTR:0 '= KSTR:0 + KSTR:1
	KSTR:1 '= ""
ENDIF

$表示位置
CALL PRINT_STATEコメント表示(対象キャラ, 2)


;--------------------------------------------------
;ステータス画面一言口上_友情
;--------------------------------------------------
@口上_ステータス画面_友情コメント_3487(対象キャラ, ARG=0)
#DIM 対象キャラ
CALL 口上変数初期化

;口上と同じ感覚で使う為に書式を統一しているが、ステータス画面で表示されるので
;基本的にWAIT系列は使わないことを推奨
;こちらも簡易版なので一行のみに限定

SELECTCASE CFLAG:対象キャラ:友情度
	CASE IS == 0
		;初対面
		KSTR:(K++) = （スケバン（SMG）はこちらに気づいていないようだ）
	CASE IS <= 経験値テーブル:(関係閾値:1)
		;他人
		KSTR:(K++) = 「あ？　なんだこっちをじろじろ見てやんのか？」
	CASE IS <= 経験値テーブル:(関係閾値:2)
		;顔見知り
		KSTR:(K++) = 「なんだ_主人_か……いや悪かったって知らねーヤツがじろじろ見てるんだ警戒くらいするだろ？」
	CASE IS <= 経験値テーブル:(関係閾値:3)
		;友人
		KSTR:(K++) = 「つーかこんなでけーリゾートの経営とか疲れねーの？　『案外楽しい？』　マジかすげぇな……」
	CASE IS <= 経験値テーブル:(関係閾値:4)
		;親友
		KSTR:(K++) = 「今だから言えるけど最初見た時は『うさんくせー』って思ってたんだよな、今？　……ダチだよ言わせんな恥ずかしい」
	CASEELSE
		;無二の友
		KSTR:(K++) = 「なんかあったら_1st_も手伝うぜ、ダチだからな」
ENDSELECT

SIF ARG
	RETURN

CALL PRINT_STATEコメント表示(対象キャラ)

;--------------------------------------------------
;ステータス画面一言口上_信頼
;--------------------------------------------------
@口上_ステータス画面_信頼コメント_3487(対象キャラ, ARG=0)
#DIM 対象キャラ
CALL 口上変数初期化
SELECTCASE CFLAG:対象キャラ:信頼度
	CASE IS == 0
		;初対面
		KSTR:(K++) = 「……」（無言で銃に手を掛けている）
	CASE IS <= 経験値テーブル:(関係閾値:1)
		;他人
		KSTR:(K++) = 「……どーも」（いつでも銃に指が伸ばせるようにしている）
	CASE IS <= 経験値テーブル:(関係閾値:2)
		;顔見知り
		KSTR:(K++) = 「おう」（こちらに気づいて片手をあげた
	CASE IS <= 経験値テーブル:(関係閾値:3)
		;知己
		KSTR:(K++) = 「そういえば今日こんなことがあったんだよな～」（気安い会話が続いている……
	CASE IS <= 経験値テーブル:(関係閾値:4)
		;相棒
		KSTR:(K++) = 「_2nd_がキヴォトスにいりゃあ_1st_も違ったのかな……」（_主人_を信頼しているようだ……
	CASEELSE
		;水魚の交わり
		KSTR:(K++) = 「今日は何処に行く？」（もはや_主人_の隣に彼女がいるのは当たり前の光景だ……
ENDSELECT

SIF ARG
	RETURN

CALL PRINT_STATEコメント表示(対象キャラ)



;--------------------------------------------------3217
;专属奥义
;--------------------------------------------------
@固有奥義_3217(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義威力表示

    隊列番号 = キャラ隊列検索(キャラ番号)

    ;アビ汎用変数:必要奥義ゲージ量 = 200
    ;アビ汎用変数:消費奥義ゲージ量 = 200
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = ビッグシスター
    ENDIF
    奥義威力 = 0
    奥義威力表示 = 0

    SELECTCASE RAND:3
        CASE 0
        アビ汎用文字列:実行時メッセージ１ = 「これが必要なのでしょう？」
        CASE 1
        アビ汎用文字列:実行時メッセージ１ = 「これが、あなたの可能性よ。」
        CASE 2
        アビ汎用文字列:実行時メッセージ１ = 「受け取ってちょうだい。」
    ENDSELECT
    
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力表示}％
            詳細文文字列受け渡し変数 += @"<br> <br>自身を除く味方1人に［1回］の奥義再発動効果を与える。"
            詳細文文字列受け渡し変数 += @"<br>対象の攻撃力を35％増加（A枠・3ターン）"
            ;詳細文文字列受け渡し変数 += @"<br>ヒフミの最大HPの160％のバリアを与える。味方を援護する。"
            
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
        CASE "奥義追加効果"
    
            CALL アビ対象選択テンプレート_味方単体_生者のみ_自己以外
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 奥義再発動
            アビ汎用文字列:バフ・デバフ対象能力 = 奥義再発動
            アビ汎用変数:持続回数 = 1
            CALL アビテンプレート_有利効果_バフ効果セット
            
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 攻撃力A
            アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
            アビ汎用変数:効果割合 = 35
            アビ汎用変数:持続ターン = 3
            CALL アビテンプレート_有利効果_バフ効果セット
ENDSELECT

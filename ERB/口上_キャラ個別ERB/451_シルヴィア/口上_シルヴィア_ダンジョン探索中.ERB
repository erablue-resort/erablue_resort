;--------------------------------------------------
;ダンジョン探索中に条件を満たしていた時表示される文章
;--------------------------------------------------
;・使い方
;「8」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;--------------------------------------------------

;--------------------------------------------------
;「仲間と会話」ボタン押下時
;簡単に何度も見られるので、条件分岐やランダム化で複数パターンの登録を推奨
;--------------------------------------------------
@KOJO_DUNGEON_仲間と会話_451(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化
LOCAL = キャラ隊列検索(対象キャラ)

IF キャラ隊列検索(GETCHARA(79)) > -1 && RAND:2 == 2
	SELECTCASE RAND:4
		CASE 0
			KSTR:(K++) = 「オリヴィエはやっぱり相変わらずみたいね」
		CASE 1
			KSTR:(K++) = 「オリヴィエ………」
		CASE 2
			KSTR:(K++) = 「堕天司はまだあの卵の中に…」
		CASE 3
			KSTR:(K++) = 「ベルソーともう少し話してみたいのだけれど」
	ENDSELECT
ELSE
	SELECTCASE RAND:6
		CASE 0
			KSTR:(K++) = 「断罪こそが我が使命…」
		CASE 1
			KSTR:(K++) = 「…どうして忘れてしまったのかしら」
		CASE 2
			KSTR:(K++) = 「空の民たちのことは愛しく思うわ」
		CASE 3
			KSTR:(K++) = 「自由を受け入れるわけにはいかない…」
		CASE 4
			KSTR:(K++) = 「こんなことが私の望みなの？」
		CASE 5
			KSTR:(K++) = 「買い物にでも行きたい気分だわ」
	ENDSELECT
ENDIF

CALL メッセージ欄表示用関数(@"探索用_{LOCAL}_顔", CALLNAME:対象キャラ)


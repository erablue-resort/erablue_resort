
@固有アビ_451_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM デバフ判定1
#DIM デバフ判定2

;レベルなどの条件でアビを強化する場合、アビ名の文字列を条件分岐で変化させる
IF 基礎BATTLE_STATE:キャラ番号:Lv >= 55
	アビ名 = エッジ・オブ・エンフォーサー＋
	
	IF 探索中カウント:戦闘行動キャラ:0 == 1
		消費ＭＰ = 0
	ELSE
		消費ＭＰ = 200
	ENDIF
ELSE
	アビ名 = エッジ・オブ・エンフォーサー
	
	IF 探索中カウント:戦闘行動キャラ:0 == 1
		消費ＭＰ = 0
	ELSE
		消費ＭＰ = 250
	ENDIF
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［攻撃力×300％］の水属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>［10％（最大40％）］（累積枠・5ターン）の攻撃力減少効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>［10％（最大40％）］（累積枠・5ターン）の防御力減少効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>ランダムな弱体効果を［2つ］与える。"
		RETURN 消費ＭＰ
	CASE "アビ説明文_詳細"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>敵単体に［攻撃力×300％］の水属性ダメージを与える。
		詳細文文字列受け渡し変数 += @"<br>［10％（最大40％）］（累積枠・5ターン）の攻撃力減少効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>［10％（最大40％）］（累積枠・5ターン）の防御力減少効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>以下の弱体効果からランダムな弱体効果を［2つ］与える。"
		詳細文文字列受け渡し変数 += @"<br>・［50］（3ターン）の灼熱効果"
		詳細文文字列受け渡し変数 += @"<br>・（3ターン）の睡眠効果"
		詳細文文字列受け渡し変数 += @"<br>・［30％］（3ターン）の魅了効果"
		詳細文文字列受け渡し変数 += @"<br>・（3ターン）の恐怖効果"
		詳細文文字列受け渡し変数 += @"<br>・［60％］（3ターン）の暗闇効果"
		詳細文文字列受け渡し変数 += @"<br>・［60％］（3ターン）の命中率減少効果"
		詳細文文字列受け渡し変数 += @"<br>・［25％］（A枠・3ターン）の攻撃力減少効果"
		詳細文文字列受け渡し変数 += @"<br>・［25％］（A枠・3ターン）の防御力減少効果"
		詳細文文字列受け渡し変数 += @"<br>・（3ターン）の麻痺効果"
	CASE "アビ効果"
		$REPEAT1
		
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:効果割合 = 300
		CALL アビテンプレート_ダメージ処理_水属性
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 攻撃力_累積枠
		アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
		アビ汎用変数:効果割合 = 10
		アビ汎用変数:累積上限_割合 = 40
		アビ汎用変数:持続ターン = 5
		CALL アビテンプレート_不利効果_累積デバフ効果セット
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 防御力_累積枠
		アビ汎用文字列:バフ・デバフ対象能力 = 防御力
		アビ汎用変数:効果割合 = 10
		アビ汎用変数:累積上限_割合 = 40
		アビ汎用変数:持続ターン = 5
		CALL アビテンプレート_不利効果_累積デバフ効果セット
		
		$REDRAW1
		デバフ判定1 = RAND(1,9)
		デバフ判定2 = RAND(1,9)
		
		SIF デバフ判定1 == デバフ判定2
			GOTO REDRAW1
		
		IF デバフ判定1 == 1 || デバフ判定2 == 1
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 灼熱
			アビ汎用文字列:バフ・デバフ対象能力 = 灼熱
			アビ汎用変数:効果量 = 50
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 2 || デバフ判定2 == 2
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 睡眠
			アビ汎用文字列:バフ・デバフ対象能力 = 睡眠
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 3 || デバフ判定2 == 3
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 魅了
			アビ汎用文字列:バフ・デバフ対象能力 = 魅了
			アビ汎用変数:効果割合 = 30
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 4 || デバフ判定2 == 4
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 恐怖
			アビ汎用文字列:バフ・デバフ対象能力 = 恐怖
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 5 || デバフ判定2 == 5
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 暗闇
			アビ汎用文字列:バフ・デバフ対象能力 = 暗闇
			アビ汎用変数:効果割合 = 60
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 6 || デバフ判定2 == 6
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 命中率
			アビ汎用文字列:バフ・デバフ対象能力 = 命中率
			アビ汎用変数:効果量 = 60
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 7 || デバフ判定2 == 7
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 攻撃力_A枠
			アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
			アビ汎用変数:効果割合 = 25
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 8 || デバフ判定2 == 8
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 防御力_A枠
			アビ汎用文字列:バフ・デバフ対象能力 = 防御力
			アビ汎用変数:効果割合 = 25
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 9 || デバフ判定2 == 9
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 麻痺
			アビ汎用文字列:バフ・デバフ対象能力 = 麻痺
			アビ汎用変数:持続ターン = 2
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF 探索中カウント:戦闘行動キャラ:0 == 1
			探索中カウント:戦闘行動キャラ:0 = 0
			
			アビテンプレート用_行動消費無しフラグ = 1
			
			GOTO REPEAT1
		ENDIF
		
		
ENDSELECT



@固有アビ_451_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 75
	アビ名 = クライシス・パーセキュート＋
	
	IF 探索中カウント:戦闘行動キャラ:1 == 1
		消費ＭＰ = 0
	ELSE
		消費ＭＰ = 200
	ENDIF
ELSE
	アビ名 = クライシス・パーセキュート
	
	IF 探索中カウント:戦闘行動キャラ:1 == 1
		消費ＭＰ = 0
	ELSE
		消費ＭＰ = 250
	ENDIF
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>味方全体に［20％］の奥義ゲージ増加を与える。
		詳細文文字列受け渡し変数 += @"<br>［200］のHP回復を与える。"
		詳細文文字列受け渡し変数 += @"<br>［2ターン］の弱体効果短縮を与える。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		$REPEAT2

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_味方全体_生者のみ
		アビ汎用変数:効果量 = 20
		CALL アビテンプレート_有利効果_奥義ゲージUP

		CALL アビ汎用変数文字列リセット
		アビ汎用変数:効果量 = 200
		CALL アビテンプレート_回復処理_MAXでも回復

		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = ALL
		アビ汎用変数:効果量 = 2
		CALL アビテンプレート_有利効果_デバフ効果短縮_持続ターン
		
		IF 探索中カウント:戦闘行動キャラ:1 == 1
			探索中カウント:戦闘行動キャラ:1 = 0
			
			アビテンプレート用_行動消費無しフラグ = 1
			
			GOTO REPEAT2
		ENDIF
ENDSELECT



@固有アビ_451_3(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM シルヴィア隊列

シルヴィア隊列 = キャラ隊列検索(キャラ番号)

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
	アビ名 = ワールド・コンヴィクション
	消費ＭＰ = 750
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}<br>自身に［200％］の奥義ゲージ増加を与える。
		詳細文文字列受け渡し変数 += @"<br>（2回）の被ダメージ無効効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>（2ターン）の再行動効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>このアビリティでは行動回数を消費しない。"
		詳細文文字列受け渡し変数 += @"<br>◆断罪Lvが5の時、次のエッジ・オブ・エンフォーサー/クライシス・パーセキュートがMP・行動回数を消費せず、2回発動する。"
		RETURN 消費ＭＰ
	CASE "アビ効果"
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用変数:効果量 = 200
		CALL アビテンプレート_有利効果_奥義ゲージUP

		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 被ダメージ減少
		アビ汎用文字列:バフ・デバフ対象能力 = 被ダメージ
		アビ汎用変数:効果割合 = 100
		アビ汎用変数:持続回数 = 2
		CALL アビテンプレート_有利効果_バフ効果セット

		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 再行動
		アビ汎用文字列:バフ・デバフ対象能力 = 再行動
		アビ汎用変数:効果量 = 1
		アビ汎用変数:持続ターン = 2
		CALL アビテンプレート_有利効果_バフ効果セット
		
		IF 刻印現在数確認("断罪", シルヴィア隊列) == 5
			探索中カウント:戦闘行動キャラ:0 = 1
			探索中カウント:戦闘行動キャラ:1 = 1
			
			WSTR:(K++) = 次のエッジ・オブ・エンフォーサーとクライシス・パーセキュートがMPと行動回数を消費せず2回発動するようになった！
		ENDIF
		
		アビテンプレート用_行動消費無しフラグ = 1
ENDSELECT



@固有戦闘開始時処理_キャラ_451
#DIM バフ・デバフ行数

CALL アビ汎用変数文字列リセット
CALL アビ対象選択テンプレート_自己のみ
アビ汎用文字列:バフ・デバフ枠 = 堕天司の監視者
アビ汎用文字列:バフ・デバフ対象能力 = 堕天司の監視者
アビ汎用変数:持続ターン = -1
アビ汎用変数:消去不可オプション = 1
アビ汎用変数:特殊表示オプション = -1
アビ汎用文字列:適用範囲 = 味方全体
CALL アビテンプレート_有利効果_パッシブバフ効果セット



@固有奥義後処理_バフ_堕天司の監視者(バフ・デバフ行数, 全滅フラグ)
#DIM バフ・デバフ行数
#DIM 全滅フラグ
#DIM シルヴィア隊列
#DIM 行動キャラ保存
#DIM デバフ判定1
#DIM デバフ判定2

SIF 全滅フラグ
	RETURN 0

シルヴィア隊列 = キャラ隊列検索(GETCHARA(451))

SIF INRANGE(シルヴィア隊列, 0, 3) && 探索中カウント:シルヴィア隊列:2 < 2
	探索中カウント:シルヴィア隊列:2 += 1

IF 探索中カウント:シルヴィア隊列:2 == 2
	;一時的に戦闘行動キャラをシルヴィアに渡す
	SWAP 戦闘行動キャラ, 行動キャラ保存
	戦闘行動キャラ = シルヴィア隊列
	
	CALL アビ汎用変数文字列リセット
	CALL アビテンプレート用_表示メッセージ変換処理
	CALL メッセージ欄表示用関数(,,,0)
	アビテンプレート用_アビ名表示済フラグ = 0

	アビ汎用文字列:実行時メッセージ１ = 「刃を受けよ！」
	アビ汎用文字列:実行時メッセージ２ = シルヴィアのエッジ・オブ・エンフォーサー！
	
	ARRAYCOPY "アビテンプレート用_奥義使用先保存", "アビテンプレート用_対象保存"
	
		CALL アビ汎用変数文字列リセット
		アビ汎用変数:効果割合 = 300
		CALL アビテンプレート_ダメージ処理_水属性
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 攻撃力_累積枠
		アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
		アビ汎用変数:効果割合 = 10
		アビ汎用変数:累積上限_割合 = 40
		アビ汎用変数:持続ターン = 5
		CALL アビテンプレート_不利効果_累積デバフ効果セット
		
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = 防御力_累積枠
		アビ汎用文字列:バフ・デバフ対象能力 = 防御力
		アビ汎用変数:効果割合 = 10
		アビ汎用変数:累積上限_割合 = 40
		アビ汎用変数:持続ターン = 5
		CALL アビテンプレート_不利効果_累積デバフ効果セット
		
		$REDRAW
		デバフ判定1 = RAND(1,9)
		デバフ判定2 = RAND(1,9)
		
		SIF デバフ判定1 == デバフ判定2
			GOTO REDRAW
		
		IF デバフ判定1 == 1 || デバフ判定2 == 1
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 灼熱
			アビ汎用文字列:バフ・デバフ対象能力 = 灼熱
			アビ汎用変数:効果量 = 50
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 2 || デバフ判定2 == 2
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 睡眠
			アビ汎用文字列:バフ・デバフ対象能力 = 睡眠
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 3 || デバフ判定2 == 3
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 魅了
			アビ汎用文字列:バフ・デバフ対象能力 = 魅了
			アビ汎用変数:効果割合 = 30
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 4 || デバフ判定2 == 4
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 恐怖
			アビ汎用文字列:バフ・デバフ対象能力 = 恐怖
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 5 || デバフ判定2 == 5
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 暗闇
			アビ汎用文字列:バフ・デバフ対象能力 = 暗闇
			アビ汎用変数:効果割合 = 60
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 6 || デバフ判定2 == 6
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 命中率
			アビ汎用文字列:バフ・デバフ対象能力 = 命中率
			アビ汎用変数:効果量 = 60
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 7 || デバフ判定2 == 7
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 攻撃力_A枠
			アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
			アビ汎用変数:効果割合 = 25
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 8 || デバフ判定2 == 8
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 防御力_A枠
			アビ汎用文字列:バフ・デバフ対象能力 = 防御力
			アビ汎用変数:効果割合 = 25
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
		
		IF デバフ判定1 == 9 || デバフ判定2 == 9
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 麻痺
			アビ汎用文字列:バフ・デバフ対象能力 = 麻痺
			アビ汎用変数:持続ターン = 2
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
	
	CALL アビ汎用変数文字列リセット
	CALL アビ対象選択テンプレート_自己のみ
	アビ汎用変数:効果量 = 20
	CALL アビテンプレート_有利効果_奥義ゲージUP
	
	;戦闘行動キャラを戻す
	SWAP 戦闘行動キャラ, 行動キャラ保存
	
	探索中カウント:シルヴィア隊列:2 = 0
ENDIF





;--------------------------------------------------3054
;专属奥义
;--------------------------------------------------
@固有奥義_3054(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
#DIM 奥義威力表示

    隊列番号 = キャラ隊列検索(キャラ番号)

    アビ汎用変数:必要奥義ゲージ量 = 200
    アビ汎用変数:消費奥義ゲージ量 = 200
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        奥義名 = 終幕：イシュ・ボシェテ
    ENDIF
    奥義威力 = 0
    奥義威力表示 = 408
    SELECTCASE RAND:3
        CASE 0
        アビ汎用文字列:実行時メッセージ１ = 「どれくらい耐えられるか見ものね？」
        CASE 1
        アビ汎用文字列:実行時メッセージ１ = 「逃げることはできない。」
        CASE 2
        アビ汎用文字列:実行時メッセージ１ = 「逃さない。」
    ENDSELECT
    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"

            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力表示}％
            詳細文文字列受け渡し変数 += @"<br> ランダムな敵4体に［攻撃力✕{奥義威力表示}％］の自属性ダメージを3回与える。"
            詳細文文字列受け渡し変数 += @"<br>◆奥義ゲージ200％の時のみ奥義発動可能"
            ;詳細文文字列受け渡し変数 += @"<br>ヒフミの最大HPの160％のバリアを与える。味方を援護する。"
            
            RETURN 奥義威力
            ;RETURN 1

        CASE "奥義前効果"
           
        CASE "奥義追加効果"

            CALL アビ汎用変数文字列リセット
            アビ汎用変数:敵対心無視オプション = 1
			CALL アビ対象選択テンプレート_敵ランダムＸ体_重複無し(4)
			アビ汎用変数:効果割合 = 奥義威力表示
            アビ汎用文字列:ダメージ種類 = 奥義ダメージ
			CALL アビテンプレート_ダメージ処理_自属性
            CALL アビテンプレート_ダメージ処理_自属性
            CALL アビテンプレート_ダメージ処理_自属性

ENDSELECT

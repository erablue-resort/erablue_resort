;--------------------------------------------------
; キクル 专属技能
;--------------------------------------------------

;--------------------------------------------------
; 技能 1: 魔道回復
;--------------------------------------------------
@固有アビ_3024_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM クールタイム

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF BATTLE_STATE:戦闘行動キャラ:ＭＰ >= 2500 ;2500
        アビ名 = 魔道回復
        消費ＭＰ = 0 ;修改2500
    ENDIF
    IF INRANGE(隊列番号, 0, 3) && 戦闘中カウント:隊列番号:0
        クールタイム = MAX(0, 99 + 戦闘中カウント:隊列番号:0 - 現在ターン数)
        SIF クールタイム > 0
            アビテンプレート用_アビ封印用フラグ = 1
    ELSE
        クールタイム = 0
    ENDIF

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
                詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>「高濃度の魔素に全身が浸かる」という条件を満たしてしまったが故にキクルの魔道が繋がり、あまりにも膨大なマナを放出しながら現れた「何か」。
                詳細文文字列受け渡し変数 += @"<br>このアビリティでは行動回数を消費しない。"
            ENDIF
            SIF クールタイム > 0
		    	詳細文文字列受け渡し変数 += @"（剩余{クールタイム}回合）"
            RETURN 消費ＭＰ

        CASE "アビ効果"
            
                ; --- 效果处理 ---
                ; 净化我方Debuff (消除指定数量)
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                ;アビ汎用変数:消去不可バフデバフ削除オプション = 1
                CALL アビテンプレート_有利効果_デバフ全て消去()
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                アビ汎用変数:効果割合 = 100
                アビ汎用文字列:回復側使用能力値 = 最大ＨＰ
                CALL アビテンプレート_回復処理_MAXでも回復
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 魔道回復_攻撃力
                アビ汎用文字列:バフ・デバフ対象能力 = 攻撃力
                アビ汎用変数:効果割合 = 200
                アビ汎用変数:持続ターン = -1
                CALL アビテンプレート_有利効果_バフ効果セット
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 魔道回復_クリティカル率
                アビ汎用文字列:バフ・デバフ対象能力 = クリティカル率
                アビ汎用変数:効果割合 = 50
                アビ汎用変数:持続ターン = -1
                CALL アビテンプレート_有利効果_バフ効果セット
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 魔道回復_与ダメージ
                アビ汎用文字列:バフ・デバフ対象能力 = 与ダメージ
                アビ汎用変数:効果割合 = 100
                アビ汎用変数:持続ターン = -1
                CALL アビテンプレート_有利効果_バフ効果セット
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 魔道回復_ダメージ補正_アビリティダメージ
                アビ汎用文字列:バフ・デバフ対象能力 = ダメージ補正_アビリティダメージ
                アビ汎用変数:効果割合 = 100
                アビ汎用変数:持続ターン = -1
                CALL アビテンプレート_有利効果_バフ効果セット
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 魔道回復_クリティカルダメージ率
                アビ汎用文字列:バフ・デバフ対象能力 = クリティカルダメージ率
                アビ汎用変数:効果割合 = 150
                アビ汎用変数:持続ターン = -1
                CALL アビテンプレート_有利効果_バフ効果セット
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 魔道回復_回避率
                アビ汎用文字列:バフ・デバフ対象能力 = 回避率
                アビ汎用変数:効果割合 = 100
                アビ汎用変数:持続ターン = -1
                CALL アビテンプレート_有利効果_バフ効果セット
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 魔道回復_再行動
                アビ汎用文字列:バフ・デバフ対象能力 = 再行動
                アビ汎用変数:効果量 = 2
		        アビ汎用変数:持続ターン = -1
                CALL アビテンプレート_有利効果_バフ効果セット

                アビテンプレート用_行動消費無しフラグ = 1
                戦闘中カウント:隊列番号:0 = 現在ターン数
    ENDSELECT
    RETURN RESULT

;--------------------------------------------------
; 技能 2: 石火・零式
;--------------------------------------------------
@固有アビ_3024_2(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM クールタイム1
    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        アビ名 = 石火・零式
        消費ＭＰ = 0
    ENDIF
    IF INRANGE(隊列番号, 0, 3) && 戦闘中カウント:隊列番号:1
        クールタイム1 = MAX(0, 5 + 戦闘中カウント:隊列番号:1 - 現在ターン数)
        SIF クールタイム1 > 0
            アビテンプレート用_アビ封印用フラグ = 1
    ELSE
        クールタイム1 = 0
    ENDIF

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
                詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>自身に［60％］（独自枠・2ターン）の追撃効果<br>［30］（独自枠・2ターン）の連続攻撃率上昇効果を与える。 
            ENDIF
            SIF クールタイム1 > 0
		    	詳細文文字列受け渡し変数 += @"（剩余{クールタイム1}回合）"
            詳細文文字列受け渡し変数 += @"<br>このアビリティでは行動回数を消費しない。"
            RETURN 消費ＭＰ

        CASE "アビ効果"
           
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 石火・零式_追撃
                アビ汎用文字列:バフ・デバフ対象能力 = 追撃
                アビ汎用変数:効果割合 = 60
                アビ汎用変数:持続ターン = 2
                CALL アビテンプレート_有利効果_バフ効果セット
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_自己のみ
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 石火・零式_連続攻撃率
                アビ汎用文字列:バフ・デバフ対象能力 = 連続攻撃率
                アビ汎用変数:効果量 = 30
                アビ汎用変数:持続ターン = 2
                CALL アビテンプレート_有利効果_バフ効果セット
                
            ENDIF
            アビテンプレート用_行動消費無しフラグ = 1
            戦闘中カウント:隊列番号:1 = 現在ターン数
    ENDSELECT
    RETURN RESULT

;--------------------------------------------------
; 技能 3: 明鏡止水・零式
;--------------------------------------------------
@固有アビ_3024_3(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名
#DIM 隊列番号
#DIM クールタイム2
#DIM キクル隊列

    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        アビ名 = 明鏡止水・零式
        消費ＭＰ = 0
    ENDIF
    IF INRANGE(キクル隊列, 0, 3) && 戦闘中カウント:キクル隊列:2
        クールタイム2 = MAX(0, 4 + 戦闘中カウント:キクル隊列:2 - 現在ターン数)
        SIF クールタイム2 > 0
            アビテンプレート用_アビ封印用フラグ = 1
    ELSE
        クールタイム2 = 0
    ENDIF

    SELECTCASE ARGS
        CASE "アビ名"
            TSTR:コマンド名受渡 = %アビ名%
        
        CASE "アビ説明文"

            詳細文文字列受け渡し変数 = 消耗ＭＰ：{消費ＭＰ}<br>自身に3回の弱体無効効果を与える。
            詳細文文字列受け渡し変数 += @"<br>［50％］（C枠・3ターン）の回避率上昇効果を与える。"
            詳細文文字列受け渡し変数 += @"<br>［40％］（C枠・3ターン）の弱体耐性上昇効果を与える。"
            

            SIF クールタイム2 > 0
		    	詳細文文字列受け渡し変数 += @"（剩余{クールタイム2}回合）"
            詳細文文字列受け渡し変数 += @"<br>このアビリティでは行動回数を消費しない。"
            RETURN 消費ＭＰ

        CASE "アビ効果"
            

            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_自己のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 明鏡止水・零式
            アビ汎用文字列:バフ・デバフ対象能力 = 弱体無効
            アビ汎用変数:持続回数 = 3
            CALL アビテンプレート_有利効果_バフ効果セット
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_自己のみ
            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 回避率C
            アビ汎用文字列:バフ・デバフ対象能力 = 回避率
            アビ汎用変数:効果割合 = 50
            アビ汎用変数:持続ターン = 3
            CALL アビテンプレート_有利効果_バフ効果セット
            ; --- 效果处理 ---
            CALL アビ対象選択テンプレート_自己のみ
            ; 净化我方Debuff (消除指定数量)
            アビ汎用変数:効果量 = 1
            CALL アビテンプレート_有利効果_デバフ消去

            CALL アビ汎用変数文字列リセット
            アビ汎用文字列:バフ・デバフ枠 = 弱体耐性C
            アビ汎用文字列:バフ・デバフ対象能力 = 弱体耐性
            アビ汎用変数:効果割合 = 40
            アビ汎用変数:持続ターン = 3
            CALL アビテンプレート_有利効果_バフ効果セット

            アビテンプレート用_行動消費無しフラグ = 1
            戦闘中カウント:キクル隊列:2 = 現在ターン数
    ENDSELECT
    RETURN RESULT

;--------------------------------------------------
; 战斗开始时处理 (常驻Buff等)
;--------------------------------------------------
@固有戦闘開始時処理_キャラ_3024
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数

    キャラ番号 = GETCHARA(3024)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0
    ; --- 特性: 零式 ---
    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
        CALL アビ対象選択テンプレート_自己のみ
        CALL アビ汎用変数文字列リセット
        アビ汎用文字列:バフ・デバフ枠 = 零式
        アビ汎用文字列:バフ・デバフ対象能力 = 弱体耐性
        アビ汎用変数:効果割合 = 100
        アビ汎用変数:持続ターン = -1
      ;  アビ汎用変数:特殊表示オプション = 1
        CALL アビテンプレート_有利効果_パッシブバフ効果セット
    ENDIF
    RETURN 0


;--------------------------------------------------
; 回合开始时处理 (回复/CD/动态Buff更新)
;--------------------------------------------------
@固有行動開始時処理_キャラ_3024
#DIM キャラ番号
#DIM 隊列番号
#DIM バフ・デバフ行数

    キャラ番号 = GETCHARA(3024)
    SIF キャラ番号 < 0
        RETURN 0
    隊列番号 = キャラ隊列検索(キャラ番号)
    SIF 隊列番号 < 0
        RETURN 0

    IF バフ番号取得_枠("魔道回復_攻撃力", 隊列番号) > -1
        IF BATTLE_STATE:隊列番号:ＭＰ < 2500            
            ;WSTR:(K++) = 「「魔道回復」は解除された」
            アビテンプレート用_アビ名 = 「魔道回復」解除
            CALL アビ対象選択テンプレート_自己のみ
            アビ汎用変数:消去不可バフデバフ削除オプション = 1
            CALL アビテンプレート_不利効果_バフ消去("魔道回復_攻撃力")
            CALL アビテンプレート_不利効果_バフ消去("魔道回復_クリティカル率")
            CALL アビテンプレート_不利効果_バフ消去("魔道回復_与ダメージ")
            CALL アビテンプレート_不利効果_バフ消去("魔道回復_ダメージ補正_アビリティダメージ")
            CALL アビテンプレート_不利効果_バフ消去("魔道回復_クリティカルダメージ率")
            CALL アビテンプレート_不利効果_バフ消去("魔道回復_回避率")
            CALL アビテンプレート_不利効果_バフ消去("魔道回復_再行動")
           
            CALL アビ汎用変数文字列リセット
           
        ELSE 
            
        ENDIF
    ENDIF

    RETURN 0

;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3024(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ 特性：零式 □-------------------------------------------------------------------
KSTR:(K++) = 　キケルの戦闘ステータスが上昇、敏捷性と弱体耐性が大幅に強化されるが、ジョブ証は使用不可、最大MPは成長しない。
KSTR:(K++) = 　（しかし、魔道が修復されたなら…）

CALL 口上変数表示(対象キャラ, 1)

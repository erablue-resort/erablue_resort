
;--------------------------------------------------
; Unknown 专属奥义
;--------------------------------------------------
@固有奥義_3024(ARGS, キャラ番号)
#DIM キャラ番号
#DIMS 奥義名
#DIM 隊列番号
#DIM 奥義威力
    隊列番号 = キャラ隊列検索(キャラ番号)

    IF 基礎BATTLE_STATE:キャラ番号:Lv >= 60
        奥義名 = 狙撃・零式
        奥義威力 = 600
    ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
        奥義名 = 狙撃+
        奥義威力 = 450
    ELSE
        奥義名 = 狙撃 
        奥義威力 = 350
    ENDIF

    

    SELECTCASE ARGS
        CASE "奥義名"
            TSTR:コマンド名受渡 = %奥義名%
        
        CASE "奥義説明文"
            詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％<br>
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 60
                詳細文文字列受け渡し変数 += @"<br>［30％］（C枠・3ターン）の回避率と防御力減少効果を与える。"
            ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                詳細文文字列受け渡し変数 += @"<br>［20％］（C枠・3ターン）の防御力減少効果を与える。"
            ELSE                
            ENDIF
            RETURN 奥義威力
        CASE "奥義前効果"

        CASE "奥義追加効果"
            IF 基礎BATTLE_STATE:キャラ番号:Lv >= 60
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_指定(アビテンプレート用_対象保存:0)
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ枠 = 回避率C
                アビ汎用文字列:バフ・デバフ対象能力 = 回避率
                アビ汎用変数:基礎成功確率 = 30
                アビ汎用変数:持続ターン = 3
                CALL アビテンプレート_不利効果_デバフ効果セット
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_指定(アビテンプレート用_対象保存:0)
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ対象能力 = 防御力
                アビ汎用変数:基礎成功確率 = 30
                アビ汎用変数:持続ターン = 3
                CALL アビテンプレート_不利効果_デバフ効果セット

            ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 45
                ; --- 效果处理 ---
                CALL アビ対象選択テンプレート_指定(アビテンプレート用_対象保存:0)
                CALL アビ汎用変数文字列リセット
                アビ汎用文字列:バフ・デバフ対象能力 = 防御力
                アビ汎用変数:基礎成功確率 = 20
                アビ汎用変数:持続ターン = 3
                CALL アビテンプレート_不利効果_デバフ効果セット
            ELSE

            ENDIF

    ENDSELECT
    RETURN RESULT

;・使い方
;「71」をキャラクター番号に置換し、それぞれの関数に処理を入れる

;--------------------------------------------------
;リゾート来訪前の履歴登録
;--------------------------------------------------

@口上_ステータス画面_初期履歴登録_71(対象キャラ)
#DIM 対象キャラ
#DIMS フィルタ内容
#DIM 履歴順カウント
;自由入力の履歴を登録する関数
履歴順カウント = 1

;複数登録する場合、下の処理をコピーして使用すること
;フィルタは履歴の種類を示すもの。「日常」「うふふ」「探索」「その他」から選択することを推奨
フィルタ内容 = うふふ
CALL 履歴データベース登録(CFLAG:対象キャラ:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>純朴な青年の筆下ろしをしてあげた</font>", フィルタ内容, , -999, 履歴順カウント++)
CALL 履歴データベース登録(CFLAG:対象キャラ:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>おませな少年をつまみ食いした</font>", フィルタ内容, , -999, 履歴順カウント++)
CALL 履歴データベース登録(CFLAG:対象キャラ:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>経験豊富なオジサマと存分に楽しんだ</font>", フィルタ内容, , -999, 履歴順カウント++)



@口上_ステータス画面_Ｖ挿入_初期履歴登録_71(対象キャラ)
#DIM 対象キャラ
#DIM 相手キャラ
#DIM 履歴順カウント
#DIMS 相手キャラ名
#DIMS 体験場所
#DIMS 体験方法
#DIMS 体験内容
;既にV処女を失ったキャラの履歴を登録する関数
;自動で関数が呼ばれるため、履歴登録順は制御不能。こだわる場合はこの関数を消し、「口上_ステータス画面_初期履歴登録_71」で全て制御すること
履歴順カウント = 0

;+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
;相手キャラが実装されている場合は以下に二つ名込の名前を入力
相手キャラ = キャラ検索("[サンプル]サンプル太郎")
;相手キャラが不明・未実装の場合は以下のように-1と入れ、名前を直接入力すること（上の行は削除する）
相手キャラ = -1
相手キャラ名 = 見知らぬ相手

;体験場所、不明なら空白のままで良い
体験場所 = 

;体験方法、たいていはペニスのはず。想定されているのはペニス、 バイブ、指、触手、ペニスバンドの５種類
体験場所 = ペニス

;体験内容、特に理由がなければ変更しなくて良い
IF 相手キャラ == -1
	体験内容 '= @"<font color='#%カラーパレット_HTML("薄ピンク")%'>初めて%相手キャラ名%からＶ挿入された</font>"
ELSE
	体験内容 '= @"<font color='#%カラーパレット_HTML("薄ピンク")%'>初めて%CALLNAME:相手キャラ%からＶ挿入された</font>"
ENDIF

;--------------------------------
;以下は編集しないこと
CALL 初体験日登録処理(対象キャラ, 相手キャラ, "Ｖ挿入初体験", -1, 体験場所, 体験方法, , 1)
CALL 初体験日登録処理(対象キャラ, 相手キャラ, "Ｖ挿入体験", -1, 体験場所, 体験方法, , 0)
CALL 履歴データベース登録(CFLAG:対象キャラ:人物番号, 体験内容, "うふふ", , -999, 履歴順カウント++)
;ここまで編集しないこと

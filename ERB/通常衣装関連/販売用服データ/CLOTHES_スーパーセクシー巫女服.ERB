@CLOTHES_衣装説明_スーパーセクシー巫女服()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 20000
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = エロ衣装
;販売させない服はこれに1を入れる
;セクシー巫女服を入手後に販売開始
販売禁止フラグ = !(STRCOUNT(所持制服文字列, @"汎用/セクシー巫女服_") + STRCOUNT(所持エロ衣装文字列, @"エロ/セクシー巫女服_"))

説明文章 = 
説明文章 += "セクシー巫女服の露出を上げるよう更に大胆にアレンジした服装。<br>"
説明文章 += "白小袖はもはや乳房をことを辞め、袖をつなぐ役割くらいしかなく<br>"
説明文章 += "緋袴は陰部が見えるくらい短いミニスカートへと変貌している。<br>"
説明文章 += "こらっ！十二神将ですら恥ずかして着用しないとか言わない。<br>"
説明文章 += "着用者が変態露出狂とか、そんな畏れ多いこと言ってはなりません。<br>"

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格


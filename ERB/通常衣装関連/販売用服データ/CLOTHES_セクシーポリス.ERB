@CLOTHES_衣装説明_セクシーポリス()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 10000
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = エロ衣装
;販売させない服はこれに1を入れる
販売禁止フラグ = 0

説明文章 = 
説明文章 += "異国の警備組織である制服を、極限まで扇情的に再解釈した挑発の極致である。<br>"
説明文章 += "青い制帽に黄金の徽章まではどこにでもある組み合わせだ。だが、その下はもはや制服とは呼べないレベルの衣装に仕上がっている。<br>"
説明文章 += "光沢のある深い青色のショートジャケットは胸元を大胆に切り開き、白いシャツは胸すら隠しきれず、青いネクタイだけが細く垂れて無意味に清純さを装う。<br>"
説明文章 += "白い手袋が長い袖の下から覗き、指先まで覆いながらも露わな肌とのコントラストで余計に扇情的に映る。<br>"
説明文章 += "極端に短い光沢のある深い青色のミニスカートは、わずかな動きで秘部を隠すか否かの瀬戸際を晒し、歩くたびに周囲の視覚を刺激する。<br>"
説明文章 += "ロングブーツが太ももを大胆に露わにし、鋭いヒールが危険な魅力を放つ。  <br>"
説明文章 += "抗えず手を伸ばす男たちの欲望や視線を身体で絡め取り、甘く残酷に「逮捕」する、完璧で淫靡な罠だ。<br>"

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格


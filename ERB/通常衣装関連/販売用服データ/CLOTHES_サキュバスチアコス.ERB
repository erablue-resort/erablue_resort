@CLOTHES_衣装説明_サキュバスチアコス()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 20000
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = エロ衣装
;販売させない服はこれに1を入れる
IF STRCOUNT(所持制服文字列, @"汎用/チアリーダー_") || STRCOUNT(所持制服文字列, @"エロ/セクシーチア_")
	販売禁止フラグ = 0
ELSE
	販売禁止フラグ = 1
ENDIF

説明文章 = 
説明文章 += "とある世界にて、応援を先導する少女（？）たちが身に着ける服。<br>"
説明文章 += "胸元が大きく開き双丘の頂点のみを覆うVフロントのレオタードに<br>"
説明文章 += "何一つ隠す意図のない申し訳程度のマイクロスカートが臀部を彩っている。<br>"
説明文章 += "悪魔のような角と尻尾、腰回りに着けた小さな羽。そして下腹部に光る淫紋がチャームポイント。<br>"
説明文章 += "一体ナニを応援してくれるのか、まったくもって興味は尽きない。<br>"

;出典元がある場合、それを記載
出典元 = 麻雀ファイトガール

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格


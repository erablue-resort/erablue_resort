@CLOTHES_衣装説明_リゾート警備制服()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 10000
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = 通常衣装
;販売させない服はこれに1を入れる
販売禁止フラグ = 0

説明文章 = 
説明文章 += "異国の警備組織に所属する婦警の制服を極端に再解釈した、挑発的な装束である。<br>"
説明文章 += "切り詰められた白シャツが、柔らかな曲線と引き締まった腰回りを惜しげもなく露わにし、青いジャケットがそのシルエットをより妖しく際立たせる。<br>"
説明文章 += "短い青スカートは歩くたびに軽やかに揺れ、黒革のロングブーツが脚全体を優雅に締め上げる。<br>"
説明文章 += "それを纏った者は、清廉な治安維持官の姿からは遥か遠く、ただ牝としての性的魅力を極限まで際立たせた存在となるだろう。<br>"
説明文章 += "あるいは、溢れ出るその色気に抗えず手を伸ばしてきた屈強な男たちの欲望を、逆にその肉体で「逮捕」するための、甘美な罠なのかもしれない……。<br>"

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格


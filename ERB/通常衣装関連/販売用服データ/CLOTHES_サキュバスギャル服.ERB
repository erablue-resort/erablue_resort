@CLOTHES_衣装説明_サキュバスギャル服()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 20000
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = エロ衣装
;販売させない服はこれに1を入れる
IF STRCOUNT(所持制服文字列, @"汎用/学生服_") || STRCOUNT(所持制服文字列, @"エロ/アメスク_")
	販売禁止フラグ = 0
ELSE
	販売禁止フラグ = 1
ENDIF

説明文章 = 
説明文章 += "プリーツスカートのように見える短い丈の布を裾に縫い付けた、スクールカーディガン。<br>"
説明文章 += "普通に着てもなかなかセクシーだが、最近のギャルは全裸の上からこれを<br>"
説明文章 += "肘から先の袖周りと臍下のボタン一つで留めて、オフショルダー風に着こなすのがトレンドだとか。<br>"
説明文章 += "首周りに纏うセーラー襟と、大きめのリボンで胸部を隠せば『メロすぎてキャパい』…らしい<br>"
説明文章 += "時代が一周回ってルーズソックスも人気なのだそう。本当か？<br>"

出典元 = 麻雀ファイトガール

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格


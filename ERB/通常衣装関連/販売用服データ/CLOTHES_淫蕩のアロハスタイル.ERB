@CLOTHES_衣装説明_淫蕩のアロハスタイル()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 0
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = エロ衣装
;販売させない服はこれに1を入れる
IF STRFIND(所持制服文字列, @"汎用/常夏のアロハスタイル_") >= 0
	販売禁止フラグ = 0
ELSE
	販売禁止フラグ = 1
ENDIF

説明文章 = 
説明文章 += "常夏のアロハスタイルにいくつか改造を施した衣服<br>"
説明文章 += "華やかでカラフルな色彩の開襟シャツはそのままに半ズボンはハサミを入れてホットパンツになっている<br>"
説明文章 += " <br>"
説明文章 += "しかしそれだけではなくよく見ると上にインナーの類はなく素肌の上に直接シャツを羽織り<br>"
説明文章 += "下は丈の短いホットパンツからは眩しいまでにふとももと素足が覗いている<br>"
説明文章 += "これでは本来なら見えるはずのないものが性別問わず見えてしまうかもしれない<br>"
説明文章 += " <br>"
説明文章 += "この格好は夕暮れと薄暗い路地、もしくは寝具の上でこそ鈍く光るのだろう<br>"

;出典元がある場合、それを記載
出典元 = 夏衣装？

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格


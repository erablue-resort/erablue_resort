@CLOTHES_初期所持関数_すけすけボディースーツ()
SIF STRCOUNT(所持制服文字列, @"汎用/つやつや光沢服_") || STRCOUNT(所持エロ衣装文字列, @"エロ/つやつや光沢服_")
CALL エロ衣装登録処理("すけすけボディースーツ")

@CLOTHES_衣装説明_すけすけボディースーツ()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 0
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = エロ衣装
;販売させない服はこれに1を入れる
販売禁止フラグ = 1

説明文章 += "異世界の護謨と呼ばれる素材でできた、全身をぴっちりと覆うとても薄手のボディスーツ<br>"
説明文章 += "ぴったりと肌に張り付きそのボディラインを強調するだけでなく<br>"
説明文章 += "その下の、本来隠すべきいろいろなモノが透けて見えてしまっている。<br>"
説明文章 += "とてつもなくえっちですね♪<br>"

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格


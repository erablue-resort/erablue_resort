@CLOTHES_衣装説明_生き恥ウエディングドレス()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 20000
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = エロ衣装
;販売させない服はこれに1を入れる
IF STRCOUNT(所持制服文字列, @"汎用/ウエディングドレス_") || STRCOUNT(所持エロ衣装文字列, @"エロ/ウエディングビキニ_")
	販売禁止フラグ = 0
ELSE
	販売禁止フラグ = 1
ENDIF

説明文章 = 
説明文章 += "結婚式で着るはずの花嫁衣装を、花婿の劣情を煽るべく改造したもの。<br>"
説明文章 += "全裸よりも煽情的に、秘部を自らさらけ出す破廉恥な下着姿を<br>"
説明文章 += "かろうじて清純さを残すヴェールとオーバースカートが覆い隠そうと無駄な抵抗をしている。<br>"
説明文章 += "この衣装の向かう先はヴァージン・ロードなどではない。<br>"
説明文章 += "ケダモノが集い番う真っ暗な寝室こそが終着点だ。<br>"

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格


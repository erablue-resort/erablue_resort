@CLOTHES_初期所持関数_ロングドレス()
CALL 制服登録処理("ロングドレス")

@CLOTHES_衣装説明_ロングドレス()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 0
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = 通常衣装
;販売させない服はこれに1を入れる
販売禁止フラグ = 1

説明文章 = 
説明文章 += "露出の極端に少ない貞淑なワンピースのドレス。<br>"
説明文章 += "あくまで清楚に、可憐に。そして優雅にエスコートするそのさまは<br>"
説明文章 += "制服姿によるそれとはまた違った、ラグジュアリーな体験をお客様にもたらすでしょう。<br>"

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格

@CLOTHES_CHANGE_ロングドレス(対象キャラ)
#DIM 対象キャラ

;保留前一套服装
SIF CSTR:対象キャラ:着せ替え服 != "ロングドレス"

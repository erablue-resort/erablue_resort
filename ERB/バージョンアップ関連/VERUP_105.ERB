;Ver0.105と旧バージョンとの互換のための処理
;Ver0.108にしたとき消す、互換を106に

;追加TALENT、追加CSTRのチェック
@VERUP_105_CHARA(ARG)

IF デジモンランダム化フォロー == 0 && CSVCSTR(NO:ARG, GETNUM(CSTR, "ランダムキャラ設定")) == "デジモン"
	CSTR:ARG:ランダムキャラ設定 = デジモン
	TALENT:ARG:ランダムキャラ = 1
ENDIF

;その他広域変数の書き換えなど
@VERUP_105()

; IF なんらかフォロー == 0
; 	;なんらかのフォロー処理
; 	;ここで"なんらかフォロー = 1"しない
; ENDIF

IF デジタマフォロー == 0
	FOR LOCAL, 0, 家畜設定上限
		SIF 現在設定家畜:LOCAL == "デジタマ"
			現在設定家畜:LOCAL = デジタマ（デジモンシリーズ）
	NEXT
ENDIF

;対応処理用フラグを対応済状態にセット
@VERUP_105_FINISH()
; なんらかフォロー = 1

デジタマフォロー = 1
デジモンランダム化フォロー = 1

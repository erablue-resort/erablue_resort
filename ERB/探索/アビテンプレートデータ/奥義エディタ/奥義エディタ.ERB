
;効果の管理などはアビエディタのものを流用



@奥義エディタ()
#DIM 対象NO
#DIM 既存奥義
#DIM 表示Lv
#DIM 奥義作成中フラグ
#DIM 奥義ID, 100
#DIMS HTML文字列
#DIM 枠配置縦位置
#DIM 奥義段階
#DIM 最大奥義段階
#DIMS 奥義名, 5
#DIM 消費ＭＰ, 5
#DIMS 取得条件, 5
#DIM 表示候補数
#DIM 選択番号
#DIM ダメージ倍率

#DIM 取得条件_Lv
#DIMS 取得条件_陥落

;初期化部分

;奥義名を呼び出すためにキャラを１人追加する
ADDCHARA 0
;奥義作成中フラグ = 0
;開発中のためいきなり作成中に飛ぶ
奥義作成中フラグ = 1
表示Lv = 1
基礎BATTLE_STATE:0:Lv = 表示Lv
VARSET 奥義名, "（未定）"
VARSET 消費ＭＰ, 0
VARSET 取得条件
奥義段階 = 0
最大奥義段階 = 0
CALL アビエディタデータベースセット()
;奥義攻撃部分を最初にセット
ダメージ倍率 = 300
DT_ROW_ADD "アビエディタデータベース", "効果順番", 0, "アビ段階", 0, "アビ効果種別", "ダメージ効果", "アビ対象", "敵単体", "アビ文字列１", "攻撃力", "アビ文字列３", "奥義基礎攻撃", "アビ数値１", ダメージ倍率, "アビ数値３", -1, "アビ数値４", 1


対象NO = 1

$動作LOOP

DRAWLINE
PRINTL 固有奥義を作成するためのエディタです。
PRINTL 現在開発中のため、作成出来る機能に制限があります。
DRAWLINE

HTML文字列 = 
;選択キャラ表示枠
HTML文字列 += "<div rect='50, 0, 5000, 1200' padding='50,25,50' color='#101010' border='31' bcolor='#C0C0C0'><nobr>"
IF 対象NO > 0
	HTML文字列 += @"%CSVNAME(対象NO)%<br>"
	;現在ある奥義を呼んでくる
	既存奥義 = EXISTFUNCTION(@"固有奥義_{対象NO}")
	IF 既存奥義 > 0
		HTML文字列 += @"Lv{表示Lv, 2}時奥義："
		TSTR:コマンド名受渡 = 
		詳細文文字列受け渡し変数 = 
		CALLFORM 固有奥義_{対象NO}("奥義名", 0)
		IF TSTR:コマンド名受渡 != ""
			CALLFORM 固有奥義_{対象NO}("奥義説明文_詳細", 0)
			SIF 詳細文文字列受け渡し変数 == ""
				CALLFORM 固有奥義_{対象NO}("奥義説明文", 0)
			HTML文字列 += @"<nonbutton title='<br>%詳細文文字列受け渡し変数%<br>'>■%TSTR:コマンド名受渡%</nonbutton>　　"
		ENDIF
	ENDIF
	HTML文字列 += "<br>"
	HTML文字列 += "<br>"
ELSE
	HTML文字列 += "（選択なし）<br>"
	HTML文字列 += "<br>"
	HTML文字列 += "<br>"
ENDIF
HTML文字列 += "<button value='200'>[作成キャラを変更する]</button> / <button value='201'>[表示レベルを変更する]</button>"
HTML文字列 += "</div>"
IF 対象NO > 0 && EXIST画像FILE(@"resources/{対象NO}%CSVCALLNAME(対象NO)%/顔_デフォルト")
	;何番でもいいけどとりあえず20000以降を使用
	GDISPOSE 20000
	SPRITEDISPOSE @"口上用画像0"
	CALL GCREATE_拡張子(20000, @"{対象NO}%CSVCALLNAME(対象NO)%/顔_デフォルト")
	SPRITECREATE @"口上用画像0", 20000
	HTML文字列 += @"<div rect='3900, 50, 1500, 1500'><img src='口上用画像0' height='{GHEIGHT(20000) / 16 * 100}' width='{GWIDTH(20000) / 16 * 100}'></div>"
ENDIF

;操作パネル
HTML文字列 += "<div rect='50, 1250, 1600, 4200' padding='50,25,50' color='#101010' border='31' bcolor='#C0C0C0'><nobr>"
IF 奥義作成中フラグ == 0
	HTML文字列 += "<button value='900'>[900] 新規奥義作成</button><br>"
	;作成中
	;HTML文字列 += "<button value='101'>[101] アビデータ読込</button><br>"
ELSE
	;アビパーツの選択肢を並べる
	HTML文字列 += "<button value='0'>[ 0] 奥義名を変更する</button><br>"
	HTML文字列 += "<button value='1'>[ 1] ダメージ効果を追加</button><br>"
	HTML文字列 += "<button value='2'>[ 2] バフ効果を追加</button><br>"
	HTML文字列 += "<button value='3'>[ 3] その他有利効果を追加</button><br>"
	HTML文字列 += "<button value='4'>[ 4] デバフ効果を追加</button><br>"
	HTML文字列 += "<button value='5'>[ 5] その他不利効果を追加</button><br>"
	HTML文字列 += "<button value='6'>[ 6] 回復効果を追加</button><br>"
ENDIF
HTML文字列 += "<br>"
HTML文字列 += "<br>"
IF 奥義作成中フラグ
	HTML文字列 += "<button value='997'>[997] 奥義段階を増やす</button><br>"
	HTML文字列 += "<br>"
	HTML文字列 += "<button value='998'>[998] 奥義ERBを生成する</button><br>"
ENDIF
HTML文字列 += "<button value='999'>[999] 戻る</button><br>"
HTML文字列 += "</div>"

;作成奥義効果表示枠
HTML文字列 += "<div rect='1700, 1425, 5050, 4025' padding='50,25,50' color='#101010' border='31' bcolor='#C0C0C0'><nobr>"
HTML文字列 += @"<button value='0'>■%奥義名:奥義段階, 30, LEFT%</button>取得条件：%アビエディタ_取得条件文章化(取得条件:奥義段階)%　　<button value='202'>[取得条件変更]</button><br>"
; HTML文字列 += @"消費ＭＰ："
; IF 消費ＭＰ:奥義段階 < 0
; 	HTML文字列 += @"自動設定（現在{ABS(消費ＭＰ:奥義段階)}）　　<button value='203'>[手動で設定する]</button><br>"
; ELSE
; 	;HTML文字列 += @"{消費ＭＰ:奥義段階}　　<button value='203'>[自動で設定する]</button><br>"
; 	HTML文字列 += @"{消費ＭＰ:奥義段階}　　<button value='203'>[消費ＭＰを変更]</button><br>"
; ENDIF
HTML文字列 += "------------------------------------------------------------------------------------------------------<br>"
HTML文字列 += "</div>"
IF 奥義作成中フラグ
	枠配置縦位置 = 0
	VARSET RESULT
	表示候補数 = DT_SELECT("アビエディタデータベース", @"アビ段階 = {奥義段階}", "効果順番 ASC")
	;配列に保存
	ARRAYCOPY "RESULT", "奥義ID"
	ARRAYSHIFT 奥義ID, -1, 0
	FOR LOCAL, 0, 表示候補数
		SELECTCASE DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ効果種別", 1)
			CASE "ダメージ効果"
				IF DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列３", 1) == "奥義基礎攻撃"
					HTML文字列 += @"<div rect='1800, {1825 + 枠配置縦位置}, 4850, 380' padding='50,25,50' color='#101010' border='31' bcolor='#ff9292'><nobr>"
					HTML文字列 += @"奥義基礎攻撃："
				ELSE
					HTML文字列 += @"<div rect='1800, {1825 + 枠配置縦位置}, 4850, 380' padding='50,25,50' color='#101010' border='31' bcolor='#C0C0C0'><nobr>"
				ENDIF
				HTML文字列 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ対象", 1)%に"
				IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1) > 0
					HTML文字列 += @"［{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1)}％］"
					IF DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1) != "攻撃力"
						HTML文字列 += @"（%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1)%依存）"
					ENDIF
				ELSE
					HTML文字列 += @"［{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値２", 1)}］"
				ENDIF
				IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値３", 1) < 0
					HTML文字列 += "の自属性ダメージを"
				ELSE
					HTML文字列 += @"の<font color='#%カラーパレット_HTML(@"%属性数値文字列変換(DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値３", 1))%属性")%'>%属性数値文字列変換(DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値３", 1))%属性</font>ダメージを"
				ENDIF
				IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値４", 1) < 2
					HTML文字列 += "与える。"
				ELSE
					HTML文字列 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値４", 1)}回与える。"
				ENDIF
				HTML文字列 += "<br>"
				HTML文字列 += @"<button value='{LOCAL + 100}'>[効果を変更する]</button>　　<button value='{LOCAL + 300}'>[効果を削除する]</button>　　"
				
				;奥義前効果を実装する前の暫定処置
				IF DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列３", 1) != "奥義基礎攻撃"
					IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "効果順番", 1) > 1
						HTML文字列 += @"<button value='{LOCAL + 400}'>[↑]</button>"
					ELSE
						HTML文字列 += "　　"
					ENDIF
					HTML文字列 += "　"
					IF 表示候補数 > LOCAL + 1
						HTML文字列 += @"<button value='{LOCAL + 500}'>[↓]</button>"
					ENDIF
					HTML文字列 += "<br>"
				ENDIF
				HTML文字列 += "</div>"
				枠配置縦位置 += 430
			CASE "バフ効果"
				RSTR:表示設定受け渡し = 
				CALLF アビエディタ_ＭＰ自動計算_バフ種類(DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1))
				HTML文字列 += @"<div rect='1800, {1825 + 枠配置縦位置}, 4850, 380' padding='50,25,50' color='#101010' border='31' bcolor='#C0C0C0'><nobr>"
				HTML文字列 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ対象", 1)%に"
				IF STRFIND(RSTR:表示設定受け渡し, "［］") >= 0
					HTML文字列 += "［"
					IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1) > 0
						HTML文字列 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1)}％"
					ENDIF
					IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値２", 1) > 0
						SIF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1) > 0
							HTML文字列 += "＋"
						HTML文字列 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値２", 1)}"
					ENDIF
					HTML文字列 += "］"
				ENDIF
				HTML文字列 += "（"
				IF STRFIND(DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列２", 1), DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1)) == 0
					HTML文字列 += @"%TOFULL(REPLACE(DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列２", 1), DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1), ""))%枠"
				ELSE
					HTML文字列 += "独自枠"
				ENDIF
				IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値３", 1) > 0
					HTML文字列 += @"・{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値３", 1)}%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列３", 1)%"
				ENDIF
				IF STRFIND(DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列４", 1), "消去不可") >= 0
					HTML文字列 += "・消去不可"
				ENDIF
				IF STRFIND(RSTR:表示設定受け渡し, "上昇") >= 0
					HTML文字列 += @"）の%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1)%上昇効果を与える。"
				ELSE
					HTML文字列 += @"）の%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1)%効果を与える。"
				ENDIF
				HTML文字列 += "<br>"
				HTML文字列 += @"<button value='{LOCAL + 100}'>[効果を変更する]</button>　　<button value='{LOCAL + 300}'>[効果を削除する]</button>　　"
				
				;奥義前効果を実装する前の暫定処置
				IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "効果順番", 1) > 1
					HTML文字列 += @"<button value='{LOCAL + 400}'>[↑]</button>"
				ELSE
					HTML文字列 += "　　"
				ENDIF
				HTML文字列 += "　"
				IF 表示候補数 > LOCAL + 1
					HTML文字列 += @"<button value='{LOCAL + 500}'>[↓]</button>"
				ENDIF
				HTML文字列 += "<br>"
				HTML文字列 += "</div>"
				枠配置縦位置 += 430
			CASE "その他有利効果"
				RSTR:表示設定受け渡し = 
				CALLF アビエディタ_ＭＰ自動計算_有利効果種類(DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1))
				HTML文字列 += @"<div rect='1800, {1825 + 枠配置縦位置}, 4850, 380' padding='50,25,50' color='#101010' border='31' bcolor='#C0C0C0'><nobr>"
				HTML文字列 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ対象", 1)%に"
				IF STRFIND(RSTR:表示設定受け渡し, "［］") >= 0
					HTML文字列 += "［"
					IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1) > 0
						HTML文字列 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1)}％"
					ENDIF
					IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値２", 1) > 0
						SIF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1) > 0
							HTML文字列 += "＋"
						HTML文字列 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値２", 1)}"
					ENDIF
					IF STRFIND(RSTR:表示設定受け渡し, "期間表示") >= 0
						HTML文字列 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列２", 1)%"
					ENDIF
					HTML文字列 += "］"
					HTML文字列 += @"の"
				ENDIF
				HTML文字列 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1)%効果を与える。"
				HTML文字列 += "<br>"
				HTML文字列 += @"<button value='{LOCAL + 100}'>[効果を変更する]</button>　　<button value='{LOCAL + 300}'>[効果を削除する]</button>　　"
				
				;奥義前効果を実装する前の暫定処置
				IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "効果順番", 1) > 1
					HTML文字列 += @"<button value='{LOCAL + 400}'>[↑]</button>"
				ELSE
					HTML文字列 += "　　"
				ENDIF
				HTML文字列 += "　"
				IF 表示候補数 > LOCAL + 1
					HTML文字列 += @"<button value='{LOCAL + 500}'>[↓]</button>"
				ENDIF
				HTML文字列 += "<br>"
				HTML文字列 += "</div>"
				枠配置縦位置 += 430
			CASE "デバフ効果"
				RSTR:表示設定受け渡し = 
				CALLF アビエディタ_ＭＰ自動計算_デバフ種類(DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1))
				HTML文字列 += @"<div rect='1800, {1825 + 枠配置縦位置}, 4850, 380' padding='50,25,50' color='#101010' border='31' bcolor='#C0C0C0'><nobr>"
				HTML文字列 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ対象", 1)%に"
				IF STRFIND(RSTR:表示設定受け渡し, "［］") >= 0
					HTML文字列 += "［"
					IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1) > 0
						HTML文字列 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1)}％"
					ENDIF
					IF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値２", 1) > 0
						SIF DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値１", 1) > 0
							HTML文字列 += "＋"
						HTML文字列 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:LOCAL, "アビ数値２", 1)}"
					ENDIF
					HTML文字列 += "］"
				ENDIF
				HTML文字列 += "（"
				IF STRFIND(DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列２", 1), DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1)) == 0
					HTML文字列 += @"%TOFULL(REPLACE(DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列２", 1), DT_CELL_GETS("アビエディタデータベース", 奥義ID:LOCAL, "アビ文字列１", 1), ""))%枠"

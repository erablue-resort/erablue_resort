PRINTFORML 		ENDIF
奥義ERB記述 = 
奥義ERB記述 += "	CASE \"奥義追加効果\"<br>"
FOR 奥義段階, 最大奥義段階, -1, -1
	IF 奥義段階 == 最大奥義段階
		奥義ERB記述 += @"		IF %取得条件_文字列:奥義段階%<br>"
	ELSE
		奥義ERB記述 += @"		ELSEIF %取得条件_文字列:奥義段階%<br>"
	ENDIF
	奥義ERB記述 += @"			%REPLACE(奥義効果記述:奥義段階, "<br>", "<br>			")%"
	奥義ERB記述 '= SUBSTRING(奥義ERB記述, 0, STRLENS(奥義ERB記述) - 3)
NEXT
	奥義ERB記述 += "		ENDIF<br>"
奥義ERB記述 += "ENDSELECT<br><br><br>"



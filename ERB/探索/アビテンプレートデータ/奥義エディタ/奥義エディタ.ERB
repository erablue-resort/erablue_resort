		LOCALS '= DT_CELL_GETS("アビエディタデータベース", RESULT:1, "アビ対象", 1)
		IF LOCAL - 1 == 0 && LOCALS == "上と同じ相手"
			LOCALS '= DT_CELL_GETS("アビエディタデータベース", 奥義ID:(選択番号 - 500), "アビ対象", 1)
			DT_CELL_SET "アビエディタデータベース", 奥義ID:(選択番号 - 500), "アビ対象", DT_CELL_GETS("アビエディタデータベース", RESULT:1, "アビ対象", 1), 1
			DT_CELL_SET "アビエディタデータベース", RESULT:1, "アビ対象", LOCALS, 1
		ENDIF
	CASE 1000 TO 1010
		奥義段階 = 選択番号 - 1000
ENDSELECT

; SIF 消費ＭＰ:奥義段階 < 0
; 	CALL ＭＰ自動計算(消費ＭＰ, 取得条件:奥義段階, 奥義段階)
GOTO 動作LOOP



@奥義エディタ_ERB生成(対象No, 奥義名, 取得条件)
#DIM DB行数
#DIMS 奥義ERB記述
#DIMS 奥義説明記述, 10
#DIMS 奥義効果記述, 10
#DIM 奥義段階
#DIM 奥義威力
#DIM DYNAMIC 最大奥義段階
#DIM 対象No
#DIMS REF 奥義名
#DIMS REF 取得条件
#DIMS 取得条件_文字列, 10
#DIM 奥義ID, 100

VARSET 奥義説明記述
VARSET 奥義効果記述

;奥義段階は連番であること、全てに奥義名が設定されていることを前提とする
FOR 奥義段階, 0, VARSIZE("奥義名")
	SIF 奥義名:奥義段階 != "" && 奥義名:奥義段階 != "（未定）"
		最大奥義段階 = 奥義段階
NEXT

奥義ERB記述 = @固有アビ_{対象No}_YYYY(ARGS, キャラ番号)<br>
奥義ERB記述 += "#DIM キャラ番号<br>"
奥義ERB記述 += "#DIM 奥義威力<br>"
奥義ERB記述 += "#DIMS 奥義名<br>"
奥義ERB記述 += "#DIM 表示用奥義威力<br>"
奥義ERB記述 += "<br>"

;ここに習得条件入れる
IF MATCH(取得条件, "") < VARSIZE("取得条件") || MATCH(奥義名, "（未定）") < VARSIZE("奥義名") - 1
	;取得条件存在、もしくは奥義名複数時にIF文を記述する
	VARSET 取得条件_文字列 
	FOR 奥義段階, 最大奥義段階, -1, -1
		;取得条件を解析
		VARSET RESULTS
		SPLIT 取得条件:奥義段階, "***", RESULTS
		FOR LOCAL, 0, RESULT
			IF STRFIND(RESULTS:LOCAL, "Lv") >= 0
				SIF 取得条件_文字列:奥義段階 != ""
					取得条件_文字列:奥義段階 += " &amp;&amp; "
				取得条件_文字列:奥義段階 += @"基礎BATTLE_STATE:キャラ番号:Lv >= %REPLACE(RESULTS:LOCAL, "Lv_", "")%"
			ELSEIF STRFIND(RESULTS:LOCAL, "陥落") >= 0
				SIF 取得条件_文字列:奥義段階 != ""
					取得条件_文字列:奥義段階 += " &amp;&amp; "
				SELECTCASE REPLACE(RESULTS:LOCAL, "陥落_", "")
					CASE "陥落"
						取得条件_文字列:奥義段階 += "陥落チェック(キャラ番号)"
					CASE "恋慕"
						取得条件_文字列:奥義段階 += "陥落チェック_恋慕系(キャラ番号)"
					CASE "セフレ"
						取得条件_文字列:奥義段階 += "GETBIT(陥落チェック(キャラ番号), 1)"
					CASE "非エロ"
						取得条件_文字列:奥義段階 += "陥落チェック_非性的(キャラ番号)"
				ENDSELECT
			ENDIF
		NEXT
		SIF 取得条件_文字列:奥義段階 == ""
			取得条件_文字列:奥義段階 = 1
		IF 奥義段階 == 最大奥義段階
			奥義ERB記述 += @"IF %取得条件_文字列:奥義段階%<br>"
		ELSE
			奥義ERB記述 += @"ELSEIF %取得条件_文字列:奥義段階%<br>"
		ENDIF
		奥義ERB記述 += @"	奥義名 = %奥義名:奥義段階%<br>"
		DT_SELECT "アビエディタデータベース", @"アビ段階 = {奥義段階} And アビ文字列３ = '奥義基礎攻撃'"
		IF DT_CELL_GETS("アビエディタデータベース", RESULT:1, "アビ対象", 1) == "敵単体"
			奥義ERB記述 += @"	奥義威力 = {DT_CELL_GET("アビエディタデータベース", RESULT:1, "アビ数値１", 1)}<br>"
		ELSE
			奥義ERB記述 += @"	奥義威力 = 0<br>"
			奥義ERB記述 += @"	表示用奥義威力 = {DT_CELL_GET("アビエディタデータベース", RESULT:1, "アビ数値１", 1)}<br>"
		ENDIF
	NEXT
	奥義ERB記述 += "ENDIF<br><br>"
ELSE
	奥義ERB記述 += @"奥義名 = %奥義名:0%<br>"
	DT_SELECT "アビエディタデータベース", @"アビ段階 = {奥義段階} And アビ文字列３ = '奥義基礎攻撃'"
	IF DT_CELL_GETS("アビエディタデータベース", RESULT:1, "アビ対象", 1) == "敵単体"
		奥義ERB記述 += @"	奥義威力 = {DT_CELL_GET("アビエディタデータベース", RESULT:1, "アビ数値１", 1)}<br>"
	ELSE
		奥義ERB記述 += @"	奥義威力 = 0<br>"
		奥義ERB記述 += @"	表示用奥義威力 = {DT_CELL_GET("アビエディタデータベース", RESULT:1, "アビ数値１", 1)}<br>"
	ENDIF
ENDIF

VARSET RESULT
DT_SELECT "アビエディタデータベース", "", "アビ段階 ASC, 効果順番 ASC"
;配列に保存
ARRAYCOPY "RESULT", "奥義ID"
ARRAYSHIFT 奥義ID, -1, 0
奥義段階 = 0

FOR DB行数, 0, DT_ROW_LENGTH("アビエディタデータベース")
	SIF 奥義段階 != DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ段階", 1)
		奥義段階 = DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ段階", 1)

	;まず奥義基礎攻撃
	IF DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列３", 1) == "奥義基礎攻撃"
		IF DT_CELL_GETS("アビエディタデータベース", RESULT:1, "アビ対象", 1) == "敵単体"
			奥義説明記述:奥義段階 += @"奥義威力：{DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1)}<br>"
			CONTINUE
		ENDIF
	ENDIF

	;各種効果
	SELECTCASE DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ効果種別", 1)
		CASE "ダメージ効果"
			奥義説明記述:奥義段階 += "<br>"
			IF DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1) != "上と同じ相手"
				奥義説明記述:奥義段階 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1)%に"
			ENDIF
			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1) > 0
				奥義説明記述:奥義段階 += @"［{DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1)}％］"
				IF DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1) != "攻撃力"
					奥義説明記述:奥義段階 += @"（%DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1)%依存）"
				ENDIF
			ELSE
				奥義説明記述:奥義段階 += @"［{DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値２", 1)}］"
			ENDIF
			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値３", 1) < 0
				奥義説明記述:奥義段階 += "の自属性ダメージを"
			ELSE
				奥義説明記述:奥義段階 += @"の<font color='#%カラーパレット_HTML(@"%属性数値文字列変換(DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値３", 1))%属性")%'>%属性数値文字列変換(DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値３", 1))%属性</font>ダメージを"
			ENDIF
			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値４", 1) < 2
				奥義説明記述:奥義段階 += "与える。"
			ELSE
				奥義説明記述:奥義段階 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値４", 1)}回与える。"
			ENDIF

			奥義効果記述:奥義段階 += "CALL アビ汎用変数文字列リセット<br>"
			IF DB行数 > 0 && DT_CELL_GETS("アビエディタデータベース", 奥義ID:(DB行数 - 1), "アビ文字列３", 1) == "奥義基礎攻撃" && DT_CELL_GETS("アビエディタデータベース", 奥義ID:(DB行数 - 1), "アビ対象", 1) == "敵単体" && DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1) == "上と同じ相手"
				奥義効果記述:奥義段階 += アビエディタ_対象CALL変換("奥義対象と同じ")
			ELSE
				奥義効果記述:奥義段階 += アビエディタ_対象CALL変換(DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1))
			ENDIF
			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1) > 0
				奥義効果記述:奥義段階 += @"アビ汎用変数:効果割合 = {DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1)}<br>"
				奥義効果記述:奥義段階 += @"アビ汎用文字列:攻撃側使用能力値 = %DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1)%<br>"
			ELSE
				奥義効果記述:奥義段階 += @"アビ汎用変数:効果量 = {DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値２", 1)}<br>"
			ENDIF
			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値３", 1) < 0
				LOCALS = CALL アビテンプレート_ダメージ処理_自属性
			ELSE
				LOCALS = CALL アビテンプレート_ダメージ処理_%属性数値文字列変換(DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値３", 1))%属性
			ENDIF
			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値４", 1) > 1
				奥義効果記述:奥義段階 += @"FOR LOCAL, 0, {DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値４", 1)}<br>"
				奥義効果記述:奥義段階 += @"	%LOCALS%<br>"
				奥義効果記述:奥義段階 += @"NEXT<br>"
			ELSE
				奥義効果記述:奥義段階 += @"%LOCALS%<br>"
			ENDIF
		CASE "バフ効果"
			RSTR:表示設定受け渡し = 
			CALLF アビエディタ_ＭＰ自動計算_バフ種類(DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1))
			奥義説明記述:奥義段階 += "<br>"
			IF DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1) != "上と同じ相手"
				奥義説明記述:奥義段階 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1)%に"
			ENDIF
			IF STRFIND(RSTR:表示設定受け渡し, "［］") >= 0
				奥義説明記述:奥義段階 += "［"
				IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1) > 0
					奥義説明記述:奥義段階 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1)}％"
				ENDIF
				IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値２", 1) > 0
					SIF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1) > 0
						奥義説明記述:奥義段階 += "＋"
					奥義説明記述:奥義段階 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値２", 1)}"
				ENDIF
				奥義説明記述:奥義段階 += "］"
			ENDIF
			奥義説明記述:奥義段階 += "（"
			IF STRFIND(DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列２", 1), DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1)) == 0
				奥義説明記述:奥義段階 += @"%TOFULL(REPLACE(DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列２", 1), DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1), ""))%枠"
			ELSE
				奥義説明記述:奥義段階 += "独自枠"
			ENDIF
			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値３", 1) > 0
				奥義説明記述:奥義段階 += @"・{DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値３", 1)}%DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列３", 1)%"
			ENDIF
			IF STRFIND(DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列４", 1), "消去不可") >= 0
				奥義説明記述:奥義段階 += @"・消去不可"
			ENDIF
			奥義説明記述:奥義段階 += "）の"
			IF STRFIND(RSTR:表示設定受け渡し, "上昇") >= 0
				奥義説明記述:奥義段階 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1)%上昇効果を与える。"
			ELSE
				奥義説明記述:奥義段階 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1)%効果を与える。"
			ENDIF

			奥義効果記述:奥義段階 += "CALL アビ汎用変数文字列リセット<br>"
			IF DB行数 > 0 && DT_CELL_GETS("アビエディタデータベース", 奥義ID:(DB行数 - 1), "アビ文字列３", 1) == "奥義基礎攻撃" && DT_CELL_GETS("アビエディタデータベース", 奥義ID:(DB行数 - 1), "アビ対象", 1) == "敵単体" && DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1) == "上と同じ相手"
				奥義効果記述:奥義段階 += アビエディタ_対象CALL変換("奥義対象と同じ")
			ELSE
				奥義効果記述:奥義段階 += アビエディタ_対象CALL変換(DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1))
			ENDIF

			奥義効果記述:奥義段階 += @"アビ汎用文字列:バフ・デバフ枠 = %DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列２", 1)%<br>"
			奥義効果記述:奥義段階 += @"アビ汎用文字列:バフ・デバフ対象能力 = %DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1)%<br>"

			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1) > 0
				奥義効果記述:奥義段階 += @"アビ汎用変数:効果割合 = {DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値１", 1)}<br>"
			ENDIF
			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値２", 1) > 0
				奥義効果記述:奥義段階 += @"アビ汎用変数:効果量 = {DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値２", 1)}<br>"
			ENDIF

			SELECTCASE DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列３", 1)
				CASE "ターン"
					奥義効果記述:奥義段階 += @"アビ汎用変数:持続ターン = "
				CASE "回"
					奥義効果記述:奥義段階 += @"アビ汎用変数:持続回数 = "
				CASE "行動"
					奥義効果記述:奥義段階 += @"アビ汎用変数:持続行動回数 = "
				CASE "被ダメ"
					奥義効果記述:奥義段階 += @"アビ汎用変数:持続被ダメ回数 = "
			ENDSELECT
			奥義効果記述:奥義段階 += @"{DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値３", 1)}<br>"

			IF DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値４", 1) > 0
				奥義効果記述:奥義段階 += @"アビ汎用変数:基礎成功確率 = {DT_CELL_GET("アビエディタデータベース", 奥義ID:DB行数, "アビ数値４", 1)}<br>"
			ENDIF

			奥義効果記述:奥義段階 += "CALL アビテンプレート_有利効果_バフ効果セット<br>"
		CASE "その他有利効果"
			RSTR:表示設定受け渡し = 
			CALLF アビエディタ_ＭＰ自動計算_有利効果種類(DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ文字列１", 1))
			奥義説明記述:奥義段階 += "<br>"
			IF DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1) != "上と同じ相手"
				奥義説明記述:奥義段階 += @"%DT_CELL_GETS("アビエディタデータベース", 奥義ID:DB行数, "アビ対象", 1)%に"
			ENDIF

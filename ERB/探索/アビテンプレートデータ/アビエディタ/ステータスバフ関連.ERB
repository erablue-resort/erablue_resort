@アビエディタ_効果目安_ステータスバフ種類(バフ対象能力, 取得条件_Lv, 取得条件_陥落)
#FUNCTIONS
#DIMS バフ対象能力
#DIM 取得条件_Lv
#DIMS 取得条件_陥落
#DIMS HTML文字列

;目安説明を返す

HTML文字列 = 
SELECTCASE バフ対象能力
	CASE "攻撃力", "防御力", "回復力", 
		SELECTCASE 取得条件_Lv + (取得条件_陥落 != "" ? 20 # 0)
			CASE 1 TO 20
				LOCAL = 20
			CASE 20 TO 40
				LOCAL = 30
			CASE 40 TO 60
				LOCAL = 35
			CASEELSE
				LOCAL = 40
		ENDSELECT
		HTML文字列 += @"　　単体対象　効果固定割合目安：<font color='#%カラーパレット_HTML("黄")%'>{LOCAL * 3 / 2, 4}</font><br>"
		HTML文字列 += @"　　　　　　　　効果固定値目安：<font color='#%カラーパレット_HTML("黄")%'>{(取得条件_Lv + (取得条件_陥落 != "" ? 20 # 0) * 20 + 80) * (LOCAL * 3 / 2) / 100, 4}</font><br>"
		HTML文字列 += @"　　全体対象　効果固定割合目安：<font color='#%カラーパレット_HTML("黄")%'>{LOCAL, 4}</font><br>"
		HTML文字列 += @"　　　　　　　　効果固定値目安：<font color='#%カラーパレット_HTML("黄")%'>{(取得条件_Lv + (取得条件_陥落 != "" ? 20 # 0) * 20 + 80) * LOCAL / 100, 4}</font><br>"
		HTML文字列 += @"<br>"
		HTML文字列 += @"　　　　　　　　　効果時間目安：<font color='#%カラーパレット_HTML("黄")%'>３～５ターン</font><br>"
	CASE "行動速度"
		SELECTCASE 取得条件_Lv + (取得条件_陥落 != "" ? 20 # 0)
			CASE 1 TO 20
				LOCAL = 30
			CASE 20 TO 40
				LOCAL = 50
			CASE 40 TO 60
				LOCAL = 60
			CASEELSE
				LOCAL = 70
		ENDSELECT
		HTML文字列 += @"　　単体対象　効果固定割合目安：<font color='#%カラーパレット_HTML("黄")%'>{LOCAL * 3 / 2, 4}</font><br>"
		HTML文字列 += @"　　　　　　　　効果固定値目安：<font color='#%カラーパレット_HTML("黄")%'>{(取得条件_Lv + (取得条件_陥落 != "" ? 20 # 0) * 20 + 80) * (LOCAL * 3 / 2) / 100, 4}</font><br>"
		HTML文字列 += @"　　全体対象　効果固定割合目安：<font color='#%カラーパレット_HTML("黄")%'>{LOCAL, 4}</font><br>"
		HTML文字列 += @"　　　　　　　　効果固定値目安：<font color='#%カラーパレット_HTML("黄")%'>{(取得条件_Lv + (取得条件_陥落 != "" ? 20 # 0) * 20 + 80) * LOCAL / 100, 4}</font><br>"
		HTML文字列 += @"<br>"
		HTML文字列 += @"　　　　　　　　　効果時間目安：<font color='#%カラーパレット_HTML("黄")%'>３～５ターン</font><br>"
	CASE "ダメージ補正_通常攻撃ダメージ", "ダメージ補正_アビリティダメージ", "ダメージ補正_奥義ダメージ"
		SELECTCASE 取得条件_Lv + (取得条件_陥落 != "" ? 20 # 0)
			CASE 1 TO 20
				LOCAL = 30
			CASE 20 TO 40
				LOCAL = 40
			CASE 40 TO 60
				LOCAL = 45
			CASEELSE
				LOCAL = 50
		ENDSELECT
		HTML文字列 += @"　　単体対象　効果固定割合目安：<font color='#%カラーパレット_HTML("黄")%'>{LOCAL * 3 / 2, 4}</font><br>"
		HTML文字列 += @"　　　　　　　　効果固定値目安：<font color='#%カラーパレット_HTML("黄")%'>{(取得条件_Lv + (取得条件_陥落 != "" ? 20 # 0) * 20 + 80) / 4 * LOCAL / 100 * 3 / 2, 4}</font><br>"
